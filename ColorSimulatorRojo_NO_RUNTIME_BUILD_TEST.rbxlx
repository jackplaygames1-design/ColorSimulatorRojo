local function addTextStroke(label, thickness)
	local stroke = Instance.new("UIStroke")
	stroke.Color = UI_WHITE
	stroke.Thickness = thickness or 2
	stroke.Transparency = 0.15
	stroke.Parent = label
end

local function makeFallbackIcon(parent, color, shapeRotation)
	local icon = Instance.new("Frame")
	icon.Name = "FallbackIcon"
	icon.Size = UDim2.fromScale(1, 1)
	icon.BackgroundColor3 = color
	icon.BorderSizePixel = 0
	icon.Rotation = shapeRotation or 0
	icon.ZIndex = parent.ZIndex + 1
	icon.Parent = parent
	local corner = Instance.new("UICorner")
	corner.CornerRadius = shapeRotation and shapeRotation ~= 0 and UDim.new(0, 4) or UDim.new(1, 0)
	corner.Parent = icon
	local stroke = Instance.new("UIStroke")
	stroke.Color = UI_DARK
	stroke.Thickness = 3
	stroke.Parent = icon
	local shine = Instance.new("Frame")
	shine.Name = "Shine"
	shine.Size = UDim2.new(0.38, 0, 0.24, 0)
	shine.Position = UDim2.new(0.18, 0, 0.13, 0)
	shine.BackgroundColor3 = UI_WHITE
	shine.BackgroundTransparency = 0.45
	shine.BorderSizePixel = 0
	shine.ZIndex = icon.ZIndex + 1
	shine.Parent = icon
	Instance.new("UICorner").Parent = shine
	return icon
end

local function makeImageLabel(parent, name, key, size, position, zIndex)
	local image = Instance.new("ImageLabel")
	image.Name = name
	image.Size = size
	image.Position = position
	image.BackgroundTransparency = 1
	image.BorderSizePixel = 0
	image.ScaleType = Enum.ScaleType.Fit
	image.ZIndex = zIndex
	image.Parent = parent
	return image, applyHudImage(image, key)
end

local function makeCurrencyDisplay(parent, displayName, iconKey, counterKey, fallbackColor, textOrder)
	parent.LayoutOrder = textOrder
	parent.Size = UDim2.new(0, 132, 0, 32)
	parent.BackgroundTransparency = 1
	parent.ZIndex = 20

	local counterImage, hasCounterImage = makeImageLabel(parent, displayName .. "CounterImage", counterKey, UDim2.new(0, 120, 0, 32), UDim2.new(0, 0, 0, 0), 20)
	counterImage.Visible = hasCounterImage

	local iconHolder = Instance.new("Frame")
	iconHolder.Name = displayName .. "IconHolder"
	iconHolder.Size = UDim2.new(0, 28, 0, 28)
	iconHolder.Position = UDim2.new(0, 0, 0.5, -14)
	iconHolder.BackgroundTransparency = 1
	iconHolder.ZIndex = 22
	iconHolder.Parent = parent

	local iconImage, hasIconImage = makeImageLabel(iconHolder, displayName .. "Icon", iconKey, UDim2.fromScale(1, 1), UDim2.fromScale(0, 0), 23)
	if not hasIconImage then
		iconImage.Visible = false
		makeFallbackIcon(iconHolder, fallbackColor, iconKey == "GemIcon" and 45 or 0)
	end

	local valueLabel = Instance.new("TextLabel")
	valueLabel.Name = displayName .. "Value"
	valueLabel.Size = UDim2.new(1, -38, 1, 0)
	valueLabel.Position = UDim2.new(0, 38, 0, 0)
	valueLabel.BackgroundTransparency = 1
	valueLabel.Font = Enum.Font.GothamBlack
	valueLabel.TextSize = 24
	valueLabel.TextColor3 = Color3.fromRGB(28, 28, 34)
	valueLabel.TextXAlignment = Enum.TextXAlignment.Left
	valueLabel.TextYAlignment = Enum.TextYAlignment.Center
	valueLabel.Text = "0"
	valueLabel.ZIndex = 24
	valueLabel.Parent = parent
	addTextStroke(valueLabel, 2)
	return valueLabel
end

