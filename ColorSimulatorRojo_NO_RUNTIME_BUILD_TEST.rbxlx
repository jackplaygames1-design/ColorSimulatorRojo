    <Item class="ModuleScript" referent="6">
      <Properties>
        <string name="Name">ColorMutationData</string>
        <string name="Source"><![CDATA[local ColorMutationData = {}

ColorMutationData.NoneId = "None"

ColorMutationData.Mutations = {
	None = {
		Id = "None",
		DisplayName = "Normal",
		Description = "No mutation.",
		Chance = 0,
		PowerMultiplier = 1,
		Effects = {},
		AuraColor = Color3.fromRGB(210, 220, 235),
		VisualTag = "none",
		SortOrder = 999,
		RarityText = "Normal",
	},
	Shiny = {
		Id = "Shiny",
		DisplayName = "Shiny",
		Description = "A shiny Color with extra power.",
		Chance = 0.05,
		PowerMultiplier = 1.25,
		Effects = { ColorGainMultiplier = 1.05 },
		AuraColor = Color3.fromRGB(220, 255, 255),
		VisualTag = "sparkle",
		SortOrder = 10,
		RarityText = "Rare Mutation",
	},
	Golden = {
		Id = "Golden",
		DisplayName = "Golden",
		Description = "A golden Color that improves Coin rewards.",
		Chance = 0.015,
		PowerMultiplier = 1.5,
		Effects = { SellCoinsMultiplier = 1.10 },
		AuraColor = Color3.fromRGB(255, 202, 58),
		VisualTag = "gold",
		SortOrder = 20,
		RarityText = "Epic Mutation",
	},
	Featherlight = {
		Id = "Featherlight",
		DisplayName = "Featherlight",
		Description = "Makes movement feel lighter.",
		Chance = 0.0125,
		PowerMultiplier = 1.35,
		Effects = { WalkSpeedBonus = 2, JumpPowerBonus = 8 },
		AuraColor = Color3.fromRGB(185, 235, 255),
		VisualTag = "featherlight",
		SortOrder = 30,
		RarityText = "Epic Mutation",
	},
	Hyper = {
		Id = "Hyper",
		DisplayName = "Hyper",
		Description = "Speeds up brushing.",
		Chance = 0.01,
		PowerMultiplier = 1.5,
		Effects = { BrushCooldownMultiplier = 0.88, BrushRangeMultiplier = 1.06 },
		AuraColor = Color3.fromRGB(255, 186, 66),
		VisualTag = "hyper",
		SortOrder = 40,
		RarityText = "Epic Mutation",
	},
	Magnetic = {
		Id = "Magnetic",
		DisplayName = "Magnetic",
		Description = "Pulls Color from farther away.",
		Chance = 0.0075,
		PowerMultiplier = 1.6,
		Effects = { BrushRangeMultiplier = 1.16, MagnetProcChance = 0.08, MagnetRange = 36 },
		AuraColor = Color3.fromRGB(105, 230, 255),
		VisualTag = "magnetic",
		SortOrder = 50,
		RarityText = "Legendary Mutation",
	},
	Rainbow = {
		Id = "Rainbow",
		DisplayName = "Rainbow",
		Description = "A rare rainbow mutation with balanced bonuses.",
		Chance = 0.005,
		PowerMultiplier = 2,
		Effects = { ColorGainMultiplier = 1.12, SellCoinsMultiplier = 1.08, HatchLuckBonus = 0.04 },
		AuraColor = Color3.fromRGB(255, 120, 220),
		VisualTag = "rainbow",
		SortOrder = 60,
		RarityText = "Mythic Mutation",
	},
	Storm = {
		Id = "Storm",
		DisplayName = "Storm",
		Description = "Strikes nearby Color blobs with lightning.",
		Chance = 0.0025,
		PowerMultiplier = 2.25,
		Effects = {
			LightningProcChance = 0.18,
			LightningTargets = 2,
			LightningRange = 42,
			LightningCooldown = 3,
		},
		AuraColor = Color3.fromRGB(95, 175, 255),
		VisualTag = "storm",
		SortOrder = 70,
		RarityText = "Secret Mutation",
	},
	Glitched = {
		Id = "Glitched",
		DisplayName = "Glitched",
		Description = "A strange unstable Color with powerful effects.",
		Chance = 0.001,
		PowerMultiplier = 3,
		Effects = {
			BrushCooldownMultiplier = 0.90,
			ColorGainMultiplier = 1.15,
			LightningProcChance = 0.12,
			LightningTargets = 2,
			LightningRange = 38,
			LightningCooldown = 3.5,
		},
		AuraColor = Color3.fromRGB(140, 245, 255),
		VisualTag = "glitch",
		SortOrder = 80,
		RarityText = "Glitched Mutation",
	},
}

ColorMutationData.LegacyAliases = {
	Sparked = "Shiny",
	Chromatic = "Rainbow",
}

ColorMutationData.RollOrder = {
	"Glitched",
	"Storm",
	"Rainbow",
	"Magnetic",
	"Hyper",
	"Featherlight",
	"Golden",
	"Shiny",
}

function ColorMutationData.get(mutationId)
	mutationId = ColorMutationData.LegacyAliases[mutationId or ""] or mutationId
	return ColorMutationData.Mutations[mutationId or ColorMutationData.NoneId]
		or ColorMutationData.Mutations[ColorMutationData.NoneId]
end

function ColorMutationData.isMutated(mutationId)
	mutationId = ColorMutationData.LegacyAliases[mutationId or ""] or mutationId
	return mutationId ~= nil and mutationId ~= "" and mutationId ~= ColorMutationData.NoneId
end

function ColorMutationData.normalize(mutationId)
	mutationId = ColorMutationData.LegacyAliases[mutationId or ""] or mutationId
	if ColorMutationData.Mutations[mutationId or ""] then
		return mutationId
	end
	return ColorMutationData.NoneId
end

function ColorMutationData.roll(luckMultiplier)
	luckMultiplier = math.clamp(tonumber(luckMultiplier) or 1, 0.5, 2.5)
	local roll = math.random()
	local cumulative = 0

	for _, mutationId in ipairs(ColorMutationData.RollOrder) do
		local mutation = ColorMutationData.Mutations[mutationId]
		cumulative += math.min(0.35, (mutation.Chance or 0) * luckMultiplier)
		if roll <= cumulative then
			return mutation
		end
	end

	return ColorMutationData.Mutations.None
end

return ColorMutationData
]]></string>
      </Properties>
    </Item>
    <Item class="ModuleScript" referent="7">
      <Properties>
        <string name="Name">ColorPersonalityData</string>
        <string name="Source"><![CDATA[local ColorPersonalityData = {}

-- Internal systems may use Pet naming, but player-facing companions are called Colors.
ColorPersonalityData.DefaultId = "Neutral"

ColorPersonalityData.Personalities = {
	Neutral = {
		Id = "Neutral",
		DisplayName = "Neutral",
		Description = "A steady Color with no special bonus.",
		Weight = 25,
		EffectType = "None",
		EffectValue = 0,
		Color = Color3.fromRGB(185, 190, 205),
		Icon = "-",
	},
	Cheerful = {
