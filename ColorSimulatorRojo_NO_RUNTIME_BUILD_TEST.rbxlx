local responsiveScales = {}
local camera = workspace.CurrentCamera
local function updateResponsiveScales()
	local viewportY = camera and camera.ViewportSize.Y or 1080
	local scale = math.clamp(viewportY / 1080, 0.70, 1.0)
	for _, uiScale in ipairs(responsiveScales) do
		uiScale.Scale = scale
	end
end
local function addResponsiveScale(target)
	local uiScale = Instance.new("UIScale")
	uiScale.Name = "ResponsiveScale"
	uiScale.Parent = target
	table.insert(responsiveScales, uiScale)
	updateResponsiveScales()
	return uiScale
end

local comingSoonTicket = 0
local function showComingSoon(label)
	comingSoonTicket += 1
	local ticket = comingSoonTicket
	local popup = Instance.new("TextLabel")
	popup.Name = "ComingSoonToast"
	popup.AnchorPoint = Vector2.new(0.5, 0.5)
	popup.Size = UDim2.new(0, 260, 0, 48)
	popup.Position = UDim2.new(0.5, 0, 0.72, 0)
	popup.BackgroundColor3 = Color3.fromRGB(35, 38, 45)
	popup.Font = Enum.Font.LuckiestGuy
	popup.TextSize = 20
	popup.TextColor3 = UI_WHITE
	popup.TextStrokeTransparency = 1
	popup.Text = tostring(label or "Coming Soon") .. " coming soon"
	popup.ZIndex = 120
	popup.Parent = toastContainer
	local corner = Instance.new("UICorner")
	corner.CornerRadius = UDim.new(0, 12)
	corner.Parent = popup

	TweenService:Create(popup, TweenInfo.new(0.14), {
		BackgroundTransparency = 0.08,
	}):Play()
	task.delay(1.4, function()
		if ticket ~= comingSoonTicket or not popup.Parent then
			return
		end
		TweenService:Create(popup, TweenInfo.new(0.16), {
			BackgroundTransparency = 1,
			TextTransparency = 1,
		}):Play()
		task.wait(0.16)
		if popup and popup.Parent then
			popup:Destroy()
		end
	end)
end
if camera then
	camera:GetPropertyChangedSignal("ViewportSize"):Connect(updateResponsiveScales)
end

