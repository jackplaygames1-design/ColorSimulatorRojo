        <Item class="LocalScript" referent="83">
          <Properties>
            <string name="Name">CodesUI</string>
            <string name="Source"><![CDATA[-- CodesUI.client.luau
local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local TweenService = game:GetService("TweenService")

local player = Players.LocalPlayer
local UIManager = require(ReplicatedStorage:WaitForChild("UIManager"))
local UITheme = require(ReplicatedStorage:WaitForChild("UITheme"))
local ClientUIRoot = require(ReplicatedStorage:WaitForChild("ClientUIRoot"))

local Events = ReplicatedStorage:WaitForChild("Events")
local redeemEvent = Events:WaitForChild("RedeemCode", 10)

local DARK = Color3.fromRGB(35, 38, 45)
local WHITE = Color3.fromRGB(255, 255, 255)
local BLUE = Color3.fromRGB(118, 205, 255)
local GREEN = Color3.fromRGB(116, 220, 125)
local RED = Color3.fromRGB(255, 105, 125)
local PANEL = Color3.fromRGB(255, 248, 252)
local PANEL_WIDTH = 540
local PANEL_HEIGHT = 320

local screenGui = ClientUIRoot.GetLayer(player.PlayerGui, "CodesUI")

local overlay = UITheme.CreateDimOverlay(screenGui, 50)

local panel = Instance.new("Frame")
panel.Name = "CodesPanel"
panel.AnchorPoint = Vector2.new(0.5, 0.5)
panel.Size = UDim2.new(0, PANEL_WIDTH, 0, PANEL_HEIGHT)
panel.Position = UDim2.fromScale(0.5, 0.5)
panel.BackgroundColor3 = PANEL
panel.BorderSizePixel = 0
panel.Visible = false
panel.ZIndex = 60
panel.Parent = screenGui
UITheme.ApplyResponsiveScale(panel, PANEL_WIDTH, PANEL_HEIGHT, 0.74, 28)
local corner = Instance.new("UICorner")
corner.CornerRadius = UDim.new(0, 22)
corner.Parent = panel
local stroke = Instance.new("UIStroke")
stroke.Color = DARK
stroke.Thickness = 5
stroke.Parent = panel

local header = Instance.new("Frame")
header.Size = UDim2.new(1, 0, 0, 62)
header.BackgroundColor3 = BLUE
header.BorderSizePixel = 0
header.Parent = panel
local headerCorner = Instance.new("UICorner")
headerCorner.CornerRadius = UDim.new(0, 22)
headerCorner.Parent = header

local title = Instance.new("TextLabel")
title.Size = UDim2.new(1, -76, 1, 0)
title.Position = UDim2.new(0, 20, 0, 0)
title.BackgroundTransparency = 1
title.Font = Enum.Font.LuckiestGuy
title.TextSize = 30
title.TextColor3 = WHITE
title.TextStrokeTransparency = 0
title.TextStrokeColor3 = DARK
title.TextXAlignment = Enum.TextXAlignment.Left
title.Text = "CODES"
title.Parent = header

local closeBtn = Instance.new("TextButton")
closeBtn.Size = UDim2.new(0, 42, 0, 42)
closeBtn.Position = UDim2.new(1, -54, 0.5, -21)
closeBtn.BackgroundColor3 = RED
closeBtn.Font = Enum.Font.LuckiestGuy
closeBtn.TextSize = 22
closeBtn.TextColor3 = WHITE
closeBtn.TextStrokeTransparency = 0
closeBtn.TextStrokeColor3 = DARK
closeBtn.Text = "X"
closeBtn.Parent = header
local closeCorner = Instance.new("UICorner")
closeCorner.CornerRadius = UDim.new(0, 12)
closeCorner.Parent = closeBtn

local prompt = Instance.new("TextLabel")
prompt.Size = UDim2.new(1, -40, 0, 48)
prompt.Position = UDim2.new(0, 20, 0, 88)
prompt.BackgroundTransparency = 1
prompt.Font = Enum.Font.GothamBold
prompt.TextSize = 16
prompt.TextColor3 = Color3.fromRGB(80, 84, 104)
prompt.TextWrapped = true
prompt.TextXAlignment = Enum.TextXAlignment.Left
prompt.Text = "Redeem update codes for Coins, Color, and starter rewards."
prompt.Parent = panel

local input = Instance.new("TextBox")
input.Size = UDim2.new(1, -180, 0, 54)
input.Position = UDim2.new(0, 20, 0, 150)
input.BackgroundColor3 = WHITE
input.Font = Enum.Font.LuckiestGuy
input.TextSize = 22
input.TextColor3 = DARK
input.PlaceholderText = "ENTER CODE"
input.PlaceholderColor3 = Color3.fromRGB(150, 155, 175)
input.Text = ""
input.ClearTextOnFocus = false
input.Parent = panel
local inputCorner = Instance.new("UICorner")
inputCorner.CornerRadius = UDim.new(0, 14)
inputCorner.Parent = input
local inputStroke = Instance.new("UIStroke")
inputStroke.Color = DARK
inputStroke.Thickness = 3
inputStroke.Parent = input

local redeemBtn = Instance.new("TextButton")
redeemBtn.Size = UDim2.new(0, 130, 0, 54)
redeemBtn.Position = UDim2.new(1, -150, 0, 150)
redeemBtn.BackgroundColor3 = GREEN
redeemBtn.Font = Enum.Font.LuckiestGuy
redeemBtn.TextSize = 20
redeemBtn.TextColor3 = WHITE
redeemBtn.TextStrokeTransparency = 0
redeemBtn.TextStrokeColor3 = DARK
redeemBtn.Text = "REDEEM"
redeemBtn.Parent = panel
local redeemCorner = Instance.new("UICorner")
redeemCorner.CornerRadius = UDim.new(0, 14)
redeemCorner.Parent = redeemBtn
local redeemStroke = Instance.new("UIStroke")
redeemStroke.Color = DARK
redeemStroke.Thickness = 3
redeemStroke.Parent = redeemBtn

local statusLabel = Instance.new("TextLabel")
statusLabel.Size = UDim2.new(1, -40, 0, 46)
statusLabel.Position = UDim2.new(0, 20, 0, 222)
statusLabel.BackgroundTransparency = 1
statusLabel.Font = Enum.Font.GothamBold
statusLabel.TextSize = 15
statusLabel.TextColor3 = Color3.fromRGB(80, 84, 104)
statusLabel.TextWrapped = true
statusLabel.TextXAlignment = Enum.TextXAlignment.Left
statusLabel.Text = "Try RELEASE or COLOR."
statusLabel.Parent = panel

local isOpen = false
local pending = false

local function applyModalLayer()
	panel.ZIndex = 60
	for _, obj in ipairs(panel:GetDescendants()) do
		if obj:IsA("GuiObject") and obj.ZIndex < 61 then
			obj.ZIndex = 61
		end
	end
	closeBtn.ZIndex = 70
end

local function setStatus(text, color)
	statusLabel.Text = text or ""
	statusLabel.TextColor3 = color or Color3.fromRGB(80, 84, 104)
end

local function submitCode()
	if pending then
		return
	end

	local code = input.Text
	if code == "" then
		setStatus("Enter a code first.", RED)
		return
	end

	pending = true
	redeemBtn.Text = "..."
	setStatus("Checking code...")
	if not redeemEvent then
		pending = false
		redeemBtn.Text = "REDEEM"
		setStatus("Codes are still loading. Restart Play after Rojo syncs.", RED)
		return
	end
	redeemEvent:FireServer(code)
end

local function toggleCodes(open)
	isOpen = open
	if open then
		overlay.Visible = true
		overlay.BackgroundTransparency = 1
		panel.Visible = true
		panel.Size = UDim2.new(0, 80, 0, 80)
		panel.Position = UDim2.fromScale(0.5, 0.5)
		applyModalLayer()
		TweenService:Create(overlay, TweenInfo.new(0.18), {
			BackgroundTransparency = 0.4,
		}):Play()
		TweenService:Create(panel, TweenInfo.new(0.25, Enum.EasingStyle.Back), {
			Size = UDim2.new(0, PANEL_WIDTH, 0, PANEL_HEIGHT),
			Position = UDim2.fromScale(0.5, 0.5),
		}):Play()
	else
		TweenService:Create(overlay, TweenInfo.new(0.16), {
			BackgroundTransparency = 1,
		}):Play()
		TweenService:Create(panel, TweenInfo.new(0.16), {
			Size = UDim2.new(0, 0, 0, 0),
			Position = UDim2.fromScale(0.5, 0.5),
		}):Play()
		task.delay(0.16, function()
			if not isOpen then
				panel.Visible = false
				overlay.Visible = false
			end
		end)
	end
end

redeemBtn.MouseButton1Click:Connect(submitCode)
input.FocusLost:Connect(function(enterPressed)
	if enterPressed then
		submitCode()
	end
end)

closeBtn.MouseButton1Click:Connect(function()
	toggleCodes(false)
end)

overlay.MouseButton1Click:Connect(function()
	toggleCodes(false)
end)

if redeemEvent then
	redeemEvent.OnClientEvent:Connect(function(success, message)
		pending = false
		redeemBtn.Text = "REDEEM"
		if success then
			input.Text = ""
			setStatus(tostring(message or "Code redeemed!"), Color3.fromRGB(45, 150, 80))
		else
			setStatus(tostring(message or "Could not redeem code."), RED)
		end
	end)
end

UIManager.register("Codes", function() toggleCodes(true) end, function() toggleCodes(false) end, function() return isOpen end)

local codesBtn = ReplicatedStorage:WaitForChild("HudButton_CODES", 10)
if codesBtn then
	codesBtn.Event:Connect(function()
		UIManager.toggle("Codes")
	end)
end
]]></string>
          </Properties>
        </Item>
        <Item class="LocalScript" referent="84">
          <Properties>
            <string name="Name">ColorEffectClient</string>
            <string name="Source"><![CDATA[local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local TweenService = game:GetService("TweenService")
local Debris = game:GetService("Debris")

local player = Players.LocalPlayer
local Events = ReplicatedStorage:WaitForChild("Events")
local colorEffectVfxEvent = Events:WaitForChild("ColorEffectVFX")

local function getClientSetting(key, defaultValue)
	local value = player:GetAttribute("Setting" .. key)
	return type(value) == "boolean" and value or defaultValue
end

local EFFECT_COLORS = {
	Lightning = Color3.fromRGB(92, 220, 255),
	Magnet = Color3.fromRGB(105, 230, 255),
	Storm = Color3.fromRGB(95, 175, 255),
	Glitched = Color3.fromRGB(180, 90, 255),
	Rainbow = Color3.fromRGB(255, 120, 220),
}

local function getFxColor(payload)
	local mutationId = payload and payload.MutationId
	return EFFECT_COLORS[mutationId] or EFFECT_COLORS[payload and payload.Effect] or EFFECT_COLORS.Lightning
end

local function makeBeamPart(fromPosition, toPosition, color)
	local direction = toPosition - fromPosition
	local distance = direction.Magnitude
	if distance <= 0.1 then
		return
	end

	local part = Instance.new("Part")
	part.Name = "ColorEffectBeam"
	part.Anchored = true
	part.CanCollide = false
	part.CanTouch = false
	part.CanQuery = false
	part.CastShadow = false
	part.Material = Enum.Material.Neon
	part.Color = color
	part.Size = Vector3.new(0.18, 0.18, distance)
	part.CFrame = CFrame.lookAt(fromPosition:Lerp(toPosition, 0.5), toPosition)
	part.Transparency = 0.12
	part.Parent = workspace

	TweenService:Create(part, TweenInfo.new(0.18), {
		Transparency = 1,
		Size = Vector3.new(0.04, 0.04, distance),
	}):Play()
	Debris:AddItem(part, 0.22)
end

local function makeFlash(position, color)
	local flash = Instance.new("Part")
	flash.Name = "ColorEffectFlash"
	flash.Shape = Enum.PartType.Ball
	flash.Anchored = true
	flash.CanCollide = false
	flash.CanTouch = false
	flash.CanQuery = false
	flash.CastShadow = false
	flash.Material = Enum.Material.Neon
	flash.Color = color
	flash.Size = Vector3.new(1.2, 1.2, 1.2)
	flash.CFrame = CFrame.new(position)
	flash.Transparency = 0.2
	flash.Parent = workspace

	TweenService:Create(flash, TweenInfo.new(0.22, Enum.EasingStyle.Quad), {
		Transparency = 1,
		Size = Vector3.new(3.5, 3.5, 3.5),
	}):Play()
	Debris:AddItem(flash, 0.28)
end

local function playLightning(payload)
	local fromPosition = payload.From
	local targets = payload.Targets
	if typeof(fromPosition) ~= "Vector3" or type(targets) ~= "table" then
		return
	end

	local color = getFxColor(payload)
	for _, targetPosition in ipairs(targets) do
		if typeof(targetPosition) == "Vector3" then
			makeBeamPart(fromPosition, targetPosition, color)
			makeFlash(targetPosition, color)
		end
	end
end

local function playMagnet(payload)
	local fromPosition = payload.From
	local targets = payload.Targets
	if typeof(fromPosition) ~= "Vector3" or type(targets) ~= "table" then
		return
	end

	local color = getFxColor(payload)
	for _, targetPosition in ipairs(targets) do
		if typeof(targetPosition) == "Vector3" then
			local orb = Instance.new("Part")
			orb.Name = "ColorMagnetOrb"
			orb.Shape = Enum.PartType.Ball
			orb.Anchored = true
			orb.CanCollide = false
			orb.CanTouch = false
			orb.CanQuery = false
			orb.CastShadow = false
			orb.Material = Enum.Material.Neon
			orb.Color = color
			orb.Size = Vector3.new(0.7, 0.7, 0.7)
			orb.CFrame = CFrame.new(targetPosition)
			orb.Parent = workspace
			TweenService:Create(orb, TweenInfo.new(0.24, Enum.EasingStyle.Quad), {
				CFrame = CFrame.new(fromPosition),
				Transparency = 1,
			}):Play()
			Debris:AddItem(orb, 0.3)
		end
	end
end

colorEffectVfxEvent.OnClientEvent:Connect(function(payload)
	if type(payload) ~= "table" then
		return
	end
	if getClientSetting("LowFX", false) then
		return
	end

	if payload.Effect == "Magnet" then
		playMagnet(payload)
	else
		playLightning(payload)
	end
end)
]]></string>
          </Properties>
        </Item>
        <Item class="LocalScript" referent="85">
          <Properties>
            <string name="Name">CoreGuiPolish</string>
            <string name="Source"><![CDATA[-- Hide old Roblox CoreGui panels that clash with the custom simulator HUD.
local StarterGui = game:GetService("StarterGui")

local function setCoreGuiEnabled(coreGuiType, enabled)
	for _ = 1, 20 do
		local ok = pcall(function()
			StarterGui:SetCoreGuiEnabled(coreGuiType, enabled)
		end)
		if ok then
			return
		end
		task.wait(0.25)
	end
end

task.spawn(function()
	setCoreGuiEnabled(Enum.CoreGuiType.Backpack, false)
	setCoreGuiEnabled(Enum.CoreGuiType.PlayerList, false)
end)
]]></string>
          </Properties>
        </Item>
        <Item class="LocalScript" referent="86">
          <Properties>
            <string name="Name">CoreJuice</string>
            <string name="Source"><![CDATA[-- Client-only feedback layer for the core loop: break Color, hatch, merge, unlock.
local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local SoundService = game:GetService("SoundService")
local TweenService = game:GetService("TweenService")
local UserInputService = game:GetService("UserInputService")
local Debris = game:GetService("Debris")

local player = Players.LocalPlayer
local playerGui = player:WaitForChild("PlayerGui")
local ClientUIRoot = require(ReplicatedStorage:WaitForChild("ClientUIRoot"))

local Events = ReplicatedStorage:WaitForChild("Events")
local collectEvent = Events:WaitForChild("CollectColor")
local petBreakRewardEvent = Events:WaitForChild("PetBreakReward")
local hatchEvent = Events:WaitForChild("HatchEgg")
local mergeEvent = Events:WaitForChild("MergePet")
local unlockEvent = Events:WaitForChild("UnlockArea")
local hatchFocusActive = ReplicatedStorage:FindFirstChild("HatchFocusActive")
if not hatchFocusActive then
	hatchFocusActive = Instance.new("BoolValue")
	hatchFocusActive.Name = "HatchFocusActive"
	hatchFocusActive.Parent = ReplicatedStorage
end

local stats = player:WaitForChild("leaderstats")
local coins = stats:WaitForChild("Coins")

local UI_DARK = Color3.fromRGB(35, 38, 45)
local CYAN = Color3.fromRGB(118, 238, 244)
local YELLOW = Color3.fromRGB(255, 235, 105)
local GREEN = Color3.fromRGB(116, 245, 42)
local PINK = Color3.fromRGB(255, 24, 96)
local PURPLE = Color3.fromRGB(200, 120, 255)
local WHITE = Color3.fromRGB(255, 255, 255)
local ORANGE = Color3.fromRGB(255, 170, 70)

local SOUND_IDS = {
	collect = "rbxasset://sounds/button.wav",
	coins = "rbxasset://sounds/electronicpingshort.wav",
	hatch = "rbxasset://sounds/electronicpingshort.wav",
	merge = "rbxasset://sounds/button.wav",
	unlock = "rbxasset://sounds/electronicpingshort.wav",
}

local juiceGui = ClientUIRoot.GetLayer(playerGui, "CoreJuiceUI")

local function playSound(kind, volume, speed)
	local soundId = SOUND_IDS[kind]
	if not soundId then
		return
	end

	local sound = Instance.new("Sound")
	sound.SoundId = soundId
	sound.Volume = volume or 0.25
	sound.PlaybackSpeed = speed or 1
	sound.Parent = SoundService
	sound:Play()
	Debris:AddItem(sound, 3)
end

local function getHudObject(name)
	local currentRoot = playerGui:FindFirstChild("ColorSimulatorUI")
	if currentRoot then
		local hud = currentRoot:FindFirstChild("HUD")
		if hud then
			local object = hud:FindFirstChild(name, true)
			if object then
				return object
			end
		end

		local legacyLayer = currentRoot:FindFirstChild("HudUI")
		if legacyLayer then
			return legacyLayer:FindFirstChild(name, true)
		end
	end

	local legacyRoot = playerGui:FindFirstChild("HudUI")
	return legacyRoot and legacyRoot:FindFirstChild(name, true) or nil
end

local function pulse(guiObject, peak)
	if not guiObject then
		return
	end

	local scale = guiObject:FindFirstChild("JuiceScale")
	if not scale then
		scale = Instance.new("UIScale")
		scale.Name = "JuiceScale"
		scale.Scale = 1
		scale.Parent = guiObject
	end

	TweenService:Create(scale, TweenInfo.new(0.08, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
		Scale = peak or 1.08,
	}):Play()

	task.delay(0.08, function()
		if scale and scale.Parent then
			TweenService:Create(scale, TweenInfo.new(0.18, Enum.EasingStyle.Back), {
				Scale = 1,
			}):Play()
		end
	end)
end

local function makeFlash(color, transparency)
	local flash = Instance.new("Frame")
	flash.Size = UDim2.new(1, 0, 1, 0)
	flash.BackgroundColor3 = color
	flash.BackgroundTransparency = transparency or 0.55
	flash.BorderSizePixel = 0
	flash.ZIndex = 300
	flash.Parent = juiceGui

	TweenService:Create(flash, TweenInfo.new(0.35, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
		BackgroundTransparency = 1,
	}):Play()

	Debris:AddItem(flash, 0.4)
end

local function burstAt(screenPos, color, count, spread)
	count = count or 12
	spread = spread or 60

	for i = 1, count do
		local dot = Instance.new("Frame")
		local size = math.random(7, 13)
		dot.Size = UDim2.new(0, size, 0, size)
		dot.AnchorPoint = Vector2.new(0.5, 0.5)
		dot.Position = UDim2.new(0, screenPos.X, 0, screenPos.Y)
		dot.BackgroundColor3 = color
		dot.BorderSizePixel = 0
		dot.ZIndex = 250
		dot.Parent = juiceGui
		local corner = Instance.new("UICorner")
		corner.CornerRadius = UDim.new(1, 0)
		corner.Parent = dot
		local stroke = Instance.new("UIStroke")
		stroke.Color = UI_DARK
		stroke.Thickness = 1
		stroke.Transparency = 0.25
		stroke.Parent = dot

		local angle = math.rad((360 / count) * i + math.random(-18, 18))
		local distance = math.random(math.floor(spread * 0.45), spread)
		local target = screenPos + Vector2.new(math.cos(angle) * distance, math.sin(angle) * distance)

		TweenService:Create(dot, TweenInfo.new(0.45, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
			Position = UDim2.new(0, target.X, 0, target.Y),
			BackgroundTransparency = 1,
			Size = UDim2.new(0, 2, 0, 2),
		}):Play()

		task.delay(0.3, function()
			if stroke and stroke.Parent then
				TweenService:Create(stroke, TweenInfo.new(0.15), { Transparency = 1 }):Play()
			end
		end)
		Debris:AddItem(dot, 0.55)
	end
end

local function toast(text, color)
	local label = Instance.new("TextLabel")
	label.AnchorPoint = Vector2.new(0.5, 0.5)
	label.Size = UDim2.new(0, 320, 0, 42)
	label.Position = UDim2.new(0.5, 0, 0.22, 0)
	label.BackgroundTransparency = 1
	label.Font = Enum.Font.LuckiestGuy
	label.TextSize = 24
	label.TextColor3 = color or WHITE
	label.TextStrokeTransparency = 0
	label.TextStrokeColor3 = UI_DARK
	label.Text = text
	label.ZIndex = 260
	label.Parent = juiceGui

	label.TextTransparency = 1
	label.TextStrokeTransparency = 1
	TweenService:Create(label, TweenInfo.new(0.16, Enum.EasingStyle.Back), {
		TextTransparency = 0,
		TextStrokeTransparency = 0,
		Position = UDim2.new(0.5, 0, 0.18, 0),
	}):Play()

	task.delay(1.1, function()
		if label and label.Parent then
			TweenService:Create(label, TweenInfo.new(0.2), {
				TextTransparency = 1,
				TextStrokeTransparency = 1,
				Position = UDim2.new(0.5, 0, 0.14, 0),
			}):Play()
		end
	end)

	Debris:AddItem(label, 1.45)
end

local function ripple(button, color)
	if not button or not button:IsA("GuiButton") then
		return
	end

	local pos = UserInputService:GetMouseLocation()
	local absPos = button.AbsolutePosition
	local localX = pos.X - absPos.X
	local localY = pos.Y - absPos.Y
	local maxSize = math.max(button.AbsoluteSize.X, button.AbsoluteSize.Y) * 1.6

	local circle = Instance.new("Frame")
	circle.AnchorPoint = Vector2.new(0.5, 0.5)
	circle.Size = UDim2.new(0, 0, 0, 0)
	circle.Position = UDim2.new(0, localX, 0, localY)
	circle.BackgroundColor3 = color or WHITE
	circle.BackgroundTransparency = 0.55
	circle.BorderSizePixel = 0
	circle.ZIndex = button.ZIndex + 4
	circle.Active = false
	circle.Parent = button
	local corner = Instance.new("UICorner")
	corner.CornerRadius = UDim.new(1, 0)
	corner.Parent = circle

	TweenService:Create(circle, TweenInfo.new(0.32, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
		Size = UDim2.new(0, maxSize, 0, maxSize),
		BackgroundTransparency = 1,
	}):Play()

	Debris:AddItem(circle, 0.36)
end

local function buttonColor(button)
	if button:IsA("TextButton") or button:IsA("ImageButton") then
		return button.BackgroundColor3
	end
	return CYAN
end

local function enhanceButton(button)
	if not button:IsA("GuiButton") or button:GetAttribute("CoreJuiced") then
		return
	end
	button:SetAttribute("CoreJuiced", true)

	local scale = button:FindFirstChild("ButtonJuiceScale")
	if not scale then
		scale = Instance.new("UIScale")
		scale.Name = "ButtonJuiceScale"
		scale.Scale = 1
		scale.Parent = button
	end

	local function tweenScale(value, duration)
		if scale and scale.Parent then
			TweenService:Create(scale, TweenInfo.new(duration or 0.12, Enum.EasingStyle.Back), { Scale = value }):Play()
		end
	end

	button.MouseEnter:Connect(function()
		tweenScale(1.045, 0.12)
	end)

	button.MouseLeave:Connect(function()
		tweenScale(1, 0.12)
	end)

	button.MouseButton1Down:Connect(function()
		tweenScale(0.94, 0.06)
	end)

	button.MouseButton1Up:Connect(function()
		tweenScale(1.045, 0.1)
		task.delay(0.09, function()
			tweenScale(1, 0.12)
		end)
	end)

	button.Activated:Connect(function()
		local color = buttonColor(button)
		playSound("collect", 0.08, math.random(112, 124) / 100)
		ripple(button, color:Lerp(WHITE, 0.45))
		burstAt(UserInputService:GetMouseLocation(), color:Lerp(WHITE, 0.25), 5, 22)
	end)
end

local function enhancePanel(panel)
	if not panel:IsA("Frame") or panel:GetAttribute("CoreShine") then
		return
	end
	if panel:IsDescendantOf(juiceGui) then
		return
	end
	if not panel:FindFirstChildOfClass("UIStroke") then
		return
	end

	local name = string.lower(panel.Name)
	if not (string.find(name, "panel") or string.find(name, "popup") or string.find(name, "card")) then
		return
	end

	panel:SetAttribute("CoreShine", true)

	local shine = Instance.new("Frame")
	shine.Name = "CoreShineSweep"
	shine.Size = UDim2.new(0, 70, 1, 40)
	shine.Position = UDim2.new(0, -90, 0, -20)
	shine.BackgroundColor3 = WHITE
	shine.BackgroundTransparency = 0.7
	shine.BorderSizePixel = 0
	shine.Rotation = 14
	shine.ZIndex = panel.ZIndex + 2
	shine.Active = false
	shine.Parent = panel
	local gradient = Instance.new("UIGradient")
	gradient.Transparency = NumberSequence.new({
		NumberSequenceKeypoint.new(0, 1),
		NumberSequenceKeypoint.new(0.5, 0.15),
		NumberSequenceKeypoint.new(1, 1),
	})
	gradient.Parent = shine

	task.spawn(function()
		while shine.Parent do
			task.wait(math.random(18, 32) / 10)
			if panel.Visible then
				shine.Position = UDim2.new(0, -90, 0, -20)
				TweenService:Create(shine, TweenInfo.new(0.7, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
					Position = UDim2.new(1, 30, 0, -20),
				}):Play()
			end
		end
	end)
end

local function enhanceExistingGui(root)
	for _, obj in ipairs(root:GetDescendants()) do
		if obj:IsA("GuiButton") then
			enhanceButton(obj)
		elseif obj:IsA("Frame") then
			enhancePanel(obj)
		end
	end
end

task.defer(function()
	enhanceExistingGui(playerGui)
end)

playerGui.DescendantAdded:Connect(function(obj)
	task.defer(function()
		if obj:IsA("GuiButton") then
			enhanceButton(obj)
		elseif obj:IsA("Frame") then
			enhancePanel(obj)
		end
	end)
end)

collectEvent.OnClientEvent:Connect(function(success, amount)
	if not success or not amount or amount <= 0 then
		return
	end

	playSound("collect", 0.18, math.random(96, 110) / 100)
	pulse(getHudObject("CoinsRow") or getHudObject("CoinPill"), 1.04)
	burstAt(UserInputService:GetMouseLocation(), CYAN, 8, 42)
end)

local lastCoins = coins.Value
local lastCoinJuiceAt = 0
local petRewardCoinsToSuppress = 0
local lastPetRewardAt = 0

local function playCoinJuice()
	local now = os.clock()
	if now - lastCoinJuiceAt < 0.45 then
		return
	end
	lastCoinJuiceAt = now

	playSound("coins", 0.28, 1.05)
	pulse(getHudObject("CoinsRow") or getHudObject("CoinPill"), 1.08)
	makeFlash(YELLOW, 0.72)
	toast("COINS +", YELLOW)
end

coins:GetPropertyChangedSignal("Value"):Connect(function()
	local oldCoins = lastCoins
	local gained = coins.Value - oldCoins
	if gained > 0 then
		pulse(getHudObject("CoinsRow") or getHudObject("CoinPill"), 1.05)
		local suppressForPet = false
		if petRewardCoinsToSuppress > 0 and os.clock() - lastPetRewardAt < 2 then
			local consumed = math.min(petRewardCoinsToSuppress, gained)
			petRewardCoinsToSuppress -= consumed
			suppressForPet = consumed > 0
		end
		if not suppressForPet then
			playCoinJuice()
		end
	end
	lastCoins = coins.Value
end)

petBreakRewardEvent.OnClientEvent:Connect(function(payload)
	local amount = 0
	if type(payload) == "table" then
		amount = tonumber(payload.Amount or payload.amount) or 0
	else
		amount = tonumber(payload) or 0
	end
	amount = math.floor(amount)
	if amount <= 0 then
		return
	end

	petRewardCoinsToSuppress += amount
	lastPetRewardAt = os.clock()
	pulse(getHudObject("CoinsRow") or getHudObject("CoinPill"), 1.05)
	toast("+" .. tostring(amount) .. " COINS", YELLOW)
end)

local hatchToastToken = 0
hatchEvent.OnClientEvent:Connect(function(success, entry)
	if not success or not entry then
		return
	end

	hatchToastToken += 1
	local token = hatchToastToken
	task.delay(2.65, function()
		if token ~= hatchToastToken then
			return
		end

		playSound("hatch", 0.32, entry.rarity == "Legendary" and 0.9 or 1.12)
		local color = entry.rarity == "Legendary" and YELLOW
			or entry.rarity == "Epic" and PURPLE
			or entry.rarity == "Rare" and CYAN
			or WHITE
		makeFlash(color, entry.rarity == "Legendary" and 0.45 or 0.75)
		if hatchFocusActive.Value == true then
			return
		end
		local label = string.upper(entry.displayName or entry.baseName or "COLOR")
		if entry.traitName then
			label ..= " [" .. string.upper(entry.traitName) .. "]"
		elseif entry.trait then
			label ..= " [" .. string.upper(entry.trait.name) .. "]"
		end
		toast("HATCHED " .. label, color)
	end)
end)

mergeEvent.OnClientEvent:Connect(function(success, petId, result)
	if not success then
		return
	end

	playSound("merge", 0.3, 0.82)
	makeFlash(PURPLE, 0.65)
	toast("MERGE UPGRADE", PURPLE)
	burstAt(Vector2.new(workspace.CurrentCamera.ViewportSize.X / 2, workspace.CurrentCamera.ViewportSize.Y * 0.35), PURPLE, 18, 96)
end)

unlockEvent.OnClientEvent:Connect(function(kind, colorType, world)
	if kind ~= "unlocked" then
		return
	end

	playSound("unlock", 0.38, 0.82)
	makeFlash(GREEN, 0.55)
	toast((world and string.upper(world.name) or "WORLD") .. " UNLOCKED", GREEN)
	burstAt(Vector2.new(workspace.CurrentCamera.ViewportSize.X / 2, workspace.CurrentCamera.ViewportSize.Y * 0.28), GREEN, 24, 130)
end)
]]></string>
          </Properties>
        </Item>
        <Item class="LocalScript" referent="87">
          <Properties>
            <string name="Name">EggShopUI</string>
            <string name="Source"><![CDATA[-- Focused world egg shop: one usable egg per world.
local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local TweenService = game:GetService("TweenService")
local Debris = game:GetService("Debris")
local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")

local player = Players.LocalPlayer
local PetData = require(ReplicatedStorage:WaitForChild("PetData"))
local ColorData = require(ReplicatedStorage:WaitForChild("ColorData"))
local UIManager = require(ReplicatedStorage:WaitForChild("UIManager"))
local GameBalance = require(ReplicatedStorage:WaitForChild("GameBalance"))
local UITheme = require(ReplicatedStorage:WaitForChild("UITheme"))
local ClientUIRoot = require(ReplicatedStorage:WaitForChild("ClientUIRoot"))
local Modules = ReplicatedStorage:WaitForChild("Modules")
local PetModelUtil = require(Modules:WaitForChild("PetModelUtil"))

local Events = ReplicatedStorage:WaitForChild("Events")
local hatchEvent = Events:WaitForChild("HatchEgg")
local hatchFocusActive = ReplicatedStorage:FindFirstChild("HatchFocusActive")
if not hatchFocusActive then
	hatchFocusActive = Instance.new("BoolValue")
	hatchFocusActive.Name = "HatchFocusActive"
	hatchFocusActive.Parent = ReplicatedStorage
end
local autoHatchActive = ReplicatedStorage:FindFirstChild("AutoHatchActive")
if not autoHatchActive then
	autoHatchActive = Instance.new("BoolValue")
	autoHatchActive.Name = "AutoHatchActive"
	autoHatchActive.Parent = ReplicatedStorage
end
local openEggShopEvent = ReplicatedStorage:FindFirstChild("OpenEggShop")
if not openEggShopEvent then
	openEggShopEvent = Instance.new("BindableEvent")
	openEggShopEvent.Name = "OpenEggShop"
	openEggShopEvent.Parent = ReplicatedStorage
end

local colorStorage = player:WaitForChild("ColorStorage")
local unlockedColors = colorStorage:WaitForChild("UnlockedColors")
local playerGui = player:WaitForChild("PlayerGui")

local DARK = Color3.fromRGB(35, 38, 45)
local WHITE = Color3.fromRGB(255, 255, 255)
local PANEL_BG = Color3.fromRGB(255, 248, 252)
local PANEL_STROKE = Color3.fromRGB(255, 180, 220)
local TITLE_BG = Color3.fromRGB(180, 220, 255)
local TITLE_TEXT = Color3.fromRGB(80, 60, 130)
local SUB_BG = Color3.fromRGB(245, 235, 252)
local GREEN = Color3.fromRGB(116, 220, 125)
local LOCKED = Color3.fromRGB(205, 210, 225)
local PANEL_WIDTH = 650
local PANEL_HEIGHT = 430

local RARITY_COLOR = {
	Common = Color3.fromRGB(150, 150, 160),
	Uncommon = Color3.fromRGB(70, 190, 95),
	Rare = Color3.fromRGB(80, 130, 255),
	Epic = Color3.fromRGB(180, 80, 255),
	Legendary = Color3.fromRGB(255, 190, 50),
	Secret = Color3.fromRGB(255, 80, 140),
}

local EGG_BY_WORLD = {}
for _, eggId in ipairs(PetData.EggOrder or {}) do
	local egg = PetData.Eggs[eggId]
	if egg and egg.areaColor then
		EGG_BY_WORLD[egg.areaColor] = eggId
	end
end

local selectedEggId = (PetData.EggOrder and PetData.EggOrder[1]) or next(PetData.Eggs)
local isOpen = false
local isHatching = false
local hatchPending = false
local hatchStartedAt = 0
local hatchToken = 0
local worldRows = {}
local hiddenWorldGuis = {}
local eggOptionGuis = {}
local eggParts = {}
local currentNearbyEgg = nil
local autoHatchEnabled = false
local autoHatchRunning = false
local autoHatchThread = nil
local lastAutoHatchAt = 0
local hatchOverlay = nil
local stopAutoButton = nil
local setExternalHatchUiHidden = function() end

local function updateHatchFocusState()
	local overlayVisible = hatchOverlay and hatchOverlay.Visible == true
	hatchFocusActive.Value = overlayVisible or isHatching or hatchPending or autoHatchEnabled
	autoHatchActive.Value = autoHatchEnabled == true
	setExternalHatchUiHidden(hatchFocusActive.Value == true)
	if stopAutoButton then
		stopAutoButton.Visible = autoHatchEnabled == true
	end
end

local function formatNum(value)
	value = tonumber(value) or 0
	if value >= 1000000 then
		return string.format("%.1fM", value / 1000000)
	elseif value >= 1000 then
		return string.format("%.1fK", value / 1000)
	end
	return tostring(value)
end

local function getWorldForEgg(egg)
	return egg and egg.areaColor and ColorData.getWorldByColor(egg.areaColor) or nil
end

local function isEggUnlocked(egg)
	return not egg.areaColor or egg.areaColor == "Red" or ColorData.isColorUnlocked(unlockedColors.Value, egg.areaColor)
end

local function chooseBestUnlockedEgg()
	local best = selectedEggId
	for _, eggId in ipairs(PetData.EggOrder or {}) do
		local egg = PetData.Eggs[eggId]
		if egg and isEggUnlocked(egg) then
			best = eggId
		end
	end
	return best
end

local function getEggIdFromPart(part)
	return part and part:GetAttribute("EggId")
end

local function getEggCostText(eggId)
	local egg = eggId and PetData.Eggs[eggId]
	if not egg then
		return ""
	end
	return formatNum(egg.cost or 0) .. " Coins"
end

local function configureEggPrompt(prompt)
	if not prompt or not prompt:IsA("ProximityPrompt") then
		return
	end

	prompt.ActionText = "Hatch"
	prompt.ObjectText = "Egg"
	prompt.KeyboardKeyCode = Enum.KeyCode.E
	prompt.GamepadKeyCode = Enum.KeyCode.ButtonX
	prompt.HoldDuration = 0
	prompt.MaxActivationDistance = math.max(prompt.MaxActivationDistance, 18)
	prompt.RequiresLineOfSight = false
	prompt.Style = Enum.ProximityPromptStyle.Custom
	prompt:SetAttribute("EggShopPrompt", true)
end

local function createEggOptionsGui(eggPart)
	eggParts[eggPart] = true
	if eggOptionGuis[eggPart] then
		return eggOptionGuis[eggPart]
	end

	local eggId = getEggIdFromPart(eggPart)
	local egg = eggId and PetData.Eggs[eggId]
	local title = egg and egg.displayName or "Egg"

	local gui = Instance.new("BillboardGui")
	gui.Name = "EggOptions"
