local function setNotificationCount(count)
	count = math.max(0, tonumber(count) or 0)
	notificationBadge.Visible = count > 0
	notificationBadgeText.Text = count > 99 and "99+" or tostring(count)
end
notificationCountValue:GetPropertyChangedSignal("Value"):Connect(function()
	setNotificationCount(notificationCountValue.Value)
end)
setNotificationCount(notificationCountValue.Value)

local function getMenuTargetLayout(scaleOffset)
	scaleOffset = scaleOffset or 0
	if hatchFocusActive.Value then
		local size = math.clamp(64 + scaleOffset, 54, 72)
		return UDim2.new(0, size, 0, size), UDim2.new(1, -68, 0.5, size / 2)
	end

	local size = math.clamp(64 + scaleOffset, 54, 72)
	return UDim2.new(0, size, 0, size), UDim2.new(0.5, 0, 1, -116)
end

local function applyHatchFocusHud()
	local focused = hatchFocusActive.Value == true
	local inTutorial = tutorialActive.Value == true
	leftHudContainer.Visible = not focused and not inTutorial
	nextWorldProgressContainer.Visible = not focused and not inTutorial
	objectiveContainer.Visible = not focused
	centerMenuButton.Visible = true

	local size, position = getMenuTargetLayout(0)
	menuBtn.Size = size
	menuBtn.Position = position
	if focused then
		notificationBadge.Position = UDim2.new(1, -39, 0.5, -28)
	else
		notificationBadge.Position = UDim2.new(0.5, 29, 1, -176)
	end
end

