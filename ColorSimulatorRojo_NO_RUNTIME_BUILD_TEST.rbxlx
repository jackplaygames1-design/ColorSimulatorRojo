local coinsLabel = makeCurrencyDisplay(coinsDisplay, "Coins", "CoinIcon", "CoinCounterBlank", Color3.fromRGB(255, 204, 34), 2)

local function makeFallbackButtonVisual(parent, labelText, color, kind)
	local bg = Instance.new("Frame")
	bg.Size = UDim2.fromScale(1, 1)
	bg.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
	bg.BorderSizePixel = 0
	bg.ZIndex = parent.ZIndex + 1
	bg.Parent = parent
	local corner = Instance.new("UICorner")
	corner.CornerRadius = UDim.new(0, 14)
	corner.Parent = bg
	local stroke = Instance.new("UIStroke")
	stroke.Color = UI_DARK
	stroke.Thickness = 3
	stroke.Parent = bg

	if kind == "ShopButton" then
		local sign = addRounded(bg, UDim2.new(0, 38, 0, 14), UDim2.new(0.5, -19, 0, 7), Color3.fromRGB(235, 56, 56), bg.ZIndex + 1, UDim.new(0, 4), 1)
		local signText = Instance.new("TextLabel")
		signText.Size = UDim2.fromScale(1, 1)
		signText.BackgroundTransparency = 1
		signText.Font = Enum.Font.GothamBlack
		signText.TextSize = 9
		signText.TextColor3 = UI_WHITE
		signText.Text = "SHOP"
		signText.ZIndex = sign.ZIndex + 1
		signText.Parent = sign
		for i = 0, 3 do
			addRounded(bg, UDim2.new(0, 10, 0, 11), UDim2.new(0, 8 + i * 10, 0, 23), i % 2 == 0 and Color3.fromRGB(235, 56, 56) or UI_WHITE, bg.ZIndex + 1, UDim.new(0, 3), 1)
		end
		addRounded(bg, UDim2.new(0, 34, 0, 17), UDim2.new(0.5, -17, 0, 33), Color3.fromRGB(255, 239, 215), bg.ZIndex + 1, UDim.new(0, 3), 1)
		addRounded(bg, UDim2.new(0, 8, 0, 13), UDim2.new(0.5, -4, 0, 37), Color3.fromRGB(235, 56, 56), bg.ZIndex + 2, UDim.new(0, 2), 0)
		return
	elseif kind == "WorldButton" then
		local globe = addRounded(bg, UDim2.new(0, 36, 0, 36), UDim2.new(0.5, -18, 0.5, -18), Color3.fromRGB(247, 250, 255), bg.ZIndex + 1, UDim.new(1, 0), 2)
		addRounded(globe, UDim2.new(0, 4, 0, 34), UDim2.new(0.5, -2, 0.5, -17), UI_DARK, globe.ZIndex + 1, UDim.new(1, 0), 0)
		addRounded(globe, UDim2.new(0, 30, 0, 4), UDim2.new(0.5, -15, 0.5, -2), UI_DARK, globe.ZIndex + 1, UDim.new(1, 0), 0)
		addRounded(globe, UDim2.new(0, 22, 0, 4), UDim2.new(0.5, -11, 0, 8), UI_DARK, globe.ZIndex + 1, UDim.new(1, 0), 0)
		addRounded(globe, UDim2.new(0, 22, 0, 4), UDim2.new(0.5, -11, 1, -12), UI_DARK, globe.ZIndex + 1, UDim.new(1, 0), 0)
		return
	end

	local label = Instance.new("TextLabel")
	label.Size = UDim2.fromScale(1, 1)
	label.BackgroundTransparency = 1
	label.Font = Enum.Font.GothamBlack
	label.TextSize = 13
	label.TextColor3 = color
	label.Text = labelText
	label.ZIndex = bg.ZIndex + 1
	label.Parent = bg
end

local function makeHudButton(container, buttonName, imageKey, fallbackText, layoutOrder)
	container.LayoutOrder = layoutOrder
	container.Size = UDim2.new(0, 56, 0, layoutOrder == 3 and 78 or 56)
	container.BackgroundTransparency = 1
	container.ZIndex = 20

	local button = Instance.new("ImageButton")
	button.Name = buttonName
	button.Size = UDim2.new(0, 56, 0, 56)
	button.Position = UDim2.new(0, 0, 0, layoutOrder == 3 and 12 or 0)
	button.BackgroundTransparency = 1
	button.AutoButtonColor = false
	button.ScaleType = Enum.ScaleType.Fit
	button.ZIndex = 22
	button.Parent = container
	if not applyHudImage(button, imageKey) then
		makeFallbackButtonVisual(button, fallbackText, imageKey == "ShopButton" and Color3.fromRGB(230, 45, 45) or UI_DARK, imageKey)
	end
	return button
end

local shopHudButton = makeHudButton(shopButtonContainer, "ShopImageButton", "ShopButton", "SHOP", 3)
local worldHudButton = makeHudButton(worldButtonContainer, "WorldImageButton", "WorldButton", "WORLD", 4)

local function openWindowWhenReady(windowName, fallbackBindable)
	if UIManager.isRegistered(windowName) then
		UIManager.toggle(windowName)
		return
	end
	task.spawn(function()
		local startedAt = os.clock()
		while os.clock() - startedAt < 2 do
			task.wait(0.1)
			if UIManager.isRegistered(windowName) then
				UIManager.toggle(windowName)
				return
			end
		end
		if fallbackBindable then
			fallbackBindable:Fire()
		end
		if not UIManager.isRegistered(windowName) then
			showComingSoon(windowName)
		end
	end)
end

shopHudButton.Activated:Connect(function()
	openWindowWhenReady("Gamepass", HudButton_GAMEPASS)
end)

worldHudButton.Activated:Connect(function()
	openWindowWhenReady("World", HudButton_WORLD)
end)

