		Size = UDim2.new(0, 44, 0, 44),
		Position = UDim2.new(1, -58, 0.5, -22),
		BackgroundColor3 = Color3.fromRGB(255, 98, 123),
	}):Play()
end)

menuCloseBtn.MouseEnter:Connect(function()
	TweenService:Create(menuCloseBtn, TweenInfo.new(0.12), {
		BackgroundColor3 = Color3.fromRGB(255, 120, 145),
	}):Play()
end)

menuCloseBtn.MouseLeave:Connect(function()
	TweenService:Create(menuCloseBtn, TweenInfo.new(0.12), {
		Size = UDim2.new(0, 44, 0, 44),
		Position = UDim2.new(1, -58, 0.5, -22),
		BackgroundColor3 = Color3.fromRGB(255, 98, 123),
	}):Play()
end)

menuCloseBtn.MouseButton1Click:Connect(function()
	UIManager.close("Menu")
end)

menuBackdrop.MouseButton1Click:Connect(function()
	UIManager.close("Menu")
end)

-- ========================
--   GRID BUTTON EVENTS
--   Fire BindableEvents that UIManagerClient listens to
-- ========================
local buttonBindables = {
	PETS      = ReplicatedStorage:FindFirstChild("HudButton_PETS")      or HudButton_PETS,
	UPGRADES  = ReplicatedStorage:FindFirstChild("HudButton_UPGRADES")  or HudButton_UPGRADES,
	WORLD     = ReplicatedStorage:FindFirstChild("HudButton_WORLD")     or HudButton_WORLD,
	GAMEPASS  = ReplicatedStorage:FindFirstChild("HudButton_GAMEPASS")  or HudButton_GAMEPASS,
	INVENTORY = ReplicatedStorage:FindFirstChild("HudButton_INVENTORY") or HudButton_INVENTORY,
	SHOP      = ReplicatedStorage:FindFirstChild("HudButton_SHOP")      or HudButton_SHOP,
	CODES     = ReplicatedStorage:FindFirstChild("HudButton_CODES")     or HudButton_CODES,
}

local CORE_WINDOWS = {
	Inventory = true,
	World = true,
	Gamepass = true,
	Shop = true,
	Codes = true,
	Upgrades = true,
}

local function toggleWindowWhenReady(windowName, fallbackBindable, context)
	context = context or { from = "Menu" }
	if UIManager.isRegistered(windowName) then
		UIManager.open(windowName, context)
		return
	end

	task.spawn(function()
		local startedAt = os.clock()
		local timeout = CORE_WINDOWS[windowName] and 12 or 2
		while os.clock() - startedAt < timeout do
			task.wait(0.1)
			if UIManager.isRegistered(windowName) then
				UIManager.open(windowName, context)
				return
			end
		end

		if fallbackBindable then
			fallbackBindable:Fire()
			local fallbackStartedAt = os.clock()
			while os.clock() - fallbackStartedAt < 4 do
				task.wait(0.1)
				if UIManager.isRegistered(windowName) then
					UIManager.open(windowName, context)
					return
				end
			end
		end

		if CORE_WINDOWS[windowName] then
			warn("HUD menu could not open " .. tostring(windowName) .. "; UI did not register in time.")
			return
		end
		showComingSoon(windowName)
	end)
end

local lastMenuTileActivatedAt = {}
local function activateMenuTile(key, bindable)
	local now = os.clock()
	if lastMenuTileActivatedAt[key] and now - lastMenuTileActivatedAt[key] < 0.25 then
		return
	end
	lastMenuTileActivatedAt[key] = now

	local windowName = ({
		UPGRADES = "Upgrades",
		WORLD = "World",
		GAMEPASS = "Gamepass",
		INVENTORY = "Inventory",
		SHOP = "Shop",
		CODES = "Codes",
		SETTINGS = "Settings",
		TRADING = "Trading",
		PETS = "Inventory",
	})[key]

	if windowName then
		closeMenu(true)
		local context = { from = "Menu" }
		if key == "INVENTORY" or key == "PETS" then
			context.defaultTab = "Brushes"
		end
		if windowName == "Inventory" and openInventoryBindable then
			print("HUD direct inventory open requested")
			openInventoryBindable:Fire(context)
		else
			toggleWindowWhenReady(windowName, bindable, context)
		end
	elseif bindable then
		closeMenu(true)
		task.wait(0.05)
		bindable:Fire()
	end
end

for key, btn in pairs(gridButtons) do
	local tileKey = key
	local be = buttonBindables[tileKey]
	local tileScale = gridButtonScales[tileKey]
	local tileStroke = gridButtonStrokes[tileKey]

	btn.MouseButton1Down:Connect(function()
		TweenService:Create(tileScale, TweenInfo.new(0.07), {
			Scale = 0.94
		}):Play()
	end)

	btn.MouseButton1Up:Connect(function()
		TweenService:Create(tileScale, TweenInfo.new(0.18, Enum.EasingStyle.Back), {
			Scale = 1
		}):Play()
		activateMenuTile(tileKey, be)
	end)

	btn.Activated:Connect(function()
		activateMenuTile(tileKey, be)
	end)

	btn.MouseEnter:Connect(function()
		if tileStroke then
			tileStroke.Thickness = 4
		end
		TweenService:Create(tileScale, TweenInfo.new(0.12, Enum.EasingStyle.Back), {
			Scale = 1.02
		}):Play()
		TweenService:Create(btn, TweenInfo.new(0.1), {
			BackgroundColor3 = btn.BackgroundColor3:Lerp(Color3.new(1,1,1), 0.15)
		}):Play()
	end)
	btn.MouseLeave:Connect(function()
		if tileStroke then
			tileStroke.Thickness = 3
		end
		TweenService:Create(tileScale, TweenInfo.new(0.12), {
			Scale = 1
		}):Play()
		-- Find original color from MENU_ITEMS
		for _, item in ipairs(MENU_ITEMS) do
			if item.key == tileKey then
				TweenService:Create(btn, TweenInfo.new(0.1), {
					BackgroundColor3 = item.color
				}):Play()
				break
			end
		end
	end)
end

local function printHudDebugCounts()
	if screenGui:GetAttribute("HUDDebugPrinted") == true then
		return
	end
	cleanupDuplicateHudElements(screenGui)
	cleanupDuplicateNamedDescendants(screenGui, "CleanCompactHUD")
	cleanupDuplicateNamedDescendants(screenGui, "LeftCompactHud")
	cleanupDuplicateNamedDescendants(screenGui, "CenterMenuHud")
	cleanupDuplicateNamedDescendants(screenGui, "BottomNextWorldHud")
	screenGui:SetAttribute("HUDDebugPrinted", true)
	local cleanRoots = countNamedDescendants(screenGui, "CleanCompactHUD")
	print("HUD Debug: CleanCompactHUD roots = " .. cleanRoots)
	if cleanRoots > 1 then
		warnHudCleanupOnce("HUD cleanup: duplicate CleanCompactHUD count after build")
	end
end

printHudDebugCounts()
applyHatchFocusHud()
hatchFocusActive:GetPropertyChangedSignal("Value"):Connect(applyHatchFocusHud)
autoHatchActive:GetPropertyChangedSignal("Value"):Connect(applyHatchFocusHud)
tutorialActive:GetPropertyChangedSignal("Value"):Connect(applyHatchFocusHud)

-- ========================
--   UPDATE LOOP
-- ========================
RunService.Heartbeat:Connect(function()
	setMenuButtonDisabled(false)
	local coinValue = 0
	local stats = player:FindFirstChild("leaderstats")
	if stats then
		local coins = stats:FindFirstChild("Coins")
		local gems = stats:FindFirstChild("Gems") or stats:FindFirstChild("Diamonds")
		if coins then
			coinValue = tonumber(coins.Value) or 0
			coinsLabel.Text = formatCompact(coinValue)
		else
			coinsLabel.Text = "0"
		end
		if gems then
			gemsLabel.Text = formatCompact(gems.Value)
		else
			gemsLabel.Text = "0"
		end
	end

	local nextWorld = ColorData.getNextLockedWorld(unlockedColors.Value)
	if nextWorld then
		local cost = math.max(tonumber(nextWorld.unlockCost) or 0, 1)
		local progress = math.clamp(coinValue / cost, 0, 1)
		nextWorldLabel.Text = "NEXT WORLD:"
		progressText.Text = formatCompact(math.min(coinValue, cost)) .. " / " .. formatCompact(cost)
		progressBar.Visible = true
		progressBarFill.Size = UDim2.new(progress, 0, 1, 0)
	else
		nextWorldLabel.Text = "MAX WORLD"
		progressText.Text = ""
		progressBar.Visible = false
		progressBarFill.Size = UDim2.new(1, 0, 1, 0)
	end
end)







