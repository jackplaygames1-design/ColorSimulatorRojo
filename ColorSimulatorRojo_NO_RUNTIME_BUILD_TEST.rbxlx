      </Item>
      <Item class="ModuleScript" referent="56">
        <Properties>
          <string name="Name">BuffService</string>
          <string name="Source"><![CDATA[local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")

local BuffService = {}

BuffService.Enabled = true

BuffService.Definitions = {
	CoinsRush = {
		DisplayName = "Coins Rush",
		Duration = 45,
		Color = Color3.fromRGB(255, 214, 55),
		Effects = {
			SellCoinsMultiplier = 2.0,
		},
	},
	SpeedRush = {
		DisplayName = "Speed Rush",
		Duration = 45,
		Color = Color3.fromRGB(136, 255, 70),
		Effects = {
			WalkSpeedMultiplier = 1.3,
		},
	},
	BrushFrenzy = {
		DisplayName = "Brush Frenzy",
		Duration = 45,
		Color = Color3.fromRGB(70, 225, 255),
		Effects = {
			ColorGainMultiplier = 1.25,
			BrushRangeMultiplier = 1.25,
		},
	},
	LuckyAura = {
		DisplayName = "Lucky Aura",
		Duration = 45,
		Color = Color3.fromRGB(180, 105, 255),
		Effects = {
			HatchLuckMultiplier = 1.25,
		},
	},
	GemSurge = {
		DisplayName = "Gem Surge",
		Duration = 30,
		Color = Color3.fromRGB(255, 255, 255),
		Effects = {
			GemRewardMultiplier = 2.0,
			GemDamageMultiplier = 2.0,
		},
	},
}

local events = ReplicatedStorage:FindFirstChild("Events")
if not events then
	events = Instance.new("Folder")
	events.Name = "Events"
	events.Parent = ReplicatedStorage
end

local noticeEvent = events:FindFirstChild("WildBuffNotice")
if not noticeEvent then
	noticeEvent = Instance.new("RemoteEvent")
	noticeEvent.Name = "WildBuffNotice"
	noticeEvent.Parent = events
end

local activeBuffs = {}
local buffChanged = Instance.new("BindableEvent")
BuffService.BuffChanged = buffChanged

local function now()
	return os.clock()
end

local function getPlayerBuffs(player)
	local buffs = activeBuffs[player]
	if not buffs then
		buffs = {}
		activeBuffs[player] = buffs
	end
	return buffs
end

local function ensureBuffFolder(player)
	local folder = player:FindFirstChild("WildBuffs")
	if not folder then
		folder = Instance.new("Folder")
		folder.Name = "WildBuffs"
		folder.Parent = player
	end
	return folder
end

local function syncBuffValue(player, buffId, expiresAt)
	local folder = ensureBuffFolder(player)
	local value = folder:FindFirstChild(buffId)
	if expiresAt and expiresAt > now() then
		if not value then
			value = Instance.new("NumberValue")
			value.Name = buffId
			value.Parent = folder
		end
		value.Value = expiresAt
	elseif value then
		value:Destroy()
	end
end

local function pruneExpired(player)
	local buffs = activeBuffs[player]
	if not buffs then
		return false
	end

	local changed = false
	local t = now()
	for buffId, expiresAt in pairs(buffs) do
		if expiresAt <= t then
			buffs[buffId] = nil
			syncBuffValue(player, buffId, nil)
			changed = true
		end
	end
	if changed then
		buffChanged:Fire(player)
	end
	return changed
end

function BuffService.GetDefinition(buffId)
	return BuffService.Definitions[buffId]
end

function BuffService.Grant(player, buffId, durationOverride)
	if not BuffService.Enabled or not player or not player:IsDescendantOf(Players) then
		return false
	end

	local definition = BuffService.GetDefinition(buffId)
	if not definition then
		warn("BuffService: unknown buff " .. tostring(buffId))
		return false
	end

	local duration = math.max(1, tonumber(durationOverride or definition.Duration) or 1)
	local expiresAt = now() + duration
	local buffs = getPlayerBuffs(player)
	buffs[buffId] = expiresAt
	syncBuffValue(player, buffId, expiresAt)
	buffChanged:Fire(player)

	noticeEvent:FireClient(player, {
		type = "buff",
		id = buffId,
		name = definition.DisplayName or buffId,
		duration = duration,
		expiresAt = expiresAt,
		color = definition.Color,
	})
	return true
end

function BuffService.GetActiveBuffs(player)
	pruneExpired(player)
	local result = {}
	local buffs = activeBuffs[player]
	if not buffs then
		return result
	end

	for buffId, expiresAt in pairs(buffs) do
		local definition = BuffService.GetDefinition(buffId)
		if definition then
			result[buffId] = {
				ExpiresAt = expiresAt,
				Remaining = math.max(0, expiresAt - now()),
				Definition = definition,
			}
		end
	end
	return result
end

function BuffService.HasBuff(player, buffId)
	pruneExpired(player)
	local buffs = activeBuffs[player]
	return buffs and buffs[buffId] and buffs[buffId] > now() or false
end

function BuffService.GetEffects(player)
	local effects = {}
	local buffs = BuffService.GetActiveBuffs(player)
	for _, state in pairs(buffs) do
		local definition = state.Definition
		for key, value in pairs(definition.Effects or {}) do
			if string.find(key, "Multiplier") then
				effects[key] = (effects[key] or 1) * (tonumber(value) or 1)
			else
				effects[key] = (effects[key] or 0) + (tonumber(value) or 0)
			end
		end
	end
	return effects
end

function BuffService.GetMultiplier(player, key)
	local effects = BuffService.GetEffects(player)
	return tonumber(effects[key]) or 1
end

Players.PlayerRemoving:Connect(function(player)
	activeBuffs[player] = nil
end)

task.spawn(function()
	while true do
		task.wait(0.5)
		for _, player in ipairs(Players:GetPlayers()) do
			pruneExpired(player)
		end
	end
end)

return BuffService

]]></string>
        </Properties>
      </Item>
      <Item class="Script" referent="57">
        <Properties>
          <string name="Name">CodeHandler</string>
          <token name="RunContext">0</token>
          <string name="Source"><![CDATA[-- Server-authoritative redeem code handling.
local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")

local codeDataModule = ReplicatedStorage:FindFirstChild("CodeData")
local CodeData = codeDataModule and require(codeDataModule) or {
	Codes = {
		RELEASE = {
			Code = "RELEASE",
			Active = true,
			MaxUsesPerPlayer = 1,
			Message = "Release reward claimed!",
			Rewards = {
				{ Type = "Coins", Amount = 1000 },
			},
		},
		COLOR = {
			Code = "COLOR",
			Active = true,
			MaxUsesPerPlayer = 1,
			Message = "Color boost claimed!",
			Rewards = {
				{ Type = "Coins", Amount = 250 },
			},
		},
		PET = {
			Code = "PET",
			Active = true,
			MaxUsesPerPlayer = 1,
			Message = "Starter Color claimed!",
			Rewards = {
				{ Type = "Pet", PetId = "RedBlob", Amount = 5 },
			},
		},
	},
}

CodeData.normalize = CodeData.normalize or function(code)
	return string.upper((tostring(code or ""):gsub("%s+", "")))
end

CodeData.getCode = CodeData.getCode or function(code)
	return CodeData.Codes[CodeData.normalize(code)]
end

local Events = ReplicatedStorage:WaitForChild("Events")
local redeemEvent = Events:FindFirstChild("RedeemCode")
if not redeemEvent then
	redeemEvent = Instance.new("RemoteEvent")
	redeemEvent.Name = "RedeemCode"
	redeemEvent.Parent = Events
end
local grantPetFunction = ReplicatedStorage:FindFirstChild("ServerGrantPet")
if not grantPetFunction then
	grantPetFunction = Instance.new("BindableFunction")
	grantPetFunction.Name = "ServerGrantPet"
	grantPetFunction.Parent = ReplicatedStorage
end

local cooldowns = {}
local COOLDOWN = 0.8

local function getRedeemedFolder(player)
	local folder = player:FindFirstChild("RedeemedCodes")
	if not folder then
		folder = Instance.new("Folder")
		folder.Name = "RedeemedCodes"
		folder.Parent = player
	end
	return folder
end

local function getUses(player, normalizedCode)
	local existing = getRedeemedFolder(player):FindFirstChild(normalizedCode)
	return existing and existing.Value or 0
end

local function setUses(player, normalizedCode, uses)
	local folder = getRedeemedFolder(player)
	local existing = folder:FindFirstChild(normalizedCode)
	if not existing then
		existing = Instance.new("IntValue")
		existing.Name = normalizedCode
		existing.Parent = folder
	end
	existing.Value = uses
end

local function awardReward(player, reward)
	local rewardType = tostring(reward.Type or reward.type or "")
	local amount = math.max(1, math.floor(tonumber(reward.Amount or reward.amount) or 1))

	if rewardType == "Coins" then
		local stats = player:FindFirstChild("leaderstats")
		local coins = stats and stats:FindFirstChild("Coins")
		if not coins then
			return false, "Coins are not ready."
		end
		coins.Value += amount
		return true
	elseif rewardType == "Color" or rewardType == "Storage" then
		local stats = player:FindFirstChild("leaderstats")
		local coins = stats and stats:FindFirstChild("Coins")
		if not coins then
			return false, "Coins are not ready."
		end
		coins.Value += amount
		return true
	elseif rewardType == "Pet" then
		if not grantPetFunction then
			return false, "Color rewards are not ready."
		end
		local ok, granted = pcall(function()
			return grantPetFunction:Invoke(player, reward.PetId or reward.petId, amount)
		end)
		if not ok or not granted then
			return false, "Color reward failed."
		end
		return true
	end

	return false, "Unsupported reward type."
end

redeemEvent.OnServerEvent:Connect(function(player, rawCode)
	local now = os.clock()
	if cooldowns[player] and now - cooldowns[player] < COOLDOWN then
		return
	end
	cooldowns[player] = now

	local normalized = CodeData.normalize(rawCode)
	if normalized == "" then
		redeemEvent:FireClient(player, false, "Enter a code first.")
		return
	end

	local code = CodeData.getCode(normalized)
	if not code or code.Active == false then
		redeemEvent:FireClient(player, false, "Invalid or expired code.")
		return
	end

	if code.ExpiresAt and os.time() > code.ExpiresAt then
		redeemEvent:FireClient(player, false, "That code has expired.")
		return
	end

	local maxUses = tonumber(code.MaxUsesPerPlayer) or 1
	local uses = getUses(player, normalized)
	if uses >= maxUses then
		redeemEvent:FireClient(player, false, "You already redeemed that code.")
		return
	end

	for _, reward in ipairs(code.Rewards or {}) do
		local ok, message = awardReward(player, reward)
		if not ok then
			redeemEvent:FireClient(player, false, message or "Could not redeem code.")
			return
		end
	end

	setUses(player, normalized, uses + 1)
	redeemEvent:FireClient(player, true, code.Message or "Code redeemed!")
end)

Players.PlayerRemoving:Connect(function(player)
	cooldowns[player] = nil
end)
]]></string>
        </Properties>
      </Item>
      <Item class="Script" referent="58">
        <Properties>
          <string name="Name">ColorCollectHandler</string>
          <token name="RunContext">0</token>
          <string name="Source"><![CDATA[-- Server-authoritative click collection for color breakables.
local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local RunService = game:GetService("RunService")
local DEBUG_LOGS = RunService:IsStudio()

local ColorData = require(ReplicatedStorage:WaitForChild("ColorData"))
local GameBalance = require(ReplicatedStorage:WaitForChild("GameBalance"))
local PetData = require(ReplicatedStorage:WaitForChild("PetData"))
local GamepassBenefits = require(script.Parent:WaitForChild("GamepassBenefits"))
local ColorEffectHandler = require(script.Parent:WaitForChild("ColorEffectHandler"))

local function loadToolData()
	local module = ReplicatedStorage:WaitForChild("ToolData", 3)
	if module then
		return require(module)
	end

	warn("ColorCollectHandler: ToolData missing; using Starter Brush fallback config.")
	local fallback = {}
	fallback.Tools = {
		StarterBrush = {
			Id = "StarterBrush",
			DisplayName = "Starter Brush",
			Range = 9,
			Width = 7,
			Cooldown = 0.45,
			PowerMultiplier = 1,
			CollectPowerMultiplier = 1,
			SweepWidthMultiplier = 1,
			UseSpeedMultiplier = 1,
			PickupRadiusMultiplier = 1,
			VisualType = "Brush",
			MaxTargets = 8,
			MaxServerRange = 24,
		},
	}
	function fallback.get(toolId)
		return fallback.Tools[toolId or ""] or fallback.Tools.StarterBrush
	end
	function fallback.GetEffectiveStats(toolId)
		local tool = fallback.get(toolId)
		return {
			Id = tool.Id,
			CollectPowerMultiplier = tool.CollectPowerMultiplier or tool.PowerMultiplier or 1,
			SweepWidthMultiplier = tool.SweepWidthMultiplier or 1,
			UseSpeedMultiplier = tool.UseSpeedMultiplier or 1,
			PickupRadiusMultiplier = tool.PickupRadiusMultiplier or 1,
			PassiveId = tool.PassiveId or "None",
			PassiveDescription = tool.PassiveDescription or "",
			PassiveEnabled = tool.PassiveEnabled == true,
		}
	end
	return fallback
end

local ToolData = loadToolData()

local Events = ReplicatedStorage:WaitForChild("Events")
local collectEvent = Events:WaitForChild("CollectColor")
local paintSweepEvent = Events:FindFirstChild("PaintToolSweep")
if not paintSweepEvent then
	paintSweepEvent = Instance.new("RemoteEvent")
	paintSweepEvent.Name = "PaintToolSweep"
	paintSweepEvent.Parent = Events
end
local colorEffectVfxEvent = Events:FindFirstChild("ColorEffectVFX")
if not colorEffectVfxEvent then
	colorEffectVfxEvent = Instance.new("RemoteEvent")
	colorEffectVfxEvent.Name = "ColorEffectVFX"
	colorEffectVfxEvent.Parent = Events
end
local tutorialPatchClearedEvent = Events:FindFirstChild("TutorialPatchCleared")
if not tutorialPatchClearedEvent then
	tutorialPatchClearedEvent = Instance.new("BindableEvent")
	tutorialPatchClearedEvent.Name = "TutorialPatchCleared"
	tutorialPatchClearedEvent.Parent = Events
end

local COLLECT_RANGE = 22
local COLLECT_COOLDOWN = 0.18
local RESPAWN_DELAY = 4
local PET_PRIORITY_SECONDS = 6

local lastCollectAt = {}
local lastSweepAt = {}
local lastLightningAt = {}
local lastMagnetAt = {}
local collectionWarnings = {}
local touchConnections = {}
local unexpectedClientWarnings = {}

local function warnCollectionOnce(player, reason, detail)
	local playerKey = player and player.UserId or "server"
	local key = tostring(playerKey) .. ":" .. tostring(reason)
	if collectionWarnings[key] then
		return
	end
	collectionWarnings[key] = true
	warn("Collection ignored: " .. tostring(reason) .. (detail and (" - " .. tostring(detail)) or ""))
end

local function markPetPriorityTarget(player, part)
	if not player or typeof(part) ~= "Instance" or not part:IsA("BasePart") then
		return
	end
	part:SetAttribute("PetPriorityOwnerUserId", player.UserId)
	part:SetAttribute("PetPriorityUntil", os.clock() + PET_PRIORITY_SECONDS)
	part:SetAttribute("PetPrioritySetAt", os.clock())
end

local function warnUnexpectedClientValuesOnce(player, action)
	local key = tostring(player and player.UserId or "server") .. ":" .. tostring(action)
	if unexpectedClientWarnings[key] then
		return
	end
	unexpectedClientWarnings[key] = true
	warn("Collection request ignored unexpected client value fields for " .. tostring(action) .. ". Server calculates rewards.")
end

local function isTouchFallbackEnabled()
	return GameBalance.Collection and GameBalance.Collection.AllowTouchCollectionFallback == true
end

local function getVisualColor(colorType)
	if colorType == "Rainbow" then
		return Color3.fromRGB(215, 180, 255)
	end

	local colorInfo = ColorData.Colors[colorType]
	return colorInfo and colorInfo.color or Color3.new(1, 1, 1)
end

local function getStoredColor(part, colorType)
	local stored = part and part:GetAttribute("SpawnColor")
	if typeof(stored) == "Color3" then
		return stored
	end
	return getVisualColor(colorType)
end

local function parseInventory(str)
	local inventory = {}
	if not str or str == "" then
		return inventory
	end

	for _, part in ipairs(string.split(str, ",")) do
		local segments = string.split(part, ":")
		local variantKey
		local petId
		local stackIndex
		if tonumber(segments[2]) then
			petId = segments[1]
			stackIndex = 2
		else
			variantKey = segments[1]
			petId = segments[2]
			stackIndex = 3
		end
		local stackAmount = tonumber(segments[stackIndex]) or 1
		local traitId = PetData.normalizeTraitId(segments[stackIndex + 1])
		local shinyStr = segments[stackIndex + 2] or "normal"
		local personalityId = PetData.normalizePersonalityId(segments[stackIndex + 3] or "Neutral")
		local mutationId = PetData.normalizeMutationId(segments[stackIndex + 4] or "None")
		variantKey = variantKey or PetData.makeVariantKey(petId, personalityId, mutationId, traitId)
		if petId and petId ~= "" then
			inventory[variantKey] = {
				petId = petId,
				stackAmount = stackAmount,
				traitId = traitId,
				isShiny = shinyStr == "shiny" or shinyStr == "true",
				personalityId = personalityId,
				mutationId = mutationId,
			}
		end
	end

	return inventory
end

local function getPetColorMultiplier(player)
	return ColorEffectHandler.GetColorGainMultiplier(player)
end

local function getPickupRange(player)
	local range = COLLECT_RANGE
	local upgrades = player:FindFirstChild("Upgrades")
	local pickupRange = upgrades and upgrades:FindFirstChild("PickupRange")
	if pickupRange then
		range = pickupRange.Value
	end

	local boostFolder = player:FindFirstChild("Boosts")
	local rangeBoost = boostFolder and boostFolder:FindFirstChild("range")
	if rangeBoost and os.time() < rangeBoost.Value then
		range *= 1.5
	end

	range *= ColorEffectHandler.CalculateEquippedColorEffects(player).BrushRangeMultiplier

	return range
end

local function getCollectMultiplier(player)
	local multiplier = getPetColorMultiplier(player)
	local upgrades = player:FindFirstChild("Upgrades")
	local colorMultiplier = upgrades and upgrades:FindFirstChild("ColorMultiplier")
	if colorMultiplier then
		multiplier *= colorMultiplier.Value
	end

	return multiplier
end

local function getZoneCoinMultiplier(colorType)
	local configured = GameBalance.Sell
		and GameBalance.Sell.ColorValueMultipliers
		and GameBalance.Sell.ColorValueMultipliers[colorType]
	local world = ColorData.getWorldByColor(colorType)
	return tonumber(configured or (world and world.colorValueMultiplier)) or 1
end

local function getInstantCoinMultiplier(player, colorType)
	local multiplier = getZoneCoinMultiplier(colorType)
	multiplier *= ColorEffectHandler.GetSellCoinsMultiplier(player)

	local boostFolder = player:FindFirstChild("Boosts")
	local coinBoost = boostFolder and boostFolder:FindFirstChild("coins")
	if coinBoost and os.time() < coinBoost.Value then
		multiplier *= 2
	end

	multiplier *= GamepassBenefits.getCoinMultiplier(player)
	return multiplier
end

local function awardCoins(player, amount)
	amount = math.max(0, math.floor(tonumber(amount) or 0))
	if amount <= 0 then
		return false
	end

	local stats = player:FindFirstChild("leaderstats")
	local coins = stats and stats:FindFirstChild("Coins")
	if not coins then
		warnCollectionOnce(player, "missing player data", "leaderstats/Coins not ready")
		return false
	end

	coins.Value += amount
	return true
end

local function getPickupUpgradeValue(player)
	local upgrades = player:FindFirstChild("Upgrades")
	local pickupRange = upgrades and upgrades:FindFirstChild("PickupRange")
	return pickupRange and pickupRange.Value or 8
end

local function getToolEffectiveStats(toolConfig)
	if ToolData.GetEffectiveStats then
		return ToolData.GetEffectiveStats(toolConfig and toolConfig.Id or "StarterBrush")
	end

	return {
		CollectPowerMultiplier = toolConfig and (toolConfig.CollectPowerMultiplier or toolConfig.PowerMultiplier) or 1,
		SweepWidthMultiplier = toolConfig and toolConfig.SweepWidthMultiplier or 1,
		UseSpeedMultiplier = toolConfig and toolConfig.UseSpeedMultiplier or 1,
		PickupRadiusMultiplier = toolConfig and toolConfig.PickupRadiusMultiplier or 1,
	}
end

local function getPaintToolRange(player, toolConfig)
	local upgradeRange = getPickupUpgradeValue(player)
	local upgradedBonus = math.max(0, upgradeRange - 8) * 0.35
	local effects = ColorEffectHandler.CalculateEquippedColorEffects(player)
	local baseRange = (toolConfig.Range or 9) + upgradedBonus
	local toolStats = getToolEffectiveStats(toolConfig)
	return math.min(baseRange * effects.BrushRangeMultiplier * (toolStats.PickupRadiusMultiplier or 1), toolConfig.MaxServerRange or 24)
end

local function getBaseBreakableReward(part, data)
	local reward = tonumber(part:GetAttribute("BaseColorReward"))
		or tonumber(data.baseReward)
		or tonumber(data.rewardMin)
		or 1
	return math.max(1, math.floor(reward))
end

local function ownsPaintTool(player, toolId)
	if toolId == "StarterBrush" then
		return true
	end

	local toolsFolder = player:FindFirstChild("PaintTools")
	local ownedValue = toolsFolder and toolsFolder:FindFirstChild("Owned")
	for _, ownedId in ipairs(string.split(ownedValue and ownedValue.Value or "", ",")) do
		if ownedId == toolId then
			return true
		end
	end
	return false
end

local function canUsePaintTool(player, toolConfig)
	if not toolConfig then
		return false
	end
	if not ownsPaintTool(player, toolConfig.Id) then
		return false
	end

	local requiredColor = toolConfig.RequiredColor or "Red"
	if requiredColor == "Red" then
		return true
	end

	local storage = player:FindFirstChild("ColorStorage")
	local unlocked = storage and storage:FindFirstChild("UnlockedColors")
	return unlocked and ColorData.isColorUnlocked(unlocked.Value, requiredColor)
end

local function getEquippedPaintTool(player)
	local character = player.Character
	if not character then
		return nil, nil
	end

	local toolsFolder = player:FindFirstChild("PaintTools")
	local equippedValue = toolsFolder and toolsFolder:FindFirstChild("Equipped")
	local equippedToolId = equippedValue and equippedValue.Value or "StarterBrush"
	local equippedConfig = ToolData.get(equippedToolId)
	if not canUsePaintTool(player, equippedConfig) then
		equippedConfig = ToolData.get("StarterBrush")
	end

	for _, child in ipairs(character:GetChildren()) do
		if child:IsA("Tool") and child:GetAttribute("PaintToolId") then
			return child, equippedConfig
		end
	end

	return nil, equippedConfig
end

local function isInsideToolSweep(player, part, range, width)
	local character = player.Character
	local root = character and character:FindFirstChild("HumanoidRootPart")
	if not root or not part then
		return false
	end

	local offset = part.Position - root.Position
	local distance = offset.Magnitude
	if distance > range then
		return false
	end

	local look = root.CFrame.LookVector
	local forward = distance > 0 and offset.Unit:Dot(look) or 1
	local side = math.abs(offset:Cross(look).Magnitude)
	return forward > -0.2 and side <= width
end

local function isInsideWalkPickup(player, part, range)
	local character = player.Character
	local root = character and character:FindFirstChild("HumanoidRootPart")
	if not root or not part then
		return false
	end

	return (part.Position - root.Position).Magnitude <= range
end

local function resetBreakable(part)
	if not part or not part.Parent then
		return
	end

	local breakableType = part:GetAttribute("BreakableType")
	local colorType = part:GetAttribute("ColorType")
	local data = breakableType and ColorData.Breakables[breakableType]
	if not data then
		part:SetAttribute("Respawning", false)
		part:SetAttribute("IsCollected", false)
		return
	end

	local colorInfo = colorType and ColorData.Colors[colorType]
	if colorInfo then
		local visualColor = getStoredColor(part, colorType)
		part.Color = visualColor
		local light = part:FindFirstChildOfClass("PointLight")
		if light then
			light.Color = visualColor
		end
	end

	part.Size = part:GetAttribute("OriginalSize") or data.size
	part.Transparency = part:GetAttribute("CollectorBaseTransparency") or 0
	part.CanCollide = false
	part:SetAttribute("IsCollected", false)
	part:SetAttribute("Respawning", false)
	part:SetAttribute("PetPriorityOwnerUserId", nil)
	part:SetAttribute("PetPriorityUntil", nil)
	part:SetAttribute("PetPrioritySetAt", nil)
end

local function hideAndRespawn(part)
	part:SetAttribute("IsCollected", true)
	part:SetAttribute("PetPriorityOwnerUserId", nil)
	part:SetAttribute("PetPriorityUntil", nil)
	part:SetAttribute("PetPrioritySetAt", nil)
	part.Transparency = 1
	part.CanCollide = false
	part.CanTouch = false

	for _, child in ipairs(part:GetDescendants()) do
		if child:IsA("BasePart") then
			child.Transparency = 1
			child.CanCollide = false
			child.CanTouch = false
			child.CanQuery = false
		end
	end

	if part:GetAttribute("TutorialColorPatch") or part:GetAttribute("NoRespawn") then
		part:SetAttribute("Respawning", false)
		part.CanQuery = false
		return
	end

	part:SetAttribute("Respawning", true)

	task.delay(RESPAWN_DELAY, function()
		resetBreakable(part)
	end)
end

local function canCollect(player, part, options)
	options = options or {}
	if typeof(part) ~= "Instance" or not part:IsA("BasePart") or not part:IsDescendantOf(workspace) then
		return false, "Invalid target."
	end

	local breakableType = part:GetAttribute("BreakableType")
	if not breakableType or not ColorData.Breakables[breakableType] then
		return false, "That is not color."
	end

	local colorType = part:GetAttribute("ColorType")
	local storage = player:FindFirstChild("ColorStorage")
	local unlocked = storage and storage:FindFirstChild("UnlockedColors")
	if colorType and unlocked and not ColorData.isColorUnlocked(unlocked.Value, colorType) then
		return false, "Area locked."
	end

	if part:GetAttribute("IsCollected") or part.Transparency >= 1 then
		return false, "Already collected."
	end

	local character = player.Character
	local root = character and character:FindFirstChild("HumanoidRootPart")
	local humanoid = character and character:FindFirstChildOfClass("Humanoid")
	if not root or not humanoid or humanoid.Health <= 0 then
		return false, "You cannot collect right now."
	end

	local maxRange = options.maxRange or getPickupRange(player)
	if (root.Position - part.Position).Magnitude > maxRange then
		return false, "Too far away."
	end

	local now = os.clock()
	if not options.skipCooldown and lastCollectAt[player] and now - lastCollectAt[player] < COLLECT_COOLDOWN then
		return false, "Slow down."
	end

	if not options.skipCooldown then
		lastCollectAt[player] = now
	end
	return true
end

local function collectBreakable(player, part, options)
	options = options or {}
	local ok, message = canCollect(player, part, options)
	if not ok then
		return false, 0, message
	end

	local data = ColorData.Breakables[part:GetAttribute("BreakableType")]
	local colorType = part:GetAttribute("ColorType")
	local areaMult = tonumber(part:GetAttribute("RewardMultiplier")) or 1
	local toolMult = options.powerMultiplier or 1
	local reward = math.floor(
		getBaseBreakableReward(part, data)
		* areaMult
		* getCollectMultiplier(player)
		* toolMult
		* getInstantCoinMultiplier(player, colorType)
	)
	reward = math.max(reward, 1)

	if not awardCoins(player, reward) then
		return false, 0, "Coins are not ready."
	end

	if options.source == "brush" and tutorialPatchClearedEvent then
		tutorialPatchClearedEvent:Fire(player, colorType, reward, part, options.mode or "sweep")
	end

	hideAndRespawn(part)
	return true, reward, "Coins"
end

local function getPlayerFromHit(hit)
	local character = hit and hit.Parent
	if not character then
		return nil
	end

	local humanoid = character:FindFirstChildOfClass("Humanoid")
	if not humanoid and character.Parent then
		character = character.Parent
		humanoid = character:FindFirstChildOfClass("Humanoid")
	end
	if not humanoid then
		return nil
	end

	return Players:GetPlayerFromCharacter(character)
end

local function hookTouchCollection(part)
	if not isTouchFallbackEnabled() then
		return
	end
	if typeof(part) ~= "Instance" or not part:IsA("BasePart") then
		return
	end
	if not part:GetAttribute("BreakableType") then
		return
	end
	if touchConnections[part] then
		part.CanTouch = true
		return
	end

	part.CanTouch = true
	touchConnections[part] = part.Touched:Connect(function(hit)
		local player = getPlayerFromHit(hit)
		if not player then
			return
		end

		local ok, awarded, message = collectBreakable(player, part, {
			source = "touch",
		})
		if ok then
			collectEvent:FireClient(player, true, awarded, "Coins")
		elseif message == "Coins are not ready." then
			warnCollectionOnce(player, "missing player data", message)
		elseif message == "Invalid target." or message == "That is not color." then
			warnCollectionOnce(player, "blob invalid", message)
		end
	end)

	part.Destroying:Connect(function()
		local connection = touchConnections[part]
		if connection then
			connection:Disconnect()
		end
		touchConnections[part] = nil
	end)
end

local function getPlayerRoot(player)
	local character = player.Character
	return character and character:FindFirstChild("HumanoidRootPart")
end

local function hasCompletedTutorial(player)
	local folder = player and player:FindFirstChild("TutorialObjectives")
	local completed = folder and folder:FindFirstChild("TutorialCompleted")
	return completed and completed.Value == true
end

local function canWalkCollectDuringTutorial(player, candidates)
	local folder = player and player:FindFirstChild("TutorialObjectives")
	local completed = folder and folder:FindFirstChild("TutorialCompleted")
	if completed and completed.Value == true then
		return true
	end

	local stage = folder and folder:FindFirstChild("Stage")
	if stage and stage.Value ~= "CleanSpills" and stage.Value ~= "GoToRed" then
		return false
	end

	if type(candidates) ~= "table" then
		return false
	end

	for _, part in ipairs(candidates) do
		if typeof(part) == "Instance"
			and part:IsA("BasePart")
			and part:GetAttribute("BreakableType")
			and part:GetAttribute("ColorType") == "Red"
			and not part:GetAttribute("IsCollected")
			and part.Transparency < 1
		then
			return true
		end
	end

	return false
end

local function findNearbyBreakables(player, origin, range, maxTargets)
	local candidates = {}
	for _, obj in ipairs(workspace:GetDescendants()) do
		if obj:IsA("BasePart")
			and obj:GetAttribute("BreakableType")
			and not obj:GetAttribute("IsCollected")
			and obj.Transparency < 1
		then
			local distance = (obj.Position - origin).Magnitude
			if distance <= range then
				table.insert(candidates, { part = obj, distance = distance })
			end
		end
	end

	table.sort(candidates, function(a, b)
		return a.distance < b.distance
	end)

	local result = {}
	for _, candidate in ipairs(candidates) do
		table.insert(result, candidate.part)
		if #result >= maxTargets then
			break
		end
	end
	return result
end

local function fireEffectVfx(player, effectName, fromPosition, targetPositions, mutationId)
	if #targetPositions == 0 then
		return
	end

	colorEffectVfxEvent:FireClient(player, {
		Effect = effectName,
		From = fromPosition,
		Targets = targetPositions,
		MutationId = mutationId or "None",
	})
end

local function collectProcTargets(player, targets, range)
	local total = 0
	local collected = 0
	local positions = {}

	for _, part in ipairs(targets) do
		local position = part.Position
		local ok, awarded = collectBreakable(player, part, {
			maxRange = range,
			skipCooldown = true,
			powerMultiplier = 1,
		})
		if ok and awarded > 0 then
			table.insert(positions, position)
			collected += 1
			total += awarded
		end
	end

	return collected, total, positions
end

local function tryBrushEffectProcs(player)
	local root = getPlayerRoot(player)
	if not root then
		return 0
	end

	local effects = ColorEffectHandler.CalculateEquippedColorEffects(player)
	local now = os.clock()
	local totalAwarded = 0
	local caps = GameBalance.ColorEffects or {}

	if effects.LightningProcChance > 0 then
		local cooldown = math.max(
			effects.LightningCooldown or 0,
			caps.LightningGlobalCooldown or 1
		)
		if (not lastLightningAt[player] or now - lastLightningAt[player] >= cooldown)
			and math.random() < effects.LightningProcChance
		then
			lastLightningAt[player] = now
			local range = math.min(effects.LightningRange, caps.LightningMaxRange or 55)
			local maxTargets = math.clamp(
				effects.LightningTargets,
				1,
				caps.LightningMaxTargetsPerProc or 4
			)
			local targets = findNearbyBreakables(player, root.Position, range, maxTargets)
			local _, awarded, positions = collectProcTargets(player, targets, range)
			totalAwarded += awarded
			fireEffectVfx(player, "Lightning", root.Position, positions, effects.SourceMutationId)
		end
	end

	if effects.MagnetProcChance > 0 then
		local cooldown = caps.MagnetGlobalCooldown or 1
		if (not lastMagnetAt[player] or now - lastMagnetAt[player] >= cooldown)
			and math.random() < effects.MagnetProcChance
		then
			lastMagnetAt[player] = now
			local range = math.min(effects.MagnetRange, caps.MagnetMaxRange or 55)
			local maxTargets = math.clamp(
				effects.MagnetTargets,
				1,
				caps.MagnetMaxTargetsPerProc or 5
			)
			local targets = findNearbyBreakables(player, root.Position, range, maxTargets)
			local _, awarded, positions = collectProcTargets(player, targets, range)
			totalAwarded += awarded
			fireEffectVfx(player, "Magnet", root.Position, positions, effects.SourceMutationId)
		end
	end

	return totalAwarded
end

collectEvent.OnServerEvent:Connect(function(player, part, ...)
	if select("#", ...) > 0 then
		warnUnexpectedClientValuesOnce(player, "CollectColor")
	end

	if GameBalance.Collection and GameBalance.Collection.RequireBrushToCollect then
		collectEvent:FireClient(player, false, 0, "Use your Brush to collect Color.")
		return
	end

	local ok, awarded, message = collectBreakable(player, part)
	if not ok then
		if message == "Coins are not ready." then
			warnCollectionOnce(player, "missing player data", message)
		elseif message == "Invalid target." or message == "That is not color." then
			warnCollectionOnce(player, "blob invalid", message)
		elseif message ~= "Slow down." and message ~= "Already collected." then
			warnCollectionOnce(player, "server rejected request", message)
		end
	end
	collectEvent:FireClient(player, ok, awarded, message)
end)

paintSweepEvent.OnServerEvent:Connect(function(player, toolId, candidates, mode, ...)
	if select("#", ...) > 0 then
		warnUnexpectedClientValuesOnce(player, "PaintToolSweep")
	end

	local tool, toolConfig = getEquippedPaintTool(player)
	if not toolConfig then
		paintSweepEvent:FireClient(player, {
			success = false,
			total = 0,
			collected = 0,
			message = "Equip your Brush first.",
		})
		return
	end

	if tool and toolId and toolConfig.Id ~= toolId then
		paintSweepEvent:FireClient(player, {
			success = false,
			total = 0,
			collected = 0,
			message = "Wrong Brush.",
		})
		return
	end

	mode = mode == "walk" and "walk" or "sweep"

	local effects = ColorEffectHandler.CalculateEquippedColorEffects(player)
	local toolStats = getToolEffectiveStats(toolConfig)
	local useSpeedMultiplier = math.max(tonumber(toolStats.UseSpeedMultiplier) or 1, 0.01)
	local cooldown = ((mode == "walk" and 0.78 or (toolConfig.Cooldown or 0.45)) * effects.BrushCooldownMultiplier) / useSpeedMultiplier
	cooldown = math.max(cooldown, (GameBalance.ColorEffects and GameBalance.ColorEffects.MinimumBrushCooldown) or 0.2)

	local now = os.clock()
	if lastSweepAt[player] and now - lastSweepAt[player] < cooldown then
		return
	end
	lastSweepAt[player] = now

	if type(candidates) ~= "table" then
		paintSweepEvent:FireClient(player, {
			success = false,
			total = 0,
			collected = 0,
			message = "No Color in range.",
		})
		return
	end

	if mode == "walk" and not canWalkCollectDuringTutorial(player, candidates) then
		return
	end

	local range = getPaintToolRange(player, toolConfig)
	local width = (tonumber(toolConfig.Width) or 7) * (tonumber(toolStats.SweepWidthMultiplier) or 1)
	if mode == "walk" then
		range = math.min(6 * (tonumber(toolStats.PickupRadiusMultiplier) or 1), range)
	end
	local maxTargets = mode == "walk" and 2 or math.clamp(tonumber(toolConfig.MaxTargets) or 8, 1, 18)
	local collected = 0
	local total = 0
	local lastMessage = "No Color in range."
	local seen = {}

	for _, part in ipairs(candidates) do
		if collected >= maxTargets then
			break
		end
		if typeof(part) == "Instance" and not seen[part] then
			seen[part] = true
			if part:GetAttribute("GemDeposit") then
				continue
			end
			local inRange = mode == "walk"
				and isInsideWalkPickup(player, part, range)
				or isInsideToolSweep(player, part, range, width)
			if inRange then
				markPetPriorityTarget(player, part)
				local ok, awarded, message = collectBreakable(player, part, {
					maxRange = range,
					skipCooldown = true,
					powerMultiplier = toolStats.CollectPowerMultiplier or toolConfig.PowerMultiplier or 1,
					source = "brush",
					mode = mode,
				})
				lastMessage = message or lastMessage
				if ok and awarded > 0 then
					collected += 1
					total += awarded
				end
			end
		end
	end

	local procAwarded = mode == "sweep" and tryBrushEffectProcs(player) or 0
	total += procAwarded

	local success = total > 0
	if DEBUG_LOGS and success then
		print("PaintToolSweep: " .. player.Name .. " broke " .. tostring(collected) .. " Color blobs for " .. tostring(total) .. " Coins via " .. mode)
	end
	paintSweepEvent:FireClient(player, {
		success = success,
		total = total,
		collected = collected,
		message = success and ("+" .. tostring(total) .. " Coins") or lastMessage,
	})
	if success then
		collectEvent:FireClient(player, true, total, "Coins")
	end
end)

Players.PlayerRemoving:Connect(function(player)
	lastCollectAt[player] = nil
	lastSweepAt[player] = nil
	lastLightningAt[player] = nil
	lastMagnetAt[player] = nil
end)

if isTouchFallbackEnabled() then
	for _, obj in ipairs(workspace:GetDescendants()) do
		if obj:IsA("BasePart") and obj:GetAttribute("BreakableType") then
			hookTouchCollection(obj)
		end
	end

	workspace.DescendantAdded:Connect(function(obj)
		if obj:IsA("BasePart") and obj:GetAttribute("BreakableType") then
			hookTouchCollection(obj)
		end
	end)
end
]]></string>
        </Properties>
      </Item>
      <Item class="ModuleScript" referent="59">
        <Properties>
          <string name="Name">ColorEffectHandler</string>
          <string name="Source"><![CDATA[local ReplicatedStorage = game:GetService("ReplicatedStorage")

local PetData = require(ReplicatedStorage:WaitForChild("PetData"))
local ColorTraitData = require(ReplicatedStorage:WaitForChild("ColorTraitData"))
local ColorMutationData = require(ReplicatedStorage:WaitForChild("ColorMutationData"))
local GameBalance = require(ReplicatedStorage:WaitForChild("GameBalance"))
local BuffService = require(script.Parent:WaitForChild("BuffService"))

local ColorEffectHandler = {}

local CAPS = GameBalance.ColorEffects or {}

local DEFAULT_EFFECTS = {
	WalkSpeedBonus = 0,
	WalkSpeedMultiplier = 1,
	JumpPowerBonus = 0,
	BrushCooldownMultiplier = 1,
	BrushRangeMultiplier = 1,
	ColorGainMultiplier = 1,
	SellCoinsMultiplier = 1,
	HatchLuckBonus = 0,
	HatchLuckMultiplier = 1,
	LightningProcChance = 0,
	LightningTargets = 0,
	LightningRange = 0,
	LightningCooldown = 0,
	MagnetProcChance = 0,
	MagnetRange = 0,
	MagnetTargets = 0,
	SourceMutationId = "None",
	BaseColorGainMultiplier = 1,
	BaseSellCoinsMultiplier = 1,
}

local function cloneDefaults()
	local result = {}
	for key, value in pairs(DEFAULT_EFFECTS) do
		result[key] = value
	end
	return result
end

local function parseInventory(str)
	local inventory = {}
	if not str or str == "" then
		return inventory
	end

	for _, part in ipairs(string.split(str, ",")) do
		local segments = string.split(part, ":")
		local variantKey
		local petId
		local stackIndex
		if tonumber(segments[2]) then
			petId = segments[1]
			stackIndex = 2
		else
			variantKey = segments[1]
			petId = segments[2]
			stackIndex = 3
		end

		if not petId or petId == "" or not PetData.Pets[petId] then
			continue
		end

		local stackAmount = math.max(1, tonumber(segments[stackIndex]) or 1)
		local traitId = PetData.normalizeTraitId(segments[stackIndex + 1])
		local shinyStr = segments[stackIndex + 2] or "normal"
		local personalityId = PetData.normalizePersonalityId(segments[stackIndex + 3] or "Neutral")
		local mutationId = PetData.normalizeMutationId(segments[stackIndex + 4] or "None")
		variantKey = PetData.makeVariantKey(petId, personalityId, mutationId, traitId)

		inventory[variantKey] = {
			petId = petId,
			stackAmount = stackAmount,
			traitId = traitId,
			isShiny = shinyStr == "shiny" or shinyStr == "true",
			personalityId = personalityId,
			mutationId = mutationId,
		}
	end

	return inventory
end

local function getPlayerInventoryData(player)
	local petFolder = player:FindFirstChild("PetData")
	local invVal = petFolder and petFolder:FindFirstChild("Inventory")
	local equippedVal = petFolder and petFolder:FindFirstChild("Equipped")
	if not invVal or not equippedVal then
		return {}, {}
	end

	local inventory = parseInventory(invVal.Value)
	local equipped = {}
	for _, rawKey in ipairs(string.split(equippedVal.Value or "", ",")) do
		local key = rawKey
		if inventory[key] then
			table.insert(equipped, key)
		else
			local legacyParts = string.split(rawKey, "|")
			for variantKey, data in pairs(inventory) do
				if rawKey == data.petId
					or rawKey == variantKey
					or (#legacyParts >= 3 and legacyParts[1] == data.petId and PetData.normalizeMutationId(legacyParts[3]) == data.mutationId)
				then
					table.insert(equipped, variantKey)
					break
				end
			end
		end
	end

	return inventory, equipped
end

local function multiplyEffect(result, key, value)
	value = tonumber(value)
	if value and value > 0 then
		result[key] *= value
	end
end

local function addEffect(result, key, value)
	value = tonumber(value)
	if value then
		result[key] += value
	end
end

local function mergeEffects(result, effects)
	if type(effects) ~= "table" then
		return
	end

	addEffect(result, "WalkSpeedBonus", effects.WalkSpeedBonus)
	multiplyEffect(result, "WalkSpeedMultiplier", effects.WalkSpeedMultiplier)
	addEffect(result, "JumpPowerBonus", effects.JumpPowerBonus)
	multiplyEffect(result, "BrushCooldownMultiplier", effects.BrushCooldownMultiplier)
	multiplyEffect(result, "BrushRangeMultiplier", effects.BrushRangeMultiplier)
	multiplyEffect(result, "ColorGainMultiplier", effects.ColorGainMultiplier)
	multiplyEffect(result, "SellCoinsMultiplier", effects.SellCoinsMultiplier)
	addEffect(result, "HatchLuckBonus", effects.HatchLuckBonus)
	multiplyEffect(result, "HatchLuckMultiplier", effects.HatchLuckMultiplier)
	addEffect(result, "LightningProcChance", effects.LightningProcChance)
	result.LightningTargets += math.floor(tonumber(effects.LightningTargets) or 0)
	result.LightningRange = math.max(result.LightningRange, tonumber(effects.LightningRange) or 0)
	result.LightningCooldown = result.LightningCooldown == 0
		and (tonumber(effects.LightningCooldown) or 0)
		or math.min(result.LightningCooldown, tonumber(effects.LightningCooldown) or result.LightningCooldown)
	addEffect(result, "MagnetProcChance", effects.MagnetProcChance)
	result.MagnetRange = math.max(result.MagnetRange, tonumber(effects.MagnetRange) or 0)
	result.MagnetTargets += math.floor(tonumber(effects.MagnetTargets) or 0)
end

local function clampEffects(result)
	result.WalkSpeedBonus = math.clamp(
		result.WalkSpeedBonus,
		0,
		CAPS.MaxWalkSpeedFromColors or 8
	)
	result.WalkSpeedMultiplier = math.clamp(result.WalkSpeedMultiplier, 1, CAPS.MaxWalkSpeedMultiplierFromBuffs or 1.6)
	result.JumpPowerBonus = math.clamp(
		result.JumpPowerBonus,
		0,
		CAPS.MaxJumpPowerFromColors or 30
	)
	result.BrushRangeMultiplier = math.clamp(
		result.BrushRangeMultiplier,
		1,
		CAPS.MaxBrushRangeMultiplier or 1.75
	)
	result.ColorGainMultiplier = math.clamp(
		result.ColorGainMultiplier,
		1,
		CAPS.MaxColorGainMultiplierFromColors or 3
	)
	result.SellCoinsMultiplier = math.clamp(
		result.SellCoinsMultiplier,
		1,
		CAPS.MaxSellMultiplierFromColors or 3
	)
	result.HatchLuckBonus = math.clamp(
		result.HatchLuckBonus,
		0,
		CAPS.MaxHatchLuckBonusFromColors or 0.5
	)
	result.HatchLuckMultiplier = math.clamp(result.HatchLuckMultiplier, 1, CAPS.MaxHatchLuckMultiplierFromBuffs or 2)
	result.LightningProcChance = math.clamp(result.LightningProcChance, 0, 0.75)
	result.LightningTargets = math.clamp(
		result.LightningTargets,
		0,
		CAPS.LightningMaxTargetsPerProc or 4
	)
	result.LightningRange = math.clamp(result.LightningRange, 0, CAPS.LightningMaxRange or 55)
	result.MagnetProcChance = math.clamp(result.MagnetProcChance, 0, 0.75)
	result.MagnetTargets = math.clamp(
		result.MagnetTargets > 0 and result.MagnetTargets or 2,
		0,
		CAPS.MagnetMaxTargetsPerProc or 5
	)
	result.MagnetRange = math.clamp(result.MagnetRange, 0, CAPS.MagnetMaxRange or 55)
	if result.LightningCooldown <= 0 then
		result.LightningCooldown = 4
	end
end

function ColorEffectHandler.CalculateEquippedColorEffects(player)
	local result = cloneDefaults()
	local inventory, equipped = getPlayerInventoryData(player)

	for _, variantKey in ipairs(equipped) do
		local data = inventory[variantKey]
		if data then
			local entry = PetData.buildPetEntry(
				data.petId,
				data.stackAmount,
				data.isShiny,
				data.personalityId,
				data.mutationId,
				data.traitId
			)
			if entry then
				multiplyEffect(result, "BaseColorGainMultiplier", entry.colorMult or 1)
				multiplyEffect(result, "BaseSellCoinsMultiplier", entry.coinMult or 1)
			end

			local trait = ColorTraitData.get(data.traitId)
			local mutation = ColorMutationData.get(data.mutationId)
			mergeEffects(result, trait and trait.Effects)
			mergeEffects(result, mutation and mutation.Effects)
			if mutation and ColorMutationData.isMutated(mutation.Id) then
				result.SourceMutationId = mutation.Id
			end
		end
	end

	mergeEffects(result, BuffService.GetEffects(player))

	clampEffects(result)
	result.ColorGainMultiplier *= result.BaseColorGainMultiplier
	result.SellCoinsMultiplier *= result.BaseSellCoinsMultiplier
	return result
end

function ColorEffectHandler.GetColorGainMultiplier(player)
	return ColorEffectHandler.CalculateEquippedColorEffects(player).ColorGainMultiplier
end

function ColorEffectHandler.GetSellCoinsMultiplier(player)
	return ColorEffectHandler.CalculateEquippedColorEffects(player).SellCoinsMultiplier
end

function ColorEffectHandler.GetHatchLuckBonus(player)
	return ColorEffectHandler.CalculateEquippedColorEffects(player).HatchLuckBonus
end

function ColorEffectHandler.GetHatchLuckMultiplier(player)
	return ColorEffectHandler.CalculateEquippedColorEffects(player).HatchLuckMultiplier
end

function ColorEffectHandler.ApplyCharacterEffects(player)
	local character = player.Character
	local humanoid = character and character:FindFirstChildOfClass("Humanoid")
	if not humanoid then
		return
	end

	local effects = ColorEffectHandler.CalculateEquippedColorEffects(player)
	local upgrades = player:FindFirstChild("Upgrades")
	local walkSpeedValue = upgrades and upgrades:FindFirstChild("WalkSpeed")
	local baseWalkSpeed = walkSpeedValue and walkSpeedValue.Value or (CAPS.BaseWalkSpeed or 16)
	local walkSpeed = math.min(
		(baseWalkSpeed + effects.WalkSpeedBonus) * effects.WalkSpeedMultiplier,
		CAPS.AbsoluteMaxWalkSpeed or 28
	)
	humanoid.WalkSpeed = walkSpeed

	humanoid.UseJumpPower = true
	local baseJumpPower = CAPS.BaseJumpPower or 50
	local jumpPower = math.min(
		baseJumpPower + effects.JumpPowerBonus,
		CAPS.AbsoluteMaxJumpPower or 85
	)
	humanoid.JumpPower = jumpPower
end

return ColorEffectHandler
]]></string>
