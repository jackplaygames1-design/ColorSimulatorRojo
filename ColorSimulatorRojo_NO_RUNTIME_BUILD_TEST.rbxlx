      <Item class="Script" referent="62">
        <Properties>
          <string name="Name">DevTools</string>
          <token name="RunContext">0</token>
          <string name="Source"><![CDATA[local ReplicatedStorage = game:GetService("ReplicatedStorage")
local RunService = game:GetService("RunService")
local Players = game:GetService("Players")

local Events = ReplicatedStorage:WaitForChild("Events")
local PetData = require(ReplicatedStorage:WaitForChild("PetData"))
local ColorTraitData = require(ReplicatedStorage:WaitForChild("ColorTraitData"))
local ColorMutationData = require(ReplicatedStorage:WaitForChild("ColorMutationData"))
local grantCoinsEvent = Events:WaitForChild("DevGrantCoins")
local resetProfileRemote = Events:FindFirstChild("DevResetProfile")
if not resetProfileRemote then
	resetProfileRemote = Instance.new("RemoteEvent")
	resetProfileRemote.Name = "DevResetProfile"
	resetProfileRemote.Parent = Events
end
local resetProfileFunction = ReplicatedStorage:FindFirstChild("StudioResetProfile")
if not resetProfileFunction then
	resetProfileFunction = Instance.new("BindableFunction")
	resetProfileFunction.Name = "StudioResetProfile"
	resetProfileFunction.Parent = ReplicatedStorage
end

local DEV_COIN_AMOUNT = 2000000000

local DEFAULTS = {
	Coins = 0,
	Gems = 0,
	Rebirths = 0,
	UnlockedColors = "Red",
	CurrentWorld = "Red",
	MaxPetSlots = 3,
	WalkSpeed = 44,
}

grantCoinsEvent.OnServerEvent:Connect(function(player)
	if not RunService:IsStudio() then
		warn("DevTools: blocked coin grant outside Studio for " .. player.Name)
		return
	end

	local leaderstats = player:FindFirstChild("leaderstats")
	local coins = leaderstats and leaderstats:FindFirstChild("Coins")
	if not coins or not coins:IsA("IntValue") then
		return
	end

	coins.Value = DEV_COIN_AMOUNT
	print("DevTools: set " .. player.Name .. " coins to " .. tostring(DEV_COIN_AMOUNT))
end)

local function clearChildren(folder)
	if not folder then
		return
	end

	for _, child in ipairs(folder:GetChildren()) do
		child:Destroy()
	end
end

local function setValue(parent, name, value)
	local child = parent and parent:FindFirstChild(name)
	if child and child:IsA("ValueBase") then
		child.Value = value
	end
end

local function resetPlayer(player)
	if not RunService:IsStudio() then
		warn("DevTools: blocked profile reset outside Studio for " .. tostring(player and player.Name))
		return false
	end
	player:SetAttribute("IntentionalProfileReset", true)

	local leaderstats = player:FindFirstChild("leaderstats")
	if leaderstats then
		setValue(leaderstats, "Coins", DEFAULTS.Coins)
		setValue(leaderstats, "Gems", DEFAULTS.Gems)
		setValue(leaderstats, "Rebirths", DEFAULTS.Rebirths)
	end

	local storage = player:FindFirstChild("ColorStorage")
	if storage then
		setValue(storage, "UnlockedColors", DEFAULTS.UnlockedColors)
		setValue(storage, "CurrentWorld", DEFAULTS.CurrentWorld)
	end
	player:SetAttribute("ActiveWorldColor", DEFAULTS.CurrentWorld)

	local petFolder = player:FindFirstChild("PetData")
	if petFolder then
		setValue(petFolder, "Inventory", "")
		setValue(petFolder, "Equipped", "")
		local maxSlots = petFolder:FindFirstChild("MaxSlots")
		if not maxSlots then
			maxSlots = Instance.new("IntValue")
			maxSlots.Name = "MaxSlots"
			maxSlots.Parent = petFolder
		end
		maxSlots.Value = DEFAULTS.MaxPetSlots
	end

	local upgrades = player:FindFirstChild("Upgrades")
	if upgrades then
		for _, child in ipairs(upgrades:GetChildren()) do
			if child:IsA("IntValue") and child.Name:find("_Level") then
				child.Value = 0
			elseif child:IsA("NumberValue") or child:IsA("IntValue") then
				if child.Name == "PickupRange" then
					child.Value = 8
				elseif child.Name == "ColorMultiplier" then
					child.Value = 1
				elseif child.Name == "HatchSpeed" then
					child.Value = 1
				elseif child.Name == "WalkSpeed" then
					child.Value = DEFAULTS.WalkSpeed
				elseif child.Name == "PetSlots" then
					child.Value = DEFAULTS.MaxPetSlots
				end
			end
		end
	end

	clearChildren(player:FindFirstChild("RedeemedCodes"))
	clearChildren(player:FindFirstChild("Boosts"))
	clearChildren(player:FindFirstChild("ItemFlags"))

	local character = player.Character
	local humanoid = character and character:FindFirstChildOfClass("Humanoid")
	if humanoid then
		humanoid.WalkSpeed = DEFAULTS.WalkSpeed
	end

	print("Studio profile reset complete")
	print("DevTools: reset profile stats for " .. player.Name)
	return true
end

resetProfileFunction.OnInvoke = function(playerName)
	if not RunService:IsStudio() then
		warn("DevTools: blocked profile reset outside Studio")
		return false
	end

	local player = playerName and Players:FindFirstChild(tostring(playerName)) or Players:GetPlayers()[1]
	if not player then
		warn("DevTools: no player found to reset")
		return false
	end

	return resetPlayer(player)
end

resetProfileRemote.OnServerEvent:Connect(function(player)
	if not RunService:IsStudio() then
		warn("DevTools: blocked remote profile reset outside Studio for " .. player.Name)
		return
	end

	resetPlayer(player)
end)

Players.PlayerAdded:Connect(function(player)
	player.Chatted:Connect(function(message)
		if not RunService:IsStudio() then
			return
		end

		local normalized = string.lower(tostring(message or ""))
		if normalized == "/resetprofile" or normalized == "!resetprofile" or normalized == "/reset" then
			resetPlayer(player)
			return
		end

		local parts = string.split(tostring(message or ""), " ")
		local command = string.lower(parts[1] or "")
		if command == "/printpetdata" or command == "/printcolordata" then
			local printPetDataFunction = ReplicatedStorage:FindFirstChild("PrintPetData")
			if printPetDataFunction and printPetDataFunction:IsA("BindableFunction") then
				printPetDataFunction:Invoke(player.Name)
			else
				warn("DevTools: PrintPetData function is missing")
			end
		elseif command == "/forceMutation" or command == "/forcemutation" then
			local mutationId = parts[2] or "Storm"
			if ColorMutationData.Mutations[mutationId] then
				player:SetAttribute("ForceNextMutation", mutationId)
				print("DevTools: next hatch mutation for " .. player.Name .. " forced to " .. mutationId)
			else
				warn("DevTools: unknown mutation " .. tostring(mutationId))
			end
		elseif command == "/givecolor" then
			local petId = parts[2] or "RedCubey"
			local traitId = PetData.normalizeTraitId(parts[3] or "Neutral")
			local mutationId = PetData.normalizeMutationId(parts[4] or "None")
			if not PetData.Pets[petId] then
				warn("DevTools: unknown Color " .. tostring(petId))
				return
			end

			local grantPetFunction = ReplicatedStorage:FindFirstChild("ServerGrantPet")
			if grantPetFunction and grantPetFunction:IsA("BindableFunction") then
				local ok, entry = grantPetFunction:Invoke(player, petId, 1, traitId, mutationId)
				print("DevTools: givecolor " .. tostring(ok) .. " " .. tostring(entry and entry.displayName or petId)
					.. " trait=" .. tostring(ColorTraitData.get(traitId).DisplayName)
					.. " mutation=" .. tostring(ColorMutationData.get(mutationId).DisplayName))
			end
		elseif command == "/printcoloreffects" then
			local handler = script.Parent:FindFirstChild("ColorEffectHandler")
			if handler then
				local ColorEffectHandler = require(handler)
				local effects = ColorEffectHandler.CalculateEquippedColorEffects(player)
				print("DevTools Color Effects for " .. player.Name .. ":")
				for key, value in pairs(effects) do
					print("  " .. tostring(key) .. " = " .. tostring(value))
				end
			end
		end
	end)
end)
]]></string>
        </Properties>
      </Item>
      <Item class="Script" referent="63">
        <Properties>
          <string name="Name">EarlySupporterHandler</string>
          <token name="RunContext">0</token>
          <string name="Source"><![CDATA[-- Marks players who own the Support Dev gamepass so chat can show an Early Supporter tag.
local MarketplaceService = game:GetService("MarketplaceService")
local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")

local RobuxShopConfig = require(ReplicatedStorage:WaitForChild("RobuxShopConfig"))
local AdminConfig = require(ReplicatedStorage:WaitForChild("AdminConfig"))

local SUPPORT_PASS_ID
for _, pass in ipairs(RobuxShopConfig.Gamepasses or {}) do
	if pass.id == "SupportDev" or pass.earlySupporterTag then
		SUPPORT_PASS_ID = pass.gamepassId
		break
	end
end

local function setSupporter(player, owns)
	player:SetAttribute("EarlySupporter", owns == true)
end

local function refreshSupporter(player)
	if AdminConfig.isEarlyTesterName(player.Name) then
		setSupporter(player, true)
		return
	end

	if not SUPPORT_PASS_ID or SUPPORT_PASS_ID <= 0 then
		setSupporter(player, false)
		return
	end

	local ok, owns = pcall(function()
		return MarketplaceService:UserOwnsGamePassAsync(player.UserId, SUPPORT_PASS_ID)
	end)
	setSupporter(player, ok and owns == true)
end

Players.PlayerAdded:Connect(function(player)
	setSupporter(player, false)
	task.defer(function()
		refreshSupporter(player)
	end)
end)

MarketplaceService.PromptGamePassPurchaseFinished:Connect(function(player, gamepassId, wasPurchased)
	if gamepassId == SUPPORT_PASS_ID and wasPurchased then
		setSupporter(player, true)
	end
end)
]]></string>
        </Properties>
      </Item>
      <Item class="ModuleScript" referent="64">
        <Properties>
          <string name="Name">GamepassBenefits</string>
          <string name="Source"><![CDATA[local MarketplaceService = game:GetService("MarketplaceService")
local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local RunService = game:GetService("RunService")

local RobuxShopConfig = require(ReplicatedStorage:WaitForChild("RobuxShopConfig"))

local GamepassBenefits = {}
local ownershipCache = {}

local function getCache(player)
	ownershipCache[player] = ownershipCache[player] or {}
	return ownershipCache[player]
end

local function hasRealId(pass)
	return pass and tonumber(pass.gamepassId) and tonumber(pass.gamepassId) > 0
end

function GamepassBenefits.owns(player, passId)
	if not player then
		return false
	end

	local pass = RobuxShopConfig.getGamepass(passId)
	if not hasRealId(pass) then
		return player:GetAttribute("Pass_" .. tostring(passId)) == true
	end

	local cache = getCache(player)
	if cache[passId] ~= nil then
		return cache[passId]
	end

	local ok, owns = pcall(function()
		return MarketplaceService:UserOwnsGamePassAsync(player.UserId, pass.gamepassId)
	end)

	cache[passId] = ok and owns == true
	player:SetAttribute("Pass_" .. passId, cache[passId])
	return cache[passId]
end

function GamepassBenefits.invalidate(player, passId)
	if not player then
		return
	end
	local cache = getCache(player)
	cache[passId] = nil
end

function GamepassBenefits.refreshPlayer(player)
	if not player then
		return
	end

	for _, pass in ipairs(RobuxShopConfig.Gamepasses or {}) do
		local owns = GamepassBenefits.owns(player, pass.id)
		player:SetAttribute("Pass_" .. pass.id, owns)
	end
	player:SetAttribute("IsVIP", GamepassBenefits.owns(player, "VIP"))
	if GamepassBenefits.owns(player, "SupportDev") then
		player:SetAttribute("EarlySupporter", true)
	end
end

function GamepassBenefits.getCoinMultiplier(player)
	local multiplier = 1
	if GamepassBenefits.owns(player, "DoubleCoins") then
		multiplier *= 2
	end
	return multiplier
end

function GamepassBenefits.getLuckMultiplier(player)
	local multiplier = 1
	if GamepassBenefits.owns(player, "LuckyHatch") then
		multiplier *= 1.35
	end
	if GamepassBenefits.owns(player, "VIP") then
		multiplier *= 1.1
	end
	return multiplier
end

function GamepassBenefits.getExtraEquippedColorSlots(player)
	local extra = 0
	if GamepassBenefits.owns(player, "Plus3Colors") then
		extra += 3
	end
	if GamepassBenefits.owns(player, "VIP") then
		extra += 1
	end
	return extra
end

function GamepassBenefits.hasAutoSell(player)
	return false
end

Players.PlayerAdded:Connect(function(player)
	for _, pass in ipairs(RobuxShopConfig.Gamepasses or {}) do
		player:SetAttribute("Pass_" .. pass.id, false)
	end
	player:SetAttribute("IsVIP", false)
	player:SetAttribute("EarlySupporter", false)
	task.defer(function()
		GamepassBenefits.refreshPlayer(player)
	end)
end)

Players.PlayerRemoving:Connect(function(player)
	ownershipCache[player] = nil
end)

MarketplaceService.PromptGamePassPurchaseFinished:Connect(function(player, gamepassId, wasPurchased)
	if not wasPurchased then
		return
	end

	local pass = RobuxShopConfig.getGamepassByRobloxId(gamepassId)
	if not pass then
		return
	end

	local cache = getCache(player)
	cache[pass.id] = true
	player:SetAttribute("Pass_" .. pass.id, true)
	if pass.id == "VIP" then
		player:SetAttribute("IsVIP", true)
	end
	if pass.id == "SupportDev" or pass.earlySupporterTag == true then
		player:SetAttribute("EarlySupporter", true)
	end

	print("GamepassBenefits: " .. player.Name .. " unlocked " .. pass.id)
end)

if RunService:IsStudio() then
	ReplicatedStorage:SetAttribute("GamepassBenefitsReady", true)
end

return GamepassBenefits
]]></string>
        </Properties>
      </Item>
      <Item class="Script" referent="65">
        <Properties>
          <string name="Name">GemDepositHandler</string>
          <token name="RunContext">0</token>
          <string name="Source"><![CDATA[local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local TweenService = game:GetService("TweenService")
local Debris = game:GetService("Debris")

local ColorData = require(ReplicatedStorage:WaitForChild("ColorData"))
local ToolData = require(ReplicatedStorage:WaitForChild("ToolData"))
local GameBalance = require(ReplicatedStorage:WaitForChild("GameBalance"))
local BuffService = require(script.Parent:WaitForChild("BuffService"))

local FEATURE_ENABLED = not (GameBalance.FeatureFlags and GameBalance.FeatureFlags.GemDepositsEnabled == false)
local DEPOSIT_CONFIG = GameBalance.WildGameplay and GameBalance.WildGameplay.GemDeposits or {}
local MAX_PER_ZONE = DEPOSIT_CONFIG.MaxPerZone or 2
local RESPAWN_MIN = DEPOSIT_CONFIG.RespawnMin or 30
local RESPAWN_MAX = DEPOSIT_CONFIG.RespawnMax or 60
local BRUSH_MAX_RANGE = 38
local PASSIVE_RANGE = 25
local PASSIVE_INTERVAL = 0.75
local PASSIVE_DAMAGE_PER_COLOR = 1
local PASSIVE_DAMAGE_CAP = 6
local PET_PRIORITY_SECONDS = 6

local HEALTH_BY_COLOR = {
	Red = 25,
	Orange = 40,
	Blue = 60,
	Yellow = 85,
	Green = 120,
	Purple = 170,
	Neon = 240,
	Rainbow = 325,
}

local events = ReplicatedStorage:WaitForChild("Events")
local paintSweepEvent = events:WaitForChild("PaintToolSweep")
local noticeEvent = events:FindFirstChild("WildBuffNotice")

local rootFolder = workspace:FindFirstChild("DynamicGameplay")
if not rootFolder then
	rootFolder = Instance.new("Folder")
	rootFolder.Name = "DynamicGameplay"
	rootFolder.Parent = workspace
end

local depositsFolder = rootFolder:FindFirstChild("GemDeposits")
if not depositsFolder then
	depositsFolder = Instance.new("Folder")
	depositsFolder.Name = "GemDeposits"
	depositsFolder.Parent = rootFolder
end

local activeByColor = {}
local nextSpawnAt = {}
local lastPassiveAt = 0
local lastBrushDamageAt = {}
local zonePartCache = {}

local function inferColorFromMapPart(part)
	local attrColor = part:GetAttribute("ColorType") or part:GetAttribute("WorldColor") or part:GetAttribute("AreaColor")
	if ColorData.getWorldByColor(attrColor) then
		return attrColor
	end

	local partName = string.lower(part.Name or "")
	local parentName = part.Parent and string.lower(part.Parent.Name or "") or ""
	local looksLikeFloor = string.find(partName, "floor") or string.find(partName, "ground") or string.find(partName, "zone") or string.find(partName, "area")
	for _, world in ipairs(ColorData.Worlds or {}) do
		local color = world.primaryColor
		local loweredColor = string.lower(color)
		if looksLikeFloor and (string.find(partName, loweredColor) or string.find(parentName, loweredColor)) then
			return color
		end
	end

	return nil
end

local function configureColorZonePart(part)
	local colorType = inferColorFromMapPart(part)
	if not colorType then
		return nil
	end

	if part:GetAttribute("ColorZone") ~= true then
		part:SetAttribute("ColorZone", true)
	end
	if part:GetAttribute("ColorType") ~= colorType then
		part:SetAttribute("ColorType", colorType)
	end
	return colorType
end

local function isUnlocked(player, colorType)
	local storage = player:FindFirstChild("ColorStorage")
	local unlocked = storage and storage:FindFirstChild("UnlockedColors")
	return ColorData.isColorUnlocked(unlocked and unlocked.Value or "Red", colorType)
end

local function isWorldActive(colorType)
	for _, player in ipairs(Players:GetPlayers()) do
		if isUnlocked(player, colorType) then
			return true
		end
	end
	return false
end

local function getWorldColor(world)
	local info = ColorData.Colors[world.primaryColor]
	return info and info.color or Color3.fromRGB(82, 255, 110)
end

local function getActiveList(colorType)
	local list = activeByColor[colorType]
	if not list then
		list = {}
		activeByColor[colorType] = list
	end
	for index = #list, 1, -1 do
		local model = list[index]
		if not model or not model.Parent or model:GetAttribute("Broken") == true then
			table.remove(list, index)
		end
	end
	return list
end

local function findZonePart(colorType)
	local cached = zonePartCache[colorType]
	if cached and cached.Parent then
		return cached
	end

	local fallback = nil
	for _, obj in ipairs(workspace:GetDescendants()) do
		if obj:IsA("BasePart") then
			local attrColor = configureColorZonePart(obj)
			if attrColor == colorType then
				if obj:GetAttribute("ColorZone") then
					zonePartCache[colorType] = obj
					return obj
				end
				fallback = fallback or obj
			end
		end
	end
	zonePartCache[colorType] = fallback
	return fallback
end

local function isBadSpawnNeighbor(part)
	if not part or part:IsDescendantOf(depositsFolder) then
		return false
	end
	if part:GetAttribute("SellZone")
		or part:GetAttribute("SellLocation")
		or part:GetAttribute("BrushShop")
		or part:GetAttribute("CombinedShop")
		or part:GetAttribute("ShopStation")
		or part:GetAttribute("UpgradeStation")
		or part:GetAttribute("EggStation")
		or part:GetAttribute("AreaGate")
		or part:GetAttribute("GateInteraction")
	then
		return true
	end
	local name = string.lower(part.Name)
	return string.find(name, "wall")
		or string.find(name, "portal")
		or string.find(name, "gate")
		or string.find(name, "sell")
		or string.find(name, "shop")
		or string.find(name, "upgrade")
		or string.find(name, "egg")
end

local function isSafePosition(position)
	local params = OverlapParams.new()
	params.FilterType = Enum.RaycastFilterType.Exclude
	params.FilterDescendantsInstances = { depositsFolder }
	for _, part in ipairs(workspace:GetPartBoundsInRadius(position, 8, params)) do
		if isBadSpawnNeighbor(part) then
			return false
		end
	end
	return true
end

local function getSpawnPosition(world)
	local zone = findZonePart(world.primaryColor)
	if not zone then
		return nil
	end

	local rayParams = RaycastParams.new()
	rayParams.FilterType = Enum.RaycastFilterType.Exclude
	rayParams.FilterDescendantsInstances = { depositsFolder }

	for _ = 1, 16 do
		local x = (math.random() - 0.5) * math.max(8, zone.Size.X * 0.78)
		local z = (math.random() - 0.5) * math.max(8, zone.Size.Z * 0.78)
		local above = zone.CFrame:PointToWorldSpace(Vector3.new(x, zone.Size.Y * 0.5 + 45, z))
		local result = workspace:Raycast(above, Vector3.new(0, -120, 0), rayParams)
		local position = result and result.Position + Vector3.new(0, 2.2, 0)
			or zone.CFrame:PointToWorldSpace(Vector3.new(x, zone.Size.Y * 0.5 + 2.2, z))
		if isSafePosition(position) then
			return position
		end
	end
	return nil
end

local function makeDeposit(world, position)
	local colorType = world.primaryColor
	local health = HEALTH_BY_COLOR[colorType] or 60
	local model = Instance.new("Model")
	model.Name = colorType .. "GemDeposit"
	model:SetAttribute("GemDeposit", true)
	model:SetAttribute("ColorType", colorType)
	model:SetAttribute("WorldName", world.name)
	model:SetAttribute("Health", health)
	model:SetAttribute("MaxHealth", health)
	model:SetAttribute("Broken", false)

	local core = Instance.new("Part")
	core.Name = "Core"
	core.Size = Vector3.new(2.2, 2.2, 2.2)
	core.CFrame = CFrame.new(position) * CFrame.Angles(0, math.rad(45), math.rad(45))
	core.Shape = Enum.PartType.Block
	core.Color = Color3.fromRGB(50, 255, 90)
	core.Material = Enum.Material.Neon
	core.Anchored = true
	core.CanCollide = false
	core.CanTouch = false
	core.CanQuery = true
	core.CastShadow = false
	core:SetAttribute("GemDeposit", true)
	core:SetAttribute("ColorType", colorType)
	core:SetAttribute("Health", health)
	core:SetAttribute("MaxHealth", health)
	core.Parent = model
	model.PrimaryPart = core

	local light = Instance.new("PointLight")
	light.Name = "GemGlow"
	light.Color = Color3.fromRGB(80, 255, 120)
	light.Range = 12
	light.Brightness = 1.8
	light.Shadows = false
	light.Parent = core

	local sparkle = Instance.new("ParticleEmitter")
	sparkle.Name = "GemSparkles"
	sparkle.Texture = "rbxasset://textures/particles/sparkles_main.dds"
	sparkle.Color = ColorSequence.new(Color3.fromRGB(120, 255, 150), Color3.fromRGB(255, 255, 255))
	sparkle.LightEmission = 0.75
	sparkle.Rate = 8
	sparkle.Lifetime = NumberRange.new(0.8, 1.3)
	sparkle.Speed = NumberRange.new(0.4, 1.1)
	sparkle.SpreadAngle = Vector2.new(180, 180)
	sparkle.Parent = core

	local healthGui = Instance.new("BillboardGui")
	healthGui.Name = "GemDepositHealthBar"
	healthGui.AlwaysOnTop = true
	healthGui.Size = UDim2.new(0, 82, 0, 14)
	healthGui.StudsOffset = Vector3.new(0, 3, 0)
	healthGui.MaxDistance = 100
	healthGui.Parent = core

	local barBack = Instance.new("Frame")
	barBack.Name = "BarBack"
	barBack.Size = UDim2.fromScale(1, 1)
	barBack.BackgroundColor3 = Color3.fromRGB(24, 28, 32)
	barBack.BorderSizePixel = 0
	barBack.Parent = healthGui
	local backCorner = Instance.new("UICorner")
	backCorner.CornerRadius = UDim.new(1, 0)
	backCorner.Parent = barBack
	local backStroke = Instance.new("UIStroke")
	backStroke.Color = Color3.fromRGB(255, 255, 255)
	backStroke.Thickness = 1
	backStroke.Transparency = 0.2
	backStroke.Parent = barBack

	local fill = Instance.new("Frame")
	fill.Name = "Fill"
	fill.Size = UDim2.fromScale(1, 1)
	fill.BackgroundColor3 = Color3.fromRGB(82, 255, 110)
	fill.BorderSizePixel = 0
	fill.Parent = barBack
	local fillCorner = Instance.new("UICorner")
	fillCorner.CornerRadius = UDim.new(1, 0)
	fillCorner.Parent = fill
	syncHealthAttributes(model)

	model.Parent = depositsFolder

	local tween = TweenService:Create(core, TweenInfo.new(1.4, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut, -1, true), {
		CFrame = core.CFrame * CFrame.new(0, 0.35, 0),
	})
	tween:Play()

	return model
end

local function syncHealthAttributes(model)
	local core = model.PrimaryPart
	if core then
		local health = tonumber(model:GetAttribute("Health")) or 0
		local maxHealth = math.max(1, tonumber(model:GetAttribute("MaxHealth")) or 1)
		core:SetAttribute("Health", health)
		core:SetAttribute("MaxHealth", maxHealth)

		local healthGui = core:FindFirstChild("GemDepositHealthBar")
		local barBack = healthGui and healthGui:FindFirstChild("BarBack")
		local fill = barBack and barBack:FindFirstChild("Fill")
		if fill and fill:IsA("Frame") then
			local progress = math.clamp(health / maxHealth, 0, 1)
			fill.Size = UDim2.fromScale(progress, 1)
			fill.BackgroundColor3 = Color3.fromRGB(255, 80, 80):Lerp(Color3.fromRGB(82, 255, 110), progress)
		end
	end
end

local function markPetPriorityTarget(player, model)
	if not player or not model or not model.Parent then
		return
	end
	model:SetAttribute("PetPriorityOwnerUserId", player.UserId)
	model:SetAttribute("PetPriorityUntil", os.clock() + PET_PRIORITY_SECONDS)
	model:SetAttribute("PetPrioritySetAt", os.clock())
end

local function makeRewardPopup(position, amount)
	return
end

local function makeBurst(position)
	local part = Instance.new("Part")
	part.Name = "GemBurst"
	part.Size = Vector3.new(0.2, 0.2, 0.2)
	part.Transparency = 1
	part.Anchored = true
	part.CanCollide = false
	part.CanTouch = false
	part.CanQuery = false
	part.CFrame = CFrame.new(position)
	part.Parent = workspace

	local burst = Instance.new("ParticleEmitter")
	burst.Texture = "rbxasset://textures/particles/sparkles_main.dds"
	burst.Color = ColorSequence.new(Color3.fromRGB(80, 255, 120), Color3.fromRGB(255, 255, 255))
	burst.LightEmission = 1
	burst.Lifetime = NumberRange.new(0.45, 0.9)
	burst.Speed = NumberRange.new(8, 15)
	burst.SpreadAngle = Vector2.new(180, 180)
	burst.Rate = 0
	burst.Parent = part
	burst:Emit(32)
	Debris:AddItem(part, 1)
end

local function breakDeposit(player, model)
	if not model or not model.Parent or model:GetAttribute("Broken") == true then
		return
	end
	model:SetAttribute("Broken", true)
	local core = model.PrimaryPart
	local position = core and core.Position or model:GetPivot().Position

	local stats = player and player:FindFirstChild("leaderstats")
	local gems = stats and stats:FindFirstChild("Gems")
	local reward = math.random(5, 10)
	reward = math.floor(reward * BuffService.GetMultiplier(player, "GemRewardMultiplier"))
	if gems then
		gems.Value += reward
	end

	if noticeEvent then
		noticeEvent:FireClient(player, {
			type = "gems",
			amount = reward,
		})
	end
	makeRewardPopup(position, reward)
	makeBurst(position)
	model:Destroy()
end

local function damageDeposit(player, core, amount, shouldMarkPriority)
	if not FEATURE_ENABLED or not player or not core or not core.Parent then
		return false
	end
	local model = core:FindFirstAncestorWhichIsA("Model")
	if not model or model:GetAttribute("GemDeposit") ~= true or model:GetAttribute("Broken") == true then
		return false
	end
	local colorType = model:GetAttribute("ColorType")
	if not colorType or not isUnlocked(player, colorType) then
		return false
	end

	local root = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
	local humanoid = player.Character and player.Character:FindFirstChildOfClass("Humanoid")
	if not root or not humanoid or humanoid.Health <= 0 then
		return false
	end
	if (root.Position - core.Position).Magnitude > BRUSH_MAX_RANGE then
		return false
	end

	amount = math.max(0, tonumber(amount) or 0)
	amount *= BuffService.GetMultiplier(player, "GemDamageMultiplier")
	if amount <= 0 then
		return false
	end

	local health = math.max(0, tonumber(model:GetAttribute("Health")) or 0)
	health = math.max(0, health - amount)
	if shouldMarkPriority then
		markPetPriorityTarget(player, model)
	end
	model:SetAttribute("Health", health)
	syncHealthAttributes(model)
	core.Color = Color3.fromRGB(50, 255, 90):Lerp(Color3.fromRGB(255, 255, 255), math.clamp(1 - health / math.max(1, tonumber(model:GetAttribute("MaxHealth")) or 1), 0, 0.35))
	if health <= 0 then
		breakDeposit(player, model)
	end
	return true
end

local function getToolGemDamage(player, toolId)
	local toolsFolder = player:FindFirstChild("PaintTools")
	local equippedValue = toolsFolder and toolsFolder:FindFirstChild("Equipped")
	local equippedId = equippedValue and equippedValue.Value ~= "" and equippedValue.Value or "StarterBrush"
	local tool = ToolData.get(equippedId)
	if toolId and tool and tool.Id ~= toolId then
		tool = ToolData.get(equippedId)
	end
	local stats = ToolData.GetEffectiveStats and ToolData.GetEffectiveStats(tool and tool.Id or "StarterBrush") or {}
	return math.max(1, tonumber(stats.GemDamage) or tonumber(stats.CollectPowerMultiplier) or 1)
end

paintSweepEvent.OnServerEvent:Connect(function(player, toolId, candidates, mode)
	if type(candidates) ~= "table" then
		return
	end
	local t = os.clock()
	if lastBrushDamageAt[player] and t - lastBrushDamageAt[player] < 0.18 then
		return
	end
	lastBrushDamageAt[player] = t

	local damage = getToolGemDamage(player, toolId)
	if mode == "walk" then
		damage *= 0.5
	end

	local seen = {}
	local hits = 0
	for _, part in ipairs(candidates) do
		if hits >= 4 then
			break
		end
		if typeof(part) == "Instance" and part:IsA("BasePart") and part:GetAttribute("GemDeposit") and not seen[part] then
			seen[part] = true
			if damageDeposit(player, part, damage, true) then
				hits += 1
			end
		end
	end
end)

Players.PlayerRemoving:Connect(function(player)
	lastBrushDamageAt[player] = nil
end)

local function getEquippedColorCount(player)
	local folder = player:FindFirstChild("PetData")
	local equipped = folder and folder:FindFirstChild("Equipped")
	if not equipped or equipped.Value == "" then
		return 0
	end
	local count = 0
	for _, key in ipairs(string.split(equipped.Value, ",")) do
		if key ~= "" then
			count += 1
		end
	end
	return count
end

local function findPriorityDeposit(player)
	local bestModel = nil
	local bestSetAt = -math.huge
	local now = os.clock()
	for _, list in pairs(activeByColor) do
		for _, model in ipairs(list) do
			local core = model and model.PrimaryPart
			if core
				and model.Parent
				and model:GetAttribute("Broken") ~= true
				and model:GetAttribute("PetPriorityOwnerUserId") == player.UserId
				and (tonumber(model:GetAttribute("PetPriorityUntil")) or 0) > now
			then
				local setAt = tonumber(model:GetAttribute("PetPrioritySetAt")) or 0
				if setAt > bestSetAt then
					bestModel = model
					bestSetAt = setAt
				end
			end
		end
	end
	return bestModel
end

local function passiveDamageTick()
	for _, player in ipairs(Players:GetPlayers()) do
		local root = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
		local count = getEquippedColorCount(player)
		if not root or count <= 0 then
			continue
		end

		local damage = math.min(PASSIVE_DAMAGE_CAP, count * PASSIVE_DAMAGE_PER_COLOR)
		local priority = findPriorityDeposit(player)
		local priorityCore = priority and priority.PrimaryPart
		if priorityCore and (root.Position - priorityCore.Position).Magnitude <= PASSIVE_RANGE then
			damageDeposit(player, priorityCore, damage, false)
			continue
		end

		for _, list in pairs(activeByColor) do
			for _, model in ipairs(list) do
				local core = model and model.PrimaryPart
				if core
					and model.Parent
					and model:GetAttribute("Broken") ~= true
					and (root.Position - core.Position).Magnitude <= PASSIVE_RANGE
				then
					damageDeposit(player, core, damage, false)
					break
				end
			end
		end
	end
end

local function trySpawnForWorld(world)
	local colorType = world.primaryColor
	if not isWorldActive(colorType) then
		return
	end

	local list = getActiveList(colorType)
	if #list >= MAX_PER_ZONE then
		return
	end

	local t = os.clock()
	if not nextSpawnAt[colorType] then
		nextSpawnAt[colorType] = t + math.random(8, 18)
	end
	if t < nextSpawnAt[colorType] then
		return
	end

	local position = getSpawnPosition(world)
	nextSpawnAt[colorType] = t + math.random(RESPAWN_MIN, RESPAWN_MAX)
	if not position then
		return
	end

	local model = makeDeposit(world, position)
	table.insert(list, model)
	print("GemDeposit: spawned " .. tostring(world.primaryColor) .. " deposit on existing zone part.")
end

task.spawn(function()
	while true do
		task.wait(5)
		if FEATURE_ENABLED then
			for _, world in ipairs(ColorData.Worlds or {}) do
				trySpawnForWorld(world)
			end
		end
	end
end)

task.spawn(function()
	while true do
		task.wait(0.2)
		local t = os.clock()
		if t - lastPassiveAt >= PASSIVE_INTERVAL then
			lastPassiveAt = t
			passiveDamageTick()
		end
	end
end)
]]></string>
        </Properties>
      </Item>
      <Item class="Script" referent="66">
        <Properties>
          <string name="Name">ItemsHandler</string>
          <token name="RunContext">0</token>
          <string name="Source"><![CDATA[-- Script in ServerScriptService named "ItemsHandler"
local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local ItemsData = require(ReplicatedStorage:WaitForChild("ItemsData"))

local Events    = ReplicatedStorage:WaitForChild("Events")
local useEvent  = Events:WaitForChild("UseItem")

-- Track active boosts per player
-- { [player] = { [boostType] = expiresAt } }
local activeBoosts = {}

-- Track inventory per player
-- { [player] = { [itemId] = quantity } }
local playerInventory = {}

-- Cooldowns to prevent spam
local cooldowns = {}
local COOLDOWN  = 0.5

local MATERIAL_ITEMS = {}
local START_CLEARED_CATEGORIES = {
	Items = true,
	Boosts = true,
	Materials = true,
}

for itemId, item in pairs(ItemsData.Items) do
	if item.category == "Materials" then
		MATERIAL_ITEMS[itemId] = true
	end
end

local function getInventory(player)
	if not playerInventory[player] then
		playerInventory[player] = {}
	end
	return playerInventory[player]
end

local function getBoosts(player)
	if not activeBoosts[player] then
		activeBoosts[player] = {}
	end
	return activeBoosts[player]
end

-- ========================
--   GIVE ITEM TO PLAYER
--   Called by other scripts (e.g. dev products, rewards)
-- ========================
local function giveItem(player, itemId, quantity)
	if MATERIAL_ITEMS[itemId] then
		print("ItemsHandler: material item grant ignored for now -> " .. tostring(itemId))
		return
	end

	quantity = quantity or 1
	local inv = getInventory(player)
	inv[itemId] = (inv[itemId] or 0) + quantity

	-- Notify client
	useEvent:FireClient(player, "update", itemId, inv[itemId])
	print(player.Name .. " received " .. quantity .. "x " .. itemId)
end

local function clearMaterials(inv)
	for itemId in pairs(MATERIAL_ITEMS) do
		inv[itemId] = nil
	end
end

local function clearStartClearedItems(inv)
	for itemId, item in pairs(ItemsData.Items) do
		if START_CLEARED_CATEGORIES[item.category] then
			inv[itemId] = nil
		end
	end
end

local function clearFolderChildren(folder)
	if not folder then
		return
	end

	for _, child in ipairs(folder:GetChildren()) do
		child:Destroy()
	end
end

local function clearActiveBoostInstances(player)
	clearFolderChildren(player:FindFirstChild("Boosts"))
	clearFolderChildren(player:FindFirstChild("ItemFlags"))
end

-- ========================
--   APPLY BOOST EFFECT
-- ========================
local function applyBoost(player, boostType, duration)
	local boosts = getBoosts(player)
	local now    = os.time()

	-- Stack with existing boost time
	local current = boosts[boostType] or now
	boosts[boostType] = math.max(current, now) + duration

	-- Store in player folder so other scripts can read it
	local boostFolder = player:FindFirstChild("Boosts")
	if not boostFolder then
		boostFolder = Instance.new("Folder")
		boostFolder.Name   = "Boosts"
		boostFolder.Parent = player
	end

	local val = boostFolder:FindFirstChild(boostType)
	if not val then
		val = Instance.new("NumberValue")
		val.Name   = boostType
		val.Parent = boostFolder
	end
	val.Value = boosts[boostType]

	print(player.Name .. " boost applied: " .. boostType .. " until " .. boosts[boostType])
end

-- ========================
--   USE ITEM LOGIC
-- ========================
local function useItem(player, itemId, requestedAmount)
	local item = ItemsData.Items[itemId]
	if not item then
		useEvent:FireClient(player, "error", itemId, "Unknown item!")
		return
	end

	if not item.usable then
		useEvent:FireClient(player, "error", itemId, "This item can't be used!")
		return
	end

	local inv = getInventory(player)
	if not inv[itemId] or inv[itemId] <= 0 then
		useEvent:FireClient(player, "error", itemId, "You don't have any " .. item.displayName .. "!")
		return
	end

	-- Deduct one
	local amount = 1
	if item.boostType and item.boostDuration then
		amount = math.clamp(math.floor(tonumber(requestedAmount) or 1), 1, inv[itemId])
	end

	inv[itemId] = inv[itemId] - amount
	if inv[itemId] <= 0 then inv[itemId] = nil end

	-- Apply effect
	if item.boostType and item.boostDuration then
		applyBoost(player, item.boostType, item.boostDuration * amount)

		-- Tell client: item used successfully + boost info
		useEvent:FireClient(player, "boosted", itemId, inv[itemId] or 0, {
			boostType    = item.boostType,
			boostDuration = item.boostDuration * amount,
			usedAmount = amount,
			expiresAt    = (activeBoosts[player] or {})[item.boostType],
		})

	elseif itemId == "TripleHatchTicket" then
		-- Store flag for egg shop to read
		local flagFolder = player:FindFirstChild("ItemFlags")
		if not flagFolder then
			flagFolder = Instance.new("Folder")
			flagFolder.Name   = "ItemFlags"
			flagFolder.Parent = player
		end
		local flag = flagFolder:FindFirstChild("TripleHatch")
		if not flag then
			flag = Instance.new("IntValue")
			flag.Name   = "TripleHatch"
			flag.Parent = flagFolder
		end
		flag.Value = (flag.Value or 0) + 1

		useEvent:FireClient(player, "used", itemId, inv[itemId] or 0, {
			message = "Triple Hatch activated! Next 3 hatches are free!"
		})

	elseif itemId == "RainbowKey" then
		-- Give a big coin reward as placeholder for chest
		local stats = player:FindFirstChild("leaderstats")
		if stats then
			local coins = stats:FindFirstChild("Coins")
			if coins then
				local reward = math.random(5000, 15000)
				coins.Value  = coins.Value + reward
				useEvent:FireClient(player, "used", itemId, inv[itemId] or 0, {
					message = "Rainbow Chest opened! +" .. reward .. " Coins!"
				})
			end
		end

	elseif itemId == "MysteryCrate" then
		-- Random item reward
		local possibleRewards = {
			{ itemId = "LuckPotion",  qty = 1 },
			{ itemId = "CoinPotion",  qty = 1 },
			{ itemId = "SpeedPotion", qty = 1 },
			{ itemId = "RangePotion", qty = 1 },
		}
		local reward = possibleRewards[math.random(1, #possibleRewards)]
		giveItem(player, reward.itemId, reward.qty)

		useEvent:FireClient(player, "used", itemId, inv[itemId] or 0, {
			message = "Mystery Crate opened! Got " .. reward.qty .. "x " .. (ItemsData.Items[reward.itemId] and ItemsData.Items[reward.itemId].displayName or reward.itemId) .. "!"
		})

	else
		-- Generic usable
		useEvent:FireClient(player, "used", itemId, inv[itemId] or 0, {
			message = item.displayName .. " used!"
		})
	end
end

-- ========================
--   LISTEN FOR USE REQUESTS
-- ========================
useEvent.OnServerEvent:Connect(function(player, itemId, requestedAmount)
	local now = tick()
	if cooldowns[player] and (now - cooldowns[player]) < COOLDOWN then return end
	cooldowns[player] = now

	useItem(player, itemId, requestedAmount)
end)

-- ========================
--   BOOST EXPIRY CHECKER
-- ========================
task.spawn(function()
	while true do
		task.wait(5)
		local now = os.time()
		for player, boosts in pairs(activeBoosts) do
			for boostType, expiresAt in pairs(boosts) do
				if now >= expiresAt then
					boosts[boostType] = nil

					-- Clear from player folder
					local boostFolder = player:FindFirstChild("Boosts")
					if boostFolder then
						local val = boostFolder:FindFirstChild(boostType)
						if val then val.Value = 0 end
					end

					-- Notify client boost expired
					useEvent:FireClient(player, "boostExpired", boostType)
					print(player.Name .. " boost expired: " .. boostType)
				end
			end
		end
	end
end)

local function setupPlayer(player)
	playerInventory[player] = {}
	activeBoosts[player]    = {}
	task.defer(function()
		local inv = getInventory(player)
		clearStartClearedItems(inv)
		clearMaterials(inv)
		clearActiveBoostInstances(player)
		useEvent:FireClient(player, "sync", inv)
	end)
end

-- ========================
--   PLAYER SETUP / CLEANUP
-- ========================
Players.PlayerAdded:Connect(setupPlayer)

for _, player in ipairs(Players:GetPlayers()) do
	setupPlayer(player)
end

Players.PlayerRemoving:Connect(function(player)
	playerInventory[player] = nil
	activeBoosts[player]    = nil
	cooldowns[player]       = nil
end)

-- Expose for other scripts
return {
	giveItem   = giveItem,
	applyBoost = applyBoost,
	getBoosts  = function(player) return getBoosts(player) end,
}
]]></string>
        </Properties>
      </Item>
      <Item class="Script" referent="67">
        <Properties>
          <string name="Name">LobbyPortalHandler</string>
          <token name="RunContext">0</token>
          <string name="Source"><![CDATA[-- Server-owned lobby portal travel for baked/editable maps.
local Players = game:GetService("Players")
local Workspace = game:GetService("Workspace")

local MAP_NAME = "ColorSimulatorMap"
local COOLDOWN = 0.75
local cooldowns = {}

local function getRoot(player)
	local character = player.Character
	return character and character:FindFirstChild("HumanoidRootPart")
end

local function getPlayerFromHit(hit)
	local character = hit and hit:FindFirstAncestorOfClass("Model")
	return character and Players:GetPlayerFromCharacter(character)
end

local function isPortalPart(part)
	return part:IsA("BasePart")
		and (part:GetAttribute("LobbyRedZonePortal") == true or part.Name == "RedZonePortal")
end

local function getRedZoneDestination()
	local map = Workspace:FindFirstChild(MAP_NAME)
	if not map then
		return nil
	end

	local named = map:FindFirstChild("RedZoneArrivalSpawn", true)
	if named and named:IsA("BasePart") then
		return named
	end

	for _, obj in ipairs(map:GetDescendants()) do
		if obj:IsA("BasePart") and obj:GetAttribute("LobbyPortalArrival") == true then
			return obj
		end
	end

	for _, obj in ipairs(map:GetDescendants()) do
		if obj:IsA("BasePart") then
			local spawnColor = obj:GetAttribute("AreaSpawnColor") or obj:GetAttribute("SpawnColor") or obj:GetAttribute("TeleportColor")
			if spawnColor == "Red" then
				return obj
			end
		end
	end

	return nil
end

local function useCooldown(player)
	local now = os.clock()
	if cooldowns[player] and now - cooldowns[player] < COOLDOWN then
		return false
	end
	cooldowns[player] = now
	return true
end

local function teleportToRedZone(player)
	if not useCooldown(player) then
		return
	end

	local root = getRoot(player)
	local destination = getRedZoneDestination()
	if not root or not destination then
		warn("LobbyPortalHandler: missing character root or RedZoneArrivalSpawn.")
		return
	end

	root.CFrame = destination.CFrame + Vector3.new(0, 5, 0)
	print(player.Name .. " entered Red Zone from Lobby")
end

local function hookPrompt(prompt)
	if not prompt:IsA("ProximityPrompt") then
		return
	end

	local parent = prompt.Parent
	if not parent or not isPortalPart(parent) then
		return
	end
	if prompt:GetAttribute("LobbyPortalHooked") then
		return
	end

	prompt:SetAttribute("LobbyPortalHooked", true)
	prompt.Triggered:Connect(teleportToRedZone)
end

local function hookPortal(part)
	if not isPortalPart(part) then
		return
	end
	if part:GetAttribute("LobbyPortalTouchedHooked") then
		return
	end

	part:SetAttribute("LobbyPortalTouchedHooked", true)
	part.Touched:Connect(function(hit)
		local player = getPlayerFromHit(hit)
		if player then
			teleportToRedZone(player)
		end
	end)

	for _, child in ipairs(part:GetChildren()) do
		hookPrompt(child)
	end
end

for _, obj in ipairs(Workspace:GetDescendants()) do
	if obj:IsA("BasePart") then
		hookPortal(obj)
	elseif obj:IsA("ProximityPrompt") then
		hookPrompt(obj)
	end
end

Workspace.DescendantAdded:Connect(function(obj)
	if obj:IsA("BasePart") then
		hookPortal(obj)
	elseif obj:IsA("ProximityPrompt") then
		hookPrompt(obj)
	end
end)

Players.PlayerRemoving:Connect(function(player)
	cooldowns[player] = nil
end)
]]></string>
        </Properties>
      </Item>
      <Item class="Script" referent="68">
        <Properties>
          <string name="Name">PaintToolShopHandler</string>
          <token name="RunContext">0</token>
          <string name="Source"><![CDATA[-- Server-owned paintbrush shop and equipment state.
local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")

local ToolData = require(ReplicatedStorage:WaitForChild("ToolData"))
local ColorData = require(ReplicatedStorage:WaitForChild("ColorData"))

local Events = ReplicatedStorage:WaitForChild("Events")
local purchaseEvent = Events:WaitForChild("PurchasePaintTool")
local equipEvent = Events:WaitForChild("EquipPaintTool")
local dirtyEvent = Events:FindFirstChild("PlayerDataDirty")

local cooldowns = {}
local COOLDOWN = 0.35

local function markDirty(player, reason)
	if dirtyEvent then
		dirtyEvent:Fire(player, reason)
	end
end

local function ensureToolsFolder(player)
	local folder = player:FindFirstChild("PaintTools")
	if not folder then
		folder = Instance.new("Folder")
		folder.Name = "PaintTools"
		folder.Parent = player
	end

	local owned = folder:FindFirstChild("Owned")
	if not owned then
		owned = Instance.new("StringValue")
		owned.Name = "Owned"
		owned.Value = "StarterBrush"
		owned.Parent = folder
	end
	if owned.Value == "" then
		owned.Value = "StarterBrush"
	end

	local equipped = folder:FindFirstChild("Equipped")
	if not equipped then
		equipped = Instance.new("StringValue")
		equipped.Name = "Equipped"
		equipped.Value = "StarterBrush"
		equipped.Parent = folder
	end
	if equipped.Value == "" or not ToolData.isValid(equipped.Value) then
		equipped.Value = "StarterBrush"
	end

	return folder, owned, equipped
end

local function csvSet(value)
	local set = {}
	for _, part in ipairs(string.split(value or "", ",")) do
		if part ~= "" then
			set[part] = true
		end
	end
	return set
end

local function setToCsv(set)
	local parts = {}
	for _, toolId in ipairs(ToolData.Order) do
		if set[toolId] then
			table.insert(parts, toolId)
		end
	end
	return table.concat(parts, ",")
end

local function ownsTool(player, toolId)
	local _, owned = ensureToolsFolder(player)
	return csvSet(owned.Value)[toolId] == true
end

local function isToolUnlocked(player, tool)
	local requiredColor = tool and tool.RequiredColor or "Red"
	if requiredColor == "Red" then
		return true
	end

	local storage = player:FindFirstChild("ColorStorage")
	local unlocked = storage and storage:FindFirstChild("UnlockedColors")
	return unlocked and ColorData.isColorUnlocked(unlocked.Value, requiredColor)
end

local function getToolWorldName(tool)
	local world = ColorData.getWorldByColor(tool and tool.RequiredColor or "Red")
	return world and world.name or "Starter Field"
end

local function useCooldown(player)
	local now = os.clock()
	if cooldowns[player] and now - cooldowns[player] < COOLDOWN then
		return false
	end
	cooldowns[player] = now
	return true
end

purchaseEvent.OnServerEvent:Connect(function(player, toolId)
	if not useCooldown(player) then
		return
	end

	local tool = ToolData.Tools[toolId or ""]
	if not tool then
		purchaseEvent:FireClient(player, false, toolId, "Unknown brush.")
		return
	end
	if not isToolUnlocked(player, tool) then
		purchaseEvent:FireClient(player, false, tool.Id, "Unlock " .. getToolWorldName(tool) .. " first.")
		return
	end

	local _, owned, equipped = ensureToolsFolder(player)
	local ownedSet = csvSet(owned.Value)
	if ownedSet[tool.Id] then
		equipped.Value = tool.Id
		markDirty(player, "paint-tool-equipped")
		purchaseEvent:FireClient(player, true, tool.Id, "Equipped " .. tool.DisplayName)
		equipEvent:FireClient(player, true, tool.Id, "Equipped " .. tool.DisplayName)
		return
	end

	local stats = player:FindFirstChild("leaderstats")
	local coins = stats and stats:FindFirstChild("Coins")
	local cost = tonumber(tool.Cost) or 0
	if not coins or coins.Value < cost then
		purchaseEvent:FireClient(player, false, tool.Id, "Need " .. tostring(cost) .. " Coins.")
		return
	end

	coins.Value -= cost
	ownedSet[tool.Id] = true
	owned.Value = setToCsv(ownedSet)
	equipped.Value = tool.Id
	markDirty(player, "paint-tool-purchased")

	print(player.Name .. " bought and equipped " .. tool.DisplayName .. " for " .. tostring(cost) .. " Coins")
	purchaseEvent:FireClient(player, true, tool.Id, "Bought " .. tool.DisplayName)
	equipEvent:FireClient(player, true, tool.Id, "Equipped " .. tool.DisplayName)
end)

equipEvent.OnServerEvent:Connect(function(player, toolId, equippedRequested)
	if not useCooldown(player) then
		return
	end

	local tool = ToolData.Tools[toolId or ""]
	if not tool then
		equipEvent:FireClient(player, false, toolId, "Unknown brush.")
		return
	end
	if not isToolUnlocked(player, tool) then
		equipEvent:FireClient(player, false, tool.Id, "Unlock " .. getToolWorldName(tool) .. " first.")
		return
	end

	local _, _, equipped = ensureToolsFolder(player)
	if not ownsTool(player, tool.Id) then
		equipEvent:FireClient(player, false, tool.Id, "You do not own this brush.")
		return
	end

	if equippedRequested == false and equipped.Value == tool.Id then
		equipped.Value = "StarterBrush"
		equipEvent:FireClient(player, true, "StarterBrush", "Equipped Starter Brush")
	else
		equipped.Value = tool.Id
		equipEvent:FireClient(player, true, tool.Id, "Equipped " .. tool.DisplayName)
	end

	markDirty(player, "paint-tool-equipped")
end)

Players.PlayerAdded:Connect(function(player)
	task.defer(function()
		ensureToolsFolder(player)
	end)
end)

Players.PlayerRemoving:Connect(function(player)
	cooldowns[player] = nil
end)
]]></string>
        </Properties>
      </Item>
      <Item class="Script" referent="69">
        <Properties>
          <string name="Name">PetHandler</string>
          <token name="RunContext">0</token>
          <string name="Source"><![CDATA[-- Script in ServerScriptService named "PetHandler"
local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local RunService = game:GetService("RunService")

local PetData   = require(ReplicatedStorage:WaitForChild("PetData"))
local ColorData = require(ReplicatedStorage:WaitForChild("ColorData"))
local ColorPersonalityData = require(ReplicatedStorage:WaitForChild("ColorPersonalityData"))
local ColorTraitData = require(ReplicatedStorage:WaitForChild("ColorTraitData"))
local ColorMutationData = require(ReplicatedStorage:WaitForChild("ColorMutationData"))
local GameBalance = require(ReplicatedStorage:WaitForChild("GameBalance"))
local GamepassBenefits = require(script.Parent:WaitForChild("GamepassBenefits"))
local ColorEffectHandler = require(script.Parent:WaitForChild("ColorEffectHandler"))

-- Load PetTraits safely
local PetTraits = nil
local Modules = ReplicatedStorage:FindFirstChild("Modules")
if Modules then
	local pt = Modules:FindFirstChild("PetTraits")
	if pt then PetTraits = require(pt) end
end
if not PetTraits then warn("PetHandler: PetTraits module not found!") end

local Events          = ReplicatedStorage:WaitForChild("Events")
local hatchEvent      = Events:WaitForChild("HatchEgg")
local equipEvent      = Events:WaitForChild("EquipPet")
local mergeEvent      = Events:WaitForChild("MergePet")
local petAtkEvent     = Events:WaitForChild("PetAttack")
local petBreakRewardEvent = Events:FindFirstChild("PetBreakReward")
if not petBreakRewardEvent then
	petBreakRewardEvent = Instance.new("RemoteEvent")
	petBreakRewardEvent.Name = "PetBreakReward"
	petBreakRewardEvent.Parent = Events
end
local petsLoadedEvent = Events:WaitForChild("PetsLoaded")
local dataDirtyEvent = Events:FindFirstChild("PlayerDataDirty")
local grantPetFunction = ReplicatedStorage:FindFirstChild("ServerGrantPet")
if not grantPetFunction then
	grantPetFunction = Instance.new("BindableFunction")
	grantPetFunction.Name = "ServerGrantPet"
	grantPetFunction.Parent = ReplicatedStorage
end

local MAX_EQUIPPED = 3
local DEBUG_LOGS = RunService:IsStudio()

-- inventory: { [player] = { [variantKey] = { petId, stackAmount, traitId, mutationId } } }
-- equipped:  { [player] = { variantKey, ... } }
local playerInventory = {}
local playerEquipped  = {}
local lastMergeAt = {}
local hatchState = {}
local unexpectedClientWarnings = {}
local STUDIO_DEV_PET_ID = "DevRainbowPet"
local STUDIO_DEV_PET_TRAIT = "SuperLucky"
local STUDIO_DEV_PET_STACK = 1

local function warnUnexpectedClientValuesOnce(player, action)
	local key = tostring(player and player.UserId or "server") .. ":" .. tostring(action)
	if unexpectedClientWarnings[key] then
		return
	end
	unexpectedClientWarnings[key] = true
	warn(action .. " ignored unexpected client value fields. Server calculates costs and rewards.")
end

local TRAIT_RANK = {
	Common = 1,
	Uncommon = 2,
	Rare = 3,
	Epic = 4,
	Legendary = 5,
}

local function isEggUnlocked(player, egg)
	local areaColor = egg.areaColor
	if not areaColor or areaColor == "Red" then
		return true
	end

	local storage = player:FindFirstChild("ColorStorage")
	local unlockedColors = storage and storage:FindFirstChild("UnlockedColors")
	if not unlockedColors then
		return false
	end

	return ColorData.isColorUnlocked(unlockedColors.Value, areaColor)
end

local function isBetterTrait(newTrait, oldTrait)
	if not newTrait then
		return false
	end
	if not oldTrait then
		return true
	end

	local newRank = TRAIT_RANK[newTrait.rarity] or 0
	local oldRank = TRAIT_RANK[oldTrait.rarity] or 0
	if newRank ~= oldRank then
		return newRank > oldRank
	end

	return (newTrait.weight or 999) < (oldTrait.weight or 999)
end

local function getVisualColor(colorType)
	if colorType == "Rainbow" then
		return Color3.fromRGB(215, 180, 255)
	end

	local colorInfo = ColorData.Colors[colorType]
	return colorInfo and colorInfo.color or Color3.new(1, 1, 1)
end

local function getBaseBreakableReward(part, data)
	local reward = tonumber(part:GetAttribute("BaseColorReward"))
		or tonumber(data.baseReward)
		or tonumber(data.rewardMin)
		or 1
	return math.max(1, math.floor(reward))
end

local function getZoneCoinMultiplier(colorType)
	local configured = GameBalance.Sell
		and GameBalance.Sell.ColorValueMultipliers
		and GameBalance.Sell.ColorValueMultipliers[colorType]
	local world = ColorData.getWorldByColor(colorType)
	return tonumber(configured or (world and world.colorValueMultiplier)) or 1
end

local function getInstantCoinMultiplier(player, colorType, petStats)
	local multiplier = getZoneCoinMultiplier(colorType)
	multiplier *= petStats and petStats.coinMult or 1

	local boostFolder = player:FindFirstChild("Boosts")
	local coinBoost = boostFolder and boostFolder:FindFirstChild("coins")
	if coinBoost and os.time() < coinBoost.Value then
		multiplier *= 2
	end

	multiplier *= GamepassBenefits.getCoinMultiplier(player)
	return multiplier
end

local function awardCoins(player, amount)
	amount = math.max(0, math.floor(tonumber(amount) or 0))
	if amount <= 0 then
		return false
	end

	local stats = player:FindFirstChild("leaderstats")
	local coins = stats and stats:FindFirstChild("Coins")
	if not coins then
		return false
	end

	coins.Value += amount
	return true
end

local function getStoredColor(part, colorType)
	local stored = part and part:GetAttribute("SpawnColor")
	if typeof(stored) == "Color3" then
		return stored
	end
	return getVisualColor(colorType)
end

local function getMaxSlots(player)
	local pf = player:FindFirstChild("PetData")
	local baseSlots = 3
	if pf then
		local v = pf:FindFirstChild("MaxSlots")
		if v then
			baseSlots = v.Value
		end
	end
	return baseSlots + GamepassBenefits.getExtraEquippedColorSlots(player)
end

local function getDataDirtyEvent()
	if not dataDirtyEvent or not dataDirtyEvent.Parent then
		dataDirtyEvent = Events:FindFirstChild("PlayerDataDirty")
	end
	return dataDirtyEvent
end

local function markDataDirty(player, reason)
	local event = getDataDirtyEvent()
	if event and event:IsA("BindableEvent") then
		event:Fire(player, reason or "colors-changed")
	end
end

local function normalizeInventoryData(variantKey, data)
	if not data or not data.petId then
		return nil
	end

	data.personalityId = PetData.normalizePersonalityId(data.personalityId)
	data.mutationId = PetData.normalizeMutationId(data.mutationId)
	data.traitId = PetData.normalizeTraitId(data.traitId)
	data.stackAmount = math.max(1, tonumber(data.stackAmount) or 1)

	local expectedKey = PetData.makeVariantKey(data.petId, data.personalityId, data.mutationId, data.traitId)
	if not variantKey or variantKey == "" or variantKey ~= expectedKey then
		variantKey = expectedKey
	end

	return variantKey, data
end

local function buildEntry(variantKey, data)
	if not data then
		return nil
	end

	local entry = PetData.buildPetEntry(data.petId, data.stackAmount, data.isShiny, data.personalityId, data.mutationId, data.traitId)
	if entry then
		entry.variantKey = variantKey or entry.variantKey
		local trait = ColorTraitData.get(data.traitId)
		entry.trait = {
			name = trait.DisplayName,
			description = trait.Description,
			color = trait.TextColor,
			icon = trait.Icon or "",
			rarity = trait.Id == "Neutral" and "Common" or "Uncommon",
			visualEffect = "none",
		}
		entry.effectivePower = entry.finalPower
	end
	return entry
end

local function getEquippedPersonalityStats(player)
	local result = {
		colorGainMult = 1,
		sellMult = 1,
		pickupRangeMult = 1,
		walkSpeedBonus = 0,
		luckBonus = 0,
		totalPowerMult = 1,
	}
	-- Legacy personalities are no longer player-facing gameplay effects. Real effects come from
	-- ColorTraitData and ColorMutationData through ColorEffectHandler.
	return result
end

local function getPlayerLuckMultiplier(player)
	local luckMult = 1.0
	local boostFolder = player:FindFirstChild("Boosts")
	if boostFolder then
		local luckVal = boostFolder:FindFirstChild("luck")
		if luckVal and os.time() < luckVal.Value then
			luckMult = 1.5
		end
	end

	luckMult += ColorEffectHandler.GetHatchLuckBonus(player)
	if ColorEffectHandler.GetHatchLuckMultiplier then
		luckMult *= ColorEffectHandler.GetHatchLuckMultiplier(player)
	end
	luckMult *= GamepassBenefits.getLuckMultiplier(player)
	local maxLuckMult = 2.5
	if RunService:IsStudio() then
		local testing = GameBalance.Testing or {}
		luckMult *= tonumber(testing.StudioHatchLuckMultiplier) or 1
		maxLuckMult = tonumber(testing.MaxStudioHatchLuckMultiplier) or maxLuckMult
	end
	return math.clamp(luckMult, 1, maxLuckMult)
end

local function resolveInventoryKey(inventory, key)
	if not inventory or not key then
		return nil
	end

	local normalizedKey = tostring(key)
	if inventory[normalizedKey] then
		return normalizedKey
	end
	local legacyParts = string.split(normalizedKey, "|")

	for variantKey, data in pairs(inventory) do
		if variantKey == normalizedKey or data.petId == normalizedKey then
			return variantKey
		end

		local expectedKey = PetData.makeVariantKey(data.petId, data.personalityId, data.mutationId, data.traitId)
		if expectedKey == normalizedKey then
			return variantKey
		end

		if #legacyParts >= 3 and legacyParts[1] == data.petId then
			local legacyTraitId = PetData.normalizeTraitId(legacyParts[2])
			local legacyMutationId = PetData.normalizeMutationId(legacyParts[3])
			local mutationMatches = legacyMutationId == PetData.normalizeMutationId(data.mutationId)
			local traitMatches = legacyTraitId == PetData.normalizeTraitId(data.traitId)
				or (legacyTraitId == "Neutral" and PetData.normalizeTraitId(data.traitId) == "Neutral")
			if mutationMatches and traitMatches then
				return variantKey
			end
		end
	end

	return nil
end

local function sanitizeEquippedList(player)
	local equipped = playerEquipped[player]
	local inventory = playerInventory[player]
	if not equipped or not inventory then
		return
	end

	local seen = {}
	local writeIndex = 1
	for _, key in ipairs(equipped) do
		local resolvedKey = resolveInventoryKey(inventory, key)
		if resolvedKey and inventory[resolvedKey] and not seen[resolvedKey] then
			equipped[writeIndex] = resolvedKey
			seen[resolvedKey] = true
			writeIndex += 1
		end
	end

	for index = #equipped, writeIndex, -1 do
		table.remove(equipped, index)
	end
end

local function applyWalkSpeedBonus(player)
	local character = player.Character
	local humanoid = character and character:FindFirstChildOfClass("Humanoid")
	if not humanoid then
		return
	end

	ColorEffectHandler.ApplyCharacterEffects(player)
end

-- ========================
--   SYNC TO PETDATA FOLDER
-- ========================
local function syncPetFolder(player, dirtyReason)
	local petFolder = player:FindFirstChild("PetData")
	if not petFolder then return end
	if not playerInventory[player] or not playerEquipped[player] then return end
	sanitizeEquippedList(player)

	local invVal      = petFolder:FindFirstChild("Inventory")
	local equippedVal = petFolder:FindFirstChild("Equipped")

	if invVal then
		local parts = {}
		for variantKey, data in pairs(playerInventory[player]) do
			-- Format: "variantKey:petId:stackAmount:traitId:shiny:personalityId:mutationId"
			local traitStr = PetData.normalizeTraitId(data.traitId)
			local shinyStr = data.isShiny and "shiny" or "normal"
			table.insert(parts, tostring(variantKey) .. ":" .. data.petId .. ":" .. data.stackAmount .. ":" .. traitStr .. ":" .. shinyStr .. ":" .. (data.personalityId or "Neutral") .. ":" .. (data.mutationId or "None"))
		end
		invVal.Value = table.concat(parts, ",")
	end

	if equippedVal then
		equippedVal.Value = table.concat(playerEquipped[player], ",")
	end

	applyWalkSpeedBonus(player)
	markDataDirty(player, dirtyReason)
end

-- ========================
--   SEND STATE TO CLIENT
-- ========================
local function sendState(player)
	if not playerInventory[player] or not playerEquipped[player] then
		return
	end

	local invList = {}
	for variantKey, data in pairs(playerInventory[player]) do
		local entry = buildEntry(variantKey, data)
		if entry then
			table.insert(invList, entry)
		end
	end
	sanitizeEquippedList(player)
	local equippedCopy = table.clone(playerEquipped[player] or {})
	petsLoadedEvent:FireClient(player, invList, equippedCopy)
end

local function grantPetToPlayer(player, petId, amount, traitId, isShiny, autoEquip, personalityId, mutationId)
	local inv = playerInventory[player]
	local equipped = playerEquipped[player]
	if not inv or not equipped or not PetData.Pets[petId] then
		return false, nil
	end

	personalityId = PetData.normalizePersonalityId(personalityId)
	mutationId = PetData.normalizeMutationId(mutationId)
	traitId = PetData.normalizeTraitId(traitId)
	local variantKey = PetData.makeVariantKey(petId, personalityId, mutationId, traitId)

	amount = math.max(1, math.floor(tonumber(amount) or 1))
	if inv[variantKey] then
		inv[variantKey].stackAmount += amount
		if isShiny then
			inv[variantKey].isShiny = true
		end
	else
		inv[variantKey] = {
			petId = petId,
			stackAmount = amount,
			traitId = traitId,
			isShiny = isShiny == true,
			personalityId = personalityId,
			mutationId = mutationId,
		}
		if autoEquip and #equipped < getMaxSlots(player) then
			table.insert(equipped, variantKey)
		end
	end

	local data = inv[variantKey]
	local entry = buildEntry(variantKey, data)

	syncPetFolder(player, "grant-color")
	sendState(player)
	return true, entry
end

local function ensureStudioDevPet(player)
	if not RunService:IsStudio() then
		return
	end

	local inv = playerInventory[player]
	local equipped = playerEquipped[player]
	if not inv or not equipped or not PetData.Pets[STUDIO_DEV_PET_ID] then
		return
	end

	local traitId = PetData.normalizeTraitId(STUDIO_DEV_PET_TRAIT)
	local mutationId = PetData.normalizeMutationId("None")
	local variantKey = PetData.makeVariantKey(STUDIO_DEV_PET_ID, "Neutral", mutationId, traitId)
	local existing = inv[variantKey]
	if existing then
		existing.stackAmount = math.max(tonumber(existing.stackAmount) or 1, STUDIO_DEV_PET_STACK)
		existing.traitId = traitId
		existing.personalityId = "Neutral"
		existing.mutationId = mutationId
		existing.isShiny = false
	else
		inv[variantKey] = {
			petId = STUDIO_DEV_PET_ID,
			stackAmount = STUDIO_DEV_PET_STACK,
			traitId = traitId,
			isShiny = false,
			personalityId = "Neutral",
			mutationId = mutationId,
		}
	end

	for index = #equipped, 1, -1 do
		local key = equipped[index]
		local data = inv[key]
		if data and data.petId == STUDIO_DEV_PET_ID and key ~= variantKey then
			table.remove(equipped, index)
		end
	end

	local alreadyEquipped = false
	for _, key in ipairs(equipped) do
		if key == variantKey then
			alreadyEquipped = true
			break
		end
	end
	if not alreadyEquipped then
		table.insert(equipped, 1, variantKey)
		local maxSlots = getMaxSlots(player)
		while #equipped > maxSlots do
			table.remove(equipped)
		end
	end

	syncPetFolder(player, "studio-dev-rainbow-pet")
	sendState(player)
	print("DevTools: equipped Studio Rainbow Pet for " .. player.Name)
end

-- ========================
--   PARSE SAVED INVENTORY
-- ========================
local function parseInventory(str)
	local inv = {}
	if not str or str == "" then return inv end
	for _, part in ipairs(string.split(str, ",")) do
		local segments = string.split(part, ":")
		local variantKey
		local petId
		local stackIndex
		if tonumber(segments[2]) then
			petId = segments[1]
			stackIndex = 2
		else
			variantKey = segments[1]
			petId = segments[2]
			stackIndex = 3
		end

		local amt      = tonumber(segments[stackIndex]) or 1
		local traitId = PetData.normalizeTraitId(segments[stackIndex + 1])
		local shinyStr = segments[stackIndex + 2] or "normal"
		local personalityId = PetData.normalizePersonalityId(segments[stackIndex + 3] or "Neutral")
		local mutationId = PetData.normalizeMutationId(segments[stackIndex + 4] or "None")
		if not petId or petId == "" then
			continue
		end
		variantKey = variantKey or PetData.makeVariantKey(petId, personalityId, mutationId, traitId)

		local normalizedKey, normalizedData = normalizeInventoryData(variantKey, {
			petId = petId,
			stackAmount = math.max(1, amt),
			traitId = traitId,
			isShiny = shinyStr == "shiny" or shinyStr == "true",
			personalityId = personalityId,
			mutationId = mutationId,
		})
		if normalizedKey and normalizedData then
			inv[normalizedKey] = normalizedData
		end
	end
	return inv
end

-- ========================
--   PLAYER SETUP
-- ========================
Players.PlayerAdded:Connect(function(player)
	playerInventory[player] = {}
	playerEquipped[player]  = {}

	local petFolder = player:WaitForChild("PetData", 10)
	if not petFolder then return end

	local invVal      = petFolder:WaitForChild("Inventory", 5)
	local equippedVal = petFolder:WaitForChild("Equipped",  5)

	if invVal and invVal.Value ~= "" then
		playerInventory[player] = parseInventory(invVal.Value)
	end

	if equippedVal and equippedVal.Value ~= "" then
		local seen = {}
		local maxSlots = getMaxSlots(player)
		for _, savedKey in ipairs(string.split(equippedVal.Value, ",")) do
			local key = resolveInventoryKey(playerInventory[player], savedKey) or savedKey
			if key ~= "" and not playerInventory[player][key] then
				local legacyParts = string.split(savedKey, "|")
				if #legacyParts >= 3 then
					key = PetData.makeVariantKey(legacyParts[1], "Neutral", legacyParts[3], "Neutral")
				else
					key = PetData.makeVariantKey(savedKey, "Neutral", "None", "Neutral")
				end
			end
			if key ~= "" and playerInventory[player][key] and not seen[key] and #playerEquipped[player] < maxSlots then
				seen[key] = true
				table.insert(playerEquipped[player], key)
			end
		end
	end

	player.CharacterAdded:Connect(function()
		task.wait(0.5)
		applyWalkSpeedBonus(player)
	end)
	if player.Character then
		applyWalkSpeedBonus(player)
	end
	local upgrades = player:FindFirstChild("Upgrades")
	local walkSpeedValue = upgrades and upgrades:FindFirstChild("WalkSpeed")
	if walkSpeedValue then
		walkSpeedValue:GetPropertyChangedSignal("Value"):Connect(function()
			applyWalkSpeedBonus(player)
		end)
	end
	ensureStudioDevPet(player)
	task.wait(1)
	ensureStudioDevPet(player)
	sendState(player)
end)

Players.PlayerRemoving:Connect(function(player)
	syncPetFolder(player, "player-removing")
	playerInventory[player] = nil
	playerEquipped[player]  = nil
	lastMergeAt[player] = nil
	hatchState[player] = nil
end)

-- ========================
--   HATCH EGG
-- ========================
local function getHatchCooldown(player)
	local cooldown = tonumber(GameBalance.HatchCooldown) or 2.5
	local upgrades = player:FindFirstChild("Upgrades")
	local hatchSpeed = upgrades and upgrades:FindFirstChild("HatchSpeed")
	if hatchSpeed and typeof(hatchSpeed.Value) == "number" then
		cooldown *= math.clamp(hatchSpeed.Value, 0.1, 1)
	end
	return math.max(tonumber(GameBalance.FastHatchCooldown) or 1.25, cooldown)
end

local function rejectHatch(player, message)
	hatchEvent:FireClient(player, false, nil, message)
end

local function getEggWorldIndex(egg)
	return ColorData.getWorldIndex(egg and egg.areaColor) or 1
end

local function getHighestUnlockedWorldIndex(player)
	local storage = player:FindFirstChild("ColorStorage")
	local unlockedValue = storage and storage:FindFirstChild("UnlockedColors")
	local unlocked = ColorData.getUnlockedColorSet(unlockedValue and unlockedValue.Value or "Red")
	local highest = 1
	for index, world in ipairs(ColorData.Worlds or {}) do
		if unlocked[world.primaryColor] then
			highest = index
		end
	end
	return highest
end

local function isFeatureUnlocked(player, featureName)
	local requiredIndex = GameBalance.getFeatureUnlockWorldIndex
		and GameBalance.getFeatureUnlockWorldIndex(featureName)
		or 1
	return getHighestUnlockedWorldIndex(player) >= requiredIndex
end

local function getFeatureLockedMessage(featureName)
	return GameBalance.getFeatureUnlockText
		and GameBalance.getFeatureUnlockText(featureName)
		or ("Unlock " .. tostring(featureName) .. " later.")
end

local function traitsUnlockedForEgg(egg)
	return getEggWorldIndex(egg) >= (tonumber(GameBalance.TraitsUnlockWorldIndex) or 2)
end

local function mutationsUnlockedForEgg(egg)
	return getEggWorldIndex(egg) >= (tonumber(GameBalance.MutationsUnlockWorldIndex) or 2)
end

hatchEvent.OnServerEvent:Connect(function(player, eggId, ...)
	if select("#", ...) > 0 then
		warnUnexpectedClientValuesOnce(player, "HatchEgg")
	end

	local egg = PetData.Eggs[eggId]
	if not egg then
		rejectHatch(player, "Unknown egg.")
		return
	end

	local now = os.clock()
	local state = hatchState[player]
	if state and (state.active or now < (state.nextAllowedAt or 0)) then
		rejectHatch(player, "Please wait until your egg finishes hatching.")
		return
	end

	if not isEggUnlocked(player, egg) then
		rejectHatch(player, "Unlock " .. tostring(egg.areaColor) .. " first!")
		return
	end

	local stats = player:FindFirstChild("leaderstats")
	if not stats then
		rejectHatch(player, "Player stats are still loading.")
		return
	end
	local coins = stats:FindFirstChild("Coins")
	if not coins or coins.Value < egg.cost then
		rejectHatch(player, "Not enough coins!")
		return
	end

	local inv = playerInventory[player]
	local equipped = playerEquipped[player]
	if not inv or not equipped then
		rejectHatch(player, "Color inventory is still loading.")
		warn("PetHandler: blocked hatch before inventory was ready for " .. player.Name)
		return
	end

	local cooldown = getHatchCooldown(player)
	hatchState[player] = {
		active = true,
		nextAllowedAt = now + cooldown,
	}

	local luckMult = getPlayerLuckMultiplier(player)
	local petId = PetData.rollEgg(eggId, luckMult)
	if not petId or not PetData.Pets[petId] then
		hatchState[player] = nil
		rejectHatch(player, "Egg roll failed. Try again.")
		warn("PetHandler: egg " .. tostring(eggId) .. " rolled missing Color " .. tostring(petId))
		return
	end

	local canRollTraits = traitsUnlockedForEgg(egg)
	local canRollMutations = mutationsUnlockedForEgg(egg)
	local trait = canRollTraits and ColorTraitData.roll() or ColorTraitData.get("Neutral")
	local forcedMutationId = RunService:IsStudio() and player:GetAttribute("ForceNextMutation") or nil
	if forcedMutationId then
		player:SetAttribute("ForceNextMutation", nil)
	end
	local mutation = canRollMutations and ColorMutationData.roll(luckMult) or ColorMutationData.get("None")
	if canRollMutations and forcedMutationId and ColorMutationData.Mutations[forcedMutationId] then
		mutation = ColorMutationData.get(forcedMutationId)
	end
	local traitId = trait and trait.Id or "Neutral"
	local personalityId = "Neutral"
	local mutationId = mutation and mutation.Id or "None"
	local variantKey = PetData.makeVariantKey(petId, personalityId, mutationId, traitId)

	-- Stack or create
	local wasDuplicate = inv[variantKey] ~= nil
	if inv[variantKey] then
		inv[variantKey].stackAmount += 1
		-- (for simplicity: keep existing trait — change if you want override logic)
	else
		inv[variantKey] = {
			petId = petId,
			stackAmount = 1,
			traitId = traitId,
			isShiny = false,
			personalityId = personalityId,
			mutationId = mutationId,
		}
		-- Auto-equip first time
		if #playerEquipped[player] < getMaxSlots(player) then
			table.insert(playerEquipped[player], variantKey)
		end
	end

	coins.Value = coins.Value - egg.cost

	local newStack = inv[variantKey].stackAmount
	local entry = buildEntry(variantKey, inv[variantKey])
	if not entry then
		if wasDuplicate and inv[variantKey] then
			inv[variantKey].stackAmount = math.max(1, (inv[variantKey].stackAmount or 1) - 1)
		else
			inv[variantKey] = nil
			for index = #playerEquipped[player], 1, -1 do
				if playerEquipped[player][index] == variantKey then
					table.remove(playerEquipped[player], index)
				end
			end
		end
		coins.Value = coins.Value + egg.cost
		hatchState[player] = nil
		rejectHatch(player, "Inventory update failed. Try again.")
		warn("PetHandler: hatch rolled " .. tostring(petId) .. " but failed to build inventory entry for " .. player.Name)
		return
	end

	entry.rollIsShiny = false
	entry.wasDuplicate = wasDuplicate
	entry.duplicateCount = newStack
	entry.mergeTier = entry.currentStackTier
	entry.traitsUnlockedForEgg = canRollTraits
	entry.mutationsUnlockedForEgg = canRollMutations
	if DEBUG_LOGS then
		print("Hatched Color " .. tostring(entry.displayName or petId)
			.. " | Trait: " .. tostring(entry.traitName)
			.. " | Mutation: " .. tostring(entry.mutationName)
			.. " | Egg: " .. tostring(eggId))
	end

	syncPetFolder(player, "hatch-color")
	sendState(player)
	hatchEvent:FireClient(player, true, entry)

	task.delay(cooldown, function()
		local current = hatchState[player]
		if current and current.nextAllowedAt <= now + cooldown + 0.01 then
			hatchState[player] = nil
		end
	end)
end)

grantPetFunction.OnInvoke = function(player, petId, amount, traitId, mutationId)
	return grantPetToPlayer(player, petId, amount, traitId, false, true, "Neutral", mutationId)
end

-- ========================
--   EQUIP / UNEQUIP
-- ========================
equipEvent.OnServerEvent:Connect(function(player, action, variantKey)
	local equipped  = playerEquipped[player]
	local inventory = playerInventory[player]
	if not equipped or not inventory then return end
	local resolvedKey = resolveInventoryKey(inventory, variantKey)

	if action == "equip" then
		if not resolvedKey or not inventory[resolvedKey] then return end

		local maxSlots = getMaxSlots(player)
		for _, id in ipairs(equipped) do
			if id == resolvedKey then return end
		end
		if #equipped < maxSlots then
			table.insert(equipped, resolvedKey)
		end
	elseif action == "unequip" then
		if not variantKey then
			return
		end
		for i, id in ipairs(equipped) do
			if id == variantKey or id == resolvedKey then
				table.remove(equipped, i)
				break
			end
		end
	end

	syncPetFolder(player, "equip-color")
	sendState(player)
end)

-- ========================
--   MERGE PET STACK
-- ========================
mergeEvent.OnServerEvent:Connect(function(player, variantKey)
	local inventory = playerInventory[player]
	if not inventory then return end

	if not isFeatureUnlocked(player, "Merge") then
		mergeEvent:FireClient(player, false, variantKey, getFeatureLockedMessage("Merge"))
		return
	end

	local now = os.clock()
	if lastMergeAt[player] and now - lastMergeAt[player] < 0.5 then
		mergeEvent:FireClient(player, false, variantKey, "Slow down.")
		return
	end
	lastMergeAt[player] = now

	local data = inventory[variantKey]
	if not data or not PetData.Pets[data.petId] then
		mergeEvent:FireClient(player, false, variantKey, "You do not own that Color.")
		return
	end

	local mergeInfo = PetData.getMergeInfo(data.stackAmount)
	if not mergeInfo.canMerge then
		local need = math.max(0, mergeInfo.required - mergeInfo.ownedForTier)
		mergeEvent:FireClient(player, false, variantKey, "Need " .. need .. " more.")
		return
	end

	data.stackAmount = mergeInfo.resultStack

	local entry = buildEntry(variantKey, data)

	syncPetFolder(player, "merge-color")
	sendState(player)
	mergeEvent:FireClient(player, true, variantKey, entry)
end)

-- ========================
--   GET PET STATS (with trait multipliers)
-- ========================
local function getPlayerPetStats(player)
	local stats = { breakPower = 1, colorMult = 1.0, coinMult = 1.0, speedMult = 1.0, pickupRangeMult = 1.0, luckBonus = 0 }
	local equipped  = playerEquipped[player]
	local inventory = playerInventory[player]
	if not equipped or not inventory then return stats end
	local personalityStats = getEquippedPersonalityStats(player)

	for _, variantKey in ipairs(equipped) do
		local data  = inventory[variantKey]
		local stack = data and data.stackAmount or 1
		local entry = data and PetData.buildPetEntry(data.petId, stack, data.isShiny, data.personalityId, data.mutationId, data.traitId)
		if entry then
			local effPower = entry.finalPower

			stats.breakPower = stats.breakPower + effPower

			local baseCoinMult = entry.coinMult or 1.0
			stats.coinMult = stats.coinMult * baseCoinMult
			stats.colorMult = stats.colorMult * (entry.colorMult or 1.0)
		end
	end

	stats.breakPower = math.floor(stats.breakPower * personalityStats.totalPowerMult)
	stats.colorMult *= personalityStats.colorGainMult
	stats.coinMult *= personalityStats.sellMult
	stats.pickupRangeMult = personalityStats.pickupRangeMult
	stats.luckBonus = personalityStats.luckBonus

	local upgrades = player:FindFirstChild("Upgrades")
	local colorMultiplier = upgrades and upgrades:FindFirstChild("ColorMultiplier")
	if colorMultiplier then
		stats.colorMult *= colorMultiplier.Value
	end

	return stats
end

-- ========================
--   BREAKABLE TRACKING
-- ========================
local objectHealth    = {}
local objectMaxHealth = {}

local function registerObject(obj)
	if obj:IsA("BasePart") and obj:GetAttribute("BreakableType") then
		local data = ColorData.Breakables[obj:GetAttribute("BreakableType")]
		if data then
			objectHealth[obj]    = data.health
			objectMaxHealth[obj] = data.health
		end
	end
end
for _, obj in ipairs(workspace:GetDescendants()) do registerObject(obj) end
workspace.DescendantAdded:Connect(registerObject)

-- ========================
--   PET AUTO-ATTACK LOOP
-- ========================
local PET_ATTACK_RANGE    = 25
local PET_ATTACK_INTERVAL = 0.5
local lastAttack = {}

local function canPetAttackBreakable(player, obj, health, root, unlockedColors, maxRange)
	if health <= 0 or not obj or not obj.Parent or obj.Transparency >= 1 or obj:GetAttribute("IsCollected") then
		return false
	end

	local colorType = obj:GetAttribute("ColorType")
	if unlockedColors and colorType and not ColorData.isColorUnlocked(unlockedColors.Value, colorType) then
		return false
	end

	return (root.Position - obj.Position).Magnitude <= maxRange
end

local function getPriorityTarget(player, root, unlockedColors)
	local bestTarget = nil
	local bestSetAt = -math.huge
	local now = os.clock()
	for obj, health in pairs(objectHealth) do
		if obj:GetAttribute("PetPriorityOwnerUserId") == player.UserId
			and (tonumber(obj:GetAttribute("PetPriorityUntil")) or 0) > now
			and canPetAttackBreakable(player, obj, health, root, unlockedColors, PET_ATTACK_RANGE)
		then
			local setAt = tonumber(obj:GetAttribute("PetPrioritySetAt")) or 0
			if setAt > bestSetAt then
				bestTarget = obj
				bestSetAt = setAt
			end
		end
	end
	return bestTarget
end

RunService.Heartbeat:Connect(function()
	local now = tick()
	for _, player in ipairs(Players:GetPlayers()) do
		local char = player.Character
		if not char then continue end
		local root = char:FindFirstChild("HumanoidRootPart")
		if not root then continue end
		if (now - (lastAttack[player] or 0)) < PET_ATTACK_INTERVAL then continue end

		local petStats = getPlayerPetStats(player)
		if petStats.breakPower <= 1 then continue end

		local storage = player:FindFirstChild("ColorStorage")
		local unlockedColors = storage and storage:FindFirstChild("UnlockedColors")

		local nearest = getPriorityTarget(player, root, unlockedColors)
		local nearestDist = PET_ATTACK_RANGE
		if not nearest then
			for obj, health in pairs(objectHealth) do
				if canPetAttackBreakable(player, obj, health, root, unlockedColors, PET_ATTACK_RANGE) then
					local dist = (root.Position - obj.Position).Magnitude
					if dist < nearestDist then
						nearest = obj
						nearestDist = dist
					end
				end
			end
		end

		if nearest then
			lastAttack[player] = now
			local breakableType = nearest:GetAttribute("BreakableType")
			local colorType     = nearest:GetAttribute("ColorType")
			local colorData     = ColorData.Breakables[breakableType]

			objectHealth[nearest] = math.max(0, objectHealth[nearest] - petStats.breakPower)
			local healthPct = objectHealth[nearest] / (objectMaxHealth[nearest] or 1)

			local colorInfo = ColorData.Colors[colorType]
			if colorInfo and nearest and nearest.Parent then
				local baseColor = getStoredColor(nearest, colorType)
				nearest.Color = baseColor:Lerp(Color3.new(1, 1, 1), math.clamp((1 - healthPct) * 0.22, 0, 0.22))
			end

			petAtkEvent:FireClient(player, playerEquipped[player], nearest, colorType)

			if objectHealth[nearest] <= 0 and colorData then
				local baseReward = getBaseBreakableReward(nearest, colorData)
				local areaMult = tonumber(nearest:GetAttribute("RewardMultiplier")) or 1
				local reward = math.max(1, math.floor(
					baseReward
					* areaMult
					* petStats.colorMult
					* getInstantCoinMultiplier(player, colorType, petStats)
				))
				petBreakRewardEvent:FireClient(player, {
					Amount = reward,
					ColorType = colorType,
					Position = nearest.Position,
				})
				awardCoins(player, reward)

				nearest:SetAttribute("IsCollected", true)
				nearest:SetAttribute("Respawning", true)
				nearest:SetAttribute("PetPriorityOwnerUserId", nil)
				nearest:SetAttribute("PetPriorityUntil", nil)
				nearest:SetAttribute("PetPrioritySetAt", nil)
				nearest.Transparency = 1
				nearest.CanCollide   = false
				objectHealth[nearest] = 0

				task.delay(5, function()
					if nearest and nearest.Parent then
						local data = ColorData.Breakables[nearest:GetAttribute("BreakableType")]
						if data then
							local ci = ColorData.Colors[nearest:GetAttribute("ColorType")]
							local respawnColorType = nearest:GetAttribute("ColorType")
							if ci then nearest.Color = getStoredColor(nearest, respawnColorType) end
							objectHealth[nearest]    = data.health
							objectMaxHealth[nearest] = data.health
							nearest.Transparency     = 0
							nearest.CanCollide       = false
							nearest:SetAttribute("IsCollected", false)
							nearest:SetAttribute("Respawning", false)
							nearest:SetAttribute("PetPriorityOwnerUserId", nil)
							nearest:SetAttribute("PetPriorityUntil", nil)
							nearest:SetAttribute("PetPrioritySetAt", nil)
						end
					end
				end)
			end
		end
	end
end)

return {
	getPlayerPetStats = getPlayerPetStats,
	AddColorToInventory = grantPetToPlayer,
}
]]></string>
