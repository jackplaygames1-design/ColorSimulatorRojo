    <Item class="ModuleScript" referent="3">
      <Properties>
        <string name="Name">ClientUIRoot</string>
        <string name="Source"><![CDATA[-- Single client UI root and legacy UI cleanup for Color Simulator.
local ClientUIRoot = {}

local UI_SCREEN_NAME = "ColorSimulatorUI"
local UI_VERSION = "PublicBeta_UI_SINGLE_SOURCE_v2"
local CLIENT_VERSION = "PublicBeta_Stability_2026_05_05"

local rootByPlayerGui = setmetatable({}, { __mode = "k" })
local watchedPlayerGuis = setmetatable({}, { __mode = "k" })
local printedClientVersion = false
local warnedLegacy = {}

local LEGACY_SCREEN_GUI_NAMES = {
	MainMenu = true,
	MenuUI = true,
	MenuGui = true,
	MainGui = true,
	HudGui = true,
	OldHudUI = true,
	OldMenuUI = true,
	OldMenuGui = true,
	Inventory = true,
	InventoryUI = true,
	InventoryGui = true,
	OldInventory = true,
	OldInventoryUI = true,
	MainInventory = true,
	MainInventoryUI = true,
	GamepassGui = true,
	PetInventoryUI = true,
	LegacyPetInventoryUI_DISABLED = true,
	EquipmentShopUI = true,
	SocialPanelUI = true,
	SocialPanelsUI = true,
}

local function warnLegacyOnce(name)
	if warnedLegacy[name] then
		return
	end
	warnedLegacy[name] = true
	warn("WARNING: Legacy UI source attempted to load")
	warn("Legacy UI source disabled: " .. name)
end

local function cleanupLegacyRoots(playerGui)
	for _, child in ipairs(playerGui:GetChildren()) do
		if child:IsA("ScreenGui") and child.Name ~= UI_SCREEN_NAME then
			if child:GetAttribute("LegacyUI") == true or LEGACY_SCREEN_GUI_NAMES[child.Name] then
				warnLegacyOnce(child.Name)
				child:Destroy()
			end
		end
	end
end

local function getCurrentRoot(playerGui)
	local currentRoot = nil
	for _, child in ipairs(playerGui:GetChildren()) do
		if child:IsA("ScreenGui") and child.Name == UI_SCREEN_NAME then
			local isCurrent = child:GetAttribute("UIScreenVersion") == UI_VERSION
			if not currentRoot and isCurrent then
				currentRoot = child
			elseif not currentRoot and child:GetAttribute("CurrentColorSimulatorUI") == true then
				currentRoot = child
			else
				warnLegacyOnce(child.Name)
				child:Destroy()
			end
		end
	end

	if currentRoot and currentRoot:GetAttribute("UIScreenVersion") ~= UI_VERSION then
		warnLegacyOnce(currentRoot.Name)
		currentRoot:Destroy()
		return nil
	end

	return currentRoot
end

function ClientUIRoot.GetRoot(playerGui)
	if not playerGui then
		return nil
	end

	cleanupLegacyRoots(playerGui)
	if not watchedPlayerGuis[playerGui] then
		watchedPlayerGuis[playerGui] = true
		playerGui.ChildAdded:Connect(function(child)
			if child:IsA("ScreenGui") then
				task.defer(function()
					if child.Parent ~= playerGui then
						return
					end
					if child.Name ~= UI_SCREEN_NAME then
						if child:GetAttribute("LegacyUI") == true or LEGACY_SCREEN_GUI_NAMES[child.Name] then
							warnLegacyOnce(child.Name)
							child:Destroy()
						end
					elseif child:GetAttribute("UIScreenVersion") ~= UI_VERSION then
						warnLegacyOnce(child.Name)
						child:Destroy()
					end
				end)
			end
		end)
	end

	local root = rootByPlayerGui[playerGui]
	if root and root.Parent == playerGui then
		return root
	end

	root = getCurrentRoot(playerGui)
	if not root then
		local existing = playerGui:FindFirstChild(UI_SCREEN_NAME)
		if existing and not existing:IsA("ScreenGui") then
			warnLegacyOnce(existing.Name)
			existing:Destroy()
		end
	end

	if not root then
		root = Instance.new("ScreenGui")
		root.Name = UI_SCREEN_NAME
		root.ResetOnSpawn = false
		root.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
		root.IgnoreGuiInset = false
		root.DisplayOrder = 1
		root.Parent = playerGui
	end

	root:SetAttribute("CurrentColorSimulatorUI", true)
	root:SetAttribute("UIScreenVersion", UI_VERSION)
	playerGui:SetAttribute("CurrentColorSimulatorUI", true)
	playerGui:SetAttribute("UIScreenVersion", UI_VERSION)

	if not printedClientVersion then
		printedClientVersion = true
		print("Color Simulator Client Version: " .. CLIENT_VERSION)
		print("Color Simulator UI Loaded: " .. UI_VERSION)
	end

	rootByPlayerGui[playerGui] = root
	return root
end

function ClientUIRoot.GetLayer(playerGui, layerName)
	local root = ClientUIRoot.GetRoot(playerGui)
	if not root then
		return nil
	end

	local layer = root:FindFirstChild(layerName)
	if layer and not layer:IsA("Frame") then
		layer:Destroy()
		layer = nil
	end

	if not layer then
		layer = Instance.new("Frame")
		layer.Name = layerName
		layer.Size = UDim2.fromScale(1, 1)
		layer.BackgroundTransparency = 1
		layer.BorderSizePixel = 0
		layer.Active = false
		layer.Parent = root
	else
		for _, child in ipairs(layer:GetChildren()) do
			child:Destroy()
		end
	end

	layer:SetAttribute("UIScreenVersion", UI_VERSION)
	return layer
end

return ClientUIRoot
]]></string>
      </Properties>
    </Item>
    <Item class="ModuleScript" referent="4">
      <Properties>
        <string name="Name">CodeData</string>
        <string name="Source"><![CDATA[-- Add weekly redeem codes here. Codes are matched case-insensitively by CodeHandler.
local CodeData = {}

CodeData.Codes = {
	RELEASE = {
		Code = "RELEASE",
		Active = true,
		MaxUsesPerPlayer = 1,
		Message = "Release reward claimed!",
		Rewards = {
			{ Type = "Coins", Amount = 1000 },
		},
	},
	COLOR = {
		Code = "COLOR",
		Active = true,
		MaxUsesPerPlayer = 1,
		Message = "Color boost claimed!",
		Rewards = {
			{ Type = "Color", Amount = 250 },
		},
	},
	PET = {
		Code = "PET",
		Active = true,
		MaxUsesPerPlayer = 1,
		Message = "Starter Color claimed!",
		Rewards = {
			{ Type = "Pet", PetId = "RedBlob", Amount = 5 },
		},
	},
}

function CodeData.normalize(code)
	return string.upper((tostring(code or ""):gsub("%s+", "")))
end

function CodeData.getCode(code)
	return CodeData.Codes[CodeData.normalize(code)]
end

return CodeData
]]></string>
      </Properties>
    </Item>
    <Item class="ModuleScript" referent="5">
