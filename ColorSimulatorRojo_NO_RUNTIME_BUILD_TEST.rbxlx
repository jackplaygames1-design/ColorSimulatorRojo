        <Item class="LocalScript" referent="89">
          <Properties>
            <string name="Name">HudUI</string>
            <string name="Source"><![CDATA[-- LocalScript in StarterPlayerScripts named "HudUI"
local Players           = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local TweenService      = game:GetService("TweenService")
local RunService        = game:GetService("RunService")

local player = Players.LocalPlayer
local UIManager = require(ReplicatedStorage:WaitForChild("UIManager"))
local ClientUIRoot = require(ReplicatedStorage:WaitForChild("ClientUIRoot"))
local ColorData = require(ReplicatedStorage:WaitForChild("ColorData"))
local HUDAssetConfig = require(ReplicatedStorage:WaitForChild("HUDAssetConfig"))

local Events = ReplicatedStorage:WaitForChild("Events")
local travelEvent = Events:WaitForChild("TravelToWorldSpot")
local openInventoryBindable = ReplicatedStorage:FindFirstChild("HudOpenInventory")
if not openInventoryBindable then
	openInventoryBindable = Instance.new("BindableEvent")
	openInventoryBindable.Name = "HudOpenInventory"
	openInventoryBindable.Parent = ReplicatedStorage
end
local hatchFocusActive = ReplicatedStorage:FindFirstChild("HatchFocusActive")
if not hatchFocusActive then
	hatchFocusActive = Instance.new("BoolValue")
	hatchFocusActive.Name = "HatchFocusActive"
	hatchFocusActive.Parent = ReplicatedStorage
end
local autoHatchActive = ReplicatedStorage:FindFirstChild("AutoHatchActive")
if not autoHatchActive then
	autoHatchActive = Instance.new("BoolValue")
	autoHatchActive.Name = "AutoHatchActive"
	autoHatchActive.Parent = ReplicatedStorage
end
local UITheme = require(ReplicatedStorage:WaitForChild("UITheme"))

local colorStorage = player:WaitForChild("ColorStorage")
local unlockedColors = colorStorage:WaitForChild("UnlockedColors")

local UI_VERSION = "PublicBeta_UI_SINGLE_SOURCE_v2"
local HUD_VERSION = "CleanCompactHUD_v2"

local UI_DARK = Color3.fromRGB(35, 38, 45)
local UI_WHITE = Color3.fromRGB(255, 255, 255)
local UI_CYAN = Color3.fromRGB(118, 238, 244)
local UI_PINK = Color3.fromRGB(255, 24, 96)
local UI_LIME = Color3.fromRGB(116, 245, 42)
local UI_YELLOW = Color3.fromRGB(255, 235, 105)
local UI_LAVENDER = Color3.fromRGB(226, 222, 255)
local warnedMissingAssets = {}
local warnedFallbackHudAssets = false

local function getHudImageId(key)
	local imageId = HUDAssetConfig
		and HUDAssetConfig.Images
		and HUDAssetConfig.Images[key]
	if type(imageId) == "string" and imageId ~= "" then
		return imageId
	end
	if not warnedMissingAssets[key] then
		warnedMissingAssets[key] = true
	end
	if not warnedFallbackHudAssets then
		warnedFallbackHudAssets = true
		warn("CleanCompactHUD: missing HUD asset ids, using frame fallback.")
	end
	return nil
end

local function applyHudImage(imageObject, key)
	local imageId = getHudImageId(key)
	if imageId then
		imageObject.Image = imageId
		return true
	end
	return false
end

local function formatCompact(value)
	value = tonumber(value) or 0
	if value >= 1000000000 then
		return string.format("%.1fB", value / 1000000000):gsub("%.0", "")
	elseif value >= 1000000 then
		return string.format("%.1fM", value / 1000000):gsub("%.0", "")
	elseif value >= 1000 then
		return string.format("%.1fK", value / 1000):gsub("%.0", "")
	end
	return tostring(value)
end

local function addRounded(parent, size, position, color, zIndex, radius, strokeThickness, rotation)
	local frame = Instance.new("Frame")
	frame.Size = size
	frame.Position = position
	frame.BackgroundColor3 = color
	frame.BorderSizePixel = 0
	frame.ZIndex = zIndex
	frame.Active = false
	frame.Rotation = rotation or 0
	frame.Parent = parent

	local corner = Instance.new("UICorner")
	corner.CornerRadius = radius or UDim.new(0, 6)
	corner.Parent = frame

	if strokeThickness and strokeThickness > 0 then
		local stroke = Instance.new("UIStroke")
		stroke.Color = UI_DARK
		stroke.Thickness = strokeThickness
		stroke.Parent = frame
	end

	return frame
end

local function addIconText(parent, text, size, position, textSize, zIndex)
	local label = Instance.new("TextLabel")
	label.Size = size
	label.Position = position
	label.BackgroundTransparency = 1
	label.Font = Enum.Font.LuckiestGuy
	label.TextSize = textSize
	label.TextColor3 = UI_WHITE
	label.TextStrokeTransparency = 0
	label.TextStrokeColor3 = UI_DARK
	label.Text = text
	label.ZIndex = zIndex
	label.Active = false
	label.Parent = parent
	return label
end

local function createMenuIcon(parent, iconName, zIndex, scale)
	scale = scale or 1
	local base = 54 * scale
	local holder = Instance.new("Frame")
	holder.Name = "Icon"
	holder.Size = UDim2.new(0, base, 0, base)
	holder.Position = UDim2.new(0.5, -base / 2, 0, 0)
	holder.BackgroundTransparency = 1
	holder.ZIndex = zIndex
	holder.Active = false
	holder.Parent = parent

	local function px(x)
		return math.floor(x * scale + 0.5)
	end

	local white = UI_WHITE

	if iconName == "bag" then
		addRounded(holder, UDim2.new(0, px(24), 0, px(18)), UDim2.new(0, px(15), 0, px(10)), white, zIndex, UDim.new(0, px(8)), px(3))
		addRounded(holder, UDim2.new(0, px(34), 0, px(27)), UDim2.new(0, px(10), 0, px(20)), white, zIndex + 1, UDim.new(0, px(7)), px(3))
		addRounded(holder, UDim2.new(0, px(6), 0, px(6)), UDim2.new(0, px(17), 0, px(27)), UI_DARK, zIndex + 2, UDim.new(1, 0), 0)
		addRounded(holder, UDim2.new(0, px(6), 0, px(6)), UDim2.new(0, px(31), 0, px(27)), UI_DARK, zIndex + 2, UDim.new(1, 0), 0)
	elseif iconName == "paw" then
		addRounded(holder, UDim2.new(0, px(20), 0, px(18)), UDim2.new(0, px(17), 0, px(27)), white, zIndex, UDim.new(1, 0), px(3))
		addRounded(holder, UDim2.new(0, px(10), 0, px(10)), UDim2.new(0, px(9), 0, px(19)), white, zIndex, UDim.new(1, 0), px(3))
		addRounded(holder, UDim2.new(0, px(10), 0, px(10)), UDim2.new(0, px(21), 0, px(13)), white, zIndex, UDim.new(1, 0), px(3))
		addRounded(holder, UDim2.new(0, px(10), 0, px(10)), UDim2.new(0, px(34), 0, px(19)), white, zIndex, UDim.new(1, 0), px(3))
		addRounded(holder, UDim2.new(0, px(8), 0, px(8)), UDim2.new(0, px(27), 0, px(24)), white, zIndex, UDim.new(1, 0), px(3))
	elseif iconName == "trade" then
		addRounded(holder, UDim2.new(0, px(29), 0, px(7)), UDim2.new(0, px(8), 0, px(18)), white, zIndex, UDim.new(0, px(4)), px(2))
		addIconText(holder, ">", UDim2.new(0, px(18), 0, px(20)), UDim2.new(0, px(33), 0, px(9)), px(22), zIndex + 1)
		addRounded(holder, UDim2.new(0, px(29), 0, px(7)), UDim2.new(0, px(17), 0, px(31)), white, zIndex, UDim.new(0, px(4)), px(2))
		addIconText(holder, "<", UDim2.new(0, px(18), 0, px(20)), UDim2.new(0, px(3), 0, px(22)), px(22), zIndex + 1)
	elseif iconName == "settings" then
		for i = 0, 5 do
			addRounded(holder, UDim2.new(0, px(8), 0, px(28)), UDim2.new(0, px(23), 0, px(13)), white, zIndex, UDim.new(0, px(4)), px(2), i * 30)
		end
		addRounded(holder, UDim2.new(0, px(26), 0, px(26)), UDim2.new(0, px(14), 0, px(14)), white, zIndex + 1, UDim.new(1, 0), px(3))
		addRounded(holder, UDim2.new(0, px(10), 0, px(10)), UDim2.new(0, px(22), 0, px(22)), Color3.fromRGB(229, 229, 247), zIndex + 2, UDim.new(1, 0), px(2))
	elseif iconName == "market" then
		addRounded(holder, UDim2.new(0, px(28), 0, px(28)), UDim2.new(0, px(13), 0, px(15)), white, zIndex, UDim.new(1, 0), px(3))
		addIconText(holder, "$", UDim2.new(0, px(54), 0, px(54)), UDim2.new(0, 0, 0, px(2)), px(32), zIndex + 1)
	elseif iconName == "egg" then
		addRounded(holder, UDim2.new(0, px(29), 0, px(38)), UDim2.new(0, px(13), 0, px(9)), white, zIndex, UDim.new(1, 0), px(3))
		addRounded(holder, UDim2.new(0, px(8), 0, px(8)), UDim2.new(0, px(22), 0, px(22)), Color3.fromRGB(255, 204, 116), zIndex + 1, UDim.new(1, 0), 0)
	elseif iconName == "upgrade" then
		addRounded(holder, UDim2.new(0, px(8), 0, px(34)), UDim2.new(0, px(23), 0, px(10)), white, zIndex, UDim.new(0, px(4)), px(2))
		addRounded(holder, UDim2.new(0, px(34), 0, px(8)), UDim2.new(0, px(10), 0, px(23)), white, zIndex, UDim.new(0, px(4)), px(2))
		addRounded(holder, UDim2.new(0, px(26), 0, px(8)), UDim2.new(0, px(14), 0, px(23)), white, zIndex + 1, UDim.new(0, px(4)), px(2), 45)
		addRounded(holder, UDim2.new(0, px(26), 0, px(8)), UDim2.new(0, px(14), 0, px(23)), white, zIndex + 1, UDim.new(0, px(4)), px(2), -45)
	elseif iconName == "sell" then
		addRounded(holder, UDim2.new(0, px(32), 0, px(32)), UDim2.new(0, px(11), 0, px(12)), white, zIndex, UDim.new(1, 0), px(3))
		addRounded(holder, UDim2.new(0, px(8), 0, px(24)), UDim2.new(0, px(23), 0, px(16)), UI_DARK, zIndex + 1, UDim.new(0, px(4)), 0)
		addRounded(holder, UDim2.new(0, px(24), 0, px(8)), UDim2.new(0, px(15), 0, px(24)), UI_DARK, zIndex + 1, UDim.new(0, px(4)), 0)
	elseif iconName == "shop" then
		addRounded(holder, UDim2.new(0, px(36), 0, px(24)), UDim2.new(0, px(9), 0, px(22)), white, zIndex, UDim.new(0, px(4)), px(3))
		for i = 0, 3 do
			addRounded(holder, UDim2.new(0, px(9), 0, px(12)), UDim2.new(0, px(9 + i * 9), 0, px(12)), i % 2 == 0 and white or Color3.fromRGB(147, 245, 235), zIndex + 1, UDim.new(0, px(3)), px(2))
		end
		addRounded(holder, UDim2.new(0, px(10), 0, px(14)), UDim2.new(0, px(22), 0, px(32)), Color3.fromRGB(147, 245, 235), zIndex + 1, UDim.new(0, px(3)), px(2))
	elseif iconName == "robux" then
		addRounded(holder, UDim2.new(0, px(30), 0, px(30)), UDim2.new(0, px(12), 0, px(13)), white, zIndex, UDim.new(0, px(5)), px(3), 45)
		addRounded(holder, UDim2.new(0, px(10), 0, px(10)), UDim2.new(0, px(22), 0, px(23)), Color3.fromRGB(255, 147, 213), zIndex + 1, UDim.new(0, px(3)), px(2), 45)
	elseif iconName == "codes" then
		addRounded(holder, UDim2.new(0, px(36), 0, px(26)), UDim2.new(0, px(9), 0, px(16)), white, zIndex, UDim.new(0, px(6)), px(3), -6)
		addIconText(holder, "#", UDim2.new(0, px(54), 0, px(54)), UDim2.new(0, 0, 0, px(1)), px(30), zIndex + 1)
	elseif iconName == "world" then
		addRounded(holder, UDim2.new(0, px(36), 0, px(36)), UDim2.new(0, px(9), 0, px(9)), white, zIndex, UDim.new(1, 0), px(3))
		addRounded(holder, UDim2.new(0, px(6), 0, px(34)), UDim2.new(0, px(24), 0, px(10)), Color3.fromRGB(145, 209, 255), zIndex + 1, UDim.new(1, 0), px(2))
		addRounded(holder, UDim2.new(0, px(28), 0, px(5)), UDim2.new(0, px(13), 0, px(24)), Color3.fromRGB(145, 209, 255), zIndex + 1, UDim.new(1, 0), px(2))
	end

	return holder
end

-- ========================
--   MAKE BINDABLE EVENTS
-- ========================
local function makeBE(name)
	local old = ReplicatedStorage:FindFirstChild(name)
	if old and old:IsA("BindableEvent") then
		return old
	elseif old then
		old:Destroy()
	end
	local be = Instance.new("BindableEvent")
	be.Name   = name
	be.Parent = ReplicatedStorage
	return be
end

local HudButton_PETS     = makeBE("HudButton_PETS")
local HudButton_SHOP     = makeBE("HudButton_SHOP")
local HudButton_WORLD    = makeBE("HudButton_WORLD")
local HudButton_GAMEPASS = makeBE("HudButton_GAMEPASS")
local HudButton_INVENTORY= makeBE("HudButton_INVENTORY")
local HudButton_UPGRADES = makeBE("HudButton_UPGRADES")
local HudButton_CODES = makeBE("HudButton_CODES")

-- ========================
--   UI LAYER
-- ========================
local hudCleanupWarnings = {}
local function warnHudCleanupOnce(message)
	if hudCleanupWarnings[message] then
		return
	end
	hudCleanupWarnings[message] = true
	warn(message)
end

local function countNamedDescendants(root, name)
	local count = 0
	for _, descendant in ipairs(root:GetDescendants()) do
		if descendant.Name == name then
			count += 1
		end
	end
	return count
end

local function hasLegacyHudElement(root)
	if root.Name == "CleanHudRoot"
		or root.Name == "CleanMinimalHUD"
		or root.Name == "LeftHudContainer"
		or root.Name == "CenterMenuButton"
		or root.Name == "NextWorldProgressContainer"
		or root.Name == "ColorBar"
		or root.Name == "ColorBarContainer"
		or root.Name == "ColorStorageBar"
		or root.Name == "StorageBar"
		or root.Name == "StorageFrame"
		or root.Name == "CurrencyContainer"
		or root.Name == "CoinPill"
		or root.Name == "GemPill"
	then
		return true
	end

	for _, descendant in ipairs(root:GetDescendants()) do
		if descendant.Name == "CleanHudRoot"
			or descendant.Name == "CleanMinimalHUD"
			or descendant.Name == "LeftHudContainer"
			or descendant.Name == "CenterMenuButton"
			or descendant.Name == "NextWorldProgressContainer"
			or descendant.Name == "ColorBar"
			or descendant.Name == "ColorBarContainer"
			or descendant.Name == "ColorStorageBar"
			or descendant.Name == "StorageBar"
			or descendant.Name == "StorageFrame"
			or descendant.Name == "CurrencyContainer"
			or descendant.Name == "CoinPill"
			or descendant.Name == "GemPill"
		then
			return true
		end
	end
	return false
end

local function cleanupLegacyHudRoots(playerGui, currentRoot)
	for _, child in ipairs(playerGui:GetChildren()) do
		if child:IsA("ScreenGui") and child ~= currentRoot then
			if child:GetAttribute("LegacyUI") == true
				or child.Name == "HudGui"
				or child.Name == "HUDGui"
				or child.Name == "HudUI"
				or child.Name == "OldHudUI"
				or child.Name == "ObjectiveTrackerUI"
				or child.Name == "MenuGui"
				or child.Name == "OldMenuGui"
				or hasLegacyHudElement(child)
			then
				warnHudCleanupOnce("Legacy HUD blocked: " .. HUD_VERSION .. " is active")
				child:Destroy()
				warnHudCleanupOnce("HUD cleanup: removed legacy ScreenGui " .. child.Name)
			end
		end
	end
end

local function getExistingCurrentHud(root)
	local currentHud = nil
	for _, child in ipairs(root:GetChildren()) do
		if child:IsA("Frame") and child.Name == "HUD" then
			if child:GetAttribute("HUDVersion") == HUD_VERSION and not currentHud then
				currentHud = child
			else
				warnHudCleanupOnce("Legacy HUD blocked: " .. HUD_VERSION .. " is active")
				child:Destroy()
				warnHudCleanupOnce("HUD cleanup: removed duplicate HUD")
			end
		elseif child:IsA("Frame") and (child.Name == "HudUI" or child.Name == "ObjectiveTrackerUI") then
			child:Destroy()
			warnHudCleanupOnce("HUD cleanup: removed legacy " .. child.Name)
		elseif child:IsA("GuiObject") and hasLegacyHudElement(child) then
			child:Destroy()
			warnHudCleanupOnce("HUD cleanup: removed legacy HUD element " .. child.Name)
		end
	end
	return currentHud
end

local function makeHudContainer(parent, name)
	for _, child in ipairs(parent:GetChildren()) do
		if child.Name == name then
			child:Destroy()
			warnHudCleanupOnce("HUD cleanup: removed duplicate " .. name)
		end
	end

	local container = Instance.new("Frame")
	container.Name = name
	container.Size = UDim2.fromScale(1, 1)
	container.BackgroundTransparency = 1
	container.BorderSizePixel = 0
	container.Active = false
	container.Parent = parent
	return container
end

local function cleanupDuplicateNamedDescendants(root, name)
	local kept = nil
	for _, descendant in ipairs(root:GetDescendants()) do
		if descendant.Name == name then
			if not kept then
				kept = descendant
			else
				descendant:Destroy()
				warnHudCleanupOnce("HUD cleanup: removed duplicate " .. name)
			end
		end
	end
end

local function cleanupDuplicateHudElements(hud)
	cleanupDuplicateNamedDescendants(hud, "CleanHudRoot")
	cleanupDuplicateNamedDescendants(hud, "CleanMinimalHUD")
	cleanupDuplicateNamedDescendants(hud, "LeftHudContainer")
	cleanupDuplicateNamedDescendants(hud, "CenterMenuButton")
	cleanupDuplicateNamedDescendants(hud, "NextWorldProgressContainer")
	cleanupDuplicateNamedDescendants(hud, "ColorBarContainer")
	cleanupDuplicateNamedDescendants(hud, "CurrencyContainer")
	cleanupDuplicateNamedDescendants(hud, "QuickButtonsContainer")
	cleanupDuplicateNamedDescendants(hud, "ColorBar")
	cleanupDuplicateNamedDescendants(hud, "CoinPill")
	cleanupDuplicateNamedDescendants(hud, "GemPill")
end

local uiRoot = ClientUIRoot.GetRoot(player.PlayerGui)
cleanupLegacyHudRoots(player.PlayerGui, uiRoot)

local existingHud = getExistingCurrentHud(uiRoot)
if existingHud then
	cleanupDuplicateHudElements(existingHud)
	existingHud:SetAttribute("HUDStyleVersion", HUD_VERSION)
	if existingHud:GetAttribute("HUDLoadedPrinted") ~= true then
		existingHud:SetAttribute("HUDLoadedPrinted", true)
		print("HUD Loaded: " .. HUD_VERSION)
	end
	if existingHud:GetAttribute("HUDDebugPrinted") ~= true then
		existingHud:SetAttribute("HUDDebugPrinted", true)
		print(
			"HUD Debug: CleanCompactHUD roots = " .. countNamedDescendants(existingHud, "CleanCompactHUD")
		)
	end
	return
end

