        <Item class="LocalScript" referent="81">
          <Properties>
            <string name="Name">AdminAnnouncement</string>
            <string name="Source"><![CDATA[-- Simple display for moderator/admin announcements.
local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local TweenService = game:GetService("TweenService")

local player = Players.LocalPlayer
local ClientUIRoot = require(ReplicatedStorage:WaitForChild("ClientUIRoot"))

local gui = ClientUIRoot.GetLayer(player:WaitForChild("PlayerGui"), "AdminAnnouncementUI")

local label = Instance.new("TextLabel")
label.AnchorPoint = Vector2.new(0.5, 0)
label.Size = UDim2.new(0, 560, 0, 56)
label.Position = UDim2.new(0.5, 0, 0, 70)
label.BackgroundColor3 = Color3.fromRGB(35, 38, 45)
label.BackgroundTransparency = 0.1
label.BorderSizePixel = 0
label.Font = Enum.Font.LuckiestGuy
label.TextSize = 22
label.TextColor3 = Color3.fromRGB(255, 255, 255)
label.TextStrokeTransparency = 0
label.TextStrokeColor3 = Color3.fromRGB(20, 22, 28)
label.TextWrapped = true
label.Visible = false
label.ZIndex = 100
label.Parent = gui
Instance.new("UICorner", label).CornerRadius = UDim.new(0, 16)

local token = 0
local function show(message)
	if not message or message == "" then
		return
	end
	token += 1
	local myToken = token
	label.Text = message
	label.TextTransparency = 0
	label.TextStrokeTransparency = 0
	label.Visible = true
	task.delay(4, function()
		if myToken == token then
			local tween = TweenService:Create(label, TweenInfo.new(0.25), {
				TextTransparency = 1,
				TextStrokeTransparency = 1,
			})
			tween:Play()
			tween.Completed:Wait()
			if myToken == token then
				label.Visible = false
			end
		end
	end)
end

player:GetAttributeChangedSignal("AdminAnnouncement"):Connect(function()
	show(player:GetAttribute("AdminAnnouncement"))
end)
]]></string>
          </Properties>
        </Item>
        <Item class="LocalScript" referent="82">
          <Properties>
            <string name="Name">BuffToastUI</string>
            <string name="Source"><![CDATA[local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local TweenService = game:GetService("TweenService")
local Debris = game:GetService("Debris")

local player = Players.LocalPlayer
local ClientUIRoot = require(ReplicatedStorage:WaitForChild("ClientUIRoot"))

local events = ReplicatedStorage:WaitForChild("Events")
local noticeEvent = events:WaitForChild("WildBuffNotice")

local layer = ClientUIRoot.GetLayer(player.PlayerGui, "WildBuffToastUI")

local function showToast(message, color)
	local toast = Instance.new("TextLabel")
	toast.Name = "WildBuffToast"
	toast.AnchorPoint = Vector2.new(0.5, 1)
	toast.Size = UDim2.new(0, 260, 0, 44)
	toast.Position = UDim2.new(0.5, 0, 1, -210)
	toast.BackgroundColor3 = Color3.fromRGB(28, 32, 42)
	toast.BackgroundTransparency = 0.08
	toast.BorderSizePixel = 0
	toast.Font = Enum.Font.LuckiestGuy
	toast.TextSize = 20
	toast.TextColor3 = color or Color3.fromRGB(255, 255, 255)
	toast.TextStrokeTransparency = 0.22
	toast.TextStrokeColor3 = Color3.fromRGB(20, 22, 28)
	toast.Text = message
	toast.ZIndex = 120
	toast.Parent = layer

	local corner = Instance.new("UICorner")
	corner.CornerRadius = UDim.new(0, 14)
	corner.Parent = toast
	local stroke = Instance.new("UIStroke")
	stroke.Color = color or Color3.fromRGB(255, 255, 255)
	stroke.Thickness = 3
	stroke.Transparency = 0.2
	stroke.Parent = toast

	TweenService:Create(toast, TweenInfo.new(0.18, Enum.EasingStyle.Back), {
		Position = UDim2.new(0.5, 0, 1, -232),
	}):Play()
	task.delay(2.1, function()
		if toast.Parent then
			TweenService:Create(toast, TweenInfo.new(0.22), {
				BackgroundTransparency = 1,
				TextTransparency = 1,
				TextStrokeTransparency = 1,
			}):Play()
		end
	end)
	Debris:AddItem(toast, 2.45)
end

noticeEvent.OnClientEvent:Connect(function(payload)
	if type(payload) ~= "table" then
		return
	end

	if payload.type == "buff" then
		showToast(tostring(payload.name or "Wild Color") .. "! " .. tostring(math.floor(payload.duration or 0)) .. "s", payload.color)
	elseif payload.type == "gems" then
		showToast("+" .. tostring(payload.amount or 0) .. " Gems", Color3.fromRGB(90, 255, 120))
	end
end)

]]></string>
          </Properties>
