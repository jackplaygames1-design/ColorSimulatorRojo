end

-- ========================
--   MENU OPEN / CLOSE LOGIC
-- ========================
local PANEL_FULL_HEIGHT = MENU_PANEL_HEIGHT

local menuOpen = false
local function setMenuButtonDisabled(disabled)
	menuBtn.AutoButtonColor = not disabled
	menuBtn.BackgroundTransparency = disabled and 0.28 or 0
	menuBtn.Active = true
end

local function applyMenuLayer()
	menuPanel.ZIndex = 60
	for _, obj in ipairs(menuPanel:GetDescendants()) do
		if obj:IsA("GuiObject") and obj.ZIndex < 61 then
			obj.ZIndex = 61
		end
	end
	menuCloseBtn.ZIndex = 70
end

local function openMenu()
	menuOpen = true
	setMenuButtonDisabled(false)
	menuBackdrop.Visible = true
	menuBackdrop.BackgroundTransparency = 1
	menuPanelShadow.Visible = true
	menuPanel.Visible          = true
	menuPanel.ClipsDescendants = false
	menuPanel.Size             = UDim2.new(0, MENU_PANEL_WIDTH, 0, 0)
	menuPanel.Position         = UDim2.fromScale(0.5, 0.5)
	menuPanelShadow.Size       = UDim2.new(0, MENU_PANEL_WIDTH, 0, 0)
	menuPanelShadow.Position   = UDim2.new(0.5, 7, 0.5, 7)
	applyMenuLayer()

	TweenService:Create(menuBackdrop, TweenInfo.new(0.18), {
		BackgroundTransparency = 0.4
	}):Play()
	TweenService:Create(menuPanel, TweenInfo.new(0.3, Enum.EasingStyle.Back), {
		Size = UDim2.new(0, MENU_PANEL_WIDTH, 0, PANEL_FULL_HEIGHT)
	}):Play()
	TweenService:Create(menuPanelShadow, TweenInfo.new(0.3, Enum.EasingStyle.Back), {
		Size = UDim2.new(0, MENU_PANEL_WIDTH, 0, PANEL_FULL_HEIGHT),
		Position = UDim2.new(0.5, 7, 0.5, 7),
	}):Play()

	TweenService:Create(menuBtn, TweenInfo.new(0.15), {
		BackgroundColor3 = UI_CYAN
	}):Play()
end

local function closeMenu(instant)
	menuOpen = false
	menuPanel.ClipsDescendants = true
	if instant then
		menuPanel.Visible = false
		menuPanelShadow.Visible = false
		menuBackdrop.Visible = false
		menuBackdrop.BackgroundTransparency = 1
		menuPanel.Size = UDim2.new(0, MENU_PANEL_WIDTH, 0, 0)
		menuPanelShadow.Size = UDim2.new(0, MENU_PANEL_WIDTH, 0, 0)
		menuBtn.BackgroundColor3 = UI_WHITE
		return
	end
	TweenService:Create(menuBackdrop, TweenInfo.new(0.18), {
		BackgroundTransparency = 1
	}):Play()
	TweenService:Create(menuPanel, TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {
		Size = UDim2.new(0, MENU_PANEL_WIDTH, 0, 0)
	}):Play()
	TweenService:Create(menuPanelShadow, TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {
		Size = UDim2.new(0, MENU_PANEL_WIDTH, 0, 0)
	}):Play()
	task.delay(0.2, function()
		if not menuOpen then
			menuPanel.Visible = false
			menuPanelShadow.Visible = false
			menuBackdrop.Visible = false
		end
	end)
	TweenService:Create(menuBtn, TweenInfo.new(0.15), {
		BackgroundColor3 = UI_WHITE
	}):Play()
end

UIManager.register("Menu", openMenu, function() closeMenu(true) end, function() return menuOpen end)

-- Menu button click
menuBtn.MouseButton1Down:Connect(function()
	local size, position = getMenuTargetLayout(-10)
	TweenService:Create(menuBtn, TweenInfo.new(0.08), {
		Size     = size,
		Position = position,
	}):Play()
end)

menuBtn.MouseButton1Up:Connect(function()
	local size, position = getMenuTargetLayout(0)
	TweenService:Create(menuBtn, TweenInfo.new(0.2, Enum.EasingStyle.Back), {
		Size     = size,
		Position = position,
	}):Play()
end)

menuBtn.Activated:Connect(function()
	if menuOpen then
		UIManager.close("Menu")
	else
		UIManager.open("Menu")
	end
end)

menuBtn.MouseEnter:Connect(function()
	local size, position = getMenuTargetLayout(8)
	TweenService:Create(menuBtn, TweenInfo.new(0.15, Enum.EasingStyle.Back), {
		Size     = size,
		Position = position,
	}):Play()
end)
menuBtn.MouseLeave:Connect(function()
	local size, position = getMenuTargetLayout(0)
	TweenService:Create(menuBtn, TweenInfo.new(0.15), {
		Size     = size,
		Position = position,
	}):Play()
end)

menuCloseBtn.MouseButton1Down:Connect(function()
	TweenService:Create(menuCloseBtn, TweenInfo.new(0.08), {
		Size = UDim2.new(0, 40, 0, 40),
		Position = UDim2.new(1, -56, 0.5, -20),
		BackgroundColor3 = Color3.fromRGB(224, 68, 96),
	}):Play()
end)

menuCloseBtn.MouseButton1Up:Connect(function()
