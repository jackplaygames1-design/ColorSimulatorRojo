end)

-- ========================
--   ACTION BUTTON HOOKS
-- ========================
equipBestBtn.MouseButton1Click:Connect(function()
	local maxSlots = getMaxSlots()
	local sorted = table.clone(allPets)
	table.sort(sorted, function(a, b)
		local aPower = a.effectivePower or a.finalPower or 0
		local bPower = b.effectivePower or b.finalPower or 0
		if aPower == bPower then
			return (a.stackAmount or 0) > (b.stackAmount or 0)
		end
		return aPower > bPower
	end)
	for _, id in ipairs(table.clone(equippedPets)) do
		equipEvent:FireServer("unequip", id)
		task.wait(0.05)
	end
	for i = 1, math.min(maxSlots, #sorted) do
		equipEvent:FireServer("equip", getEntryKey(sorted[i]))
		task.wait(0.05)
	end
end)

unequipAllBtn.MouseButton1Click:Connect(function()
	clearEquippedOnlyView()
	for _, id in ipairs(table.clone(equippedPets)) do
		equipEvent:FireServer("unequip", id)
		task.wait(0.05)
	end
end)

-- ========================
--   OPEN / CLOSE
-- ========================
function toggleInventory(open, context)
	isOpen = open
	if open then
		lastInventoryOpenedAt = os.clock()
		print("Opening NEW Inventory UI:", screenGui:GetFullName())
		if not printedInventoryVersion then
			printedInventoryVersion = true
			print("InventoryUI Loaded: " .. INVENTORY_VERSION)
		end
		screenGui:SetAttribute("InventoryVersion", INVENTORY_VERSION)
		if context ~= nil then
			openedFromMenu = context.from == "Menu"
		end
		if context and context.defaultTab and tabBtns[context.defaultTab] then
			currentTab = context.defaultTab
		elseif currentTab == "Colors" and #allPets == 0 and tabBtns.Brushes then
			currentTab = "Brushes"
		end
		backBtn.Visible = openedFromMenu
		titleL.Position = openedFromMenu and UDim2.new(0, 66, 0, 0) or UDim2.new(0, 22, 0, 0)
		titleL.Size = openedFromMenu and UDim2.new(1, -126, 1, 0) or UDim2.new(1, -60, 1, 0)
		overlay.Visible          = true
		panel.Visible            = true
		overlay.BackgroundTransparency = 1
		panel.Size     = UDim2.new(0,80,0,80)
		panel.Position = UDim2.fromScale(0.5, 0.5)
		TweenService:Create(overlay, TweenInfo.new(0.25), {
			BackgroundTransparency = 0.4
		}):Play()
		TweenService:Create(panel, TweenInfo.new(0.35, Enum.EasingStyle.Back), {
			Size     = UDim2.new(0, PANEL_WIDTH, 0, PANEL_HEIGHT),
			Position = UDim2.fromScale(0.5, 0.5),
		}):Play()
		setTab(currentTab)
	else
		openedFromMenu = false
		backBtn.Visible = false
		detailPanel.Visible = false
		selectedDetailEntry = nil
		if context and context.immediate then
			panel.Visible = false
			overlay.Visible = false
			overlay.BackgroundTransparency = 1
			return
		end
		TweenService:Create(overlay, TweenInfo.new(0.2), {
			BackgroundTransparency = 1
		}):Play()
		TweenService:Create(panel, TweenInfo.new(0.2, Enum.EasingStyle.Back, Enum.EasingDirection.In), {
			Size     = UDim2.new(0,60,0,60),
			Position = UDim2.fromScale(0.5, 0.5),
		}):Play()
		task.wait(0.2)
		panel.Visible   = false
		overlay.Visible = false
	end
end

backBtn.MouseButton1Click:Connect(function()
	if openedFromMenu then
		UIManager.open("Menu")
	end
end)

closeBtn.MouseButton1Click:Connect(function() UIManager.close("Inventory") end)
overlay.InputBegan:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 then
		if os.clock() - lastInventoryOpenedAt < 0.45 then
			return
		end
		UIManager.close("Inventory")
	end
end)

-- ========================
--   SERVER EVENTS
-- ========================
useEvent.OnClientEvent:Connect(function(resultType, arg1, arg2, extra)
	if resultType == "sync" then
		table.clear(playerItems)
		if type(arg1) == "table" then
			for itemId, quantity in pairs(arg1) do
				if quantity and quantity > 0 then
					playerItems[itemId] = quantity
				end
			end
		end
		if isOpen then refreshContent() end

	elseif resultType == "update" then
		setItemQuantity(arg1, arg2)
		if isOpen then refreshContent() end

	elseif resultType == "used" then
		setItemQuantity(arg1, arg2)
		showItemFeedback(true, (extra and extra.message) or "Item used!")
		if isOpen then refreshContent() end

	elseif resultType == "boosted" then
		setItemQuantity(arg1, arg2)
		if extra then
			local remaining = (extra.expiresAt or 0) - os.time()
			local mins = math.floor(remaining/60)
			local secs = remaining % 60
			local ts   = mins > 0 and (mins.."m "..secs.."s") or (secs.."s")
			local item = ItemsData.Items[arg1]
			showItemFeedback(true,
				(item and item.displayName or "Boost").." active for "..ts.."!",
				Color3.fromRGB(100,200,255)
			)
		end
		if isOpen then refreshContent() end

	elseif resultType == "boostExpired" then
		showItemFeedback(false,
			tostring(arg1):gsub("(%l)(%u)","%1 %2").." boost expired!",
			Color3.fromRGB(255,160,100)
		)

	elseif resultType == "error" then
		showItemFeedback(false, arg2 or "Something went wrong!")
	end
end)

petsLoadedEvent.OnClientEvent:Connect(function(inventory, equipped)
	applyPetState(inventory, equipped)
end)

if petInventoryValue then
	petInventoryValue:GetPropertyChangedSignal("Value"):Connect(refreshPetsFromReplicatedValues)
end
if petEquippedValue then
	petEquippedValue:GetPropertyChangedSignal("Value"):Connect(refreshPetsFromReplicatedValues)
end
task.defer(refreshPetsFromReplicatedValues)

-- ========================
--   HOOK INVENTORY BUTTON
-- ========================
UIManager.register("Inventory",
	function(context)
		toggleInventory(true, context)
	end,
	function(context) toggleInventory(false, context) end,
	function() return isOpen end
)

local function warnLegacyInventoryBlocked()
	if warnedLegacyInventoryOpen then
		return
	end
	warnedLegacyInventoryOpen = true
	warn("WARNING: Legacy inventory attempted to open; blocked.")
end

for _, legacyKey in ipairs({ "Pets", "PetInventory", "Bag", "Colors" }) do
	UIManager.register(legacyKey,
		function()
			warnLegacyInventoryBlocked()
			toggleInventory(true)
		end,
		function() toggleInventory(false) end,
		function() return isOpen end
	)
end

local _invBtn = ReplicatedStorage:WaitForChild("HudButton_INVENTORY", 10)
if _invBtn then
	_invBtn.Event:Connect(function()
		UIManager.toggle("Inventory")
	end)
end

-- Start
setTab("Colors")
if queuedInventoryOpen then
	task.defer(toggleInventory, true, queuedInventoryOpenContext)
elseif queuedInventoryClose then
	task.defer(toggleInventory, false, queuedInventoryCloseContext)
end
]]></string>
          </Properties>
        </Item>
        <Item class="LocalScript" referent="92">
          <Properties>
            <string name="Name">LiveLeaderboardUI</string>
            <string name="Source"><![CDATA[local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")

local localPlayer = Players.LocalPlayer
local ClientUIRoot = require(ReplicatedStorage:WaitForChild("ClientUIRoot"))

local DARK = Color3.fromRGB(35, 38, 45)
local PANEL = Color3.fromRGB(22, 14, 20)
local WHITE = Color3.fromRGB(255, 255, 255)
local MUTED = Color3.fromRGB(218, 210, 224)
local LINE = Color3.fromRGB(80, 56, 68)

local STAT_NAMES = { "Color", "Gems", "Coins" }
local COLUMN_WIDTHS = {
	Color = 58,
	Gems = 52,
	Coins = 58,
}
local PANEL_WIDTH = 320
local STATS_WIDTH = 168
local leaderboardHidden = true

local function formatCompact(value)
	value = tonumber(value) or 0
	if value >= 1000000000 then
		return string.format("%.1fB", value / 1000000000)
	elseif value >= 1000000 then
		return string.format("%.1fM", value / 1000000)
	elseif value >= 1000 then
		return string.format("%.1fK", value / 1000)
	end
	return tostring(value)
end

local function getStat(player, statName)
	local stats = player:FindFirstChild("leaderstats")
	return stats and stats:FindFirstChild(statName)
end

local function getStatValue(player, statName)
	local stat = getStat(player, statName)
	return stat and stat.Value or 0
end

local screenGui = ClientUIRoot.GetLayer(localPlayer:WaitForChild("PlayerGui"), "LiveLeaderboardUI")

local panel = Instance.new("Frame")
panel.Name = "Panel"
panel.AnchorPoint = Vector2.new(1, 0)
panel.Size = UDim2.new(0, PANEL_WIDTH, 0, 86)
panel.Position = UDim2.new(1, -18, 0, 132)
panel.BackgroundColor3 = PANEL
panel.BackgroundTransparency = 0.08
panel.BorderSizePixel = 0
panel.Parent = screenGui

local corner = Instance.new("UICorner")
corner.CornerRadius = UDim.new(0, 8)
corner.Parent = panel

local stroke = Instance.new("UIStroke")
stroke.Color = Color3.fromRGB(70, 38, 50)
stroke.Transparency = 0.45
stroke.Thickness = 1
stroke.Parent = panel

local toggleButton = Instance.new("TextButton")
toggleButton.Name = "ToggleButton"
toggleButton.AnchorPoint = Vector2.new(1, 0)
toggleButton.Size = UDim2.new(0, 62, 0, 34)
toggleButton.Position = UDim2.new(1, -18, 0, 92)
toggleButton.BackgroundColor3 = Color3.fromRGB(118, 238, 244)
toggleButton.AutoButtonColor = false
toggleButton.BorderSizePixel = 0
toggleButton.Font = Enum.Font.GothamBlack
toggleButton.TextSize = 13
toggleButton.TextColor3 = DARK
toggleButton.Text = "LB"
toggleButton.Parent = screenGui

local toggleCorner = Instance.new("UICorner")
toggleCorner.CornerRadius = UDim.new(0, 12)
toggleCorner.Parent = toggleButton

local toggleStroke = Instance.new("UIStroke")
toggleStroke.Color = DARK
toggleStroke.Thickness = 3
toggleStroke.Parent = toggleButton

local function applyLeaderboardVisibility()
	panel.Visible = not leaderboardHidden
	toggleButton.Text = leaderboardHidden and "LB" or "HIDE"
	toggleButton.BackgroundColor3 = leaderboardHidden and Color3.fromRGB(118, 238, 244) or Color3.fromRGB(255, 130, 150)
end

toggleButton.MouseButton1Click:Connect(function()
	leaderboardHidden = not leaderboardHidden
	applyLeaderboardVisibility()
end)

local header = Instance.new("Frame")
header.Name = "Header"
header.Size = UDim2.new(1, -20, 0, 28)
header.Position = UDim2.new(0, 10, 0, 6)
header.BackgroundTransparency = 1
header.Parent = panel

local peopleHeader = Instance.new("TextLabel")
peopleHeader.Size = UDim2.new(1, -270, 1, 0)
peopleHeader.BackgroundTransparency = 1
peopleHeader.Font = Enum.Font.GothamMedium
peopleHeader.TextSize = 12
peopleHeader.TextColor3 = MUTED
peopleHeader.TextXAlignment = Enum.TextXAlignment.Left
peopleHeader.Text = "Players"
peopleHeader.Parent = header

local x = 0
for _, statName in ipairs(STAT_NAMES) do
	local width = COLUMN_WIDTHS[statName]
	local label = Instance.new("TextLabel")
	label.Name = statName .. "Header"
	label.AnchorPoint = Vector2.new(1, 0)
	label.Size = UDim2.new(0, width, 1, 0)
	label.Position = UDim2.new(1, -x, 0, 0)
	label.BackgroundTransparency = 1
	label.Font = Enum.Font.GothamMedium
	label.TextSize = 12
	label.TextColor3 = MUTED
	label.TextXAlignment = Enum.TextXAlignment.Right
	label.Text = statName
		label.Parent = header
		x += width
end
peopleHeader.Size = UDim2.new(1, -STATS_WIDTH - 18, 1, 0)

local rows = Instance.new("Frame")
rows.Name = "Rows"
rows.Size = UDim2.new(1, 0, 1, -36)
rows.Position = UDim2.new(0, 0, 0, 36)
rows.BackgroundTransparency = 1
rows.Parent = panel

local layout = Instance.new("UIListLayout")
layout.FillDirection = Enum.FillDirection.Vertical
layout.SortOrder = Enum.SortOrder.LayoutOrder
layout.Parent = rows

local rowConnections = {}
local statConnections = {}

local function disconnectList(list)
	for _, connection in ipairs(list) do
		connection:Disconnect()
	end
	table.clear(list)
end

local function sortedPlayers()
	local list = Players:GetPlayers()
	table.sort(list, function(a, b)
		local aCoins = getStatValue(a, "Coins")
		local bCoins = getStatValue(b, "Coins")
		if aCoins == bCoins then
			return a.Name < b.Name
		end
		return aCoins > bCoins
	end)
	return list
end

local function makeValueLabel(parent, statName, index)
	local width = COLUMN_WIDTHS[statName]
	local offset = 0
	for i = 1, index - 1 do
		offset += COLUMN_WIDTHS[STAT_NAMES[i]]
	end

	local label = Instance.new("TextLabel")
	label.Name = statName
	label.AnchorPoint = Vector2.new(1, 0)
	label.Size = UDim2.new(0, width, 1, 0)
	label.Position = UDim2.new(1, -offset - 10, 0, 0)
	label.BackgroundTransparency = 1
	label.Font = Enum.Font.GothamBold
	label.TextSize = 14
	label.TextColor3 = WHITE
	label.TextXAlignment = Enum.TextXAlignment.Right
	label.Text = "0"
	label.Parent = parent
	return label
end

local function rebuild()
	for _, child in ipairs(rows:GetChildren()) do
		if child ~= layout then
			child:Destroy()
		end
	end

	for playerIndex, listedPlayer in ipairs(sortedPlayers()) do
		local row = Instance.new("Frame")
		row.Name = listedPlayer.Name
		row.Size = UDim2.new(1, 0, 0, 38)
		row.BackgroundColor3 = listedPlayer == localPlayer and Color3.fromRGB(58, 12, 18) or PANEL
		row.BackgroundTransparency = listedPlayer == localPlayer and 0.12 or 0.24
		row.BorderSizePixel = 0
		row.LayoutOrder = playerIndex
		row.Parent = rows

		local divider = Instance.new("Frame")
		divider.Name = "Divider"
		divider.Size = UDim2.new(1, 0, 0, 1)
		divider.Position = UDim2.new(0, 0, 1, -1)
		divider.BackgroundColor3 = LINE
		divider.BackgroundTransparency = 0.35
		divider.BorderSizePixel = 0
		divider.Parent = row

		local nameLabel = Instance.new("TextLabel")
		nameLabel.Name = "PlayerName"
	nameLabel.Size = UDim2.new(1, -STATS_WIDTH - 54, 1, 0)
		nameLabel.Position = UDim2.new(0, 36, 0, 0)
		nameLabel.BackgroundTransparency = 1
		nameLabel.Font = Enum.Font.GothamBold
		nameLabel.TextSize = 14
		nameLabel.TextColor3 = WHITE
		nameLabel.TextXAlignment = Enum.TextXAlignment.Left
		nameLabel.TextTruncate = Enum.TextTruncate.AtEnd
		nameLabel.Text = listedPlayer.DisplayName
		nameLabel.Parent = row

		local icon = Instance.new("TextLabel")
		icon.Name = "Icon"
		icon.Size = UDim2.new(0, 24, 1, 0)
		icon.Position = UDim2.new(0, 10, 0, 0)
		icon.BackgroundTransparency = 1
		icon.Font = Enum.Font.GothamBold
		icon.TextSize = 16
		icon.TextColor3 = listedPlayer == localPlayer and Color3.fromRGB(255, 220, 120) or MUTED
		icon.Text = listedPlayer == localPlayer and "*" or "-"
		icon.Parent = row

		for statIndex, statName in ipairs(STAT_NAMES) do
			local valueLabel = makeValueLabel(row, statName, statIndex)
			valueLabel.Text = formatCompact(getStatValue(listedPlayer, statName))
		end
	end

	local height = 36 + math.max(1, #Players:GetPlayers()) * 38
	panel.Size = UDim2.new(0, PANEL_WIDTH, 0, math.clamp(height, 74, 120))
end

local tutorialActive = ReplicatedStorage:FindFirstChild("TutorialWelcomeActive")
if not tutorialActive then
	tutorialActive = Instance.new("BoolValue")
	tutorialActive.Name = "TutorialWelcomeActive"
	tutorialActive.Value = false
	tutorialActive.Parent = ReplicatedStorage
end
local function refreshTutorialVisibility()
	screenGui.Visible = not tutorialActive.Value
	applyLeaderboardVisibility()
end
tutorialActive:GetPropertyChangedSignal("Value"):Connect(refreshTutorialVisibility)
refreshTutorialVisibility()

local scheduled = false
local function scheduleRebuild()
	if scheduled then
		return
	end
	scheduled = true
	task.defer(function()
		scheduled = false
		rebuild()
	end)
end

local function watchPlayer(listedPlayer)
	disconnectList(rowConnections[listedPlayer] or {})
	disconnectList(statConnections[listedPlayer] or {})
	rowConnections[listedPlayer] = {}
	statConnections[listedPlayer] = {}

	local function hookStats(stats)
		disconnectList(statConnections[listedPlayer])
		table.insert(statConnections[listedPlayer], stats.ChildAdded:Connect(scheduleRebuild))
		table.insert(statConnections[listedPlayer], stats.ChildRemoved:Connect(scheduleRebuild))
		for _, statName in ipairs(STAT_NAMES) do
			local value = stats:FindFirstChild(statName)
			if value and value:IsA("ValueBase") then
				table.insert(statConnections[listedPlayer], value:GetPropertyChangedSignal("Value"):Connect(scheduleRebuild))
			end
		end
		scheduleRebuild()
	end

	local stats = listedPlayer:FindFirstChild("leaderstats")
	if stats then
		hookStats(stats)
	end

	table.insert(rowConnections[listedPlayer], listedPlayer.ChildAdded:Connect(function(child)
		if child.Name == "leaderstats" then
			hookStats(child)
		end
	end))
	table.insert(rowConnections[listedPlayer], listedPlayer:GetPropertyChangedSignal("DisplayName"):Connect(scheduleRebuild))
end

Players.PlayerAdded:Connect(function(listedPlayer)
	watchPlayer(listedPlayer)
	scheduleRebuild()
end)

Players.PlayerRemoving:Connect(function(listedPlayer)
	disconnectList(rowConnections[listedPlayer] or {})
	disconnectList(statConnections[listedPlayer] or {})
	rowConnections[listedPlayer] = nil
	statConnections[listedPlayer] = nil
	scheduleRebuild()
end)

for _, listedPlayer in ipairs(Players:GetPlayers()) do
	watchPlayer(listedPlayer)
end
scheduleRebuild()
]]></string>
          </Properties>
        </Item>
        <Item class="LocalScript" referent="93">
          <Properties>
            <string name="Name">ObjectiveTracker</string>
            <string name="Source"><![CDATA[-- Minimal Red Area onboarding UI.
local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local TweenService = game:GetService("TweenService")

local player = Players.LocalPlayer
local ClientUIRoot = require(ReplicatedStorage:WaitForChild("ClientUIRoot"))
local UITheme = require(ReplicatedStorage:WaitForChild("UITheme"))

local objectiveFolder = player:WaitForChild("TutorialObjectives", 15)
if not objectiveFolder then
	return
end

local PATCH_GOAL = 6
local stats = player:WaitForChild("leaderstats", 15)
local coins = stats and stats:WaitForChild("Coins", 10)

local tutorialActive = ReplicatedStorage:FindFirstChild("TutorialWelcomeActive")
if not tutorialActive then
	tutorialActive = Instance.new("BoolValue")
	tutorialActive.Name = "TutorialWelcomeActive"
	tutorialActive.Value = false
	tutorialActive.Parent = ReplicatedStorage
end

local function getObjectiveContainer()
	local root = ClientUIRoot.GetRoot(player.PlayerGui)
	local hud = root and (root:FindFirstChild("HUD") or root:WaitForChild("HUD", 8))
	if not hud then
		local fallback = Instance.new("Frame")
		fallback.Name = "ObjectiveContainer"
		fallback.Visible = false
		fallback.Parent = root
		return fallback
	end

	for _, child in ipairs(hud:GetChildren()) do
		if child.Name == "ObjectiveContainer" then
			child:Destroy()
		end
	end

	local container = Instance.new("Frame")
	container.Name = "ObjectiveContainer"
	container.Size = UDim2.fromScale(1, 1)
	container.BackgroundTransparency = 1
	container.BorderSizePixel = 0
	container.Active = false
	container.Parent = hud
	return container
end

local screenGui = getObjectiveContainer()

local panel = Instance.new("Frame")
panel.Name = "RedTutorialPanel"
panel.AnchorPoint = Vector2.new(0.5, 0)
panel.Size = UDim2.new(0, 470, 0, 194)
panel.Position = UDim2.new(0.5, 0, 0, 70)
panel.BackgroundColor3 = Color3.fromRGB(255, 248, 239)
panel.BorderSizePixel = 0
panel.Visible = false
panel.ZIndex = 40
panel.Parent = screenGui
UITheme.ApplyResponsiveScale(panel, 470, 194, 0.72, 18)
UITheme.ApplyCorner(panel, UDim.new(0, 12))
UITheme.ApplyStroke(panel, Color3.fromRGB(35, 38, 45), 3)

local stepText = Instance.new("TextLabel")
stepText.Name = "StepText"
stepText.Size = UDim2.new(1, -24, 0, 20)
stepText.Position = UDim2.new(0, 12, 0, 10)
stepText.BackgroundTransparency = 1
stepText.Font = Enum.Font.GothamBlack
stepText.TextSize = 13
stepText.TextColor3 = Color3.fromRGB(92, 96, 112)
stepText.TextXAlignment = Enum.TextXAlignment.Left
stepText.Text = "STEP 1 / 4"
stepText.ZIndex = 41
stepText:SetAttribute("NoTextGlow", true)
stepText.Parent = panel

local objectiveText = Instance.new("TextLabel")
objectiveText.Name = "ObjectiveText"
objectiveText.Size = UDim2.new(1, -24, 0, 24)
objectiveText.Position = UDim2.new(0, 12, 0, 30)
objectiveText.BackgroundTransparency = 1
objectiveText.Font = Enum.Font.GothamBlack
objectiveText.TextSize = 18
objectiveText.TextColor3 = Color3.fromRGB(35, 38, 45)
objectiveText.TextXAlignment = Enum.TextXAlignment.Left
objectiveText.TextYAlignment = Enum.TextYAlignment.Center
objectiveText.Text = "Move around"
objectiveText.TextTruncate = Enum.TextTruncate.AtEnd
objectiveText.ZIndex = 41
objectiveText:SetAttribute("NoTextGlow", true)
objectiveText.Parent = panel

local instructionText = Instance.new("TextLabel")
instructionText.Name = "InstructionText"
instructionText.Size = UDim2.new(1, -24, 0, 42)
instructionText.Position = UDim2.new(0, 12, 0, 56)
instructionText.BackgroundTransparency = 1
instructionText.Font = Enum.Font.GothamMedium
instructionText.TextSize = 14
instructionText.TextColor3 = Color3.fromRGB(54, 58, 70)
instructionText.TextXAlignment = Enum.TextXAlignment.Left
instructionText.TextYAlignment = Enum.TextYAlignment.Top
instructionText.TextWrapped = true
instructionText.Text = "Use WASD or the joystick to walk around."
instructionText.ZIndex = 41
instructionText:SetAttribute("NoTextGlow", true)
instructionText.Parent = panel

local hintText = Instance.new("TextLabel")
hintText.Name = "HintText"
hintText.Size = UDim2.new(1, -24, 0, 28)
hintText.Position = UDim2.new(0, 12, 0, 98)
hintText.BackgroundTransparency = 1
hintText.Font = Enum.Font.GothamBold
hintText.TextSize = 12
hintText.TextColor3 = Color3.fromRGB(115, 74, 74)
hintText.TextXAlignment = Enum.TextXAlignment.Left
hintText.TextYAlignment = Enum.TextYAlignment.Top
hintText.TextWrapped = true
hintText.Text = ""
hintText.Visible = false
hintText.ZIndex = 41
hintText:SetAttribute("NoTextGlow", true)
hintText.Parent = panel

local barBack = Instance.new("Frame")
barBack.Name = "ProgressBack"
barBack.Size = UDim2.new(1, -24, 0, 12)
barBack.Position = UDim2.new(0, 12, 0, 126)
barBack.BackgroundColor3 = Color3.fromRGB(214, 218, 228)
barBack.BorderSizePixel = 0
barBack.ClipsDescendants = true
barBack.ZIndex = 41
barBack.Parent = panel
UITheme.ApplyCorner(barBack, UDim.new(0, 6))

local barFill = Instance.new("Frame")
barFill.Name = "ProgressFill"
barFill.Size = UDim2.fromScale(0, 1)
barFill.BackgroundColor3 = Color3.fromRGB(255, 76, 92)
barFill.BorderSizePixel = 0
barFill.ZIndex = 42
barFill.Parent = barBack
UITheme.ApplyCorner(barFill, UDim.new(0, 6))

local counterRow = Instance.new("Frame")
counterRow.Name = "CounterRow"
counterRow.Size = UDim2.new(1, -24, 0, 24)
counterRow.Position = UDim2.new(0, 12, 0, 144)
counterRow.BackgroundTransparency = 1
counterRow.ZIndex = 41
counterRow.Parent = panel

local rowLayout = Instance.new("UIListLayout")
rowLayout.FillDirection = Enum.FillDirection.Horizontal
rowLayout.HorizontalAlignment = Enum.HorizontalAlignment.Left
rowLayout.VerticalAlignment = Enum.VerticalAlignment.Center
rowLayout.Padding = UDim.new(0, 14)
rowLayout.Parent = counterRow

local function makeCounter(name)
	local label = Instance.new("TextLabel")
	label.Name = name
	label.Size = UDim2.new(0, 126, 1, 0)
	label.BackgroundTransparency = 1
	label.Font = Enum.Font.GothamBold
	label.TextSize = 12
	label.TextColor3 = Color3.fromRGB(76, 82, 98)
	label.TextXAlignment = Enum.TextXAlignment.Left
	label.Text = name .. ": 0"
	label.ZIndex = 41
	label:SetAttribute("NoTextGlow", true)
	label.Parent = counterRow
	return label
end

local progressCounter = makeCounter("Progress")
local patchCounter = makeCounter("PatchesLeft")
local coinCounter = makeCounter("Coins")

local startButton = Instance.new("TextButton")
startButton.Name = "StartPlayingButton"
startButton.AnchorPoint = Vector2.new(1, 1)
startButton.Size = UDim2.new(0, 148, 0, 32)
startButton.Position = UDim2.new(1, -12, 1, -12)
startButton.BackgroundColor3 = Color3.fromRGB(255, 76, 92)
startButton.BorderSizePixel = 0
startButton.Font = Enum.Font.GothamBlack
startButton.TextSize = 14
startButton.TextColor3 = Color3.fromRGB(255, 255, 255)
startButton.Text = "Start Playing"
startButton.Visible = false
startButton.ZIndex = 42
startButton:SetAttribute("NoTextGlow", true)
startButton.Parent = panel
UITheme.ApplyCorner(startButton, UDim.new(0, 8))
UITheme.ApplyStroke(startButton, Color3.fromRGB(35, 38, 45), 2)

local values = {
	TutorialCompleted = objectiveFolder:WaitForChild("TutorialCompleted", 10),
	Stage = objectiveFolder:WaitForChild("Stage", 10),
	StepIndex = objectiveFolder:WaitForChild("StepIndex", 10),
	StepCount = objectiveFolder:WaitForChild("StepCount", 10),
	ObjectiveText = objectiveFolder:WaitForChild("ObjectiveText", 10),
	InstructionText = objectiveFolder:WaitForChild("InstructionText", 10),
	HintText = objectiveFolder:WaitForChild("HintText", 10),
	ButtonText = objectiveFolder:WaitForChild("ButtonText", 10),
	Progress = objectiveFolder:WaitForChild("Progress", 10),
	ProgressGoal = objectiveFolder:WaitForChild("ProgressGoal", 10),
	RedColor = objectiveFolder:WaitForChild("RedColor", 10),
	PatchesCleared = objectiveFolder:WaitForChild("PatchesCleared", 10),
	LastRewardMessage = objectiveFolder:WaitForChild("LastRewardMessage", 10),
}

local sawActiveTutorial = false
local completionDismissed = false
local rewardToken = 0

local function getNumber(name, defaultValue)
	local value = values[name]
	return value and tonumber(value.Value) or defaultValue or 0
end

local function getText(name, defaultValue)
	local value = values[name]
	return value and tostring(value.Value) or defaultValue or ""
end

local function setVisible(visible)
	panel.Visible = visible
	screenGui.Visible = visible
	tutorialActive.Value = visible
end

local function setProgress(progress, goal)
	goal = math.max(tonumber(goal) or 1, 1)
	progress = math.clamp(tonumber(progress) or 0, 0, goal)
	local ratio = progress / goal
	TweenService:Create(barFill, TweenInfo.new(0.16, Enum.EasingStyle.Quad), {
		Size = UDim2.fromScale(ratio, 1),
	}):Play()
	progressCounter.Text = "Progress: " .. tostring(progress) .. " / " .. tostring(goal)
end

local function showCompletion()
	if completionDismissed then
		setVisible(false)
		return
	end

	stepText.Text = "STEP 4 / 4"
	objectiveText.Text = getText("ObjectiveText", "Tutorial complete")
	instructionText.Text = getText("InstructionText", "You cleaned your first color zone. Keep clearing patches to earn coins and unlock more areas.")
	hintText.Visible = false
	startButton.Text = getText("ButtonText", "Start Playing")
	startButton.Visible = true
	setProgress(1, 1)
	patchCounter.Text = "Patches Left: 0"
	coinCounter.Text = "Coins: " .. tostring(coins and coins.Value or 0)
	setVisible(true)
end

local function refresh()
	local completed = values.TutorialCompleted and values.TutorialCompleted.Value == true
	if completed then
		if completionDismissed then
			setVisible(false)
			return
		end
		if sawActiveTutorial then
			showCompletion()
		else
			setVisible(false)
		end
		return
	end

	sawActiveTutorial = true
	completionDismissed = false
	setVisible(true)

	local stepIndex = getNumber("StepIndex", 1)
	local stepCount = math.max(getNumber("StepCount", 4), 1)
	local progress = getNumber("Progress", 0)
	local goal = math.max(getNumber("ProgressGoal", 1), 1)

	stepText.Text = "STEP " .. tostring(stepIndex) .. " / " .. tostring(stepCount)
	objectiveText.Text = getText("ObjectiveText", "Move around")
	instructionText.Text = getText("InstructionText", "")
	local hint = getText("HintText", "")
	hintText.Text = hint
	hintText.Visible = hint ~= ""
	startButton.Visible = false
	setProgress(progress, goal)
	local patchesLeft = math.max(goal - progress, 0)
	if stepIndex == 3 then
		patchCounter.Text = "Patches Left: " .. tostring(patchesLeft)
	else
		patchCounter.Text = "Patches Left: " .. tostring(math.max(PATCH_GOAL - getNumber("PatchesCleared"), 0))
	end
	coinCounter.Text = "Coins: " .. tostring(coins and coins.Value or 0)
end

local function showReward(message)
	if not message or message == "" or values.TutorialCompleted and values.TutorialCompleted.Value == true then
		return
	end
	if getNumber("StepIndex", 1) == 3 then
		return
	end

	rewardToken += 1
	local token = rewardToken
	local previous = progressCounter.Text
	progressCounter.Text = message
	progressCounter.TextColor3 = Color3.fromRGB(35, 130, 55)
	task.delay(1.35, function()
		if token == rewardToken then
			progressCounter.TextColor3 = Color3.fromRGB(76, 82, 98)
			progressCounter.Text = previous
			refresh()
		end
	end)
end

for _, value in pairs(values) do
	if value then
		value:GetPropertyChangedSignal("Value"):Connect(function()
			if value == values.LastRewardMessage then
				refresh()
				showReward(value.Value)
				return
			end
			refresh()
		end)
	end
end

if coins then
	coins:GetPropertyChangedSignal("Value"):Connect(refresh)
end

startButton.Activated:Connect(function()
	completionDismissed = true
	setVisible(false)
end)

task.defer(refresh)
]]></string>
          </Properties>
        </Item>
        <Item class="LocalScript" referent="94">
          <Properties>
            <string name="Name">OwnerChatTag</string>
            <string name="Source"><![CDATA[-- Emergency-safe chat tag handler. Disabled by GameBalance.EnableChatTags for live stability.
local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local RunService = game:GetService("RunService")
local TextChatService = game:GetService("TextChatService")

local warned = false

local STUDIO_OWNER_NAMES = {
	jackdoesrb = true,
	jackp = true,
}

local function warnOnce(...)
	if warned then
		return
	end
	warned = true
	warn("ChatTags disabled due to setup error:", ...)
end

local function getChatTagsEnabled()
	local ok, gameBalance = pcall(function()
		return require(ReplicatedStorage:WaitForChild("GameBalance"))
	end)

	if not ok or type(gameBalance) ~= "table" then
		warnOnce(gameBalance)
		return false
	end

	return gameBalance.EnableChatTags == true
end

local function sanitizeChatPrefix(text)
	text = tostring(text or "")
	text = text:gsub("<[^>]*>", "")
	text = text:gsub("%[OWNER%]%s*", "")
	text = text:gsub("%[MOD%]%s*", "")
	text = text:gsub("%[VIP%]%s*", "")
	text = text:gsub("%[SUPPORTER%]%s*", "")
	return text:gsub("^%s+", "")
end

local function isOwner(userId, player)
	if game.CreatorType == Enum.CreatorType.User and userId == game.CreatorId then
		return true
	end

	if RunService:IsStudio() and player then
		local name = string.lower(player.Name)
		local displayName = string.lower(player.DisplayName)
		return STUDIO_OWNER_NAMES[name] == true or STUDIO_OWNER_NAMES[displayName] == true
	end

	return false
end

local function insertUnique(tags, seen, tag)
	if seen[tag] then
		return
	end
	seen[tag] = true
	table.insert(tags, tag)
end

local function buildPlainPrefix(message)
	local properties = Instance.new("TextChatMessageProperties")
	local source = message and message.TextSource
	if not source then
		properties.PrefixText = sanitizeChatPrefix(message and message.PrefixText)
		return properties
	end

	local speaker = Players:GetPlayerByUserId(source.UserId)
	if not speaker then
		properties.PrefixText = sanitizeChatPrefix(message.PrefixText)
		return properties
	end

	local tags = {}
	local seenTags = {}
	if isOwner(source.UserId, speaker) then
		insertUnique(tags, seenTags, "[OWNER]")
	end
	if speaker:GetAttribute("IsModerator") == true then
		insertUnique(tags, seenTags, "[MOD]")
	end
	if speaker:GetAttribute("IsVIP") == true then
		insertUnique(tags, seenTags, "[VIP]")
	end
	if speaker:GetAttribute("EarlySupporter") == true then
		insertUnique(tags, seenTags, "[SUPPORTER]")
	end

	local basePrefix = sanitizeChatPrefix(message.PrefixText)
	if basePrefix == "" then
		basePrefix = speaker.DisplayName
	end

	if #tags > 0 then
		properties.PrefixText = table.concat(tags, " ") .. " " .. basePrefix
	else
		properties.PrefixText = basePrefix
	end

	return properties
end

local ok, err = pcall(function()
	if not getChatTagsEnabled() then
		return
	end

	TextChatService.OnIncomingMessage = function(message)
		local success, properties = pcall(buildPlainPrefix, message)
		if success then
			return properties
		end

		warnOnce(properties)
		return Instance.new("TextChatMessageProperties")
	end
end)

if not ok then
	warnOnce(err)
end
]]></string>
          </Properties>
        </Item>
        <Item class="LocalScript" referent="95">
          <Properties>
            <string name="Name">PaintToolController</string>
            <string name="Source"><![CDATA[-- Client-side paint brush feel: Tool activation, sweep visuals, and candidate detection.
local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local UserInputService = game:GetService("UserInputService")
local TweenService = game:GetService("TweenService")
local SoundService = game:GetService("SoundService")
local Debris = game:GetService("Debris")

local player = Players.LocalPlayer
local playerGui = player:WaitForChild("PlayerGui")
local ClientUIRoot = require(ReplicatedStorage:WaitForChild("ClientUIRoot"))

local function loadToolData()
	local module = ReplicatedStorage:WaitForChild("ToolData", 3)
	if module then
		return require(module)
	end

	warn("PaintToolController: ToolData missing; using Starter Brush fallback config.")
	local fallback = {}
	fallback.Tools = {
		StarterBrush = {
			Id = "StarterBrush",
			DisplayName = "Starter Brush",
			Range = 9,
			Width = 7,
			Cooldown = 0.45,
			PowerMultiplier = 1,
			CollectPowerMultiplier = 1,
			SweepWidthMultiplier = 1,
			UseSpeedMultiplier = 1,
			PickupRadiusMultiplier = 1,
			VisualType = "Brush",
			MaxTargets = 8,
			MaxServerRange = 24,
		},
	}
	function fallback.get(toolId)
		return fallback.Tools[toolId or ""] or fallback.Tools.StarterBrush
	end
	function fallback.GetEffectiveStats(toolId)
		local tool = fallback.get(toolId)
		return {
			Id = tool.Id,
			CollectPowerMultiplier = tool.CollectPowerMultiplier or tool.PowerMultiplier or 1,
			SweepWidthMultiplier = tool.SweepWidthMultiplier or 1,
			UseSpeedMultiplier = tool.UseSpeedMultiplier or 1,
			PickupRadiusMultiplier = tool.PickupRadiusMultiplier or 1,
		}
	end
	return fallback
end

local ToolData = loadToolData()
local Events = ReplicatedStorage:WaitForChild("Events", 10)
if not Events then
	warn("Brush remote missing, using touch fallback.")
	return
end
local paintSweepEvent = Events:WaitForChild("PaintToolSweep", 10)
if not paintSweepEvent then
	warn("Brush remote missing, using touch fallback.")
	return
end

local sweepGui = ClientUIRoot.GetLayer(playerGui, "PaintToolFeedbackUI")

local activeTool
local localCooldownUntil = 0
local autoCollectUntil = 0
local brushEquipped = true
local equippedToolId = "StarterBrush"
local brushVisual
local brushMotor

local equipState = ReplicatedStorage:FindFirstChild("PaintToolEquippedState")
if not equipState then
	equipState = Instance.new("BoolValue")
	equipState.Name = "PaintToolEquippedState"
	equipState.Value = true
	equipState.Parent = ReplicatedStorage
end
brushEquipped = equipState.Value

local function getClientSetting(key, defaultValue)
	local value = player:GetAttribute("Setting" .. key)
	return type(value) == "boolean" and value or defaultValue
end

local equipChangedEvent = ReplicatedStorage:FindFirstChild("PaintToolEquipChanged")
if not equipChangedEvent then
	equipChangedEvent = Instance.new("BindableEvent")
	equipChangedEvent.Name = "PaintToolEquipChanged"
	equipChangedEvent.Parent = ReplicatedStorage
end

local function getToolConfig(tool)
	if not tool then
		return nil
	end
	return ToolData.get(tool:GetAttribute("PaintToolId"))
end

local function getToolEffectiveStats(toolConfig)
	if ToolData.GetEffectiveStats then
		return ToolData.GetEffectiveStats(toolConfig and toolConfig.Id or "StarterBrush")
	end

	return {
		CollectPowerMultiplier = toolConfig and (toolConfig.CollectPowerMultiplier or toolConfig.PowerMultiplier) or 1,
		SweepWidthMultiplier = toolConfig and toolConfig.SweepWidthMultiplier or 1,
		UseSpeedMultiplier = toolConfig and toolConfig.UseSpeedMultiplier or 1,
		PickupRadiusMultiplier = toolConfig and toolConfig.PickupRadiusMultiplier or 1,
	}
end

local function hasActiveWildBuff(buffId)
	local folder = player:FindFirstChild("WildBuffs")
	return folder and folder:FindFirstChild(buffId) ~= nil
end

local function getClientRange(toolConfig)
	local range = toolConfig.Range or 9
	local upgrades = player:FindFirstChild("Upgrades")
	local pickupRange = upgrades and upgrades:FindFirstChild("PickupRange")
	if pickupRange then
		range += math.max(0, pickupRange.Value - 8) * 0.35
	end
	local stats = getToolEffectiveStats(toolConfig)
	local buffMultiplier = hasActiveWildBuff("BrushFrenzy") and 1.25 or 1
	return math.min(range * (stats.PickupRadiusMultiplier or 1) * buffMultiplier, toolConfig.MaxServerRange or 24)
end

local function playSweepSound()
	-- Keep silent for now; invalid public sound assets create noisy client error reports.
end

local function makeVisualPart(name, size, color, material)
	local part = Instance.new("Part")
	part.Name = name
	part.Size = size
	part.Color = color
	part.Material = material or Enum.Material.SmoothPlastic
	part.Anchored = false
	part.CanCollide = false
	part.CanTouch = false
	part.CanQuery = false
	part.Massless = true
	part.CastShadow = false
	return part
end

local function weldVisual(root, part, cframe)
	part.CFrame = root.CFrame * cframe
	part.Parent = root.Parent

	local weld = Instance.new("WeldConstraint")
	weld.Part0 = root
	weld.Part1 = part
	weld.Parent = part
end

local function getHand(character)
	return character:FindFirstChild("RightHand")
		or character:FindFirstChild("Right Arm")
		or character:FindFirstChild("RightLowerArm")
end

local setToolPartsHidden

local function isPaintTool(tool)
	return tool and tool:IsA("Tool") and tool:GetAttribute("PaintToolId") ~= nil
end

local function relaxPaintToolArm()
	local character = player.Character
	local humanoid = character and character:FindFirstChildOfClass("Humanoid")
	if humanoid then
		humanoid:UnequipTools()
	end

	local backpack = player:FindFirstChildOfClass("Backpack")
	if not character or not backpack then
		return
	end

	for _, child in ipairs(character:GetChildren()) do
		if isPaintTool(child) then
			setToolPartsHidden(child, false)
			child.Parent = backpack
		end
	end
	activeTool = nil
end

local function destroyBrushVisual()
	if brushMotor then
		brushMotor:Destroy()
		brushMotor = nil
	end
	if brushVisual then
		brushVisual:Destroy()
		brushVisual = nil
	end
end

function setToolPartsHidden(tool, hidden)
	if not tool then
		return
	end

	for _, child in ipairs(tool:GetDescendants()) do
		if child:IsA("BasePart") then
			child.LocalTransparencyModifier = hidden and 1 or 0
		end
	end
end

local function ensureBrushVisual(character)
	if not brushEquipped then
		destroyBrushVisual()
		return
	end

	if brushVisual and brushVisual.Parent and brushMotor and brushMotor.Parent then
		return
	end

	local hand = getHand(character)
	if not hand then
		return
	end
	local toolConfig = ToolData.get(equippedToolId)

	if brushVisual then
		brushVisual:Destroy()
	end

	local model = Instance.new("Model")
	model.Name = tostring(toolConfig.Id or "StarterBrush") .. "Visual"

	local handle = makeVisualPart("VisualHandle", Vector3.new(0.22, 0.22, 0.22), toolConfig.HandleColor or Color3.fromRGB(255, 213, 125), Enum.Material.SmoothPlastic)
	handle.CFrame = hand.CFrame
	handle.Transparency = 1
	handle.Parent = model
	model.PrimaryPart = handle

	local shaftRotation = CFrame.Angles(math.rad(90), 0, 0)
	weldVisual(handle, makeVisualPart("VisualShaft", Vector3.new(0.22, 1.45, 0.22), toolConfig.HandleColor or Color3.fromRGB(255, 213, 125), Enum.Material.Wood), CFrame.new(0, 0, -0.72) * shaftRotation)
	weldVisual(handle, makeVisualPart("VisualGrip", Vector3.new(0.34, 0.42, 0.34), Color3.fromRGB(45, 48, 58)), CFrame.new(0, 0, -0.16) * shaftRotation)
	weldVisual(handle, makeVisualPart("VisualBand", Vector3.new(0.48, 0.22, 0.48), Color3.fromRGB(190, 220, 238), Enum.Material.Metal), CFrame.new(0, 0, -1.28) * shaftRotation)
	if toolConfig.VisualType == "Roller" then
		weldVisual(handle, makeVisualPart("VisualRollerArm", Vector3.new(0.25, 0.35, 0.9), Color3.fromRGB(190, 220, 238), Enum.Material.Metal), CFrame.new(0, 0, -1.52))
		weldVisual(handle, makeVisualPart("VisualRoller", Vector3.new(1.2, 0.5, 0.5), toolConfig.PaintColor or Color3.fromRGB(255, 92, 164), Enum.Material.Neon), CFrame.new(0, -0.28, -1.7))
	else
		weldVisual(handle, makeVisualPart("VisualHead", Vector3.new(0.78, 0.42, 0.34), toolConfig.HeadColor or Color3.fromRGB(110, 235, 245)), CFrame.new(0, 0, -1.52))
		weldVisual(handle, makeVisualPart("VisualPaint", Vector3.new(0.76, 0.16, 0.38), toolConfig.PaintColor or Color3.fromRGB(255, 92, 164), Enum.Material.Neon), CFrame.new(0, -0.24, -1.55))
	end

	model.Parent = character

	local motor = Instance.new("Motor6D")
	motor.Name = "StarterBrushVisualGrip"
	motor.Part0 = hand
	motor.Part1 = handle
	motor.C0 = CFrame.new(0.08, -0.08, -0.28) * CFrame.Angles(math.rad(-8), 0, math.rad(8))
	motor.C1 = CFrame.new()
	motor.Parent = hand

	brushVisual = model
	brushMotor = motor
end

local function setBrushEquipped(equipped)
	brushEquipped = equipped == true
	equipState.Value = brushEquipped

	local character = player.Character
	if brushEquipped and character then
		ensureBrushVisual(character)
	else
		destroyBrushVisual()
		relaxPaintToolArm()
	end
end

local function showFeedback(text, color)
	if not getClientSetting("Popups", true) and text ~= "STORAGE FULL" then
		return
	end
	local label = Instance.new("TextLabel")
	label.AnchorPoint = Vector2.new(0.5, 0.5)
	label.Size = UDim2.new(0, 280, 0, 42)
	label.Position = UDim2.new(0.5, 0, 0.56, 0)
	label.BackgroundTransparency = 1
	label.Font = Enum.Font.LuckiestGuy
	label.TextSize = 24
	label.TextColor3 = color
	label.TextStrokeTransparency = 0
	label.TextStrokeColor3 = Color3.fromRGB(35, 38, 45)
	label.Text = text
	label.ZIndex = 100
	label.Parent = sweepGui

	TweenService:Create(label, TweenInfo.new(0.5, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
		Position = label.Position - UDim2.new(0, 0, 0, 48),
		TextTransparency = 1,
		TextStrokeTransparency = 1,
	}):Play()
	Debris:AddItem(label, 0.6)
end

local function animateTool(tool)
	if brushMotor and brushMotor.Parent then
		local originalC0 = brushMotor.C0
		local outC0 = originalC0 * CFrame.Angles(math.rad(-28), 0, math.rad(36))
		local backC0 = originalC0 * CFrame.Angles(math.rad(16), 0, math.rad(-22))

		local first = TweenService:Create(brushMotor, TweenInfo.new(0.08, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
			C0 = outC0,
		})
		first:Play()
		first.Completed:Wait()
		local second = TweenService:Create(brushMotor, TweenInfo.new(0.13, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
			C0 = backC0,
		})
		second:Play()
		second.Completed:Wait()
		if brushMotor and brushMotor.Parent then
			TweenService:Create(brushMotor, TweenInfo.new(0.1, Enum.EasingStyle.Quad), {
				C0 = originalC0,
			}):Play()
		end
		return
	end

	if not tool then
		return
	end

	local originalGrip = tool.Grip
	local outGrip = originalGrip * CFrame.Angles(math.rad(-36), 0, math.rad(22))
	local backGrip = originalGrip * CFrame.Angles(math.rad(18), 0, math.rad(-18))

	local first = TweenService:Create(tool, TweenInfo.new(0.08, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
		Grip = outGrip,
	})
	first:Play()
	first.Completed:Wait()
	local second = TweenService:Create(tool, TweenInfo.new(0.13, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
		Grip = backGrip,
	})
	second:Play()
	second.Completed:Wait()
	if tool and tool.Parent then
		TweenService:Create(tool, TweenInfo.new(0.1, Enum.EasingStyle.Quad), {
			Grip = originalGrip,
		}):Play()
	end
end

local function showSweepArc(root, range, width)
	local look = root.CFrame.LookVector
	local center = root.Position + look * (range * 0.48) + Vector3.new(0, -2.35, 0)

	local arc = Instance.new("Part")
	arc.Name = "PaintSweepArc"
	arc.Size = Vector3.new(width, 0.12, range)
	arc.CFrame = CFrame.lookAt(center, center + look)
	arc.Color = Color3.fromRGB(120, 245, 255)
	arc.Material = Enum.Material.Neon
	arc.Transparency = 0.68
	arc.Anchored = true
	arc.CanCollide = false
	arc.CanTouch = false
	arc.CanQuery = false
	arc.CastShadow = false
	arc.Parent = workspace

	TweenService:Create(arc, TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
		Size = Vector3.new(width * 1.18, 0.12, range * 1.05),
		Transparency = 1,
	}):Play()
	Debris:AddItem(arc, 0.25)
end

local function findSweepCandidates(root, toolConfig)
	local range = getClientRange(toolConfig)
	local stats = getToolEffectiveStats(toolConfig)
	local width = (toolConfig.Width or 7) * (stats.SweepWidthMultiplier or 1)
	local look = root.CFrame.LookVector
	local center = root.Position + look * (range * 0.5)

	local params = OverlapParams.new()
	params.FilterType = Enum.RaycastFilterType.Exclude
	params.FilterDescendantsInstances = { player.Character }

	local found = {}
	local parts = workspace:GetPartBoundsInRadius(center, range, params)
	for _, part in ipairs(parts) do
		if part:IsA("BasePart")
			and (part:GetAttribute("BreakableType") or part:GetAttribute("GemDeposit"))
			and not part:GetAttribute("IsCollected")
			and part.Transparency < 1
		then
			local offset = part.Position - root.Position
			local distance = offset.Magnitude
			local forward = distance > 0 and offset.Unit:Dot(look) or 1
			local side = math.abs(offset:Cross(look).Magnitude)
			if distance <= range and forward > -0.15 and side <= width then
				table.insert(found, part)
			end
		end
	end

	table.sort(found, function(a, b)
		return (a.Position - root.Position).Magnitude < (b.Position - root.Position).Magnitude
	end)

	local capped = {}
	for i = 1, math.min(#found, toolConfig.MaxTargets or 8) do
		table.insert(capped, found[i])
	end

	return capped, range, width
end

local function findWalkoverCandidates(root, toolConfig)
	local stats = getToolEffectiveStats(toolConfig)
	local range = math.min(5.5 + math.max(0, getClientRange(toolConfig) - (toolConfig.Range or 9)) * 0.25, 8 * (stats.PickupRadiusMultiplier or 1))
	local params = OverlapParams.new()
	params.FilterType = Enum.RaycastFilterType.Exclude
	params.FilterDescendantsInstances = { player.Character }

	local found = {}
	for _, part in ipairs(workspace:GetPartBoundsInRadius(root.Position, range, params)) do
		if part:IsA("BasePart")
			and (part:GetAttribute("BreakableType") or part:GetAttribute("GemDeposit"))
			and not part:GetAttribute("IsCollected")
			and part.Transparency < 1
		then
			table.insert(found, part)
		end
	end

	table.sort(found, function(a, b)
		return (a.Position - root.Position).Magnitude < (b.Position - root.Position).Magnitude
	end)

	local capped = {}
	for i = 1, math.min(#found, 2) do
		table.insert(capped, found[i])
	end

	return capped
end

local function activateBrush(tool)
	if not brushEquipped then
		return
	end

	local toolConfig = ToolData.get(equippedToolId)

	local now = os.clock()
	if now < localCooldownUntil then
		return
	end
	local useSpeedMultiplier = math.max(tonumber(getToolEffectiveStats(toolConfig).UseSpeedMultiplier) or 1, 0.01)
	localCooldownUntil = now + ((toolConfig.Cooldown or 0.45) / useSpeedMultiplier)

	local character = player.Character
	local root = character and character:FindFirstChild("HumanoidRootPart")
	local humanoid = character and character:FindFirstChildOfClass("Humanoid")
	if not root or not humanoid or humanoid.Health <= 0 then
		return
	end
	ensureBrushVisual(character)

	local candidates, range, width = findSweepCandidates(root, toolConfig)
	showSweepArc(root, range, width)
	playSweepSound()
	task.spawn(animateTool, tool)
	paintSweepEvent:FireServer(toolConfig.Id, candidates, "sweep")
end

local function autoCollectBrush()
	if not brushEquipped then
		return
	end

	local toolConfig = ToolData.get(equippedToolId)
	local now = os.clock()
	if now < autoCollectUntil then
		return
	end
	autoCollectUntil = now + 0.85

	local character = player.Character
	local root = character and character:FindFirstChild("HumanoidRootPart")
	local humanoid = character and character:FindFirstChildOfClass("Humanoid")
	if not root or not humanoid or humanoid.Health <= 0 then
		return
	end

	ensureBrushVisual(character)
	local candidates = findWalkoverCandidates(root, toolConfig)
	if #candidates > 0 then
		paintSweepEvent:FireServer(toolConfig.Id, candidates, "walk")
	end
end

local function watchTool(tool)
	if not tool:IsA("Tool") or not tool:GetAttribute("PaintToolId") or tool:GetAttribute("PaintToolWatched") then
		return
	end
	tool:SetAttribute("PaintToolWatched", true)
	if not brushEquipped and tool.Parent == player.Character then
		task.defer(relaxPaintToolArm)
	end

	tool.Equipped:Connect(function()
		if not brushEquipped then
			task.defer(relaxPaintToolArm)
			return
		end
		activeTool = tool
		setToolPartsHidden(tool, true)
		if brushEquipped and player.Character then
			ensureBrushVisual(player.Character)
		end
	end)
	tool.Unequipped:Connect(function()
		setToolPartsHidden(tool, false)
		if activeTool == tool then
			activeTool = nil
		end
		if brushEquipped and player.Character then
			ensureBrushVisual(player.Character)
		end
	end)
	tool.Activated:Connect(function()
		activateBrush(tool)
	end)
end

local function scan(container)
	if not container then
		return
	end
	for _, child in ipairs(container:GetChildren()) do
		watchTool(child)
	end
	container.ChildAdded:Connect(watchTool)
end

local function setupCharacter(character)
	task.wait(0.25)
	if brushEquipped then
		ensureBrushVisual(character)
	else
		relaxPaintToolArm()
	end
	scan(character)
end

scan(player:WaitForChild("Backpack"))
player.CharacterAdded:Connect(function(character)
	brushVisual = nil
	brushMotor = nil
	setupCharacter(character)
end)
if player.Character then
	setupCharacter(player.Character)
end

UserInputService.InputBegan:Connect(function(input, gameProcessed)
	if gameProcessed then
		return
	end
	if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
		if brushEquipped and not activeTool then
			activateBrush(nil)
		end
	end
end)

equipChangedEvent.Event:Connect(setBrushEquipped)
equipState:GetPropertyChangedSignal("Value"):Connect(function()
	if equipState.Value ~= brushEquipped then
		setBrushEquipped(equipState.Value)
	end
end)

local function watchEquippedToolValue(value)
	equippedToolId = value and value.Value ~= "" and value.Value or "StarterBrush"
	destroyBrushVisual()
	if brushEquipped and player.Character then
		ensureBrushVisual(player.Character)
	end
	if value then
		value:GetPropertyChangedSignal("Value"):Connect(function()
			equippedToolId = value.Value ~= "" and value.Value or "StarterBrush"
			destroyBrushVisual()
			if brushEquipped and player.Character then
				ensureBrushVisual(player.Character)
			end
		end)
	end
end

local toolsFolder = player:WaitForChild("PaintTools", 10)
if toolsFolder then
	watchEquippedToolValue(toolsFolder:WaitForChild("Equipped", 10))
end

task.spawn(function()
	while true do
		task.wait(0.15)
		autoCollectBrush()
	end
end)

paintSweepEvent.OnClientEvent:Connect(function(result)
	if type(result) ~= "table" then
		return
	end

	if result.success then
		showFeedback("+" .. tostring(result.total or 0) .. " COINS", Color3.fromRGB(255, 220, 90))
	end
end)
]]></string>
          </Properties>
        </Item>
        <Item class="LocalScript" referent="96">
          <Properties>
            <string name="Name">PetClient</string>
            <string name="Source"><![CDATA[-- LocalScript in StarterPlayerScripts named "PetClient"
local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local RunService = game:GetService("RunService")
local TweenService = game:GetService("TweenService")

local player    = Players.LocalPlayer
local PetData   = require(ReplicatedStorage:WaitForChild("PetData"))
local ColorData = require(ReplicatedStorage:WaitForChild("ColorData"))
local ClientUIRoot = require(ReplicatedStorage:WaitForChild("ClientUIRoot"))
local Modules    = ReplicatedStorage:WaitForChild("Modules")
local PetModelUtil = require(Modules:WaitForChild("PetModelUtil"))
local PetTraits  = Modules:FindFirstChild("PetTraits") and require(Modules:FindFirstChild("PetTraits"))

local function getClientSetting(key, defaultValue)
	local value = player:GetAttribute("Setting" .. key)
	return type(value) == "boolean" and value or defaultValue
end

local TRAIT_RARITY_COLOR = {
	Common    = Color3.fromRGB(160, 210, 255),
	Uncommon  = Color3.fromRGB(120, 230, 150),
	Rare      = Color3.fromRGB(120, 220, 120),
	Epic      = Color3.fromRGB(200, 100, 255),
	Legendary = Color3.fromRGB(255, 200, 40),
}

local Events          = ReplicatedStorage:WaitForChild("Events")
local hatchEvent      = Events:WaitForChild("HatchEgg")
local petAtkEvent     = Events:WaitForChild("PetAttack")
local petsLoadedEvent = Events:WaitForChild("PetsLoaded")
local equipEvent      = Events:WaitForChild("EquipPet")
local mergeEvent      = Events:WaitForChild("MergePet")

-- Pastel theme
local PANEL_BG     = Color3.fromRGB(255, 248, 252)
local PANEL_STROKE = Color3.fromRGB(255, 180, 220)
local TITLE_BG     = Color3.fromRGB(180, 220, 255)
local TITLE_TEXT   = Color3.fromRGB(80, 60, 130)
local SUB_BG       = Color3.fromRGB(245, 235, 252)

local RARITY_COLOR = {
	Common    = Color3.fromRGB(160, 160, 160),
	Uncommon  = Color3.fromRGB(60,  180, 80),
	Rare      = Color3.fromRGB(80,  120, 255),
	Epic      = Color3.fromRGB(160, 60,  240),
	Legendary = Color3.fromRGB(220, 160, 0),
}

local TIER_COLOR = {
	Normal    = Color3.fromRGB(200, 200, 200),
	Gilded    = Color3.fromRGB(255, 200, 50),
	Royal     = Color3.fromRGB(180, 60,  255),
	Celestial = Color3.fromRGB(100, 220, 255),
}

local RARITY_FX = {
	Common = { rate = 3.0, size = 0.07, light = 0.08, dust = 1.2 },
	Uncommon = { rate = 4.0, size = 0.08, light = 0.1, dust = 1.6 },
	Rare = { rate = 5.0, size = 0.095, light = 0.13, dust = 2.1 },
	Epic = { rate = 6.5, size = 0.115, light = 0.16, dust = 2.8 },
	Legendary = { rate = 8.0, size = 0.14, light = 0.2, dust = 3.5 },
}

local TIER_FX_MULT = {
	Normal = 1,
	Gilded = 1.2,
	Royal = 1.45,
	Celestial = 1.75,
}

-- State
local spawnedPets  = {}  -- { { model, variantKey } }
local allPets      = {}  -- list of buildPetEntry results
local equippedPets = {}  -- list of variant keys
local lastPetStateAt = 0

local function getEntryKey(entry)
	if typeof(entry) == "table" then
		return entry.variantKey or entry.petId
	end
	return entry
end

local function getEntryPower(entry)
	return entry.effectivePower or entry.finalPower or 0
end

local function entryMatchesKey(entry, key)
	if not entry or not key then
		return false
	end
	if getEntryKey(entry) == key or entry.petId == key then
		return true
	end
	if type(key) ~= "string" then
		return false
	end
	local parts = string.split(key, "|")
	if #parts < 3 or parts[1] ~= entry.petId then
		return false
	end
	local mutationMatches = PetData.normalizeMutationId(parts[3]) == PetData.normalizeMutationId(entry.mutationId)
	local traitMatches = PetData.normalizeTraitId(parts[2]) == PetData.normalizeTraitId(entry.traitId)
		or (PetData.normalizeTraitId(parts[2]) == "Neutral" and PetData.normalizeTraitId(entry.traitId) == "Neutral")
	return mutationMatches and traitMatches
end

local function softColor(color)
	return color:Lerp(Color3.fromRGB(215, 225, 235), 0.28)
end

local function getFxColor(petEntry, pet)
	if petEntry.hasMutation and petEntry.auraColor then
		return petEntry.auraColor
	end

	if petEntry.isShiny then
		return pet.color:Lerp(Color3.fromRGB(255, 255, 255), 0.58)
	end

	local color = petEntry.auraColor or pet.color
	if petEntry.petId == "RainbowDragon" or petEntry.petId == "RainbowSlime" or petEntry.petId == "ColorTitan" then
		return Color3.fromRGB(205, 175, 255)
	end
	return softColor(color)
end

local function getColorSequence(petEntry, pet, fxColor)
	if petEntry.mutationVisualTag == "rainbow"
		or petEntry.mutationId == "Rainbow"
		or petEntry.petId == "DevRainbowPet"
		or petEntry.petId == "RainbowDragon"
		or petEntry.petId == "RainbowSlime"
		or petEntry.petId == "ColorTitan"
	then
		return ColorSequence.new({
			ColorSequenceKeypoint.new(0, Color3.fromRGB(255, 90, 120)),
			ColorSequenceKeypoint.new(0.2, Color3.fromRGB(255, 220, 80)),
			ColorSequenceKeypoint.new(0.4, Color3.fromRGB(90, 235, 130)),
			ColorSequenceKeypoint.new(0.6, Color3.fromRGB(90, 215, 255)),
			ColorSequenceKeypoint.new(0.8, Color3.fromRGB(185, 120, 255)),
			ColorSequenceKeypoint.new(1, Color3.fromRGB(255, 115, 215)),
		})
	end

	local baseColor = petEntry.hasMutation and (petEntry.auraColor or fxColor) or pet.color
	return ColorSequence.new({
		ColorSequenceKeypoint.new(0, softColor(baseColor)),
		ColorSequenceKeypoint.new(0.55, fxColor),
		ColorSequenceKeypoint.new(1, Color3.fromRGB(255, 255, 255)),
	})
end

local function getMutationFxBoost(petEntry)
	local tag = petEntry.mutationVisualTag
	if tag == "glitch" then
		return 2.0, NumberRange.new(1.4, 3.2), NumberRange.new(0.22, 0.55)
	elseif tag == "storm" then
		return 1.8, NumberRange.new(1.2, 2.8), NumberRange.new(0.25, 0.6)
	elseif tag == "magnetic" then
		return 1.55, NumberRange.new(0.75, 1.8), NumberRange.new(0.55, 1.15)
	elseif tag == "hyper" then
		return 1.45, NumberRange.new(1.8, 3.4), NumberRange.new(0.22, 0.5)
	elseif tag == "gold" or tag == "sparkle" then
		return 1.35, NumberRange.new(0.9, 2.1), NumberRange.new(0.4, 0.9)
	end
	return 1.25, NumberRange.new(0.7, 1.8), NumberRange.new(0.45, 1.0)
end

local function tonePetPart(part, color)
	part.Anchored = true
	part.CanCollide = false
	part.CastShadow = false
	part.Material = Enum.Material.SmoothPlastic
	part.Color = softColor(color)
	part.Transparency = math.max(part.Transparency, 0)
end

local function createDevRainbowPetModel(petEntry, pet)
	local model = Instance.new("Model")
	model.Name = "RainbowPet"

	local function makePart(name, shape, size, cframe, color, material, transparency)
		local part = Instance.new("Part")
		part.Name = name
		part.Shape = shape or Enum.PartType.Ball
		part.Size = size
		part.CFrame = cframe or CFrame.new()
		tonePetPart(part, color)
		part.Material = material or Enum.Material.SmoothPlastic
		part.Transparency = transparency or 0
		part.Parent = model
		return part
	end

	local body = makePart(
		"RainbowBody",
		Enum.PartType.Ball,
		Vector3.new(2.4, 2.4, 2.4),
		CFrame.new(),
		Color3.fromRGB(255, 245, 255),
		Enum.Material.Neon
	)
	model.PrimaryPart = body

	local shell = makePart(
		"RainbowGlowShell",
		Enum.PartType.Ball,
		Vector3.new(2.72, 2.72, 2.72),
		CFrame.new(),
		Color3.fromRGB(180, 120, 255),
		Enum.Material.ForceField,
		0.62
	)
	shell:SetAttribute("NoTint", true)

	local rainbowColors = {
		Color3.fromRGB(255, 70, 95),
		Color3.fromRGB(255, 142, 54),
		Color3.fromRGB(255, 230, 70),
		Color3.fromRGB(75, 230, 120),
		Color3.fromRGB(70, 210, 255),
		Color3.fromRGB(90, 115, 255),
		Color3.fromRGB(190, 100, 255),
		Color3.fromRGB(255, 105, 205),
	}

	for index, color in ipairs(rainbowColors) do
		local angle = math.rad(index * 45)
		makePart(
			"RainbowGem" .. tostring(index),
			Enum.PartType.Ball,
			Vector3.new(0.5, 0.5, 0.5),
			CFrame.new(math.cos(angle) * 1.58, 0.18 * math.sin(angle * 2), math.sin(angle) * 1.58),
			color,
			Enum.Material.Neon
		)
	end

	for index, color in ipairs(rainbowColors) do
		local offsetY = -0.84 + ((index - 1) * 0.24)
		local band = makePart(
			"RainbowBand" .. tostring(index),
			Enum.PartType.Cylinder,
			Vector3.new(0.08, 2.66, 2.66),
			CFrame.new(0, offsetY, 0) * CFrame.Angles(0, 0, math.rad(90 + (index % 2) * 7)),
			color,
			Enum.Material.Neon,
			0.34
		)
		band:SetAttribute("NoTint", true)
	end

	makePart(
		"RainbowHalo",
		Enum.PartType.Cylinder,
		Vector3.new(0.12, 2.9, 2.9),
		CFrame.new(0, 1.65, 0) * CFrame.Angles(0, 0, math.rad(90)),
		Color3.fromRGB(255, 236, 120),
		Enum.Material.Neon,
		0.18
	)

	local leftWing = Instance.new("WedgePart")
	leftWing.Name = "LeftPrismWing"
	leftWing.Size = Vector3.new(1.1, 1.5, 0.34)
	leftWing.CFrame = CFrame.new(-1.35, 0.1, 0.05) * CFrame.Angles(0, 0, math.rad(18))
	tonePetPart(leftWing, Color3.fromRGB(105, 230, 255))
	leftWing.Material = Enum.Material.Neon
	leftWing.Transparency = 0.12
	leftWing.Parent = model

	local rightWing = Instance.new("WedgePart")
	rightWing.Name = "RightPrismWing"
	rightWing.Size = Vector3.new(1.1, 1.5, 0.34)
	rightWing.CFrame = CFrame.new(1.35, 0.1, 0.05) * CFrame.Angles(0, math.rad(180), math.rad(-18))
	tonePetPart(rightWing, Color3.fromRGB(185, 120, 255))
	rightWing.Material = Enum.Material.Neon
	rightWing.Transparency = 0.12
	rightWing.Parent = model

	body:SetAttribute("NoTint", true)
	return model
end

local function addPetParticles(model, petEntry, pet)
	if getClientSetting("LowFX", false) then
		return
	end
	if not model.PrimaryPart then
		return
	end

	local primary = model.PrimaryPart
	local tierName = petEntry.currentStackTier or "Normal"
	local rarityFx = RARITY_FX[pet.rarity] or RARITY_FX.Common
	local tierMult = TIER_FX_MULT[tierName] or 1
	local fxColor = getFxColor(petEntry, pet)
	local colorSequence = getColorSequence(petEntry, pet, fxColor)

	local attachment = primary:FindFirstChild("PetFxAttachment")
	if not attachment then
		attachment = Instance.new("Attachment")
		attachment.Name = "PetFxAttachment"
		attachment.Parent = primary
	end

	local motes = Instance.new("ParticleEmitter")
	motes.Name = "PetAuraMotes"
	motes.Texture = "rbxasset://textures/particles/sparkles_main.dds"
	motes.Color = colorSequence
	motes.LightEmission = 0.32
	motes.LightInfluence = 0.35
	motes.Size = NumberSequence.new({
		NumberSequenceKeypoint.new(0, rarityFx.size * tierMult),
		NumberSequenceKeypoint.new(1, 0),
	})
	motes.Speed = NumberRange.new(0.45, 1.35)
	motes.SpreadAngle = Vector2.new(180, 180)
	motes.Lifetime = NumberRange.new(0.65, 1.35)
	motes.Rate = rarityFx.rate * tierMult
	motes.Parent = attachment

	local dust = Instance.new("ParticleEmitter")
	dust.Name = "ColorDriftDust"
	dust.Texture = "rbxasset://textures/particles/sparkles_main.dds"
	dust.Color = colorSequence
	dust.LightEmission = 0.18
	dust.LightInfluence = 0.5
	dust.Size = NumberSequence.new({
		NumberSequenceKeypoint.new(0, rarityFx.size * 1.35 * tierMult),
		NumberSequenceKeypoint.new(0.55, rarityFx.size * 0.75 * tierMult),
		NumberSequenceKeypoint.new(1, 0),
	})
	dust.Speed = NumberRange.new(0.08, 0.45)
	dust.Acceleration = Vector3.new(0, 0.35, 0)
	dust.Drag = 1.2
	dust.SpreadAngle = Vector2.new(180, 180)
	dust.Lifetime = NumberRange.new(1.1, 2.0)
	dust.Rate = rarityFx.dust * tierMult
	dust.Rotation = NumberRange.new(0, 360)
	dust.RotSpeed = NumberRange.new(-45, 45)
	dust.Parent = attachment

	local glowPops = Instance.new("ParticleEmitter")
	glowPops.Name = "ColorGlowPops"
	glowPops.Texture = "rbxasset://textures/particles/sparkles_main.dds"
	glowPops.Color = colorSequence
	glowPops.LightEmission = 0.42
	glowPops.LightInfluence = 0.28
	glowPops.Size = NumberSequence.new({
		NumberSequenceKeypoint.new(0, rarityFx.size * 2.2 * tierMult),
		NumberSequenceKeypoint.new(0.35, rarityFx.size * 1.1 * tierMult),
		NumberSequenceKeypoint.new(1, 0),
	})
	glowPops.Speed = NumberRange.new(0.15, 0.65)
	glowPops.SpreadAngle = Vector2.new(180, 180)
	glowPops.Lifetime = NumberRange.new(0.45, 0.85)
	glowPops.Rate = math.max(0.8, rarityFx.rate * 0.22 * tierMult)
	glowPops.Parent = attachment

	if petEntry.hasMutation then
		local boost, mutationSpeed, mutationLifetime = getMutationFxBoost(petEntry)
		local mutationEmitter = Instance.new("ParticleEmitter")
		mutationEmitter.Name = "ColorMutationAura"
		mutationEmitter.Texture = "rbxasset://textures/particles/sparkles_main.dds"
		mutationEmitter.Color = colorSequence
		mutationEmitter.LightEmission = 0.55
		mutationEmitter.LightInfluence = 0.25
		mutationEmitter.Size = NumberSequence.new({
			NumberSequenceKeypoint.new(0, 0.16 * tierMult),
			NumberSequenceKeypoint.new(0.45, 0.09 * tierMult),
			NumberSequenceKeypoint.new(1, 0),
		})
		mutationEmitter.Speed = mutationSpeed
		mutationEmitter.SpreadAngle = Vector2.new(180, 180)
		mutationEmitter.Lifetime = mutationLifetime
		mutationEmitter.Rate = math.min(16, rarityFx.rate * boost)
		mutationEmitter.Rotation = NumberRange.new(0, 360)
		mutationEmitter.RotSpeed = NumberRange.new(-120, 120)
		mutationEmitter.Parent = attachment
	end

	if pet.rarity == "Epic" or pet.rarity == "Legendary" or tierName ~= "Normal" then
		local ring = Instance.new("ParticleEmitter")
		ring.Name = "PetSoftAura"
		ring.Texture = "rbxasset://textures/particles/sparkles_main.dds"
		ring.Color = colorSequence
		ring.LightEmission = 0.22
		ring.LightInfluence = 0.5
		ring.Size = NumberSequence.new({
			NumberSequenceKeypoint.new(0, 0.18 * tierMult),
			NumberSequenceKeypoint.new(0.65, 0.08 * tierMult),
			NumberSequenceKeypoint.new(1, 0),
		})
		ring.Speed = NumberRange.new(0.1, 0.35)
		ring.SpreadAngle = Vector2.new(180, 180)
		ring.Lifetime = NumberRange.new(0.8, 1.4)
		ring.Rate = math.min(5, 1.4 * tierMult)
		ring.Parent = attachment
	end

	local light = Instance.new("PointLight")
	light.Name = "PetSoftLight"
	light.Color = fxColor
	light.Range = 4.5 + tierMult
	light.Brightness = rarityFx.light * tierMult
	light.Parent = primary
end

-- ========================
--   CREATE PET MODEL
-- ========================
local function createPetModel(petEntry)
	local pet = PetData.Pets[petEntry.petId]
	if not pet then return nil end

	local tierName  = petEntry.currentStackTier
	local auraColor = petEntry.auraColor
	local model = PetModelUtil.ClonePetModel(petEntry.petId, { anchored = true, removeBillboards = true })

	if model and model:IsA("Model") then
		model.Name = petEntry.petId .. "_" .. tierName

		if not model.PrimaryPart then
			local first = model:FindFirstChild("Core") or model:FindFirstChildOfClass("BasePart")
			if first then model.PrimaryPart = first end
		end
	else
		model = Instance.new("Model")
		model.Name = petEntry.petId .. "_" .. tierName

		-- Scale body based on tier
		local sizeScale = tierName == "Celestial" and 2.8
			or tierName == "Royal"     and 2.2
			or tierName == "Gilded"    and 1.8
			or 1.5

		local body = Instance.new("Part")
		body.Shape      = Enum.PartType.Ball
		body.Size       = Vector3.new(sizeScale, sizeScale, sizeScale)
		tonePetPart(body, petEntry.isShiny and pet.color:Lerp(Color3.fromRGB(255, 255, 255), 0.58) or pet.color)
		body.Parent     = model
		model.PrimaryPart = body

		-- Tier-specific soft shell. Particles carry the visible aura.
		if tierName ~= "Normal" then
			local aura = Instance.new("Part")
			aura.Shape        = Enum.PartType.Ball
			aura.Size         = Vector3.new(sizeScale * 1.18, sizeScale * 1.18, sizeScale * 1.18)
			aura.Color        = softColor(auraColor)
			aura.Material     = Enum.Material.ForceField
			aura.Transparency = tierName == "Celestial" and 0.82 or 0.88
			aura.CastShadow   = false
			aura.Anchored     = true
			aura.CanCollide   = false
			aura.Parent       = model
		end

		if petEntry.isShiny then
			local shine = Instance.new("Part")
			shine.Shape        = Enum.PartType.Ball
			shine.Size         = Vector3.new(sizeScale * 1.32, sizeScale * 1.32, sizeScale * 1.32)
			shine.Color        = Color3.fromRGB(255, 245, 160)
			shine.Material     = Enum.Material.ForceField
			shine.Transparency = 0.74
			shine.CastShadow   = false
			shine.Anchored     = true
			shine.CanCollide   = false
			shine.Parent       = model
		end
	end

	-- Attachment for drain beams
	if model.PrimaryPart and not model.PrimaryPart:FindFirstChild("PetAttachment") then
		local att = Instance.new("Attachment")
		att.Name   = "PetAttachment"
		att.Parent = model.PrimaryPart
	end

	if petEntry.hasMutation and model.PrimaryPart then
		local extents = model:GetExtentsSize()
		local auraSize = math.max(extents.X, extents.Y, extents.Z) * 1.35
		local mutationAura = Instance.new("Part")
		mutationAura.Name = "MutationAura"
		mutationAura.Shape = Enum.PartType.Ball
		mutationAura.Size = Vector3.new(auraSize, auraSize, auraSize)
		mutationAura.CFrame = model.PrimaryPart.CFrame
		mutationAura.Color = softColor(petEntry.auraColor or pet.color)
		mutationAura.Material = Enum.Material.ForceField
		mutationAura.Transparency = petEntry.mutationVisualTag == "glitch" and 0.72 or 0.82
		mutationAura.CastShadow = false
		mutationAura.Anchored = true
		mutationAura.CanCollide = false
		mutationAura.Parent = model
	end

	-- Point light — color and intensity scale with tier
	addPetParticles(model, petEntry, pet)

	model.Parent = workspace
	return model
end
local function applyTraitEffect(model, trait)
	if not model or not model.PrimaryPart or not trait then return end
	local effect = trait.visualEffect or "none"
	local primary = model.PrimaryPart

	if effect == "glow" then
		local existing = primary:FindFirstChildOfClass("PointLight")
		if not existing then
			local light = Instance.new("PointLight")
			light.Color      = softColor(trait.color or Color3.new(1, 1, 1))
			light.Range      = 5
			light.Brightness = 0.12
			light.Parent     = primary
		end

	elseif effect == "rainbow" then
		-- Slow color cycle via Heartbeat
		local t0 = tick()
		task.spawn(function()
			while model and model.Parent do
				local t   = (tick() - t0) * 0.3
				local h   = t % 1
				local col = Color3.fromHSV(h, 0.55, 0.82)
				for _, part in ipairs(model:GetDescendants()) do
					if part:IsA("BasePart") then
						part.Color = col
					end
				end
				task.wait(0.05)
			end
		end)

	elseif effect == "giant" then
		local scale = trait.sizeScale or 1.4
		model:ScaleTo(scale)

	elseif effect == "spark" or effect == "electric" then
		local emitter = Instance.new("ParticleEmitter")
		emitter.Color         = ColorSequence.new(softColor(trait.color or Color3.fromRGB(255, 240, 80)))
		emitter.Size          = NumberSequence.new({
			NumberSequenceKeypoint.new(0, 0.08),
			NumberSequenceKeypoint.new(1, 0),
		})
		emitter.Speed         = NumberRange.new(1, 3)
		emitter.Lifetime      = NumberRange.new(0.2, 0.5)
		emitter.Rate          = 4
		emitter.LightEmission = 0.25
		emitter.LightInfluence = 0.4
		emitter.LockedToPart  = true
		emitter.Parent        = primary

	elseif effect == "celestial" then
		local emitter = Instance.new("ParticleEmitter")
		emitter.Color         = ColorSequence.new(Color3.fromRGB(150, 195, 235))
		emitter.Size          = NumberSequence.new({
			NumberSequenceKeypoint.new(0, 0.08),
			NumberSequenceKeypoint.new(1, 0),
		})
		emitter.Speed         = NumberRange.new(0.5, 1.5)
		emitter.Lifetime      = NumberRange.new(0.5, 1.2)
		emitter.Rate          = 3
		emitter.LightEmission = 0.2
		emitter.LightInfluence = 0.45
		emitter.LockedToPart  = false
		emitter.Parent        = primary
	end

	if trait.sizeScale and effect ~= "giant" then
		model:ScaleTo(trait.sizeScale)
	end
end
-- ========================
--   REBUILD ORBITING PETS
-- ========================
local function rebuildOrbitingPets()
	for _, entry in ipairs(spawnedPets) do
		if entry.model and entry.model.Parent then
			entry.model:Destroy()
		end
	end
	spawnedPets = {}

	-- Build a lookup from variantKey -> entry data. Legacy petIds still work as a fallback.
	local entryByKey = {}
	for _, entry in ipairs(allPets) do
		entryByKey[getEntryKey(entry)] = entry
		entryByKey[entry.petId] = entryByKey[entry.petId] or entry
	end

	for _, variantKey in ipairs(equippedPets) do
		local petEntry = entryByKey[variantKey]
		if not petEntry then
			for _, entry in ipairs(allPets) do
				if entryMatchesKey(entry, variantKey) then
					petEntry = entry
					break
				end
			end
		end
		if petEntry then
			local model = createPetModel(petEntry)
			if model then
				applyTraitEffect(model, petEntry.trait)
				table.insert(spawnedPets, { model = model, variantKey = variantKey })
				
			end
		end
	end
end

-- ========================
--   DRAIN BEAM
-- ========================
local function createDrainBeam(petModel, targetObj, colorType)
	if getClientSetting("LowFX", false) then return end
	if not petModel or not petModel.PrimaryPart then return end
	if not targetObj or not targetObj.Parent then return end

	local petAtt = petModel.PrimaryPart:FindFirstChild("PetAttachment")
	if not petAtt then return end

	local targetAtt = Instance.new("Attachment")
	targetAtt.Name   = "DrainAttachment"
	targetAtt.Parent = targetObj

	-- Get the breakable's current color (drains toward grey so this shifts too)
	local breakColor = targetObj.Color

	-- Get the pet's color from the model
	local petColor = petModel.PrimaryPart.Color

	-- Mix: beam starts as the breakable color at the object end
	-- and shifts to the pet color at the pet end
	-- This visually shows the color being "sucked" into the pet
	local beam = Instance.new("Beam")
	beam.Attachment0  = targetAtt   -- from object
	beam.Attachment1  = petAtt      -- to pet
	beam.Color        = ColorSequence.new({
		ColorSequenceKeypoint.new(0,    breakColor),                        -- object end: breakable color
		ColorSequenceKeypoint.new(0.4,  breakColor:Lerp(petColor, 0.4)),   -- blend
		ColorSequenceKeypoint.new(0.75, petColor:Lerp(Color3.new(1,1,1), 0.2)), -- near pet: pet color slightly brightened
		ColorSequenceKeypoint.new(1,    petColor),                          -- pet end: pure pet color
	})
	beam.Width0        = 0.18
	beam.Width1        = 0.035
	beam.TextureSpeed  = 4     -- flows toward the pet
	beam.Transparency  = NumberSequence.new({
		NumberSequenceKeypoint.new(0,   0.45),
		NumberSequenceKeypoint.new(0.5, 0.62),
		NumberSequenceKeypoint.new(1,   0.88),
	})
	beam.LightEmission = 0.25
	beam.Segments      = 8
	beam.CurveSize0    = 0.8
	beam.CurveSize1    = 0.8
	beam.FaceCamera    = true
	beam.Parent        = targetObj

	-- Particles: spawn at object, colored like the breakable, fly toward pet
	local emitter = Instance.new("ParticleEmitter")
	emitter.Color = ColorSequence.new({
		ColorSequenceKeypoint.new(0,   breakColor),
		ColorSequenceKeypoint.new(0.5, breakColor:Lerp(petColor, 0.5)),
		ColorSequenceKeypoint.new(1,   petColor),
	})
	emitter.Size          = NumberSequence.new({
		NumberSequenceKeypoint.new(0,   0.12),
		NumberSequenceKeypoint.new(0.7, 0.06),
		NumberSequenceKeypoint.new(1,   0),
	})
	emitter.Speed         = NumberRange.new(2, 4)
	emitter.Lifetime      = NumberRange.new(0.15, 0.35)
	emitter.Rate          = 8
	emitter.LightEmission = 0.25
	emitter.LightInfluence = 0.5
	emitter.LockedToPart  = false
	emitter.SpreadAngle   = Vector2.new(15, 15)
	emitter.Parent        = targetObj

	task.delay(0.4, function()
		if beam    and beam.Parent    then beam:Destroy()    end
		if targetAtt and targetAtt.Parent then targetAtt:Destroy() end
		if emitter and emitter.Parent then
			emitter.Enabled = false
			task.delay(0.4, function()
				if emitter and emitter.Parent then emitter:Destroy() end
			end)
		end
	end)
end

-- ========================
--   BUILD UI
-- ========================
local isOpen = false
local function refreshInventoryUI()
	-- Legacy inventory UI disabled. InventoryUI.client.luau is the active source.
end
-- Do not register or create a second inventory/menu UI here. PetClient only owns orbiting
-- Color companions and small VFX; InventoryUI.client.luau is the single inventory source.

-- Legacy inventory builder removed. InventoryUI.client.luau owns the single Inventory window.
-- If an old Pets/Bag/Colors route fires, InventoryUI aliases it to current Inventory and warns once.

-- ========================
--   EVENTS
-- ========================
petsLoadedEvent.OnClientEvent:Connect(function(inventory, equipped)
	inventory = inventory or {}
	equipped = equipped or {}

	if #inventory == 0 and #allPets > 0 and os.clock() - lastPetStateAt < 1.5 then
		if isOpen then refreshInventoryUI() end
		warn("PetClient: ignored a transient empty Color inventory update.")
		return
	end

	allPets      = inventory
	equippedPets = equipped
	lastPetStateAt = os.clock()
	rebuildOrbitingPets()
	if isOpen then refreshInventoryUI() end
end)

-- EggShopUI owns hatch reveal animations now.

