local function prepareHatchResult(entry, pet, rarityColor, hasMutation)
	resultStroke.Color = hasMutation and (entry.auraColor or rarityColor) or rarityColor
	resultName.Text = entry.displayName or pet.displayName
	local traitsUnlocked = entry.traitsUnlockedForEgg ~= false
	local mutationsUnlocked = entry.mutationsUnlockedForEgg ~= false
	local traitText = "Trait: " .. tostring(entry.traitName or entry.personalityName or "Neutral")
	local mutationText = "Mutation: " .. (hasMutation and tostring(entry.mutationName or "Special") or "Normal")
	resultRarity.Text = tostring(entry.rarity or pet.rarity) .. " " .. PetData.GetCompanionTypeName()
		.. (traitsUnlocked and (" | " .. traitText) or "")
	resultRarity.TextColor3 = rarityColor

	local duplicateText = entry.wasDuplicate and ("Duplicate Count: x" .. PetData.formatStack(entry.duplicateCount or entry.stackAmount or 1)) or "New Color"
	local statsLines = {
		"Power " .. tostring(entry.effectivePower or entry.finalPower or 0)
			.. "  |  Tier: " .. tostring(entry.mergeTier or entry.currentStackTier or "Normal"),
	}
	if traitsUnlocked then
		table.insert(statsLines, traitText)
	end
	if mutationsUnlocked then
		table.insert(statsLines, mutationText)
	end
	table.insert(statsLines, duplicateText)
	resultStats.Text = table.concat(statsLines, "\n")
end

local function revealPreparedHatchResult()
	resultName.Visible = true
	resultRarity.Visible = true
	resultStats.Visible = true
	resultCard.Visible = true
	resultCard.Size = UDim2.new(0, 260, 0, 100)
	TweenService:Create(resultCard, TweenInfo.new(0.32, Enum.EasingStyle.Back), {
		Size = UDim2.new(0, 380, 0, 160),
	}):Play()
end

local function clearPets()
	for _, child in ipairs(petGrid:GetChildren()) do
		if not child:IsA("UIGridLayout") then
			child:Destroy()
		end
	end
end

local function updatePetGrid(egg)
	clearPets()
	local count = 0
	for _, entry in ipairs(egg.pets) do
		local pet = PetData.Pets[entry.petId]
		if not pet then
			continue
		end

		count += 1
		local rarity = RARITY_COLOR[pet.rarity] or TITLE_TEXT
		local chip = Instance.new("Frame")
		chip.LayoutOrder = count
		chip.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
		chip.BorderSizePixel = 0
		chip.ZIndex = 13
		chip.Parent = petGrid
		local chipCorner = Instance.new("UICorner")
		chipCorner.CornerRadius = UDim.new(0, 10)
		chipCorner.Parent = chip
		local chipStroke = Instance.new("UIStroke")
		chipStroke.Color = rarity
		chipStroke.Thickness = 2
		chipStroke.Parent = chip

		local dot = Instance.new("Frame")
		dot.Size = UDim2.new(0, 14, 0, 14)
		dot.Position = UDim2.new(0, 8, 0.5, -7)
		dot.BackgroundColor3 = pet.color
		dot.BorderSizePixel = 0
		dot.ZIndex = 14
		dot.Parent = chip
		local dotCorner = Instance.new("UICorner")
		dotCorner.CornerRadius = UDim.new(1, 0)
		dotCorner.Parent = dot

		local name = Instance.new("TextLabel")
		name.Size = UDim2.new(1, -30, 0, 27)
		name.Position = UDim2.new(0, 28, 0, 4)
		name.BackgroundTransparency = 1
		name.Font = Enum.Font.LuckiestGuy
		name.TextSize = 12
		name.TextColor3 = TITLE_TEXT
		name.TextXAlignment = Enum.TextXAlignment.Left
		name.Text = pet.displayName
		name.ZIndex = 14
		name.Parent = chip

		local chance = Instance.new("TextLabel")
		chance.Size = UDim2.new(1, -30, 0, 20)
		chance.Position = UDim2.new(0, 28, 0, 31)
		chance.BackgroundTransparency = 1
		chance.Font = Enum.Font.GothamBold
		chance.TextSize = 10
		chance.TextColor3 = rarity
		chance.TextXAlignment = Enum.TextXAlignment.Left
		chance.Text = tostring(entry.chance) .. "% - " .. pet.rarity
		chance.ZIndex = 14
		chance.Parent = chip
	end
	petGrid.CanvasSize = UDim2.new(0, 0, 0, math.ceil(count / 3) * 66)
end

local function refreshWorldRows()
	for eggId, row in pairs(worldRows) do
		local egg = PetData.Eggs[eggId]
		local unlocked = egg and isEggUnlocked(egg)
		local selected = eggId == selectedEggId

		row.BackgroundColor3 = selected and Color3.fromRGB(255, 245, 255) or (unlocked and WHITE or LOCKED)
		row.UIStroke.Color = selected and (egg and egg.color or TITLE_TEXT) or (unlocked and Color3.fromRGB(210, 205, 230) or Color3.fromRGB(150, 155, 175))
		row.Status.Text = unlocked and "READY" or ("LOCKED")
		row.Status.TextColor3 = unlocked and Color3.fromRGB(35, 130, 55) or Color3.fromRGB(100, 105, 125)
	end
end

local function selectEgg(eggId)
	if isHatching then
		return
	end

	local egg = PetData.Eggs[eggId]
	if not egg then
		return
	end
	selectedEggId = eggId

	local world = getWorldForEgg(egg)
	local unlocked = isEggUnlocked(egg)
	eggIcon.BackgroundColor3 = unlocked and egg.color or LOCKED
	eggName.Text = egg.displayName
	worldName.Text = world and world.name or "World Egg"
	costLabel.Text = unlocked and (formatNum(egg.cost) .. " Coins") or ("Unlock " .. tostring(egg.areaColor) .. " first")
	costLabel.TextColor3 = unlocked and Color3.fromRGB(220, 140, 30) or Color3.fromRGB(100, 105, 125)
	setHatchButtonState(unlocked)
	updatePetGrid(egg)
	refreshWorldRows()
end

local function buildWorldRows()
	for _, world in ipairs(ColorData.Worlds) do
		local eggId = EGG_BY_WORLD[world.primaryColor]
		local egg = eggId and PetData.Eggs[eggId]
		if not egg then
			continue
		end

		local row = Instance.new("TextButton")
		row.Name = world.primaryColor .. "EggRow"
		row.Size = UDim2.new(1, -4, 0, 54)
		row.LayoutOrder = ColorData.getWorldIndex(world.primaryColor) or 1
		row.Text = ""
		row.AutoButtonColor = false
		row.BorderSizePixel = 0
		row.ZIndex = 12
		row.Parent = worldList
		local corner = Instance.new("UICorner")
		corner.CornerRadius = UDim.new(0, 12)
		corner.Parent = row
		local stroke = Instance.new("UIStroke")
		stroke.Name = "UIStroke"
		stroke.Thickness = 2
		stroke.Parent = row

		local swatch = Instance.new("Frame")
		swatch.Size = UDim2.new(0, 24, 0, 24)
		swatch.Position = UDim2.new(0, 10, 0.5, -12)
		swatch.BackgroundColor3 = egg.color
		swatch.BorderSizePixel = 0
		swatch.ZIndex = 13
		swatch.Parent = row
		local swatchCorner = Instance.new("UICorner")
		swatchCorner.CornerRadius = UDim.new(1, 0)
		swatchCorner.Parent = swatch

		local label = Instance.new("TextLabel")
		label.Size = UDim2.new(1, -46, 0, 24)
		label.Position = UDim2.new(0, 42, 0, 7)
		label.BackgroundTransparency = 1
		label.Font = Enum.Font.LuckiestGuy
		label.TextSize = 13
		label.TextColor3 = TITLE_TEXT
		label.TextXAlignment = Enum.TextXAlignment.Left
		label.Text = world.name
		label.ZIndex = 13
		label.Parent = row

		local status = Instance.new("TextLabel")
		status.Name = "Status"
		status.Size = UDim2.new(1, -46, 0, 18)
		status.Position = UDim2.new(0, 42, 0, 30)
		status.BackgroundTransparency = 1
		status.Font = Enum.Font.GothamBold
		status.TextSize = 10
		status.TextXAlignment = Enum.TextXAlignment.Left
		status.ZIndex = 13
		status.Parent = row

		row.MouseButton1Click:Connect(function()
			selectEgg(eggId)
		end)

		worldRows[eggId] = row
	end
	worldList.CanvasSize = UDim2.new(0, 0, 0, worldLayout.AbsoluteContentSize.Y + 20)
end

local function setWorldGuisHidden(hidden)
	if hidden then
		table.clear(hiddenWorldGuis)
		for _, obj in ipairs(workspace:GetDescendants()) do
			if (obj:IsA("BillboardGui") or obj:IsA("SurfaceGui")) and obj.Enabled then
				hiddenWorldGuis[obj] = true
				obj.Enabled = false
			end
		end
	else
		for gui in pairs(hiddenWorldGuis) do
			if gui.Parent then
				gui.Enabled = true
			end
		end
		table.clear(hiddenWorldGuis)
	end
end

local function softColor(color)
	return color:Lerp(Color3.fromRGB(235, 240, 250), 0.18)
end

local function clearHatchWorld()
	for _, child in ipairs(hatchWorld:GetChildren()) do
		child:Destroy()
	end
end

local function makeViewportPart(parent, name, shape, size, color, cframe, material, transparency)
	local part = Instance.new("Part")
	part.Name = name
	part.Shape = shape or Enum.PartType.Block
	part.Size = size
	part.CFrame = cframe or CFrame.new()
	part.Color = color
	part.Material = material or Enum.Material.SmoothPlastic
	part.Transparency = transparency or 0
	part.Anchored = true
	part.CanCollide = false
	part.CastShadow = false
	part.Parent = parent
	return part
end

local function createEggViewportModel(egg)
	local model = Instance.new("Model")
	model.Name = "HatchingEgg"
	model.Parent = hatchWorld

	local shellColor = softColor((egg and egg.color) or Color3.fromRGB(180, 100, 255))
	local shell = makeViewportPart(model, "Shell", Enum.PartType.Ball, Vector3.new(2.35, 3.15, 2.35), shellColor, CFrame.new(0, 0, 0), Enum.Material.SmoothPlastic)
	model.PrimaryPart = shell

	makeViewportPart(model, "Glow", Enum.PartType.Ball, Vector3.new(2.65, 3.45, 2.65), shellColor, CFrame.new(0, 0, 0), Enum.Material.ForceField, 0.78)
	makeViewportPart(model, "Highlight", Enum.PartType.Ball, Vector3.new(0.42, 0.72, 0.12), WHITE, CFrame.new(-0.55, 0.82, 1.08) * CFrame.Angles(0, 0, math.rad(-18)), Enum.Material.SmoothPlastic, 0.25)

	local spotColor = shellColor:Lerp(Color3.fromRGB(255, 255, 255), 0.22)
	makeViewportPart(model, "Spot1", Enum.PartType.Ball, Vector3.new(0.38, 0.25, 0.08), spotColor, CFrame.new(0.42, 0.48, 1.15), Enum.Material.SmoothPlastic, 0.08)
	makeViewportPart(model, "Spot2", Enum.PartType.Ball, Vector3.new(0.28, 0.2, 0.08), spotColor, CFrame.new(-0.34, -0.25, 1.16), Enum.Material.SmoothPlastic, 0.08)

	local crackColor = Color3.fromRGB(48, 38, 58)
	for i, data in ipairs({
		{ pos = Vector3.new(-0.03, 0.42, 1.22), size = Vector3.new(0.08, 0.58, 0.06), rot = -28 },
		{ pos = Vector3.new(0.16, 0.04, 1.23), size = Vector3.new(0.07, 0.54, 0.06), rot = 34 },
		{ pos = Vector3.new(-0.16, -0.22, 1.24), size = Vector3.new(0.07, 0.42, 0.06), rot = -45 },
	}) do
		local crack = makeViewportPart(model, "Crack" .. i, Enum.PartType.Block, data.size, crackColor, CFrame.new(data.pos) * CFrame.Angles(0, 0, math.rad(data.rot)), Enum.Material.SmoothPlastic, 1)
		crack:SetAttribute("Crack", true)
	end

	return model
end

local function makeEye(parent, x, y, z)
	return makeViewportPart(parent, "Eye", Enum.PartType.Ball, Vector3.new(0.12, 0.12, 0.06), Color3.fromRGB(25, 28, 35), CFrame.new(x, y, z), Enum.Material.SmoothPlastic)
end

local function createFallbackPetModel(entry)
	local pet = PetData.Pets[entry.petId]
	if not pet then
		return nil
	end

	local model = Instance.new("Model")
	model.Name = entry.petId .. "Reveal"
	model.Parent = hatchWorld

	local name = string.lower(pet.displayName or entry.petId)
	local mainColor = softColor(pet.color)
	local accent = mainColor:Lerp(WHITE, 0.35)
	local dark = mainColor:Lerp(Color3.fromRGB(20, 24, 32), 0.35)

	local bodyShape = (string.find(name, "cubey") or string.find(name, "golem") or string.find(name, "titan")) and Enum.PartType.Block or Enum.PartType.Ball
	local body = makeViewportPart(model, "Body", bodyShape, Vector3.new(1.45, 1.35, 1.25), mainColor, CFrame.new(0, -0.1, 0), Enum.Material.SmoothPlastic)
	model.PrimaryPart = body

	local head = makeViewportPart(model, "Head", Enum.PartType.Ball, Vector3.new(1.0, 0.88, 0.9), accent, CFrame.new(0, 0.76, 0.03), Enum.Material.SmoothPlastic)
	makeEye(model, -0.22, 0.85, 0.48)
	makeEye(model, 0.22, 0.85, 0.48)

	if string.find(name, "bee") then
		makeViewportPart(model, "StripeA", Enum.PartType.Block, Vector3.new(1.52, 0.12, 0.08), dark, CFrame.new(0, -0.18, 0.64), Enum.Material.SmoothPlastic)
		makeViewportPart(model, "StripeB", Enum.PartType.Block, Vector3.new(1.2, 0.1, 0.08), dark, CFrame.new(0, 0.1, 0.65), Enum.Material.SmoothPlastic)
		makeViewportPart(model, "LeftWing", Enum.PartType.Ball, Vector3.new(0.8, 0.18, 0.62), Color3.fromRGB(225, 248, 255), CFrame.new(-0.72, 0.35, -0.08) * CFrame.Angles(0, 0, math.rad(-25)), Enum.Material.Glass, 0.28)
		makeViewportPart(model, "RightWing", Enum.PartType.Ball, Vector3.new(0.8, 0.18, 0.62), Color3.fromRGB(225, 248, 255), CFrame.new(0.72, 0.35, -0.08) * CFrame.Angles(0, 0, math.rad(25)), Enum.Material.Glass, 0.28)
	elseif string.find(name, "bunny") or string.find(name, "mouse") or string.find(name, "cat") or string.find(name, "fox") or string.find(name, "wolf") or string.find(name, "pup") or string.find(name, "panda") or string.find(name, "bear") or string.find(name, "lion") then
		makeViewportPart(model, "LeftEar", Enum.PartType.Ball, Vector3.new(0.28, 0.82, 0.24), accent, CFrame.new(-0.36, 1.36, 0) * CFrame.Angles(0, 0, math.rad(-13)), Enum.Material.SmoothPlastic)
		makeViewportPart(model, "RightEar", Enum.PartType.Ball, Vector3.new(0.28, 0.82, 0.24), accent, CFrame.new(0.36, 1.36, 0) * CFrame.Angles(0, 0, math.rad(13)), Enum.Material.SmoothPlastic)
		makeViewportPart(model, "Tail", Enum.PartType.Ball, Vector3.new(0.46, 0.46, 0.46), accent, CFrame.new(0.78, -0.24, -0.42), Enum.Material.SmoothPlastic)
	elseif string.find(name, "dragon") or string.find(name, "bat") or string.find(name, "moth") or string.find(name, "wyvern") or string.find(name, "phoenix") or string.find(name, "finch") or string.find(name, "hydra") then
		makeViewportPart(model, "LeftWing", Enum.PartType.Block, Vector3.new(0.12, 1.15, 1.25), mainColor:Lerp(WHITE, 0.18), CFrame.new(-0.95, 0.18, -0.05) * CFrame.Angles(0, 0, math.rad(-28)), Enum.Material.SmoothPlastic)
		makeViewportPart(model, "RightWing", Enum.PartType.Block, Vector3.new(0.12, 1.15, 1.25), mainColor:Lerp(WHITE, 0.18), CFrame.new(0.95, 0.18, -0.05) * CFrame.Angles(0, 0, math.rad(28)), Enum.Material.SmoothPlastic)
		makeViewportPart(model, "Crest", Enum.PartType.Ball, Vector3.new(0.26, 0.42, 0.2), dark, CFrame.new(0, 1.28, 0.04), Enum.Material.SmoothPlastic)
	elseif string.find(name, "sprout") then
		makeViewportPart(model, "Stem", Enum.PartType.Block, Vector3.new(0.12, 0.5, 0.12), dark, CFrame.new(0, 1.25, 0), Enum.Material.SmoothPlastic)
		makeViewportPart(model, "LeafL", Enum.PartType.Ball, Vector3.new(0.55, 0.2, 0.28), Color3.fromRGB(110, 230, 120), CFrame.new(-0.24, 1.48, 0) * CFrame.Angles(0, 0, math.rad(-24)), Enum.Material.SmoothPlastic)
		makeViewportPart(model, "LeafR", Enum.PartType.Ball, Vector3.new(0.55, 0.2, 0.28), Color3.fromRGB(110, 230, 120), CFrame.new(0.24, 1.48, 0) * CFrame.Angles(0, 0, math.rad(24)), Enum.Material.SmoothPlastic)
	elseif string.find(name, "turtle") then
		makeViewportPart(model, "Shell", Enum.PartType.Ball, Vector3.new(1.55, 0.78, 1.15), dark, CFrame.new(0, 0.1, -0.08), Enum.Material.SmoothPlastic)
	elseif string.find(name, "unicorn") then
		makeViewportPart(model, "Horn", Enum.PartType.Block, Vector3.new(0.16, 0.62, 0.16), Color3.fromRGB(255, 245, 160), CFrame.new(0, 1.36, 0.2) * CFrame.Angles(0, 0, math.rad(45)), Enum.Material.SmoothPlastic)
	end

	local light = Instance.new("PointLight")
	light.Color = pet.color
	light.Range = 8
	light.Brightness = entry.rarity == "Legendary" and 1.6 or entry.rarity == "Epic" and 1.15 or 0.8
	light.Parent = body

	return model
end

local function createPetViewportModel(entry)
	local pet = entry and PetData.Pets[entry.petId]
	if not pet then
		return nil
	end

	local model = PetModelUtil.ClonePetModel(entry.petId, { anchored = true, removeBillboards = true })
	if model and model:IsA("Model") then
		model.Name = entry.petId .. "Reveal"
		model.Parent = hatchWorld
		if not model.PrimaryPart then
			local core = model:FindFirstChild("Core") or model:FindFirstChildOfClass("BasePart")
			if core then
				model.PrimaryPart = core
			end
		end
		local extents = model:GetExtentsSize()
		local largest = math.max(extents.X, extents.Y, extents.Z)
		if largest > 4.2 then
			pcall(function()
				model:ScaleTo(4.2 / largest)
			end)
		end
		return model
	end

	model = Instance.new("Model")
	model.Name = entry.petId .. "OrbReveal"
	model.Parent = hatchWorld

	local orbColor = entry.isShiny and pet.color:Lerp(Color3.fromRGB(255, 255, 255), 0.5) or pet.color
	if entry.hasMutation and entry.auraColor then
		orbColor = entry.auraColor
	end
	local orb = makeViewportPart(model, "PetOrb", Enum.PartType.Ball, Vector3.new(1.95, 1.95, 1.95), orbColor, CFrame.new(0, 0, 0), Enum.Material.SmoothPlastic)
	model.PrimaryPart = orb

	makeViewportPart(model, "OrbHighlight", Enum.PartType.Ball, Vector3.new(0.42, 0.42, 0.12), WHITE, CFrame.new(-0.46, 0.48, 0.86), Enum.Material.SmoothPlastic, 0.18)
	makeViewportPart(model, "OrbGlow", Enum.PartType.Ball, Vector3.new(2.32, 2.32, 2.32), entry.auraColor or orbColor, CFrame.new(0, 0, 0), Enum.Material.ForceField, (entry.isShiny or entry.hasMutation) and 0.38 or 0.72)

	if entry.isShiny then
		makeViewportPart(model, "ShinyRing", Enum.PartType.Ball, Vector3.new(2.62, 2.62, 2.62), Color3.fromRGB(255, 250, 190), CFrame.new(0, 0, 0), Enum.Material.ForceField, 0.68)
	end

	if entry.hasMutation then
		makeViewportPart(model, "MutationRing", Enum.PartType.Ball, Vector3.new(2.82, 2.82, 2.82), entry.auraColor or orbColor, CFrame.new(0, 0, 0), Enum.Material.ForceField, 0.62)
	end

	if entry.trait then
		local traitColor = entry.trait.color or WHITE
		makeViewportPart(model, "TraitAura", Enum.PartType.Ball, Vector3.new(2.82, 2.82, 2.82), traitColor, CFrame.new(0, 0, 0), Enum.Material.ForceField, 0.78)
	end

	local light = Instance.new("PointLight")
	light.Color = (entry.isShiny or entry.hasMutation) and (entry.auraColor or Color3.fromRGB(255, 245, 185)) or orbColor
	light.Range = 9
	light.Brightness = entry.hasMutation and 1.9 or entry.isShiny and 1.6 or 0.9
	light.Parent = orb

	return model
end

local function showError(message)
	hatchOverlay.Visible = true
	updateHatchFocusState()
	hatchEgg.Visible = false
	hatchViewport.Visible = false
	hideHatchResult()
	clearHatchWorld()
	hatchText.Text = message or "CAN'T HATCH"
	hatchText.TextColor3 = Color3.fromRGB(255, 120, 150)
	task.delay(1, function()
		hatchOverlay.Visible = false
		hatchText.TextColor3 = WHITE
		updateHatchFocusState()
	end)
end

local function finishHatchLock(token)
	if token and token ~= hatchToken then
		return
	end
	setHatchingLocked(false)
end

local function startHatchAnimation(eggId)
	local egg = PetData.Eggs[eggId]
	if not egg then
		return
	end

	hatchToken += 1
	local token = hatchToken
	hatchStartedAt = os.clock()
	hatchPending = true
	hatchOverlay.Visible = true
	updateHatchFocusState()
	hatchEgg.Visible = false
	hatchViewport.Visible = true
	hideHatchResult()
	hatchViewport.Size = UDim2.new(0, 260, 0, 230)
	clearHatchWorld()

	local eggModel = createEggViewportModel(egg)
	hatchText.Text = "HATCHING"
	hatchText.TextColor3 = WHITE

	TweenService:Create(hatchViewport, TweenInfo.new(0.45, Enum.EasingStyle.Back), {
		Size = UDim2.new(0, 360, 0, 300),
	}):Play()

	task.spawn(function()
		while hatchPending and token == hatchToken and eggModel and eggModel.Parent and hatchOverlay.Visible do
			local elapsed = os.clock() - hatchStartedAt
			local shake = math.clamp(elapsed / 1.8, 0.25, 1.6)
			local tilt = math.sin(elapsed * 18) * math.rad(8 + 7 * shake)
			local bob = math.sin(elapsed * 9) * 0.08
			eggModel:PivotTo(CFrame.new(0, bob, 0) * CFrame.Angles(0, math.sin(elapsed * 2.2) * 0.15, tilt))

			if elapsed > 1.05 then
				hatchText.Text = "CRACKING"
				for _, part in ipairs(eggModel:GetDescendants()) do
					if part:IsA("BasePart") and part:GetAttribute("Crack") then
						part.Transparency = 0
					end
				end
			end

			task.wait()
		end
	end)
end

local function revealHatch(entry)
	local token = hatchToken
	local pet = entry and PetData.Pets[entry.petId]
	if not pet then
		hatchOverlay.Visible = false
		updateHatchFocusState()
		clearHatchWorld()
		finishHatchLock(token)
		return
	end

	local revealDelay = math.max(0, 2.25 - (os.clock() - hatchStartedAt))
	if revealDelay > 0 then
		task.wait(revealDelay)
	end
	if token ~= hatchToken then
		return
	end

	hatchPending = false
	local rarityColor = RARITY_COLOR[entry.rarity] or WHITE
	local hasMutation = entry.hasMutation == true
	prepareHatchResult(entry, pet, rarityColor, hasMutation)

	hatchText.Text = "CRACK!"
	hatchText.TextColor3 = rarityColor
	TweenService:Create(hatchViewport, TweenInfo.new(0.18, Enum.EasingStyle.Back), {
		Size = UDim2.new(0, 410, 0, 330),
	}):Play()
	task.wait(0.25)
	if token ~= hatchToken then
		return
	end

	clearHatchWorld()
	local petModel = createPetViewportModel(entry)
	if petModel and petModel.PrimaryPart then
		petModel:PivotTo(CFrame.new(0, -0.15, 0) * CFrame.Angles(0, math.rad(180), 0))
	end

	hatchViewport.Size = UDim2.new(0, 150, 0, 130)
	TweenService:Create(hatchViewport, TweenInfo.new(0.46, Enum.EasingStyle.Back), {
		Size = UDim2.new(0, 390, 0, 310),
	}):Play()

	hatchText.Text = hasMutation and (string.upper(tostring(entry.mutationName or "Mutation")) .. " MUTATION!") or "YOU HATCHED!"
	hatchText.TextColor3 = rarityColor
	revealPreparedHatchResult()

	local spinConnection
	if petModel and petModel.PrimaryPart then
		local startTime = os.clock()
		spinConnection = RunService.RenderStepped:Connect(function()
			if token ~= hatchToken or not petModel.Parent or not petModel.PrimaryPart then
				if spinConnection then
					spinConnection:Disconnect()
				end
				return
			end

			local elapsed = os.clock() - startTime
			local y = -0.12 + math.sin(elapsed * 3.2) * 0.08
			petModel:PivotTo(CFrame.new(0, y, 0) * CFrame.Angles(0, math.rad(180) + elapsed * 1.4, 0))
		end)
	end

	for i = 1, 24 do
		local spark = Instance.new("Frame")
		spark.AnchorPoint = Vector2.new(0.5, 0.5)
		spark.Size = UDim2.new(0, math.random(7, 13), 0, math.random(7, 13))
		spark.Position = UDim2.new(0.5, 0, 0.46, 0)
		spark.BackgroundColor3 = i % 3 == 0 and WHITE or rarityColor
		spark.BorderSizePixel = 0
		spark.ZIndex = 912
		spark.Parent = hatchOverlay
		local corner = Instance.new("UICorner")
		corner.CornerRadius = UDim.new(1, 0)
		corner.Parent = spark
		local angle = math.rad((360 / 24) * i)
		local distance = math.random(105, 205)
		TweenService:Create(spark, TweenInfo.new(0.72, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
			Position = UDim2.new(0.5, math.cos(angle) * distance, 0.46, math.sin(angle) * distance),
			BackgroundTransparency = 1,
			Size = UDim2.new(0, 2, 0, 2),
		}):Play()
		Debris:AddItem(spark, 0.85)
	end

	task.delay(3.2, function()
		if token ~= hatchToken then
			return
		end
		if spinConnection then
			spinConnection:Disconnect()
		end
		clearHatchWorld()
		hatchViewport.Visible = false
		hatchOverlay.Visible = false
		hideHatchResult()
		finishHatchLock(token)
		updateHatchFocusState()
	end)
end

local function toggleShop(open, eggId)
	if eggId and PetData.Eggs[eggId] then
		selectedEggId = eggId
	elseif open then
		selectedEggId = selectedEggId or chooseBestUnlockedEgg()
	end

	isOpen = open
	modalBackdrop.Visible = open
	panel.Visible = open
	if open then
		setWorldGuisHidden(true)
		selectEgg(selectedEggId or chooseBestUnlockedEgg())
		panel.Size = UDim2.new(0, PANEL_WIDTH, 0, 70)
		panel.Position = UDim2.fromScale(0.5, 0.5)
		TweenService:Create(panel, TweenInfo.new(0.26, Enum.EasingStyle.Back), {
			Size = UDim2.new(0, PANEL_WIDTH, 0, PANEL_HEIGHT),
			Position = UDim2.fromScale(0.5, 0.5),
		}):Play()
	else
		if not isHatching then
			hatchToken += 1
			hatchPending = false
			hatchOverlay.Visible = false
			updateHatchFocusState()
			hatchViewport.Visible = false
			hideHatchResult()
			clearHatchWorld()
		end
		setWorldGuisHidden(false)
	end
end

modalBackdrop.MouseButton1Click:Connect(function()
	toggleShop(false)
end)

closeBtn.MouseButton1Click:Connect(function()
	toggleShop(false)
end)

local function requestHatch(eggId, fromAutoHatch)
	if isHatching or hatchPending then
		if not fromAutoHatch then
			setHatchButtonState(getSelectedEggUnlocked())
		end
		return false
	end
	if autoHatchEnabled and not fromAutoHatch then
		setHatchButtonState(getSelectedEggUnlocked())
		return false
	end

	local targetEggId = eggId or selectedEggId
	local egg = PetData.Eggs[targetEggId]
	if not egg then
		return false
	end
	if not isEggUnlocked(egg) then
		showError("UNLOCK " .. tostring(egg.areaColor))
		return false
	end

	selectedEggId = targetEggId
	UIManager.closeAll("Eggs")
	setHatchingLocked(true)
	startHatchAnimation(targetEggId)
	hatchEvent:FireServer(targetEggId)
	return true
end

hatchBtn.MouseButton1Click:Connect(function()
	requestHatch(selectedEggId)
end)

local function hookProximityPrompt(obj)
	if obj:IsA("ProximityPrompt")
		and (obj:GetAttribute("EggShopPrompt") or obj.Name == "EggShopPrompt" or obj.ObjectText == "Egg Shop" or obj.ObjectText == "Starter Egg")
	then
		configureEggPrompt(obj)
		obj.Triggered:Connect(function(triggeringPlayer)
			if triggeringPlayer ~= player then
				return
			end

			local parent = obj.Parent
			local eggId = parent and parent:GetAttribute("EggId")
			requestHatch(eggId or chooseBestUnlockedEgg())
		end)
	end
end

for _, obj in ipairs(workspace:GetDescendants()) do
	hookProximityPrompt(obj)
	if obj:IsA("BasePart") and obj:GetAttribute("EggId") then
		createEggOptionsGui(obj)
	end
end
workspace.DescendantAdded:Connect(function(obj)
	hookProximityPrompt(obj)
	if obj:IsA("BasePart") and obj:GetAttribute("EggId") then
		createEggOptionsGui(obj)
	end
	if isOpen and (obj:IsA("BillboardGui") or obj:IsA("SurfaceGui")) and obj.Enabled then
		hiddenWorldGuis[obj] = true
		obj.Enabled = false
	end
end)

local function stopAutoHatch()
	autoHatchEnabled = false
	setHatchButtonState(getSelectedEggUnlocked())
	setEggOptionsVisible(currentNearbyEgg)
	updateHatchFocusState()
end

local function startAutoHatch()
	if autoHatchEnabled then
		stopAutoHatch()
		return
	end
	if autoHatchRunning then
		return
	end

	local eggPart = currentNearbyEgg
	local eggId = getEggIdFromPart(eggPart)
	if not eggId or not PetData.Eggs[eggId] then
		return
	end

	autoHatchEnabled = true
	autoHatchRunning = true
	updateHatchFocusState()
	setHatchButtonState(getSelectedEggUnlocked())
	setEggOptionsVisible(eggPart)

	autoHatchThread = task.spawn(function()
		while autoHatchEnabled do
			if currentNearbyEgg ~= eggPart or not eggPart.Parent then
				break
			end

			local autoDelay = tonumber(GameBalance.AutoHatchDelay) or 2.6
			if not isHatching and not hatchPending and os.clock() - lastAutoHatchAt >= autoDelay then
				lastAutoHatchAt = os.clock()
				local started = requestHatch(eggId, true)
				if not started and not isHatching then
					autoHatchEnabled = false
					break
				end
			end

			task.wait(0.15)
		end

		autoHatchEnabled = false
		autoHatchRunning = false
		autoHatchThread = nil
		updateHatchFocusState()
		setHatchButtonState(getSelectedEggUnlocked())
		setEggOptionsVisible(currentNearbyEgg)
	end)
end

stopAutoButton.MouseButton1Click:Connect(function()
	stopAutoHatch()
end)

local lastEggScanAt = 0
RunService.RenderStepped:Connect(function()
	if os.clock() - lastEggScanAt < 0.12 then
		return
	end
	lastEggScanAt = os.clock()

	local nearestEgg = findNearestEggPart()
	if nearestEgg ~= currentNearbyEgg then
		currentNearbyEgg = nearestEgg
		if not currentNearbyEgg then
			stopAutoHatch()
		end
	end
	setEggOptionsVisible(currentNearbyEgg)
end)

UserInputService.InputBegan:Connect(function(input, gameProcessed)
	if gameProcessed or UserInputService:GetFocusedTextBox() then
		return
	end

	if input.KeyCode == Enum.KeyCode.E and currentNearbyEgg then
		local eggId = getEggIdFromPart(currentNearbyEgg)
		requestHatch(eggId or chooseBestUnlockedEgg())
	elseif input.KeyCode == Enum.KeyCode.R and currentNearbyEgg then
		startAutoHatch()
	end
end)

hatchEvent.OnClientEvent:Connect(function(success, entry, message)
	if not isHatching and not hatchPending and not hatchOverlay.Visible then
		return
	end

	if not success then
		stopAutoHatch()
		hatchPending = false
		showError(message or "CAN'T HATCH")
		finishHatchLock()
		return
	end

	revealHatch(entry)
end)

unlockedColors:GetPropertyChangedSignal("Value"):Connect(function()
	refreshWorldRows()
	selectEgg(selectedEggId or chooseBestUnlockedEgg())
end)

selectEgg(selectedEggId or chooseBestUnlockedEgg())

UIManager.register("Eggs",
	function()
		if currentNearbyEgg then
			requestHatch(getEggIdFromPart(currentNearbyEgg) or chooseBestUnlockedEgg())
		end
	end,
	function()
		toggleShop(false)
	end,
	function()
		return isOpen
	end
)

openEggShopEvent.Event:Connect(function(eggId)
	requestHatch(eggId or chooseBestUnlockedEgg())
end)
]]></string>
          </Properties>
        </Item>
        <Item class="LocalScript" referent="88">
          <Properties>
            <string name="Name">GamepassUI</string>
            <string name="Source"><![CDATA[-- GamepassUI.client.luau
local MarketplaceService = game:GetService("MarketplaceService")
local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local TweenService = game:GetService("TweenService")

local player = Players.LocalPlayer
local UIManager = require(ReplicatedStorage:WaitForChild("UIManager"))
local RobuxShopConfig = require(ReplicatedStorage:WaitForChild("RobuxShopConfig"))
local UITheme = require(ReplicatedStorage:WaitForChild("UITheme"))
local ClientUIRoot = require(ReplicatedStorage:WaitForChild("ClientUIRoot"))

local DARK = UITheme.Colors.OutlineDark
local WHITE = UITheme.Colors.TextWhite
local CYAN = UITheme.Colors.PrimaryCyan
local GREEN = UITheme.Colors.PrimaryGreen
local RED = UITheme.Colors.ErrorRed
local PANEL = UITheme.Colors.PanelCream
local TEXT_DARK = Color3.fromRGB(66, 52, 86)
local TEXT_BODY = Color3.fromRGB(90, 82, 110)
local PANEL_WIDTH = 780
local PANEL_HEIGHT = 600

local PASS_THEME = {
	AutoSell = {
		accent = Color3.fromRGB(255, 199, 87),
		button = Color3.fromRGB(255, 174, 72),
		icon = Color3.fromRGB(255, 211, 112),
	},
	Plus3Colors = {
		accent = Color3.fromRGB(114, 203, 255),
		button = Color3.fromRGB(88, 174, 255),
		icon = Color3.fromRGB(155, 224, 255),
	},
	DoubleCoins = {
		accent = Color3.fromRGB(255, 221, 84),
		button = Color3.fromRGB(255, 196, 54),
		icon = Color3.fromRGB(255, 230, 128),
	},
	VIP = {
		accent = Color3.fromRGB(193, 155, 255),
		button = Color3.fromRGB(177, 141, 255),
		icon = Color3.fromRGB(215, 190, 255),
	},
	LuckyHatch = {
		accent = Color3.fromRGB(128, 239, 150),
		button = Color3.fromRGB(91, 228, 126),
		icon = Color3.fromRGB(178, 250, 190),
	},
	SupportDev = {
		accent = Color3.fromRGB(255, 162, 196),
		button = Color3.fromRGB(255, 105, 165),
		icon = Color3.fromRGB(255, 207, 225),
	},
}

local ownedPasses = {}

local screenGui = ClientUIRoot.GetLayer(player.PlayerGui, "GamepassUI")

local overlay = UITheme.CreateDimOverlay(screenGui, 50)

local panel = Instance.new("Frame")
panel.Name = "GamepassPanel"
panel.AnchorPoint = Vector2.new(0.5, 0.5)
panel.Size = UDim2.new(0, PANEL_WIDTH, 0, PANEL_HEIGHT)
panel.Position = UDim2.fromScale(0.5, 0.5)
panel.BackgroundColor3 = PANEL
panel.BorderSizePixel = 0
panel.Visible = false
panel.ZIndex = 60
panel.Parent = screenGui
UITheme.ApplyResponsiveScale(panel, PANEL_WIDTH, PANEL_HEIGHT, 0.6, 28)
Instance.new("UICorner", panel).CornerRadius = UDim.new(0, 24)
local panelStroke = Instance.new("UIStroke")
panelStroke.Color = DARK
panelStroke.Thickness = 5
panelStroke.Parent = panel
local panelShadow = Instance.new("Frame")
panelShadow.Name = "PanelShadow"
panelShadow.AnchorPoint = Vector2.new(0.5, 0.5)
panelShadow.Size = UDim2.new(0, PANEL_WIDTH, 0, PANEL_HEIGHT)
panelShadow.Position = UDim2.new(0.5, 7, 0.5, 7)
panelShadow.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
panelShadow.BackgroundTransparency = 0.78
panelShadow.BorderSizePixel = 0
panelShadow.ZIndex = 59
panelShadow.Visible = false
panelShadow.Parent = screenGui
UITheme.ApplyResponsiveScale(panelShadow, PANEL_WIDTH, PANEL_HEIGHT, 0.6, 28)
Instance.new("UICorner", panelShadow).CornerRadius = UDim.new(0, 24)

local header = Instance.new("Frame")
header.Size = UDim2.new(1, 0, 0, 72)
header.BackgroundColor3 = CYAN
header.BorderSizePixel = 0
header.Parent = panel
Instance.new("UICorner", header).CornerRadius = UDim.new(0, 24)

local title = Instance.new("TextLabel")
title.Size = UDim2.new(1, -92, 1, 0)
title.Position = UDim2.new(0, 26, 0, 0)
title.BackgroundTransparency = 1
title.Font = Enum.Font.LuckiestGuy
title.TextSize = 33
title.TextColor3 = WHITE
title.TextStrokeTransparency = 0.25
title.TextStrokeColor3 = DARK
title.TextXAlignment = Enum.TextXAlignment.Left
title.Text = "GAMEPASSES"
title:SetAttribute("NoTextGlow", true)
title.Parent = header
UITheme.ApplyTextSizeConstraint(title, 24, 34)

local closeBtn = Instance.new("TextButton")
closeBtn.Size = UDim2.new(0, 44, 0, 44)
closeBtn.Position = UDim2.new(1, -60, 0.5, -22)
closeBtn.BackgroundColor3 = RED
closeBtn.AutoButtonColor = false
closeBtn.Font = Enum.Font.LuckiestGuy
closeBtn.TextSize = 25
closeBtn.TextColor3 = WHITE
closeBtn.TextStrokeTransparency = 0
closeBtn.TextStrokeColor3 = DARK
closeBtn.Text = "X"
closeBtn:SetAttribute("NoTextGlow", true)
closeBtn.Parent = header
Instance.new("UICorner", closeBtn).CornerRadius = UDim.new(0, 14)
local closeStroke = Instance.new("UIStroke")
closeStroke.Color = DARK
closeStroke.Thickness = 4
closeStroke.Parent = closeBtn

local backBtn = Instance.new("TextButton")
backBtn.Size = UDim2.new(0, 44, 0, 44)
backBtn.Position = UDim2.new(0, 16, 0.5, -22)
backBtn.BackgroundColor3 = UITheme.Colors.PanelCream
backBtn.AutoButtonColor = false
backBtn.Font = Enum.Font.LuckiestGuy
backBtn.TextSize = 27
backBtn.TextColor3 = DARK
backBtn.TextStrokeTransparency = 1
backBtn.Text = "<"
backBtn.Visible = false
backBtn:SetAttribute("NoTextGlow", true)
backBtn.Parent = header
Instance.new("UICorner", backBtn).CornerRadius = UDim.new(0, 14)
local backStroke = Instance.new("UIStroke")
backStroke.Color = DARK
backStroke.Thickness = 4
backStroke.Parent = backBtn

local status = Instance.new("TextLabel")
status.Size = UDim2.new(1, -44, 0, 42)
status.Position = UDim2.new(0, 22, 0, 84)
status.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
status.BackgroundTransparency = 0.08
status.BorderSizePixel = 0
status.Font = Enum.Font.GothamBold
status.TextSize = 15
status.TextColor3 = TEXT_BODY
status.TextXAlignment = Enum.TextXAlignment.Left
status.Text = "Support the game and unlock permanent perks."
status:SetAttribute("NoTextGlow", true)
status.ZIndex = 61
status.Parent = panel
Instance.new("UICorner", status).CornerRadius = UDim.new(0, 14)
local statusStroke = Instance.new("UIStroke")
statusStroke.Color = Color3.fromRGB(224, 210, 246)
statusStroke.Thickness = 2
statusStroke.Parent = status
local statusPad = Instance.new("UIPadding")
statusPad.PaddingLeft = UDim.new(0, 14)
statusPad.PaddingRight = UDim.new(0, 14)
statusPad.Parent = status

local list = Instance.new("ScrollingFrame")
list.Size = UDim2.new(1, -40, 1, -146)
list.Position = UDim2.new(0, 20, 0, 134)
list.BackgroundTransparency = 1
list.BorderSizePixel = 0
list.ScrollBarThickness = 6
list.ScrollBarImageColor3 = Color3.fromRGB(112, 96, 146)
list.CanvasSize = UDim2.new(0, 0, 0, 0)
list.AutomaticCanvasSize = Enum.AutomaticSize.Y
list.ZIndex = 61
list.Parent = panel

local layout = Instance.new("UIListLayout")
layout.Padding = UDim.new(0, 16)
layout.SortOrder = Enum.SortOrder.LayoutOrder
layout.Parent = list

local listPadding = Instance.new("UIPadding")
listPadding.PaddingTop = UDim.new(0, 16)
listPadding.PaddingBottom = UDim.new(0, 18)
listPadding.PaddingLeft = UDim.new(0, 16)
listPadding.PaddingRight = UDim.new(0, 16)
listPadding.Parent = list

local function formatPrice(price)
	return tostring(tonumber(price) or 0) .. " ROBUX"
end

local function applyModalLayer()
	panel.ZIndex = 60
	for _, obj in ipairs(panel:GetDescendants()) do
		if obj:IsA("GuiObject") and obj.ZIndex < 61 then
			obj.ZIndex = 61
		end
	end
	closeBtn.ZIndex = 70
end

local function checkOwned(pass)
	if not pass.gamepassId or pass.gamepassId <= 0 then
		ownedPasses[pass.id] = false
		return false
	end

	if ownedPasses[pass.id] ~= nil then
		return ownedPasses[pass.id]
	end

	local ok, result = pcall(function()
		return MarketplaceService:UserOwnsGamePassAsync(player.UserId, pass.gamepassId)
	end)
	ownedPasses[pass.id] = ok and result == true
	return ownedPasses[pass.id]
end

local function clearCards()
	for _, child in ipairs(list:GetChildren()) do
		if not child:IsA("UIListLayout") and not child:IsA("UIPadding") then
			child:Destroy()
		end
	end
end

local function addCorner(parent, radius)
	Instance.new("UICorner", parent).CornerRadius = UDim.new(0, radius)
end

local function addStroke(parent, color, thickness)
	local stroke = Instance.new("UIStroke")
	stroke.Color = color
	stroke.Thickness = thickness
	stroke.Parent = parent
	return stroke
end

local function makeIconLabel(parent, text, size, position, textSize, color, strokeColor)
	local label = Instance.new("TextLabel")
	label.Size = size
	label.Position = position
	label.BackgroundTransparency = 1
	label.Font = Enum.Font.LuckiestGuy
	label.Text = text
	label.TextSize = textSize
	label.TextColor3 = color or WHITE
	label.TextStrokeTransparency = 0
	label.TextStrokeColor3 = strokeColor or DARK
	label.TextScaled = false
	label.ZIndex = 65
	label:SetAttribute("NoTextGlow", true)
	label.Parent = parent
	return label
end

local function makeRoundedIconPart(parent, name, size, position, color, radius, zIndex)
	local part = Instance.new("Frame")
	part.Name = name
	part.Size = size
	part.Position = position
	part.BackgroundColor3 = color
	part.BorderSizePixel = 0
	part.ZIndex = zIndex or 64
	part.Parent = parent
	addCorner(part, radius)
	return part
end

local function makeCircle(parent, name, size, position, color, zIndex)
	local circle = makeRoundedIconPart(parent, name, size, position, color, 999, zIndex)
	addStroke(circle, DARK, 3)
	local shine = makeRoundedIconPart(circle, "Shine", UDim2.fromScale(0.32, 0.22), UDim2.fromScale(0.17, 0.14), Color3.fromRGB(255, 255, 255), 999, (zIndex or 64) + 1)
	shine.BackgroundTransparency = 0.22
	return circle
end

local function createGamepassIcon(parent, pass, accent)
	local block = Instance.new("Frame")
	block.Name = pass.id .. "Icon"
	block.Size = UDim2.new(0, 96, 0, 96)
	block.Position = UDim2.new(0, 18, 0.5, -48)
	block.BackgroundColor3 = (PASS_THEME[pass.id] and PASS_THEME[pass.id].icon or accent):Lerp(WHITE, 0.16)
	block.BorderSizePixel = 0
	block.ClipsDescendants = true
	block.ZIndex = 64
	block.Parent = parent
	addCorner(block, 18)
	addStroke(block, DARK, 3)

	local glow = Instance.new("Frame")
	glow.Name = "IconGlow"
	glow.Size = UDim2.new(1, 10, 1, 10)
	glow.Position = UDim2.new(0, -5, 0, -5)
	glow.BackgroundColor3 = accent
	glow.BackgroundTransparency = 0.82
	glow.BorderSizePixel = 0
	glow.ZIndex = 63
	glow.Parent = parent
	addCorner(glow, 22)

	if pass.iconImage and tostring(pass.iconImage) ~= "" then
		local image = Instance.new("ImageLabel")
		image.Size = UDim2.new(1, -10, 1, -10)
		image.Position = UDim2.new(0, 5, 0, 5)
		image.BackgroundTransparency = 1
		image.Image = tostring(pass.iconImage)
		image.ScaleType = Enum.ScaleType.Fit
		image.ZIndex = 65
		image.Parent = block
		return block
	end

	local id = pass.id
	if id == "AutoSell" then
		local bucket = makeRoundedIconPart(block, "PaintBucket", UDim2.new(0, 50, 0, 48), UDim2.new(0, 14, 0, 34), Color3.fromRGB(247, 249, 255), 10)
		addStroke(bucket, DARK, 3)
		makeRoundedIconPart(bucket, "PaintRed", UDim2.new(0.25, 0, 0, 16), UDim2.new(0, 0, 0, 0), Color3.fromRGB(255, 80, 100), 5, 65)
		makeRoundedIconPart(bucket, "PaintBlue", UDim2.new(0.25, 0, 0, 16), UDim2.new(0.25, 0, 0, 0), Color3.fromRGB(64, 178, 255), 5, 65)
		makeRoundedIconPart(bucket, "PaintGreen", UDim2.new(0.25, 0, 0, 16), UDim2.new(0.5, 0, 0, 0), Color3.fromRGB(78, 225, 92), 5, 65)
		makeRoundedIconPart(bucket, "PaintYellow", UDim2.new(0.25, 0, 0, 16), UDim2.new(0.75, 0, 0, 0), Color3.fromRGB(255, 224, 70), 5, 65)
		makeCircle(block, "Coin", UDim2.new(0, 28, 0, 28), UDim2.new(0, 55, 0, 54), Color3.fromRGB(255, 218, 74), 66)
		makeIconLabel(block, "$", UDim2.new(0, 28, 0, 28), UDim2.new(0, 55, 0, 54), 20, Color3.fromRGB(255, 255, 190), Color3.fromRGB(174, 111, 20))
	elseif id == "Plus3Colors" then
		makeCircle(block, "RedColor", UDim2.new(0, 36, 0, 36), UDim2.new(0, 12, 0, 21), Color3.fromRGB(255, 83, 92), 64)
		makeCircle(block, "GreenColor", UDim2.new(0, 36, 0, 36), UDim2.new(0, 42, 0, 26), Color3.fromRGB(82, 230, 84), 64)
		makeCircle(block, "BlueColor", UDim2.new(0, 36, 0, 36), UDim2.new(0, 26, 0, 52), Color3.fromRGB(77, 177, 255), 64)
		makeIconLabel(block, "+3", UDim2.new(1, 0, 0, 34), UDim2.new(0, 0, 1, -38), 31, WHITE, DARK)
	elseif id == "DoubleCoins" then
		makeCircle(block, "CoinBack", UDim2.new(0, 36, 0, 36), UDim2.new(0, 12, 0, 43), Color3.fromRGB(255, 194, 45), 64)
		makeCircle(block, "CoinMid", UDim2.new(0, 42, 0, 42), UDim2.new(0, 36, 0, 38), Color3.fromRGB(255, 218, 74), 65)
		makeIconLabel(block, "2x", UDim2.new(1, 0, 0, 52), UDim2.new(0, 0, 0, 8), 39, Color3.fromRGB(255, 247, 168), DARK)
	elseif id == "VIP" then
		local crownBase = makeRoundedIconPart(block, "CrownBase", UDim2.new(0, 56, 0, 18), UDim2.new(0, 18, 0, 62), Color3.fromRGB(255, 198, 35), 7)
		addStroke(crownBase, DARK, 3)
		makeCircle(block, "CrownLeft", UDim2.new(0, 22, 0, 22), UDim2.new(0, 13, 0, 28), Color3.fromRGB(255, 226, 65), 64)
		makeCircle(block, "CrownCenter", UDim2.new(0, 28, 0, 28), UDim2.new(0, 32, 0, 17), Color3.fromRGB(255, 226, 65), 65)
		makeCircle(block, "CrownRight", UDim2.new(0, 22, 0, 22), UDim2.new(0, 57, 0, 28), Color3.fromRGB(255, 226, 65), 64)
		makeIconLabel(block, "VIP", UDim2.new(1, 0, 0, 34), UDim2.new(0, 0, 1, -36), 27, Color3.fromRGB(255, 255, 180), DARK)
	elseif id == "LuckyHatch" then
		local egg = makeRoundedIconPart(block, "Egg", UDim2.new(0, 48, 0, 58), UDim2.new(0, 22, 0, 20), Color3.fromRGB(255, 249, 240), 999)
		addStroke(egg, DARK, 3)
		makeRoundedIconPart(egg, "EggPink", UDim2.new(0.4, 0, 0.6, 0), UDim2.new(0, 0, 0, 0), Color3.fromRGB(255, 82, 176), 999, 65)
		makeRoundedIconPart(egg, "EggBlue", UDim2.new(0.4, 0, 0.6, 0), UDim2.new(0.28, 0, 0, 0), Color3.fromRGB(82, 198, 255), 999, 65)
		makeRoundedIconPart(egg, "EggGreen", UDim2.new(0.44, 0, 0.6, 0), UDim2.new(0.58, 0, 0, 0), Color3.fromRGB(90, 232, 90), 999, 65)
		makeIconLabel(block, "*", UDim2.new(0, 32, 0, 32), UDim2.new(0, 52, 0, 14), 32, Color3.fromRGB(255, 234, 78), DARK)
	elseif id == "SupportDev" then
		makeIconLabel(block, "<3", UDim2.new(1, 0, 0, 52), UDim2.new(0, 0, 0, 21), 38, Color3.fromRGB(255, 86, 136), DARK)
		makeCircle(block, "SparkLeft", UDim2.new(0, 16, 0, 16), UDim2.new(0, 15, 0, 18), Color3.fromRGB(255, 225, 235), 64)
		makeCircle(block, "SparkRight", UDim2.new(0, 14, 0, 14), UDim2.new(0, 67, 0, 70), Color3.fromRGB(255, 225, 235), 64)
	else
		makeIconLabel(block, tostring(pass.icon or ""), UDim2.new(1, 0, 1, 0), UDim2.fromOffset(0, 0), 34, WHITE, DARK)
	end

	return block
end

local function buildPassCard(pass, order)
	local owned = checkOwned(pass)
	local theme = PASS_THEME[pass.id] or {}
	local accent = theme.accent or pass.color or GREEN
	local buttonColor = theme.button or accent
	local needsId = not pass.gamepassId or pass.gamepassId <= 0

	local card = Instance.new("Frame")
	card.Name = pass.id .. "Card"
	card.LayoutOrder = order
	card.Size = UDim2.new(1, 0, 0, 128)
	card.BackgroundColor3 = WHITE:Lerp(accent, 0.05)
	card.BorderSizePixel = 0
	card.ZIndex = 61
	card.Parent = list
	Instance.new("UICorner", card).CornerRadius = UDim.new(0, 18)
	local stroke = Instance.new("UIStroke")
	stroke.Color = owned and GREEN or DARK
	stroke.Thickness = owned and 4 or 3
	stroke.Parent = card

	local accentStrip = Instance.new("Frame")
	accentStrip.Name = "AccentStrip"
	accentStrip.Size = UDim2.new(0, 9, 1, -18)
	accentStrip.Position = UDim2.new(0, 8, 0, 9)
	accentStrip.BackgroundColor3 = accent
	accentStrip.BorderSizePixel = 0
	accentStrip.ZIndex = 62
	accentStrip.Parent = card
	Instance.new("UICorner", accentStrip).CornerRadius = UDim.new(0, 8)

	local highlight = Instance.new("Frame")
	highlight.Name = "GlossHighlight"
	highlight.Size = UDim2.new(1, -34, 0, 30)
	highlight.Position = UDim2.new(0, 17, 0, 10)
	highlight.BackgroundColor3 = WHITE
	highlight.BackgroundTransparency = 0.68
	highlight.BorderSizePixel = 0
	highlight.ZIndex = 62
	highlight.Parent = card
	Instance.new("UICorner", highlight).CornerRadius = UDim.new(0, 14)

	createGamepassIcon(card, pass, accent)

	local name = Instance.new("TextLabel")
	name.Size = UDim2.new(1, -300, 0, 30)
	name.Position = UDim2.new(0, 130, 0, 18)
	name.BackgroundTransparency = 1
	name.Font = Enum.Font.LuckiestGuy
	name.TextSize = 25
	name.TextColor3 = TEXT_DARK
	name.TextStrokeTransparency = 1
	name.TextXAlignment = Enum.TextXAlignment.Left
	name.Text = pass.displayName
	name:SetAttribute("NoTextGlow", true)
	name.ZIndex = 65
	name.Parent = card
	UITheme.ApplyTextSizeConstraint(name, 18, 26)

	local desc = Instance.new("TextLabel")
	desc.Size = UDim2.new(1, -300, 0, 38)
	desc.Position = UDim2.new(0, 130, 0, 50)
	desc.BackgroundTransparency = 1
	desc.Font = Enum.Font.GothamBold
	desc.TextSize = 14
	desc.TextWrapped = true
	desc.TextColor3 = TEXT_BODY
	desc.TextXAlignment = Enum.TextXAlignment.Left
	desc.TextYAlignment = Enum.TextYAlignment.Top
	desc.Text = pass.description
	desc:SetAttribute("NoTextGlow", true)
	desc.ZIndex = 65
	desc.Parent = card

	local tag = Instance.new("TextLabel")
	tag.Size = UDim2.new(0, 128, 0, 24)
	tag.Position = UDim2.new(0, 130, 1, -34)
	tag.BackgroundColor3 = accent:Lerp(WHITE, 0.34)
	tag.BorderSizePixel = 0
	tag.Font = Enum.Font.GothamBlack
	tag.TextSize = 11
	tag.TextColor3 = TEXT_DARK
	tag.TextStrokeTransparency = 1
	tag.Text = tostring(pass.badge or "PERMANENT")
	tag.TextXAlignment = Enum.TextXAlignment.Center
	tag:SetAttribute("NoTextGlow", true)
	tag.ZIndex = 65
	tag.Parent = card
	Instance.new("UICorner", tag).CornerRadius = UDim.new(0, 12)
	local tagStroke = Instance.new("UIStroke")
	tagStroke.Color = accent:Lerp(DARK, 0.18)
	tagStroke.Thickness = 2
	tagStroke.Transparency = 0.2
	tagStroke.Parent = tag

	local buy = Instance.new("TextButton")
	buy.Size = UDim2.new(0, 144, 0, 58)
	buy.Position = UDim2.new(1, -164, 0.5, -29)
	buy.BackgroundColor3 = owned and GREEN or (needsId and Color3.fromRGB(205, 210, 225) or buttonColor)
	buy.AutoButtonColor = not owned and not needsId
	buy.Font = Enum.Font.GothamBold
	buy.Text = ""
	buy.ZIndex = 65
	buy.Parent = card
	Instance.new("UICorner", buy).CornerRadius = UDim.new(0, 16)
	local buyStroke = Instance.new("UIStroke")
	buyStroke.Color = DARK
	buyStroke.Thickness = 4
	buyStroke.Parent = buy

	local buyTop = Instance.new("TextLabel")
	buyTop.Name = "BuyTop"
	buyTop.Size = UDim2.new(1, -10, 0, owned and 58 or 24)
	buyTop.Position = UDim2.new(0, 5, 0, owned and 0 or 7)
	buyTop.BackgroundTransparency = 1
	buyTop.Font = Enum.Font.LuckiestGuy
	buyTop.TextSize = owned and 19 or 18
	buyTop.TextColor3 = WHITE
	buyTop.TextStrokeTransparency = 0.55
	buyTop.TextStrokeColor3 = DARK
	buyTop.Text = owned and "OWNED" or (needsId and "SET ID" or "BUY")
	buyTop.ZIndex = 66
	buyTop:SetAttribute("NoTextGlow", true)
	buyTop.Parent = buy
	UITheme.ApplyTextSizeConstraint(buyTop, 13, owned and 20 or 18)

	if not owned then
		local price = Instance.new("TextLabel")
		price.Name = "Price"
		price.Size = UDim2.new(1, -10, 0, 24)
		price.Position = UDim2.new(0, 5, 0, 29)
		price.BackgroundTransparency = 1
		price.Font = Enum.Font.GothamBlack
		price.TextSize = 14
		price.TextColor3 = WHITE
		price.TextStrokeTransparency = 0.72
		price.TextStrokeColor3 = DARK
		price.Text = needsId and "CONFIGURE" or formatPrice(pass.price)
		price.ZIndex = 66
		price:SetAttribute("NoTextGlow", true)
		price.Parent = buy
		UITheme.ApplyTextSizeConstraint(price, 10, 14)
	end

	buy.MouseButton1Click:Connect(function()
		if owned then
			status.Text = "You already own " .. pass.displayName
			status.TextColor3 = Color3.fromRGB(35, 130, 55)
			return
		end
		if needsId then
			status.Text = "Add the real Roblox gamepass ID for " .. pass.displayName
			status.TextColor3 = RED
			return
		end
		status.Text = "Opening Roblox purchase prompt..."
		status.TextColor3 = TEXT_BODY
		MarketplaceService:PromptGamePassPurchase(player, pass.gamepassId)
	end)

	buy.MouseButton1Down:Connect(function()
		if owned or needsId then
			return
		end
		TweenService:Create(buy, TweenInfo.new(0.08), {
			Size = UDim2.new(0, 136, 0, 54),
			Position = UDim2.new(1, -160, 0.5, -27),
		}):Play()
	end)

	buy.MouseButton1Up:Connect(function()
		TweenService:Create(buy, TweenInfo.new(0.16, Enum.EasingStyle.Back), {
			Size = UDim2.new(0, 144, 0, 58),
			Position = UDim2.new(1, -164, 0.5, -29),
		}):Play()
	end)

	card.MouseEnter:Connect(function()
		TweenService:Create(card, TweenInfo.new(0.12), {
			BackgroundColor3 = WHITE:Lerp(accent, 0.1),
		}):Play()
	end)

	card.MouseLeave:Connect(function()
		TweenService:Create(card, TweenInfo.new(0.12), {
			BackgroundColor3 = WHITE:Lerp(accent, 0.05),
		}):Play()
	end)
end

local function refresh()
	clearCards()
	local passes = RobuxShopConfig.getSortedGamepasses and RobuxShopConfig.getSortedGamepasses() or (RobuxShopConfig.Gamepasses or {})
	for index, pass in ipairs(passes) do
		buildPassCard(pass, index)
	end
	list.CanvasSize = UDim2.new(0, 0, 0, layout.AbsoluteContentSize.Y + 48)
	applyModalLayer()
end

MarketplaceService.PromptGamePassPurchaseFinished:Connect(function(purchasingPlayer, gamepassId, wasPurchased)
	if purchasingPlayer ~= player then
		return
	end
	for _, pass in ipairs(RobuxShopConfig.Gamepasses or {}) do
		if pass.gamepassId == gamepassId then
			if wasPurchased then
				ownedPasses[pass.id] = true
				status.Text = "Thank you! " .. pass.displayName .. " unlocked."
				status.TextColor3 = Color3.fromRGB(35, 130, 55)
			else
				status.Text = "Purchase canceled."
				status.TextColor3 = Color3.fromRGB(100, 105, 125)
			end
			refresh()
			break
		end
	end
end)

local isOpen = false
local openedFromMenu = false
local function toggleGamepass(open, context)
	isOpen = open
	if open then
		openedFromMenu = context and context.from == "Menu" or false
		backBtn.Visible = openedFromMenu
		title.Position = openedFromMenu and UDim2.new(0, 72, 0, 0) or UDim2.new(0, 26, 0, 0)
		title.Size = openedFromMenu and UDim2.new(1, -138, 1, 0) or UDim2.new(1, -92, 1, 0)
		refresh()
		overlay.Visible = true
		overlay.BackgroundTransparency = 1
		panel.Visible = true
		panelShadow.Visible = true
		panel.Size = UDim2.new(0, 80, 0, 80)
		panel.Position = UDim2.fromScale(0.5, 0.5)
		panelShadow.Size = panel.Size
		panelShadow.Position = UDim2.new(0.5, 7, 0.5, 7)
		TweenService:Create(overlay, TweenInfo.new(0.18), {
			BackgroundTransparency = 0.4,
		}):Play()
		TweenService:Create(panel, TweenInfo.new(0.28, Enum.EasingStyle.Back), {
			Size = UDim2.new(0, PANEL_WIDTH, 0, PANEL_HEIGHT),
			Position = UDim2.fromScale(0.5, 0.5),
		}):Play()
		TweenService:Create(panelShadow, TweenInfo.new(0.28, Enum.EasingStyle.Back), {
			Size = UDim2.new(0, PANEL_WIDTH, 0, PANEL_HEIGHT),
			Position = UDim2.new(0.5, 7, 0.5, 7),
		}):Play()
	else
		openedFromMenu = false
		backBtn.Visible = false
		if context and context.immediate then
			panel.Visible = false
			panelShadow.Visible = false
			overlay.Visible = false
			overlay.BackgroundTransparency = 1
			return
		end
		TweenService:Create(overlay, TweenInfo.new(0.16), {
			BackgroundTransparency = 1,
		}):Play()
		TweenService:Create(panel, TweenInfo.new(0.16), {
			Size = UDim2.new(0, 0, 0, 0),
			Position = UDim2.fromScale(0.5, 0.5),
		}):Play()
		TweenService:Create(panelShadow, TweenInfo.new(0.16), {
			Size = UDim2.new(0, 0, 0, 0),
			Position = UDim2.new(0.5, 7, 0.5, 7),
		}):Play()
		task.delay(0.16, function()
			if not isOpen then
				panel.Visible = false
				panelShadow.Visible = false
				overlay.Visible = false
			end
		end)
	end
end

backBtn.MouseButton1Click:Connect(function()
	if openedFromMenu then
		UIManager.open("Menu")
	end
end)

closeBtn.MouseButton1Click:Connect(function()
	UIManager.close("Gamepass")
end)

overlay.MouseButton1Click:Connect(function()
	UIManager.close("Gamepass")
end)

UIManager.register("Gamepass", function(context) toggleGamepass(true, context) end, function(context) toggleGamepass(false, context) end, function() return isOpen end)

local gamepassBtn = ReplicatedStorage:WaitForChild("HudButton_GAMEPASS", 10)
if gamepassBtn then
	gamepassBtn.Event:Connect(function() UIManager.toggle("Gamepass") end)
end
]]></string>
