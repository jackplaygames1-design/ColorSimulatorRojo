local function getMenuTargetLayout(scaleOffset)
	scaleOffset = scaleOffset or 0
	if hatchFocusActive.Value then
		local size = 72 + scaleOffset
		return UDim2.new(0, size, 0, size), UDim2.new(1, -92 - scaleOffset / 2, 0.5, -size / 2)
	end

	local size = 90 + scaleOffset
	return UDim2.new(0, size, 0, size), UDim2.new(0.5, -size / 2, 1, -156 - scaleOffset / 2)
end

local function applyHatchFocusHud()
	local focused = hatchFocusActive.Value == true
	colorBarContainer.Visible = not focused
	quickButtonsContainer.Visible = not focused
	currencyContainer.Visible = not focused
	objectiveContainer.Visible = not focused
	menuButtonContainer.Visible = true

	local size, position = getMenuTargetLayout(0)
	menuBtn.Size = size
	menuBtn.Position = position
end

