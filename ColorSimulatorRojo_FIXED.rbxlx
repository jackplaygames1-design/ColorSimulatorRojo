    <Item class="ModuleScript" referent="3">
      <Properties>
        <string name="Name">ClientUIRoot</string>
        <string name="Source"><![CDATA[-- Single client UI root and legacy UI cleanup for Color Simulator.
local ClientUIRoot = {}

local UI_SCREEN_NAME = "ColorSimulatorUI"
local UI_VERSION = "PublicBeta_UI_SINGLE_SOURCE_v2"
local CLIENT_VERSION = "PublicBeta_Stability_2026_05_05"

local rootByPlayerGui = setmetatable({}, { __mode = "k" })
local watchedPlayerGuis = setmetatable({}, { __mode = "k" })
local printedClientVersion = false
local warnedLegacy = {}

local LEGACY_SCREEN_GUI_NAMES = {
	MainMenu = true,
	MenuUI = true,
	MenuGui = true,
	MainGui = true,
	HudGui = true,
	OldHudUI = true,
	OldMenuUI = true,
	OldMenuGui = true,
	Inventory = true,
	InventoryUI = true,
	InventoryGui = true,
	OldInventory = true,
	OldInventoryUI = true,
	MainInventory = true,
	MainInventoryUI = true,
	GamepassGui = true,
	PetInventoryUI = true,
	LegacyPetInventoryUI_DISABLED = true,
	EquipmentShopUI = true,
	SocialPanelUI = true,
	SocialPanelsUI = true,
}

local function warnLegacyOnce(name)
	if warnedLegacy[name] then
		return
	end
	warnedLegacy[name] = true
	warn("WARNING: Legacy UI source attempted to load")
	warn("Legacy UI source disabled: " .. name)
end

local function cleanupLegacyRoots(playerGui)
	for _, child in ipairs(playerGui:GetChildren()) do
		if child:IsA("ScreenGui") and child.Name ~= UI_SCREEN_NAME then
			if child:GetAttribute("LegacyUI") == true or LEGACY_SCREEN_GUI_NAMES[child.Name] then
				warnLegacyOnce(child.Name)
				child:Destroy()
			end
		end
	end
end

local function getCurrentRoot(playerGui)
	local currentRoot = nil
	for _, child in ipairs(playerGui:GetChildren()) do
		if child:IsA("ScreenGui") and child.Name == UI_SCREEN_NAME then
			local isCurrent = child:GetAttribute("UIScreenVersion") == UI_VERSION
			if not currentRoot and isCurrent then
				currentRoot = child
			elseif not currentRoot and child:GetAttribute("CurrentColorSimulatorUI") == true then
				currentRoot = child
			else
				warnLegacyOnce(child.Name)
				child:Destroy()
			end
		end
	end

	if currentRoot and currentRoot:GetAttribute("UIScreenVersion") ~= UI_VERSION then
		warnLegacyOnce(currentRoot.Name)
		currentRoot:Destroy()
		return nil
	end

	return currentRoot
end

function ClientUIRoot.GetRoot(playerGui)
	if not playerGui then
		return nil
	end

	cleanupLegacyRoots(playerGui)
	if not watchedPlayerGuis[playerGui] then
		watchedPlayerGuis[playerGui] = true
		playerGui.ChildAdded:Connect(function(child)
			if child:IsA("ScreenGui") then
				task.defer(function()
					if child.Parent ~= playerGui then
						return
					end
					if child.Name ~= UI_SCREEN_NAME then
						if child:GetAttribute("LegacyUI") == true or LEGACY_SCREEN_GUI_NAMES[child.Name] then
							warnLegacyOnce(child.Name)
							child:Destroy()
						end
					elseif child:GetAttribute("UIScreenVersion") ~= UI_VERSION then
						warnLegacyOnce(child.Name)
						child:Destroy()
					end
				end)
			end
		end)
	end

	local root = rootByPlayerGui[playerGui]
	if root and root.Parent == playerGui then
		return root
	end

	root = getCurrentRoot(playerGui)
	if not root then
		local existing = playerGui:FindFirstChild(UI_SCREEN_NAME)
		if existing and not existing:IsA("ScreenGui") then
			warnLegacyOnce(existing.Name)
			existing:Destroy()
		end
	end

	if not root then
		root = Instance.new("ScreenGui")
		root.Name = UI_SCREEN_NAME
		root.ResetOnSpawn = false
		root.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
		root.IgnoreGuiInset = false
		root.DisplayOrder = 1
		root.Parent = playerGui
	end

	root:SetAttribute("CurrentColorSimulatorUI", true)
	root:SetAttribute("UIScreenVersion", UI_VERSION)
	playerGui:SetAttribute("CurrentColorSimulatorUI", true)
	playerGui:SetAttribute("UIScreenVersion", UI_VERSION)

	if not printedClientVersion then
		printedClientVersion = true
		print("Color Simulator Client Version: " .. CLIENT_VERSION)
		print("Color Simulator UI Loaded: " .. UI_VERSION)
	end

	rootByPlayerGui[playerGui] = root
	return root
end

function ClientUIRoot.GetLayer(playerGui, layerName)
	local root = ClientUIRoot.GetRoot(playerGui)
	if not root then
		return nil
	end

	local layer = root:FindFirstChild(layerName)
	if layer and not layer:IsA("Frame") then
		layer:Destroy()
		layer = nil
	end

	if not layer then
		layer = Instance.new("Frame")
		layer.Name = layerName
		layer.Size = UDim2.fromScale(1, 1)
		layer.BackgroundTransparency = 1
		layer.BorderSizePixel = 0
		layer.Active = false
		layer.Parent = root
	else
		for _, child in ipairs(layer:GetChildren()) do
			child:Destroy()
		end
	end

	layer:SetAttribute("UIScreenVersion", UI_VERSION)
	return layer
end

return ClientUIRoot
]]></string>
      </Properties>
    </Item>
    <Item class="ModuleScript" referent="4">
      <Properties>
        <string name="Name">CodeData</string>
        <string name="Source"><![CDATA[-- Add weekly redeem codes here. Codes are matched case-insensitively by CodeHandler.
local CodeData = {}

CodeData.Codes = {
	RELEASE = {
		Code = "RELEASE",
		Active = true,
		MaxUsesPerPlayer = 1,
		Message = "Release reward claimed!",
		Rewards = {
			{ Type = "Coins", Amount = 1000 },
		},
	},
	COLOR = {
		Code = "COLOR",
		Active = true,
		MaxUsesPerPlayer = 1,
		Message = "Color boost claimed!",
		Rewards = {
			{ Type = "Color", Amount = 250 },
		},
	},
	PET = {
		Code = "PET",
		Active = true,
		MaxUsesPerPlayer = 1,
		Message = "Starter Color claimed!",
		Rewards = {
			{ Type = "Pet", PetId = "RedBlob", Amount = 5 },
		},
	},
}

function CodeData.normalize(code)
	return string.upper((tostring(code or ""):gsub("%s+", "")))
end

function CodeData.getCode(code)
	return CodeData.Codes[CodeData.normalize(code)]
end

return CodeData
]]></string>
      </Properties>
    </Item>
    <Item class="ModuleScript" referent="5">
      <Properties>
        <string name="Name">ColorData</string>
        <string name="Source"><![CDATA[-- ModuleScript in ReplicatedStorage named "ColorData"
local ColorData = {}

-- All color types in the game
ColorData.Colors = {
	Red    = { color = Color3.fromRGB(220, 50,  50),  order = 1 },
	Blue   = { color = Color3.fromRGB(50,  100, 220), order = 2 },
	Yellow = { color = Color3.fromRGB(240, 210, 40),  order = 3 },
	Green  = { color = Color3.fromRGB(60,  180, 80),  order = 4 },
	Purple = { color = Color3.fromRGB(140, 60,  200), order = 5 },
	Orange = { color = Color3.fromRGB(240, 130, 30),  order = 6 },
	Pink   = { color = Color3.fromRGB(255, 160, 180), order = 7 },
	Neon   = { color = Color3.fromRGB(0,   255, 200), order = 8 },
	Rainbow= { color = Color3.fromRGB(255, 255, 255), order = 9 },
	Void   = { color = Color3.fromRGB(20,  0,   40),  order = 10 },
}

-- Mixing recipes
ColorData.MixRecipes = {
	{ ingredientA = "Red",  ingredientB = "Blue",   result = "Purple",  amountNeeded = 500 },
	{ ingredientA = "Blue", ingredientB = "Yellow", result = "Green",   amountNeeded = 500 },
	{ ingredientA = "Red",  ingredientB = "Yellow", result = "Orange",  amountNeeded = 500 },
}

-- Worlds / zones
ColorData.Worlds = {
	{ id = "Red",     name = "Starter Field",  unlockCost = 0,       primaryColor = "Red",     breakableHealth = 10,   blobCount = 82,  rewardMultiplier = 1,   colorValueMultiplier = 1   },
	{ id = "Orange",  name = "Orange Grove",   unlockCost = 2500,    primaryColor = "Orange",  breakableHealth = 38,   blobCount = 86,  rewardMultiplier = 2,   colorValueMultiplier = 2   },
	{ id = "Blue",    name = "Blue Beach",     unlockCost = 2500,    primaryColor = "Blue",    breakableHealth = 55,   blobCount = 88,  rewardMultiplier = 3,   colorValueMultiplier = 3   },
	{ id = "Yellow",  name = "Yellow Desert",  unlockCost = 18000,   primaryColor = "Yellow",  breakableHealth = 140,  blobCount = 94,  rewardMultiplier = 7,   colorValueMultiplier = 8   },
	{ id = "Green",   name = "Green Forest",   unlockCost = 85000,   primaryColor = "Green",   breakableHealth = 320,  blobCount = 100, rewardMultiplier = 18,  colorValueMultiplier = 20  },
	{ id = "Purple",  name = "Purple Cavern",  unlockCost = 350000,  primaryColor = "Purple",  breakableHealth = 800,  blobCount = 106, rewardMultiplier = 55,  colorValueMultiplier = 55  },
	{ id = "Neon",    name = "Neon City",      unlockCost = 1200000, primaryColor = "Neon",    breakableHealth = 1800, blobCount = 112, rewardMultiplier = 150, colorValueMultiplier = 140 },
	{ id = "Rainbow", name = "Rainbow Heaven", unlockCost = 4000000, primaryColor = "Rainbow", breakableHealth = 4200, blobCount = 120, rewardMultiplier = 420, colorValueMultiplier = 350 },
}

function ColorData.getWorldByColor(colorType)
	for _, world in ipairs(ColorData.Worlds) do
		if world.primaryColor == colorType or world.id == colorType then
			return world
		end
	end
	return nil
end

function ColorData.getWorldIndex(colorType)
	for i, world in ipairs(ColorData.Worlds) do
		if world.primaryColor == colorType or world.id == colorType then
			return i
		end
	end
	return nil
end

function ColorData.getUnlockedColorSet(csv)
	local unlocked = {}
	if type(csv) ~= "string" then
		return unlocked
	end

	for _, colorType in ipairs(string.split(csv, ",")) do
		if colorType ~= "" then
			unlocked[colorType] = true
		end
	end

	return unlocked
end

function ColorData.isColorUnlocked(unlockedCsv, colorType)
	if not colorType or colorType == "" then
		return true
	end

	local unlocked = ColorData.getUnlockedColorSet(unlockedCsv)
	return unlocked[colorType] == true
end

function ColorData.getPreviousWorld(colorType)
	local index = ColorData.getWorldIndex(colorType)
	if not index or index <= 1 then
		return nil
	end
	return ColorData.Worlds[index - 1]
end

function ColorData.getNextLockedWorld(unlockedCsv)
	local unlocked = ColorData.getUnlockedColorSet(unlockedCsv)
	for _, world in ipairs(ColorData.Worlds) do
		if not unlocked[world.primaryColor] then
			return world
		end
	end
	return nil
end

-- Breakable object types (no rarity, just color paint)
ColorData.Breakables = {
	PaintBlob = {
		clusterSize = "Small",
		baseReward = 10,
		rewardMin = 10,
		rewardMax = 10,
		health    = 8,
		size      = Vector3.new(2, 2, 2),
	},
	PaintGlob = {
		clusterSize = "Medium",
		baseReward = 15,
		rewardMin = 15,
		rewardMax = 15,
		health    = 20,
		size      = Vector3.new(3, 3, 3),
	},
	PaintBoulder = {
		clusterSize = "Big",
		baseReward = 25,
		rewardMin = 25,
		rewardMax = 25,
		health    = 50,
		size      = Vector3.new(4.5, 4.5, 4.5),
	},
}

return ColorData
]]></string>
      </Properties>
    </Item>
    <Item class="ModuleScript" referent="6">
      <Properties>
        <string name="Name">ColorMutationData</string>
        <string name="Source"><![CDATA[local ColorMutationData = {}

ColorMutationData.NoneId = "None"

ColorMutationData.Mutations = {
	None = {
		Id = "None",
		DisplayName = "Normal",
		Description = "No mutation.",
		Chance = 0,
		PowerMultiplier = 1,
		Effects = {},
		AuraColor = Color3.fromRGB(210, 220, 235),
		VisualTag = "none",
		SortOrder = 999,
		RarityText = "Normal",
	},
	Shiny = {
		Id = "Shiny",
		DisplayName = "Shiny",
		Description = "A shiny Color with extra power.",
		Chance = 0.05,
		PowerMultiplier = 1.25,
		Effects = { ColorGainMultiplier = 1.05 },
		AuraColor = Color3.fromRGB(220, 255, 255),
		VisualTag = "sparkle",
		SortOrder = 10,
		RarityText = "Rare Mutation",
	},
	Golden = {
		Id = "Golden",
		DisplayName = "Golden",
		Description = "A golden Color that improves sell value.",
		Chance = 0.015,
		PowerMultiplier = 1.5,
		Effects = { SellCoinsMultiplier = 1.10 },
		AuraColor = Color3.fromRGB(255, 202, 58),
		VisualTag = "gold",
		SortOrder = 20,
		RarityText = "Epic Mutation",
	},
	Featherlight = {
		Id = "Featherlight",
		DisplayName = "Featherlight",
		Description = "Makes movement feel lighter.",
		Chance = 0.0125,
		PowerMultiplier = 1.35,
		Effects = { WalkSpeedBonus = 2, JumpPowerBonus = 8 },
		AuraColor = Color3.fromRGB(185, 235, 255),
		VisualTag = "featherlight",
		SortOrder = 30,
		RarityText = "Epic Mutation",
	},
	Hyper = {
		Id = "Hyper",
		DisplayName = "Hyper",
		Description = "Speeds up brushing.",
		Chance = 0.01,
		PowerMultiplier = 1.5,
		Effects = { BrushCooldownMultiplier = 0.88, BrushRangeMultiplier = 1.06 },
		AuraColor = Color3.fromRGB(255, 186, 66),
		VisualTag = "hyper",
		SortOrder = 40,
		RarityText = "Epic Mutation",
	},
	Magnetic = {
		Id = "Magnetic",
		DisplayName = "Magnetic",
		Description = "Pulls Color from farther away.",
		Chance = 0.0075,
		PowerMultiplier = 1.6,
		Effects = { BrushRangeMultiplier = 1.16, MagnetProcChance = 0.08, MagnetRange = 36 },
		AuraColor = Color3.fromRGB(105, 230, 255),
		VisualTag = "magnetic",
		SortOrder = 50,
		RarityText = "Legendary Mutation",
	},
	Rainbow = {
		Id = "Rainbow",
		DisplayName = "Rainbow",
		Description = "A rare rainbow mutation with balanced bonuses.",
		Chance = 0.005,
		PowerMultiplier = 2,
		Effects = { ColorGainMultiplier = 1.12, SellCoinsMultiplier = 1.08, HatchLuckBonus = 0.04 },
		AuraColor = Color3.fromRGB(255, 120, 220),
		VisualTag = "rainbow",
		SortOrder = 60,
		RarityText = "Mythic Mutation",
	},
	Storm = {
		Id = "Storm",
		DisplayName = "Storm",
		Description = "Strikes nearby Color blobs with lightning.",
		Chance = 0.0025,
		PowerMultiplier = 2.25,
		Effects = {
			LightningProcChance = 0.18,
			LightningTargets = 2,
			LightningRange = 42,
			LightningCooldown = 3,
		},
		AuraColor = Color3.fromRGB(95, 175, 255),
		VisualTag = "storm",
		SortOrder = 70,
		RarityText = "Secret Mutation",
	},
	Glitched = {
		Id = "Glitched",
		DisplayName = "Glitched",
		Description = "A strange unstable Color with powerful effects.",
		Chance = 0.001,
		PowerMultiplier = 3,
		Effects = {
			BrushCooldownMultiplier = 0.90,
			ColorGainMultiplier = 1.15,
			LightningProcChance = 0.12,
			LightningTargets = 2,
			LightningRange = 38,
			LightningCooldown = 3.5,
		},
		AuraColor = Color3.fromRGB(140, 245, 255),
		VisualTag = "glitch",
		SortOrder = 80,
		RarityText = "Glitched Mutation",
	},
}

ColorMutationData.LegacyAliases = {
	Sparked = "Shiny",
	Chromatic = "Rainbow",
}

ColorMutationData.RollOrder = {
	"Glitched",
	"Storm",
	"Rainbow",
	"Magnetic",
	"Hyper",
	"Featherlight",
	"Golden",
	"Shiny",
}

function ColorMutationData.get(mutationId)
	mutationId = ColorMutationData.LegacyAliases[mutationId or ""] or mutationId
	return ColorMutationData.Mutations[mutationId or ColorMutationData.NoneId]
		or ColorMutationData.Mutations[ColorMutationData.NoneId]
end

function ColorMutationData.isMutated(mutationId)
	mutationId = ColorMutationData.LegacyAliases[mutationId or ""] or mutationId
	return mutationId ~= nil and mutationId ~= "" and mutationId ~= ColorMutationData.NoneId
end

function ColorMutationData.normalize(mutationId)
	mutationId = ColorMutationData.LegacyAliases[mutationId or ""] or mutationId
	if ColorMutationData.Mutations[mutationId or ""] then
		return mutationId
	end
	return ColorMutationData.NoneId
end

function ColorMutationData.roll(luckMultiplier)
	luckMultiplier = math.clamp(tonumber(luckMultiplier) or 1, 0.5, 2.5)
	local roll = math.random()
	local cumulative = 0

	for _, mutationId in ipairs(ColorMutationData.RollOrder) do
		local mutation = ColorMutationData.Mutations[mutationId]
		cumulative += math.min(0.35, (mutation.Chance or 0) * luckMultiplier)
		if roll <= cumulative then
			return mutation
		end
	end

	return ColorMutationData.Mutations.None
end

return ColorMutationData
]]></string>
      </Properties>
    </Item>
    <Item class="ModuleScript" referent="7">
      <Properties>
        <string name="Name">ColorPersonalityData</string>
        <string name="Source"><![CDATA[local ColorPersonalityData = {}

-- Internal systems may use Pet naming, but player-facing companions are called Colors.
ColorPersonalityData.DefaultId = "Neutral"

ColorPersonalityData.Personalities = {
	Neutral = {
		Id = "Neutral",
		DisplayName = "Neutral",
		Description = "A steady Color with no special bonus.",
		Weight = 25,
		EffectType = "None",
		EffectValue = 0,
		Color = Color3.fromRGB(185, 190, 205),
		Icon = "-",
	},
	Cheerful = {
		Id = "Cheerful",
		DisplayName = "Cheerful",
		Description = "Boosts Color gained slightly.",
		Weight = 20,
		EffectType = "ColorGainMultiplier",
		EffectValue = 0.05,
		Color = Color3.fromRGB(116, 245, 42),
		Icon = "+",
	},
	Greedy = {
		Id = "Greedy",
		DisplayName = "Greedy",
		Description = "Boosts Coins from selling.",
		Weight = 20,
		EffectType = "SellMultiplier",
		EffectValue = 0.05,
		Color = Color3.fromRGB(255, 226, 92),
		Icon = "$",
	},
	Speedy = {
		Id = "Speedy",
		DisplayName = "Speedy",
		Description = "Slightly increases walk speed while equipped.",
		Weight = 15,
		EffectType = "WalkSpeedBonus",
		EffectValue = 1,
		Color = Color3.fromRGB(118, 238, 244),
		Icon = ">",
	},
	Curious = {
		Id = "Curious",
		DisplayName = "Curious",
		Description = "Slightly increases pickup range.",
		Weight = 10,
		EffectType = "PickupRangeMultiplier",
		EffectValue = 0.05,
		Color = Color3.fromRGB(170, 150, 255),
		Icon = "?",
	},
	Lucky = {
		Id = "Lucky",
		DisplayName = "Lucky",
		Description = "Slightly improves hatch luck while equipped.",
		Weight = 7,
		EffectType = "LuckBonus",
		EffectValue = 0.02,
		Color = Color3.fromRGB(140, 255, 145),
		Icon = "*",
	},
	Loyal = {
		Id = "Loyal",
		DisplayName = "Loyal",
		Description = "Slightly boosts all equipped Colors.",
		Weight = 3,
		EffectType = "TotalPowerMultiplier",
		EffectValue = 0.03,
		Color = Color3.fromRGB(255, 160, 190),
		Icon = "L",
	},
	Sleepy = {
		Id = "Sleepy",
		DisplayName = "Sleepy",
		Description = "A mellow Color. Future updates may give it merge bonuses.",
		Weight = 5,
		EffectType = "None",
		EffectValue = 0,
		Color = Color3.fromRGB(185, 175, 235),
		Icon = "Z",
	},
}

ColorPersonalityData.Order = {
	"Neutral",
	"Cheerful",
	"Greedy",
	"Speedy",
	"Curious",
	"Lucky",
	"Loyal",
	"Sleepy",
}

function ColorPersonalityData.get(personalityId)
	return ColorPersonalityData.Personalities[personalityId or ColorPersonalityData.DefaultId]
		or ColorPersonalityData.Personalities[ColorPersonalityData.DefaultId]
end

function ColorPersonalityData.roll()
	local totalWeight = 0
	for _, personalityId in ipairs(ColorPersonalityData.Order) do
		local personality = ColorPersonalityData.Personalities[personalityId]
		totalWeight += personality and personality.Weight or 0
	end

	local roll = math.random() * totalWeight
	for _, personalityId in ipairs(ColorPersonalityData.Order) do
		local personality = ColorPersonalityData.Personalities[personalityId]
		roll -= personality and personality.Weight or 0
		if roll <= 0 then
			return personality
		end
	end

	return ColorPersonalityData.Personalities.Neutral
end

return ColorPersonalityData
]]></string>
      </Properties>
    </Item>
    <Item class="ModuleScript" referent="8">
      <Properties>
        <string name="Name">ColorTraitData</string>
        <string name="Source"><![CDATA[local ColorTraitData = {}

ColorTraitData.DefaultId = "Neutral"

ColorTraitData.Traits = {
	Neutral = {
		Id = "Neutral",
		DisplayName = "Neutral",
		Description = "No special bonus.",
		Weight = 25,
		Effects = {},
		SortOrder = 1,
		TextColor = Color3.fromRGB(185, 190, 205),
		Icon = "-",
	},
	Swift = {
		Id = "Swift",
		DisplayName = "Swift",
		Description = "Slightly increases movement speed.",
		Weight = 16,
		Effects = { WalkSpeedBonus = 1.5 },
		SortOrder = 2,
		TextColor = Color3.fromRGB(118, 238, 244),
		Icon = ">",
	},
	Bouncy = {
		Id = "Bouncy",
		DisplayName = "Bouncy",
		Description = "Slightly increases jump power.",
		Weight = 12,
		Effects = { JumpPowerBonus = 6 },
		SortOrder = 3,
		TextColor = Color3.fromRGB(170, 150, 255),
		Icon = "^",
	},
	Quick = {
		Id = "Quick",
		DisplayName = "Quick",
		Description = "Brushes slightly faster.",
		Weight = 14,
		Effects = { BrushCooldownMultiplier = 0.95 },
		SortOrder = 4,
		TextColor = Color3.fromRGB(255, 170, 72),
		Icon = "Q",
	},
	Wide = {
		Id = "Wide",
		DisplayName = "Wide",
		Description = "Increases brush range.",
		Weight = 12,
		Effects = { BrushRangeMultiplier = 1.08 },
		SortOrder = 5,
		TextColor = Color3.fromRGB(91, 230, 235),
		Icon = "+",
	},
	Bright = {
		Id = "Bright",
		DisplayName = "Bright",
		Description = "Collects slightly more Color.",
		Weight = 12,
		Effects = { ColorGainMultiplier = 1.06 },
		SortOrder = 6,
		TextColor = Color3.fromRGB(255, 75, 200),
		Icon = "*",
	},
	Greedy = {
		Id = "Greedy",
		DisplayName = "Greedy",
		Description = "Sells Color for slightly more Coins.",
		Weight = 10,
		Effects = { SellCoinsMultiplier = 1.06 },
		SortOrder = 7,
		TextColor = Color3.fromRGB(255, 210, 64),
		Icon = "$",
	},
	Lucky = {
		Id = "Lucky",
		DisplayName = "Lucky",
		Description = "Slightly improves hatch luck.",
		Weight = 6,
		Effects = { HatchLuckBonus = 0.03 },
		SortOrder = 8,
		TextColor = Color3.fromRGB(91, 228, 126),
		Icon = "%",
	},
	SuperLucky = {
		Id = "SuperLucky",
		DisplayName = "Super Lucky",
		Description = "Massively improves hatch luck.",
		Weight = 0,
		Effects = { HatchLuckBonus = 1.5 },
		SortOrder = 9,
		TextColor = Color3.fromRGB(255, 235, 90),
		Icon = "%",
	},
	Charged = {
		Id = "Charged",
		DisplayName = "Charged",
		Description = "Sometimes zaps nearby Color blobs while brushing.",
		Weight = 3,
		Effects = {
			LightningProcChance = 0.08,
			LightningTargets = 1,
			LightningRange = 28,
			LightningCooldown = 4,
		},
		SortOrder = 9,
		TextColor = Color3.fromRGB(107, 218, 255),
		Icon = "Z",
	},
}

ColorTraitData.Order = {
	"Neutral",
	"Swift",
	"Bouncy",
	"Quick",
	"Wide",
	"Bright",
	"Greedy",
	"Lucky",
	"SuperLucky",
	"Charged",
}

function ColorTraitData.normalize(traitId)
	if ColorTraitData.Traits[traitId or ""] then
		return traitId
	end
	return ColorTraitData.DefaultId
end

function ColorTraitData.get(traitId)
	return ColorTraitData.Traits[ColorTraitData.normalize(traitId)]
end

function ColorTraitData.roll()
	local totalWeight = 0
	for _, traitId in ipairs(ColorTraitData.Order) do
		local trait = ColorTraitData.Traits[traitId]
		totalWeight += trait and trait.Weight or 0
	end

	local roll = math.random() * totalWeight
	for _, traitId in ipairs(ColorTraitData.Order) do
		local trait = ColorTraitData.Traits[traitId]
		roll -= trait and trait.Weight or 0
		if roll <= 0 then
			return trait
		end
	end

	return ColorTraitData.Traits.Neutral
end

return ColorTraitData
]]></string>
      </Properties>
