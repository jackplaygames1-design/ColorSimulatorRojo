screenGui.Parent = uiRoot
screenGui:SetAttribute("UIScreenVersion", UI_VERSION)
screenGui:SetAttribute("HUDVersion", HUD_VERSION)
screenGui:SetAttribute("HUDLoadedPrinted", true)
