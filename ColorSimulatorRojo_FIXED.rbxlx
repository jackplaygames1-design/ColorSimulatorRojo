          <string name="Name">LegendaryColorOrbGenerator</string>
          <token name="RunContext">0</token>
          <string name="Source"><![CDATA[local ReplicatedStorage = game:GetService("ReplicatedStorage")

local modules = ReplicatedStorage:WaitForChild("Modules")
local definitions = require(modules:WaitForChild("LegendaryColorOrbDefinitions"))
local builder = require(modules:WaitForChild("LegendaryColorOrbBuilder"))

local folder = builder.BuildAll(ReplicatedStorage, definitions)
print("LegendaryColorOrbGenerator: built " .. tostring(#definitions) .. " legendary orb pet models in " .. folder:GetFullName())
]]></string>
