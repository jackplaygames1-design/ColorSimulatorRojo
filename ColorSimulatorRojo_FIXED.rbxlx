      <Item class="Script" referent="70">
        <Properties>
          <string name="Name">SellHandler</string>
          <token name="RunContext">0</token>
          <string name="Source"><![CDATA[-- SellHandler.server.luau
local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local RunService = game:GetService("RunService")
local DEBUG_LOGS = RunService:IsStudio()

local ColorData = require(ReplicatedStorage:WaitForChild("ColorData"))
local PetData = require(ReplicatedStorage:WaitForChild("PetData"))
local GameBalance = require(ReplicatedStorage:WaitForChild("GameBalance"))
local GamepassBenefits = require(script.Parent:WaitForChild("GamepassBenefits"))
local ColorEffectHandler = require(script.Parent:WaitForChild("ColorEffectHandler"))

local Events = ReplicatedStorage:WaitForChild("Events")
local teleportToSellEvent = Events:WaitForChild("TeleportToSell")
local sellColorEvent = Events:FindFirstChild("SellColor")
local dataDirtyEvent = Events:FindFirstChild("PlayerDataDirty")
local serverSellPaint = ReplicatedStorage:FindFirstChild("ServerSellPaint")
if not serverSellPaint then
	serverSellPaint = Instance.new("BindableFunction")
	serverSellPaint.Name = "ServerSellPaint"
	serverSellPaint.Parent = ReplicatedStorage
end
local sellDebounce = {}
local unexpectedSellWarnings = {}

local function warnUnexpectedSellValuesOnce(player, action)
	local key = tostring(player and player.UserId or "server") .. ":" .. tostring(action)
	if unexpectedSellWarnings[key] then
		return
	end
	unexpectedSellWarnings[key] = true
	warn("Sell request ignored unexpected client value fields for " .. tostring(action) .. ". Server calculates Coins.")
end
local SELL_DEBOUNCE = 1.25

local SELL_DARK = Color3.fromRGB(28, 35, 42)
local SELL_GREEN = Color3.fromRGB(98, 255, 190)
local SELL_CYAN = Color3.fromRGB(118, 238, 244)
local SELL_YELLOW = Color3.fromRGB(255, 226, 92)

local function sellPartMatchesColor(part, colorType)
	if not part or not colorType then
		return false
	end

	local sellColor = part:GetAttribute("ColorType")
		or part:GetAttribute("AreaColor")
		or part:GetAttribute("SellColor")
	return sellColor == colorType
end

local function isSellPart(obj)
	return obj:IsA("BasePart")
		and (obj:GetAttribute("SellZone")
			or obj:GetAttribute("SellLocation")
			or obj.Name == "SellZone"
			or obj.Name == "Sell"
			or obj.Name == "SellPart"
			or obj.Name == "SellArea"
			or obj.Name == "SellPad"
			or string.match(obj.Name, "^World%d+_Sell$")
			or string.match(obj.Name, "SellStation$"))
end

local function findSellPart(colorType)
	local fallback = nil
	for _, obj in ipairs(workspace:GetDescendants()) do
		if isSellPart(obj) then
			fallback = fallback or obj
			if sellPartMatchesColor(obj, colorType) then
				return obj
			end
		end
	end

	return colorType == "Red" and fallback or nil
end

local function ensureSellBillboard(sellPart)
	for _, child in ipairs(sellPart:GetChildren()) do
		if child:IsA("BillboardGui") and child.Name ~= "SellZoneLabel" then
			child:Destroy()
		end
	end

	local billboard = sellPart:FindFirstChild("SellZoneLabel")
	if not billboard then
		billboard = Instance.new("BillboardGui")
		billboard.Name = "SellZoneLabel"
		billboard.AlwaysOnTop = true
		billboard.LightInfluence = 0
		billboard.MaxDistance = 190
		billboard.Size = UDim2.new(0, 310, 0, 96)
		billboard.StudsOffset = Vector3.new(0, 10.5, 0)
		billboard.Parent = sellPart
	end

	local title = billboard:FindFirstChild("Title")
	if not title then
		title = Instance.new("TextLabel")
		title.Name = "Title"
		title.BackgroundTransparency = 1
		title.Size = UDim2.new(1, 0, 0, 48)
		title.Font = Enum.Font.LuckiestGuy
		title.TextSize = 34
		title.TextColor3 = Color3.fromRGB(255, 255, 255)
		title.TextStrokeTransparency = 0
		title.TextStrokeColor3 = SELL_DARK
		title.Parent = billboard
	end
	title.Text = "SELL COLOR"

	local sub = billboard:FindFirstChild("Subtitle")
	if not sub then
		sub = Instance.new("TextLabel")
		sub.Name = "Subtitle"
		sub.BackgroundTransparency = 1
		sub.Size = UDim2.new(1, 0, 0, 28)
		sub.Position = UDim2.new(0, 0, 0, 50)
		sub.Font = Enum.Font.GothamBold
		sub.TextSize = 16
		sub.TextColor3 = Color3.fromRGB(205, 255, 236)
		sub.TextStrokeTransparency = 0.15
		sub.TextStrokeColor3 = SELL_DARK
		sub.Parent = billboard
	end
	sub.Text = "Turn Color into Coins"
end

local function makeVisualPart(root, name, size, offset, color, material, transparency)
	local part = root:FindFirstChild(name)
	if not part then
		part = Instance.new("Part")
		part.Name = name
		part.Anchored = true
		part.CanCollide = false
		part.CanTouch = false
		part.CanQuery = false
		part.CastShadow = false
		part.Parent = root
	end

	part.Size = size
	part.CFrame = root.CFrame * CFrame.new(offset)
	part.Color = color
	part.Material = material or Enum.Material.SmoothPlastic
	part.Transparency = transparency or 0
	part:SetAttribute("SellZoneDecor", true)
	return part
end

local function ensureSellVisuals(sellPart)
	for _, child in ipairs(sellPart:GetChildren()) do
		if (child:IsA("BasePart") and child:GetAttribute("SellZoneDecor"))
			or child:IsA("ParticleEmitter")
			or child:IsA("PointLight")
			or child.Name == "SellSparkles"
			or child.Name == "SellZoneLabel"
		then
			child:Destroy()
		elseif child:IsA("BillboardGui") and (child.Name == "SellZoneLabel" or child.Name == "ProximityStationLabel") then
			child:Destroy()
		end
	end

	sellPart:SetAttribute("SellZone", true)
	sellPart.Anchored = true
	sellPart.CanCollide = false
	sellPart.CanTouch = true

	local prompt = sellPart:FindFirstChild("SellPrompt")
	if not prompt then
		prompt = Instance.new("ProximityPrompt")
		prompt.Name = "SellPrompt"
		prompt.Parent = sellPart
	end
	prompt.ActionText = "Sell Color"
	prompt.ObjectText = "Sell Station"
	prompt.HoldDuration = 0
	prompt.MaxActivationDistance = 20
	prompt.RequiresLineOfSight = false

	return prompt
end

local function parseInventory(str)
	local inventory = {}
	if not str or str == "" then
		return inventory
	end

	for _, part in ipairs(string.split(str, ",")) do
		local segments = string.split(part, ":")
		local variantKey
		local petId
		local stackIndex
		if tonumber(segments[2]) then
			petId = segments[1]
			stackIndex = 2
		else
			variantKey = segments[1]
			petId = segments[2]
			stackIndex = 3
		end
		local stackAmount = tonumber(segments[stackIndex]) or 1
		local traitId = PetData.normalizeTraitId(segments[stackIndex + 1])
		local shinyStr = segments[stackIndex + 2] or "normal"
		local personalityId = PetData.normalizePersonalityId(segments[stackIndex + 3] or "Neutral")
		local mutationId = PetData.normalizeMutationId(segments[stackIndex + 4] or "None")
		variantKey = variantKey or PetData.makeVariantKey(petId, personalityId, mutationId, traitId)
		if petId and petId ~= "" then
			inventory[variantKey] = {
				petId = petId,
				stackAmount = stackAmount,
				traitId = traitId,
				isShiny = shinyStr == "shiny" or shinyStr == "true",
				personalityId = personalityId,
				mutationId = mutationId,
			}
		end
	end

	return inventory
end

local function getPetCoinMultiplier(player)
	return ColorEffectHandler.GetSellCoinsMultiplier(player)
end

local function getSellMultiplier(player)
	local multiplier = getPetCoinMultiplier(player)
	local boostFolder = player:FindFirstChild("Boosts")
	local coinBoost = boostFolder and boostFolder:FindFirstChild("coins")
	if coinBoost and os.time() < coinBoost.Value then
		multiplier *= 2
	end
	multiplier *= GamepassBenefits.getCoinMultiplier(player)

	return multiplier
end

local function isPointInside(part, worldPosition, margin)
	local localPoint = part.CFrame:PointToObjectSpace(worldPosition)
	local half = part.Size * 0.5 + Vector3.new(margin, margin, margin)
	return math.abs(localPoint.X) <= half.X
		and math.abs(localPoint.Y) <= half.Y
		and math.abs(localPoint.Z) <= half.Z
end

local function getHighestUnlockedColor(player)
	local storage = player:FindFirstChild("ColorStorage")
	local unlockedValue = storage and storage:FindFirstChild("UnlockedColors")
	local unlocked = ColorData.getUnlockedColorSet(unlockedValue and unlockedValue.Value or "Red")
	local highest = "Red"
	for _, world in ipairs(ColorData.Worlds or {}) do
		if unlocked[world.primaryColor] then
			highest = world.primaryColor
		end
	end
	return highest
end

local function getStoredCurrentWorldColor(player)
	local storage = player:FindFirstChild("ColorStorage")
	local unlockedValue = storage and storage:FindFirstChild("UnlockedColors")
	local unlockedCsv = unlockedValue and unlockedValue.Value or "Red"
	local currentWorld = storage and storage:FindFirstChild("CurrentWorld")
	local colorType = currentWorld and currentWorld.Value or player:GetAttribute("ActiveWorldColor")
	local world = ColorData.getWorldByColor(colorType)
	if world and ColorData.isColorUnlocked(unlockedCsv, world.primaryColor) then
		return world.primaryColor
	end
	return nil
end

local function setCurrentWorld(player, colorType)
	local storage = player:FindFirstChild("ColorStorage")
	local unlockedValue = storage and storage:FindFirstChild("UnlockedColors")
	if not ColorData.isColorUnlocked(unlockedValue and unlockedValue.Value or "Red", colorType) then
		return
	end

	player:SetAttribute("ActiveWorldColor", colorType)
	local currentWorld = storage and storage:FindFirstChild("CurrentWorld")
	if currentWorld and currentWorld:IsA("StringValue") and currentWorld.Value ~= colorType then
		currentWorld.Value = colorType
		if dataDirtyEvent and dataDirtyEvent:IsA("BindableEvent") then
			dataDirtyEvent:Fire(player, "current-world")
		end
	end
end

local function getCurrentSellColor(player)
	local root = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
	local storedColor = getStoredCurrentWorldColor(player)
	if root then
		local nearestColor = nil
		local nearestDistance = math.huge
		local storage = player:FindFirstChild("ColorStorage")
		local unlockedValue = storage and storage:FindFirstChild("UnlockedColors")
		local unlockedCsv = unlockedValue and unlockedValue.Value or "Red"
		for _, obj in ipairs(workspace:GetDescendants()) do
			if obj:IsA("BasePart") and obj:GetAttribute("ColorZone") and obj:GetAttribute("ColorType") then
				local colorType = obj:GetAttribute("ColorType")
				if isPointInside(obj, root.Position, 8) then
					setCurrentWorld(player, colorType)
					return colorType
				end
				if ColorData.isColorUnlocked(unlockedCsv, colorType) then
					local distance = (root.Position - obj.Position).Magnitude
					if distance < nearestDistance then
						nearestDistance = distance
						nearestColor = colorType
					end
				end
			end
		end
		if storedColor then
			return storedColor
		end
		if nearestColor then
			return nearestColor
		end
	end
	if storedColor then
		return storedColor
	end
	return getHighestUnlockedColor(player)
end

local function getZoneColorValueMultiplier(player)
	local colorType = getCurrentSellColor(player)
	local configured = GameBalance.Sell
		and GameBalance.Sell.ColorValueMultipliers
		and GameBalance.Sell.ColorValueMultipliers[colorType]
	local world = ColorData.getWorldByColor(colorType)
	return tonumber(configured or (world and world.colorValueMultiplier)) or 1, colorType or "Red"
end

local function sellPaint(player)
	local storage = player:FindFirstChild("ColorStorage")
	local stats = player:FindFirstChild("leaderstats")
	if not storage or not stats then
		return false, "Player data is not ready."
	end

	local held = storage:FindFirstChild("ColorHeld")
	local coins = stats:FindFirstChild("Coins")
	if not held or not coins or held.Value <= 0 then
		return false, "No Color to sell."
	end

	local colorSold = held.Value
	local multiplier = getSellMultiplier(player)
	local zoneMultiplier, sellColorType = getZoneColorValueMultiplier(player)
	local reward = math.floor(colorSold * GameBalance.Sell.BaseCoinsPerColor * zoneMultiplier * multiplier)
	coins.Value += reward
	held.Value = 0

	return true, {
		colorSold = colorSold,
		coinsEarned = reward,
		multiplier = multiplier,
		zoneColor = sellColorType,
		zoneMultiplier = zoneMultiplier,
		baseCoinsPerColor = GameBalance.Sell.BaseCoinsPerColor,
	}
end

serverSellPaint.OnInvoke = function(player)
	return sellPaint(player)
end

local function teleportToSell(player)
	local sellPart = findSellPart(getCurrentSellColor(player))
	local character = player.Character
	local root = character and character:FindFirstChild("HumanoidRootPart")

	if sellPart and root then
		root.CFrame = sellPart.CFrame + Vector3.new(0, 4, 0)
	end
end

local function handleSell(player, shouldTeleport, responseEvent)
	if shouldTeleport then
		teleportToSell(player)
	end

	local ok, result = sellPaint(player)
	responseEvent = responseEvent or teleportToSellEvent
	if ok then
		if DEBUG_LOGS then
			print("Sell zone sold " .. tostring(result.colorSold) .. " Color for " .. tostring(result.coinsEarned) .. " Coins")
		end
		responseEvent:FireClient(player, true, result)
	else
		responseEvent:FireClient(player, false, result)
	end
end

local function useSellZone(player, responseEvent)
	local now = os.clock()
	if sellDebounce[player] and now - sellDebounce[player] < SELL_DEBOUNCE then
		return
	end
	sellDebounce[player] = now

	if DEBUG_LOGS then
		print("Sell zone used")
	end
	handleSell(player, false, responseEvent or sellColorEvent or teleportToSellEvent)
end

teleportToSellEvent.OnServerEvent:Connect(function(player, action, ...)
	if select("#", ...) > 0 then
		warnUnexpectedSellValuesOnce(player, "TeleportToSell")
	end
	handleSell(player, action ~= "sell", teleportToSellEvent)
end)

if sellColorEvent then
	sellColorEvent.OnServerEvent:Connect(function(player, ...)
		if select("#", ...) > 0 then
			warnUnexpectedSellValuesOnce(player, "SellColor")
		end
		handleSell(player, false, sellColorEvent)
	end)
end

local function hookSellPart(sellPart)
	if not sellPart or not sellPart:IsA("BasePart") or sellPart:GetAttribute("SellZoneHooked") then
		return
	end
	sellPart:SetAttribute("SellZoneHooked", true)

	local prompt = ensureSellVisuals(sellPart)
	prompt.Triggered:Connect(function(player)
		useSellZone(player, sellColorEvent or teleportToSellEvent)
	end)

	sellPart.Touched:Connect(function(hit)
		local character = hit and hit.Parent
		local player = character and Players:GetPlayerFromCharacter(character)
		if player then
			useSellZone(player, sellColorEvent or teleportToSellEvent)
		end
	end)
end

task.defer(function()
	for _, obj in ipairs(workspace:GetDescendants()) do
		if isSellPart(obj) then
			hookSellPart(obj)
		end
	end
end)

workspace.DescendantAdded:Connect(function(obj)
	if obj:IsA("BasePart") and isSellPart(obj) then
		task.defer(function()
			hookSellPart(obj)
		end)
	end
end)

Players.PlayerRemoving:Connect(function(player)
	sellDebounce[player] = nil
end)
]]></string>
        </Properties>
      </Item>
      <Item class="Script" referent="71">
        <Properties>
          <string name="Name">StarterBrushToolHandler</string>
          <token name="RunContext">0</token>
          <string name="Source"><![CDATA[-- Gives every player a real Starter Brush Tool while keeping collection server-validated.
local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")

local ToolData = require(ReplicatedStorage:WaitForChild("ToolData"))

local TOOL_NAME = "Starter Brush"
local BRUSH_VISUAL_VERSION = "palm-grip-v2"

local function makePart(name, size, color, material)
	local part = Instance.new("Part")
	part.Name = name
	part.Size = size
	part.Color = color
	part.Material = material or Enum.Material.SmoothPlastic
	part.Anchored = false
	part.CanCollide = false
	part.CanTouch = false
	part.CanQuery = false
	part.Massless = true
	part.CastShadow = false
	part.TopSurface = Enum.SurfaceType.Smooth
	part.BottomSurface = Enum.SurfaceType.Smooth
	return part
end

local function weldToHandle(handle, part, localCFrame)
	part.CFrame = handle.CFrame * localCFrame
	part.Parent = handle.Parent

	local weld = Instance.new("WeldConstraint")
	weld.Part0 = handle
	weld.Part1 = part
	weld.Parent = part
end

local function createStarterBrushTool()
	local config = ToolData.get("StarterBrush")

	local tool = Instance.new("Tool")
	tool.Name = TOOL_NAME
	tool.ToolTip = "Collect Color"
	tool.RequiresHandle = true
	tool.CanBeDropped = false
	tool:SetAttribute("PaintToolId", "StarterBrush")
	tool:SetAttribute("GeneratedStarterBrush", true)
	tool:SetAttribute("BrushVisualVersion", BRUSH_VISUAL_VERSION)

	local handle = makePart("Handle", Vector3.new(0.22, 0.22, 0.22), config.HandleColor or Color3.fromRGB(255, 213, 125), Enum.Material.SmoothPlastic)
	handle.Transparency = 1
	handle.Parent = tool

	local shaftRotation = CFrame.Angles(math.rad(90), 0, 0)
	weldToHandle(handle, makePart("BrushShaft", Vector3.new(0.22, 1.45, 0.22), config.HandleColor or Color3.fromRGB(255, 213, 125), Enum.Material.Wood), CFrame.new(0, 0, -0.72) * shaftRotation)
	weldToHandle(handle, makePart("Grip", Vector3.new(0.34, 0.42, 0.34), Color3.fromRGB(45, 48, 58)), CFrame.new(0, 0, -0.16) * shaftRotation)
	weldToHandle(handle, makePart("Band", Vector3.new(0.48, 0.22, 0.48), Color3.fromRGB(190, 220, 238), Enum.Material.Metal), CFrame.new(0, 0, -1.28) * shaftRotation)
	weldToHandle(handle, makePart("BrushHead", Vector3.new(0.78, 0.42, 0.34), config.HeadColor or Color3.fromRGB(110, 235, 245)), CFrame.new(0, 0, -1.52))
	weldToHandle(handle, makePart("PaintTip", Vector3.new(0.76, 0.16, 0.38), config.PaintColor or Color3.fromRGB(255, 92, 164), Enum.Material.Neon), CFrame.new(0, -0.24, -1.55))

	tool.Grip = CFrame.new(0.08, -0.08, -0.28) * CFrame.Angles(math.rad(-8), 0, math.rad(8))
	return tool
end

local function removeExtraGeneratedBrushes(container, keep)
	if not container then
		return
	end

	for _, child in ipairs(container:GetChildren()) do
		if child:IsA("Tool") and child ~= keep and (child:GetAttribute("GeneratedStarterBrush") or child:GetAttribute("PaintToolId") == "StarterBrush" or child.Name == TOOL_NAME) then
			child:Destroy()
		end
	end
end

local function ensureStarterBrushIn(container)
	if not container then
		return nil
	end

	local existing
	for _, child in ipairs(container:GetChildren()) do
		if child:IsA("Tool") and (child:GetAttribute("GeneratedStarterBrush") or child:GetAttribute("PaintToolId") == "StarterBrush" or child.Name == TOOL_NAME) then
			existing = existing or child
		end
	end

	if existing and existing:GetAttribute("BrushVisualVersion") ~= BRUSH_VISUAL_VERSION then
		existing:Destroy()
		existing = nil
	end

	if existing then
		existing:SetAttribute("PaintToolId", "StarterBrush")
		existing:SetAttribute("GeneratedStarterBrush", true)
		existing:SetAttribute("BrushVisualVersion", BRUSH_VISUAL_VERSION)
		existing.CanBeDropped = false
		removeExtraGeneratedBrushes(container, existing)
		return existing
	end

	local tool = createStarterBrushTool()
	tool.Parent = container
	return tool
end

local function ensurePlayerBrush(player)
	local backpack = player:FindFirstChildOfClass("Backpack") or player:WaitForChild("Backpack", 10)
	local starterGear = player:FindFirstChild("StarterGear") or player:WaitForChild("StarterGear", 10)
	local character = player.Character

	local equippedBrush = ensureStarterBrushIn(character)
	if not equippedBrush then
		ensureStarterBrushIn(backpack)
	else
		removeExtraGeneratedBrushes(backpack)
	end
	ensureStarterBrushIn(starterGear)
end

Players.PlayerAdded:Connect(function(player)
	task.defer(function()
		ensurePlayerBrush(player)
	end)

	player.CharacterAdded:Connect(function()
		task.wait(0.35)
		ensurePlayerBrush(player)
	end)
end)
]]></string>
        </Properties>
      </Item>
      <Item class="Script" referent="72">
        <Properties>
          <string name="Name">StarterFieldPolish</string>
          <token name="RunContext">0</token>
          <string name="Source"><![CDATA[-- Polishes the first Red world into a readable starter zone without replacing core systems.
local Workspace = game:GetService("Workspace")
local ReplicatedStorage = game:GetService("ReplicatedStorage")

local PetData = require(ReplicatedStorage:WaitForChild("PetData"))
local GameBalance = require(ReplicatedStorage:WaitForChild("GameBalance"))

local MAP_NAME = "ColorSimulatorMap"
local POLISH_FOLDER_NAME = "StarterFieldPolish"
local CREATE_PHYSICAL_POLISH = true
local DEBUG_LOGS = false

local function shouldUseBakedMap()
	local mapConfig = GameBalance.Map or {}
	return mapConfig.UseBakedMap ~= false
end

local function isBakedEditableMap(map)
	return map
		and (map:GetAttribute("BakedEditableMap") == true or map:FindFirstChild("Lobby") or map:FindFirstChild("RedZone"))
end

local COLORS = {
	dark = Color3.fromRGB(35, 38, 45),
	red = Color3.fromRGB(255, 92, 112),
	pink = Color3.fromRGB(255, 174, 214),
	cyan = Color3.fromRGB(118, 238, 244),
	yellow = Color3.fromRGB(255, 228, 104),
	green = Color3.fromRGB(112, 238, 158),
	cream = Color3.fromRGB(255, 246, 224),
	blue = Color3.fromRGB(92, 178, 255),
	purple = Color3.fromRGB(192, 154, 255),
}

local function getMap()
	return Workspace:WaitForChild(MAP_NAME, 20)
end

local function createPart(parent, name, size, cframe, color, material, canCollide)
	local part = Instance.new("Part")
	part.Name = name
	part.Size = size
	part.CFrame = cframe
	part.Color = color
	part.Material = material or Enum.Material.SmoothPlastic
	part.Anchored = true
	part.CanCollide = canCollide == true
	part.CanTouch = false
	part.CastShadow = false
	part.TopSurface = Enum.SurfaceType.Smooth
	part.BottomSurface = Enum.SurfaceType.Smooth
	part.Parent = parent
	return part
end

local function addCorner(part, radius)
	local corner = Instance.new("UICorner")
	corner.CornerRadius = UDim.new(0, radius or 12)
	return corner
end

local function addBillboard(parent, name, title, subtitle, offset, titleColor)
	for _, child in ipairs(parent:GetChildren()) do
		if child:IsA("BillboardGui") and (child.Name == name or child.Name == "Label" or child.Name == "SellZoneLabel" or child:GetAttribute("StarterFieldLabel")) then
			child:Destroy()
		end
	end

	local billboard = Instance.new("BillboardGui")
	billboard.Name = name
	billboard:SetAttribute("StarterFieldLabel", true)
	billboard:SetAttribute("ProximityWorldLabel", true)
	billboard:SetAttribute("ShowDistance", 58)
	billboard:SetAttribute("HideDistance", 68)
	billboard.Size = UDim2.new(0, 260, 0, subtitle and 80 or 54)
	billboard.StudsOffset = offset or Vector3.new(0, 6, 0)
	billboard.AlwaysOnTop = true
	billboard.MaxDistance = 130
	billboard.Enabled = false
	billboard.Parent = parent

	local titleLabel = Instance.new("TextLabel")
	titleLabel.Size = UDim2.new(1, 0, 0, subtitle and 42 or 54)
	titleLabel.BackgroundTransparency = 1
	titleLabel.Font = Enum.Font.LuckiestGuy
	titleLabel.TextScaled = true
	titleLabel.TextColor3 = titleColor or Color3.new(1, 1, 1)
	titleLabel.TextStrokeTransparency = 0
	titleLabel.TextStrokeColor3 = COLORS.dark
	titleLabel.Text = title
	titleLabel.Parent = billboard

	if subtitle then
		local subLabel = Instance.new("TextLabel")
		subLabel.Size = UDim2.new(1, 0, 0, 24)
		subLabel.Position = UDim2.new(0, 0, 0, 42)
		subLabel.BackgroundTransparency = 1
		subLabel.Font = Enum.Font.GothamBold
		subLabel.TextSize = 14
		subLabel.TextColor3 = COLORS.cream
		subLabel.TextStrokeTransparency = 0.1
		subLabel.TextStrokeColor3 = COLORS.dark
		subLabel.Text = subtitle
		subLabel.Parent = billboard
	end
end

local function findPart(root, predicate)
	for _, obj in ipairs(root:GetDescendants()) do
		if obj:IsA("BasePart") and predicate(obj) then
			return obj
		end
	end
	return nil
end

local function movePart(part, center, offset, yOffset)
	if not part then
		return
	end
	local pos = center + Vector3.new(offset.X, yOffset or part.Size.Y * 0.5 + 0.05, offset.Z)
	part.CFrame = CFrame.new(pos) * CFrame.Angles(0, math.rad(offset.R or 0), 0)
end

local function makeSection(parent, center, name, offset, size, color, label, subtitle)
	local pad = createPart(
		parent,
		name,
		Vector3.new(size.X, 0.35, size.Z),
		CFrame.new(center + Vector3.new(offset.X, 1.08, offset.Z)),
		color,
		Enum.Material.SmoothPlastic,
		false
	)
	pad.Transparency = 0.1
	pad:SetAttribute("StarterFieldDecor", true)

	local stroke = createPart(
		parent,
		name .. "Outline",
		Vector3.new(size.X + 3, 0.22, size.Z + 3),
		CFrame.new(center + Vector3.new(offset.X, 1.04, offset.Z)),
		COLORS.dark,
		Enum.Material.SmoothPlastic,
		false
	)
	stroke.Transparency = 0.45
	stroke:SetAttribute("StarterFieldDecor", true)

	addBillboard(pad, name .. "Label", label, subtitle, Vector3.new(0, 4.6, 0))
	return pad
end

local function makeArrow(parent, center, name, fromOffset, toOffset, color)
	local dx = toOffset.X - fromOffset.X
	local dz = toOffset.Z - fromOffset.Z
	local distance = math.sqrt(dx * dx + dz * dz)
	if distance < 1 then
		return
	end

	local midpoint = Vector3.new((fromOffset.X + toOffset.X) * 0.5, 1.16, (fromOffset.Z + toOffset.Z) * 0.5)
	local angle = math.atan2(-dx, -dz)
	local arrow = createPart(
		parent,
		name,
		Vector3.new(5, 0.25, math.max(12, distance - 18)),
		CFrame.new(center + midpoint) * CFrame.Angles(0, angle, 0),
		color,
		Enum.Material.Neon,
		false
	)
	arrow.Transparency = 0.28
	arrow:SetAttribute("StarterFieldDecor", true)

	local head = createPart(
		parent,
		name .. "Head",
		Vector3.new(12, 0.3, 12),
		CFrame.new(center + Vector3.new(toOffset.X, 1.18, toOffset.Z)) * CFrame.Angles(0, angle + math.rad(45), 0),
		color,
		Enum.Material.Neon,
		false
	)
	head.Transparency = 0.22
	head:SetAttribute("StarterFieldDecor", true)
end

local function addUpgradePrompt(part)
	if not part then
		return
	end
	local prompt = part:FindFirstChild("UpgradeStationPrompt")
	if not prompt then
		prompt = Instance.new("ProximityPrompt")
		prompt.Name = "UpgradeStationPrompt"
		prompt.Parent = part
	end
	prompt.ActionText = "Open"
	prompt.ObjectText = "Upgrade Station"
	prompt.HoldDuration = 0
	prompt.MaxActivationDistance = 16
	prompt.RequiresLineOfSight = false
	prompt:SetAttribute("UpgradeStationPrompt", true)
end

local function ensureStarterEggPrompt(egg)
	if not egg then
		return
	end

	for _, child in ipairs(egg:GetChildren()) do
		if child:IsA("BillboardGui")
			and (child.Name == "StarterEggLabel" or child.Name == "ProximityStationLabel" or child.Name == "QuietStationLabel" or child.Name == "Label")
		then
			child:Destroy()
		end
	end

	local prompt = egg:FindFirstChild("EggShopPrompt")
	if not prompt then
		prompt = Instance.new("ProximityPrompt")
		prompt.Name = "EggShopPrompt"
		prompt.Parent = egg
	end

	prompt.ActionText = "Open"
	prompt.ObjectText = "Egg"
	prompt.KeyboardKeyCode = Enum.KeyCode.E
	prompt.GamepadKeyCode = Enum.KeyCode.ButtonX
	prompt.HoldDuration = 0
	prompt.MaxActivationDistance = 16
	prompt.RequiresLineOfSight = false
	prompt.Style = Enum.ProximityPromptStyle.Custom
	prompt:SetAttribute("EggShopPrompt", true)
end

local function polishStarterEggArea(folder, center, egg)
	if not egg then
		return
	end

	local eggData = PetData.Eggs.ColorEgg
	local costText = eggData and (tostring(eggData.cost) .. " Coins") or "Coins"
	local eggPos = center + Vector3.new(62, 8.5, 82)
	egg.CFrame = CFrame.new(eggPos)
	egg.Size = Vector3.new(12, 15, 12)
	egg.Shape = Enum.PartType.Ball
	egg.Color = eggData and eggData.color or COLORS.purple
	egg.Material = Enum.Material.SmoothPlastic
	egg:SetAttribute("EggId", "ColorEgg")
	egg:SetAttribute("ColorType", "Red")
	egg:SetAttribute("AreaColor", "Red")

	local basePos = center + Vector3.new(62, 1.35, 82)
	local pedestal = createPart(folder, "StarterEggPedestal", Vector3.new(28, 2.4, 28), CFrame.new(basePos), COLORS.dark, Enum.Material.SmoothPlastic, true)
	pedestal:SetAttribute("StarterFieldDecor", true)

	local glow = createPart(folder, "StarterEggPedestalGlow", Vector3.new(23, 0.35, 23), CFrame.new(basePos + Vector3.new(0, 1.36, 0)), COLORS.yellow, Enum.Material.Neon, false)
	glow.Transparency = 0.1
	glow:SetAttribute("StarterFieldDecor", true)

	local ring = createPart(folder, "StarterEggPedestalRing", Vector3.new(31, 0.28, 31), CFrame.new(basePos + Vector3.new(0, 1.42, 0)), COLORS.cyan, Enum.Material.Neon, false)
	ring.Transparency = 0.55
	ring:SetAttribute("StarterFieldDecor", true)

	local sign = createPart(folder, "StarterEggPhysicalSign", Vector3.new(26, 8, 1), CFrame.new(center + Vector3.new(62, 8, 61)), COLORS.dark, Enum.Material.SmoothPlastic, false)
	sign:SetAttribute("StarterFieldDecor", true)
	local signGlow = createPart(folder, "StarterEggSignTrim", Vector3.new(28, 1, 1.2), CFrame.new(center + Vector3.new(62, 12.6, 60.9)), COLORS.yellow, Enum.Material.Neon, false)
	signGlow:SetAttribute("StarterFieldDecor", true)

	local light = egg:FindFirstChild("StarterEggGlow")
	if not light then
		light = Instance.new("PointLight")
		light.Name = "StarterEggGlow"
		light.Parent = egg
	end
	light.Color = COLORS.yellow
	light.Brightness = 1.4
	light.Range = 26

	addBillboard(egg, "StarterEggLabel", "STARTER EGG", costText, Vector3.new(0, 10.5, 0), COLORS.yellow)
	ensureStarterEggPrompt(egg)
end

local function removeRuntimePolish(map)
	local old = map:FindFirstChild(POLISH_FOLDER_NAME)
	if old then
		old:Destroy()
	end

	for _, obj in ipairs(map:GetDescendants()) do
		if obj:IsA("BasePart") and obj:GetAttribute("StarterFieldDecor") then
			obj:Destroy()
		elseif obj:IsA("BillboardGui")
			and (obj:GetAttribute("StarterFieldLabel") or obj.Name == "StarterEggLabel" or obj.Name == "StarterSpawnLabel" or obj.Name == "StarterBlueGateLabel")
		then
			obj:Destroy()
		end
	end
end

local function findStarterShop(map)
	return findPart(map, function(part)
		return part:GetAttribute("BrushShop") or part.Name == "ShopBuildingBase" or part.Name == "Shop"
	end)
end

local function findUpgradeStation(map)
	return findPart(map, function(part)
		return part:GetAttribute("UpgradeStation") or part.Name == "UpgradeStation" or part.Name == "UpgradePad"
	end)
end

local function ensureSellZone(map, center, existingSell)
	if existingSell then
		existingSell:SetAttribute("SellZone", true)
		existingSell:SetAttribute("SellLocation", true)
		existingSell:SetAttribute("ColorType", existingSell:GetAttribute("ColorType") or "Red")
		existingSell:SetAttribute("AreaColor", existingSell:GetAttribute("AreaColor") or "Red")
		existingSell:SetAttribute("SellColor", existingSell:GetAttribute("SellColor") or "Red")
		return existingSell
	end

	local folder = map:FindFirstChild("FunctionalParts")
	if not folder then
		folder = Instance.new("Folder")
		folder.Name = "FunctionalParts"
		folder.Parent = map
	end

	local sell = Instance.new("Part")
	sell.Name = "SellZone"
	sell.Size = Vector3.new(42, 1, 30)
	sell.CFrame = CFrame.new(center + Vector3.new(-34, 1.25, 74))
	sell.Color = COLORS.green
	sell.Material = Enum.Material.SmoothPlastic
	sell.Transparency = 0.12
	sell.Anchored = true
	sell.CanCollide = false
	sell.CanTouch = true
	sell.TopSurface = Enum.SurfaceType.Smooth
	sell.BottomSurface = Enum.SurfaceType.Smooth
	sell:SetAttribute("SellZone", true)
	sell:SetAttribute("SellLocation", true)
	sell:SetAttribute("ColorType", "Red")
	sell:SetAttribute("AreaColor", "Red")
	sell:SetAttribute("SellColor", "Red")
	sell.Parent = folder
	if DEBUG_LOGS then
		print("StarterFieldPolish: created missing SellZone.")
	end
	return sell
end

local function ensureUpgradeStation(map, center, existingUpgrade)
	if existingUpgrade then
		existingUpgrade:SetAttribute("UpgradeStation", true)
		existingUpgrade:SetAttribute("ColorType", existingUpgrade:GetAttribute("ColorType") or "Red")
		addUpgradePrompt(existingUpgrade)
		return existingUpgrade
	end

	local folder = map:FindFirstChild("FunctionalParts")
	if not folder then
		folder = Instance.new("Folder")
		folder.Name = "FunctionalParts"
		folder.Parent = map
	end

	local upgrade = Instance.new("Part")
	upgrade.Name = "UpgradeStation"
	upgrade.Size = Vector3.new(38, 1.2, 28)
	upgrade.CFrame = CFrame.new(center + Vector3.new(42, 1.35, 52))
	upgrade.Color = COLORS.purple:Lerp(Color3.new(1, 1, 1), 0.12)
	upgrade.Material = Enum.Material.SmoothPlastic
	upgrade.Transparency = 0.06
	upgrade.Anchored = true
	upgrade.CanCollide = false
	upgrade.CanTouch = false
	upgrade.TopSurface = Enum.SurfaceType.Smooth
	upgrade.BottomSurface = Enum.SurfaceType.Smooth
	upgrade:SetAttribute("UpgradeStation", true)
	upgrade:SetAttribute("ColorType", "Red")
	upgrade.Parent = folder
	addUpgradePrompt(upgrade)

	if DEBUG_LOGS then
		print("StarterFieldPolish: created missing UpgradeStation.")
	end
	return upgrade
end

local function attachLightweightLabels(map, spawn, sell, egg)
	if spawn then
		addBillboard(spawn, "StarterSpawnLabel", "WELCOME", nil, Vector3.new(0, 5.2, 0), COLORS.cyan)
	end
	if sell then
		addBillboard(sell, "StarterSellLabel", "SELL COLOR", "Cash out", Vector3.new(0, 6.2, 0), COLORS.green)
	end

	local shop = findStarterShop(map)
	if shop then
		addBillboard(shop, "StarterShopLabel", "SHOP", nil, Vector3.new(0, 7, 0), COLORS.yellow)
	end

	local upgrade = findUpgradeStation(map)
	if upgrade then
		addBillboard(upgrade, "StarterUpgradeLabel", "UPGRADES", nil, Vector3.new(0, 6, 0), COLORS.purple)
		addUpgradePrompt(upgrade)
	end
end

local function polish()
	local map = getMap()
	if not map then
		return
	end

	if shouldUseBakedMap() and isBakedEditableMap(map) then
		if DEBUG_LOGS then
			print("StarterFieldPolish: baked editable map detected; runtime physical polish skipped.")
		end
		return
	end

	local redZone = findPart(map, function(part)
		return part:GetAttribute("ColorZone") and part:GetAttribute("ColorType") == "Red"
	end)
	if not redZone then
		warn("StarterFieldPolish: missing Red zone.")
		return
	end

	removeRuntimePolish(map)

	local folder = Instance.new("Folder")
	folder.Name = POLISH_FOLDER_NAME
	folder.Parent = map

	local center = redZone.Position

	local spawn = findPart(map, function(part)
		return part:GetAttribute("AreaSpawn") and (part:GetAttribute("AreaSpawnColor") == "Red" or part:GetAttribute("ColorType") == "Red")
	end)

	local sell = findPart(map, function(part)
		return (part:GetAttribute("SellZone") or part.Name == "SellZone")
			and (not part:GetAttribute("ColorType") or part:GetAttribute("ColorType") == "Red")
	end)
	local upgrade = findUpgradeStation(map)

	local egg = findPart(map, function(part)
		return part:GetAttribute("EggId") == "ColorEgg" or (part:GetAttribute("EggId") and part:GetAttribute("ColorType") == "Red")
	end)
	sell = ensureSellZone(map, center, sell)
	upgrade = ensureUpgradeStation(map, center, upgrade)

	if not CREATE_PHYSICAL_POLISH then
		if egg then
			egg:SetAttribute("EggId", "ColorEgg")
			egg:SetAttribute("ColorType", "Red")
			egg:SetAttribute("AreaColor", "Red")
			ensureStarterEggPrompt(egg)
		end
		attachLightweightLabels(map, spawn, sell, egg)
		if DEBUG_LOGS then
			print("StarterFieldPolish: attached lightweight proximity labels only.")
		end
		return
	end

	makeSection(folder, center, "SpawnSection", { X = -108, Z = -108 }, { X = 42, Z = 34 }, COLORS.cyan, "WELCOME", "Start here")
	makeSection(folder, center, "CollectSection", { X = -36, Z = -46 }, { X = 118, Z = 74 }, COLORS.red, "COLLECT COLOR", "Walk over bright paint")
	makeSection(folder, center, "SellSection", { X = -34, Z = 74 }, { X = 58, Z = 42 }, COLORS.green, "SELL COLOR", "Cash out here")
	makeSection(folder, center, "EggSection", { X = 62, Z = 82 }, { X = 60, Z = 42 }, COLORS.yellow, "STARTER EGG", "Spend coins here")
	polishStarterEggArea(folder, center, egg)
	local shop = findStarterShop(map)
	if shop then
		addBillboard(shop, "StarterShopLabel", "SHOP", "Better brushes", Vector3.new(0, 7, 0), COLORS.yellow)
	else
		makeSection(folder, center, "ShopSection", { X = 62, Z = -16 }, { X = 54, Z = 30 }, COLORS.yellow, "SHOP", "Better brushes")
	end
	local upgradePad = makeSection(folder, center, "UpgradeSection", { X = 62, Z = 32 }, { X = 62, Z = 34 }, COLORS.purple, "UPGRADES", "Grow stronger")
	upgradePad:SetAttribute("UpgradeStation", true)
	addUpgradePrompt(upgradePad)

	makeArrow(folder, center, "SpawnToCollectArrow", { X = -94, Z = -92 }, { X = -62, Z = -62 }, COLORS.cyan)
	makeArrow(folder, center, "CollectToSellArrow", { X = -12, Z = -18 }, { X = -30, Z = 48 }, COLORS.green)
	makeArrow(folder, center, "SellToEggArrow", { X = -2, Z = 78 }, { X = 38, Z = 82 }, COLORS.yellow)

	local gate = findPart(map, function(part)
		return part:GetAttribute("AreaGate") and (part:GetAttribute("GateColor") == "Blue" or part:GetAttribute("UnlockColor") == "Blue")
	end)
	if gate then
		addBillboard(gate, "StarterBlueGateLabel", "NEXT WORLD", "Unlock Blue Beach", Vector3.new(0, 28, 0), COLORS.blue)
	end

	if DEBUG_LOGS then
		print("StarterFieldPolish: Starter Field layout refined.")
	end
end

task.delay(2.5, polish)
Workspace.DescendantAdded:Connect(function(obj)
	if obj:IsA("BasePart") and obj:GetAttribute("ColorZone") and obj:GetAttribute("ColorType") == "Red" then
		task.delay(0.5, polish)
	end
end)
]]></string>
        </Properties>
      </Item>
      <Item class="Script" referent="73">
        <Properties>
          <string name="Name">TutorialObjectiveHandler</string>
          <token name="RunContext">0</token>
          <string name="Source"><![CDATA[-- First-session objective chain. Progress is based on real player data; rewards are small and once per session.
local Players = game:GetService("Players")

local OBJECTIVES = {
	{ key = "Collect10", rewardCoins = 150 },
	{ key = "SellColor", rewardCoins = 80 },
	{ key = "HatchColor", rewardCoins = 0 },
	{ key = "EquipColor", rewardCoins = 250 },
	{ key = "BuyUpgrade", rewardCoins = 70 },
	{ key = "UnlockBlue", rewardCoins = 0 },
}

local function ensureFolder(player)
	local folder = player:FindFirstChild("TutorialObjectives")
	if not folder then
		folder = Instance.new("Folder")
		folder.Name = "TutorialObjectives"
		folder.Parent = player
	end

	for index, objective in ipairs(OBJECTIVES) do
		local value = folder:FindFirstChild(objective.key)
		if not value then
			value = Instance.new("BoolValue")
			value.Name = objective.key
			value.Value = false
			value.Parent = folder
		end
		value:SetAttribute("Order", index)
		value:SetAttribute("RewardCoins", objective.rewardCoins)
	end

	local completed = folder:FindFirstChild("TutorialCompleted")
	if not completed then
		completed = Instance.new("BoolValue")
		completed.Name = "TutorialCompleted"
		completed.Value = false
		completed.Parent = folder
	end

	local message = folder:FindFirstChild("LastRewardMessage")
	if not message then
		message = Instance.new("StringValue")
		message.Name = "LastRewardMessage"
		message.Value = ""
		message.Parent = folder
	end

	return folder
end

local function isTutorialCompleted(folder)
	local completed = folder and folder:FindFirstChild("TutorialCompleted")
	return completed and completed.Value == true
end

local function isComplete(folder, key)
	local value = folder and folder:FindFirstChild(key)
	return value and value.Value == true
end

local function canComplete(folder, key)
	for _, objective in ipairs(OBJECTIVES) do
		if objective.key == key then
			return true
		end
		if not isComplete(folder, objective.key) then
			return false
		end
	end
	return false
end

local function awardCoins(player, amount)
	amount = tonumber(amount) or 0
	if amount <= 0 then
		return
	end

	local stats = player:FindFirstChild("leaderstats")
	local coins = stats and stats:FindFirstChild("Coins")
	if coins then
		coins.Value += amount
	end
end

local function complete(player, key)
	local folder = ensureFolder(player)
	if isTutorialCompleted(folder) then
		return
	end

	local value = folder:FindFirstChild(key)
	if not value or value.Value or not canComplete(folder, key) then
		return
	end

	value.Value = true
	local reward = tonumber(value:GetAttribute("RewardCoins")) or 0
	awardCoins(player, reward)

	local message = folder:FindFirstChild("LastRewardMessage")
	if message then
		message.Value = reward > 0 and ("Goal complete! +" .. tostring(reward) .. " Coins") or "Goal complete!"
	end
	print(player.Name .. " completed tutorial objective " .. key .. (reward > 0 and (" for +" .. reward .. " Coins") or ""))

	local allComplete = true
	for _, objective in ipairs(OBJECTIVES) do
		local objectiveValue = folder:FindFirstChild(objective.key)
		if not objectiveValue or objectiveValue.Value ~= true then
			allComplete = false
			break
		end
	end

	if allComplete then
		local completed = folder:FindFirstChild("TutorialCompleted")
		if completed then
			completed.Value = true
		end
		if message then
			message.Value = "Tutorial complete! Keep mixing rare Colors."
		end
	end
end

local function getUpgradeLevelTotal(player)
	local upgrades = player:FindFirstChild("Upgrades")
	if not upgrades then
		return 0
	end

	local total = 0
	for _, child in ipairs(upgrades:GetChildren()) do
		if child:IsA("IntValue") and string.sub(child.Name, -6) == "_Level" then
			total += child.Value
		end
	end
	return total
end

local function getPetInventoryCount(player)
	local petFolder = player:FindFirstChild("PetData")
	local inventory = petFolder and petFolder:FindFirstChild("Inventory")
	if not inventory or inventory.Value == "" then
		return 0
	end

	local count = 0
	for _, token in ipairs(string.split(inventory.Value, ",")) do
		if token ~= "" then
			count += 1
		end
	end
	return count
end

local function getEquippedCount(player)
	local petFolder = player:FindFirstChild("PetData")
	local equipped = petFolder and petFolder:FindFirstChild("Equipped")
	if not equipped or equipped.Value == "" then
		return 0
	end

	local count = 0
	for _, token in ipairs(string.split(equipped.Value, ",")) do
		if token ~= "" then
			count += 1
		end
	end
	return count
end

local function hasUnlockedBlue(player)
	local storage = player:FindFirstChild("ColorStorage")
	local unlocked = storage and storage:FindFirstChild("UnlockedColors")
	if not unlocked then
		return false
	end
	for _, color in ipairs(string.split(unlocked.Value, ",")) do
		if color == "Blue" then
			return true
		end
	end
	return false
end

local function evaluate(player, previousHeld)
	local folder = ensureFolder(player)
	if isTutorialCompleted(folder) then
		return
	end

	local storage = player:FindFirstChild("ColorStorage")
	local held = storage and storage:FindFirstChild("ColorHeld")
	local currentHeld = held and held.Value or 0

	if currentHeld >= 10 then
		complete(player, "Collect10")
	end
	if isComplete(folder, "Collect10") and previousHeld and previousHeld > 0 and currentHeld == 0 then
		complete(player, "SellColor")
	end
	if getPetInventoryCount(player) > 0 then
		complete(player, "HatchColor")
	end
	if getEquippedCount(player) > 0 then
		complete(player, "EquipColor")
	end
	if getUpgradeLevelTotal(player) > 0 then
		complete(player, "BuyUpgrade")
	end
	if hasUnlockedBlue(player) then
		complete(player, "UnlockBlue")
	end
end

local function watchValue(value, callback)
	if value then
		value:GetPropertyChangedSignal("Value"):Connect(callback)
	end
end

Players.PlayerAdded:Connect(function(player)
	ensureFolder(player)

	task.defer(function()
		local storage = player:WaitForChild("ColorStorage", 15)
		local held = storage and storage:WaitForChild("ColorHeld", 10)
		local unlocked = storage and storage:WaitForChild("UnlockedColors", 10)
		local upgrades = player:WaitForChild("Upgrades", 15)
		local petFolder = player:WaitForChild("PetData", 15)
		local inventory = petFolder and petFolder:WaitForChild("Inventory", 10)
		local equipped = petFolder and petFolder:WaitForChild("Equipped", 10)

		local lastHeld = held and held.Value or 0
		local function refresh()
			evaluate(player, lastHeld)
			lastHeld = held and held.Value or lastHeld
		end

		watchValue(held, refresh)
		watchValue(unlocked, refresh)
		watchValue(inventory, refresh)
		watchValue(equipped, refresh)
		if upgrades then
			for _, child in ipairs(upgrades:GetChildren()) do
				if child:IsA("ValueBase") then
					watchValue(child, refresh)
				end
			end
			upgrades.ChildAdded:Connect(function(child)
				if child:IsA("ValueBase") then
					watchValue(child, refresh)
					refresh()
				end
			end)
		end

		task.wait(0.5)
		refresh()
	end)
end)
]]></string>
        </Properties>
