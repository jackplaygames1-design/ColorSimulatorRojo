        <Item class="LocalScript" referent="96">
          <Properties>
            <string name="Name">ProximityWorldLabels</string>
            <string name="Source"><![CDATA[local Players = game:GetService("Players")
local RunService = game:GetService("RunService")

local player = Players.LocalPlayer
local labels = {}

local function getRoot()
	local character = player.Character
	return character and character:FindFirstChild("HumanoidRootPart")
end

local function getLabelPosition(label)
	local adornee = label.Adornee
	if adornee and adornee:IsA("BasePart") then
		return adornee.Position
	end

	local parent = label.Parent
	if parent and parent:IsA("BasePart") then
		return parent.Position
	end

	return nil
end

local function trackLabel(obj)
	if not obj:IsA("BillboardGui") or not obj:GetAttribute("ProximityWorldLabel") then
		return
	end

	labels[obj] = true
	obj.Enabled = false
end

for _, obj in ipairs(workspace:GetDescendants()) do
	trackLabel(obj)
end

workspace.DescendantAdded:Connect(function(obj)
	task.defer(trackLabel, obj)
end)

RunService.RenderStepped:Connect(function()
	local root = getRoot()
	if not root then
		return
	end

	for label in pairs(labels) do
		if not label.Parent then
			labels[label] = nil
		else
			local position = getLabelPosition(label)
			if position then
				local parent = label.Parent
				if parent and parent:IsA("BasePart") and parent:GetAttribute("EggId") and parent:FindFirstChild("EggOptions") then
					label.Enabled = false
					continue
				end

				local showDistance = tonumber(label:GetAttribute("ShowDistance")) or 58
				local hideDistance = tonumber(label:GetAttribute("HideDistance")) or (showDistance + 10)
				local distance = (root.Position - position).Magnitude

				if label.Enabled then
					label.Enabled = distance <= hideDistance
				else
					label.Enabled = distance <= showDistance
				end
			end
		end
	end
end)
]]></string>
          </Properties>
        </Item>
        <Item class="LocalScript" referent="97">
          <Properties>
            <string name="Name">RunController</string>
            <string name="Source"><![CDATA[-- Local sprint controller. It boosts the current server-provided WalkSpeed so upgrades
-- and equipped Color personality bonuses still remain the source of truth.
local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local ContextActionService = game:GetService("ContextActionService")
local TweenService = game:GetService("TweenService")
local Workspace = game:GetService("Workspace")

local player = Players.LocalPlayer
local GameBalance = require(ReplicatedStorage:WaitForChild("GameBalance"))

local RUN_ACTION = "ColorSimulatorRun"
local runningConfig = GameBalance.Running or {}
local enabled = runningConfig.Enabled ~= false
local speedMultiplier = tonumber(runningConfig.SpeedMultiplier) or 1.45
local minRunSpeed = tonumber(runningConfig.MinRunSpeed) or 62
local maxRunSpeed = tonumber(runningConfig.MaxRunSpeed) or 104

local humanoid
local baseWalkSpeed = 44
local isRunning = false
local applyingSpeed = false
local defaultFov = Workspace.CurrentCamera and Workspace.CurrentCamera.FieldOfView or 70

local function getRunSpeed()
	return math.clamp(baseWalkSpeed * speedMultiplier, minRunSpeed, maxRunSpeed)
end

local function tweenFov(target)
	local camera = Workspace.CurrentCamera
	if not camera then
		return
	end

	TweenService:Create(camera, TweenInfo.new(0.16, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
		FieldOfView = target,
	}):Play()
end

local function applySpeed()
	if not humanoid or not enabled then
		return
	end

	applyingSpeed = true
	humanoid.WalkSpeed = isRunning and getRunSpeed() or baseWalkSpeed
	applyingSpeed = false
	tweenFov(isRunning and (defaultFov + 4) or defaultFov)
end

local function setRunning(active)
	if not enabled or isRunning == active then
		return
	end

	isRunning = active
	applySpeed()
end

local function bindHumanoid(character)
	humanoid = character and character:FindFirstChildOfClass("Humanoid")
	if not humanoid then
		humanoid = character and character:WaitForChild("Humanoid", 10)
	end
	if not humanoid then
		return
	end

	baseWalkSpeed = humanoid.WalkSpeed
	humanoid:GetPropertyChangedSignal("WalkSpeed"):Connect(function()
		if applyingSpeed then
			return
		end

		if isRunning then
			local current = humanoid.WalkSpeed
			local expected = getRunSpeed()
			if math.abs(current - expected) > 0.05 then
				baseWalkSpeed = current
				applySpeed()
			end
		else
			baseWalkSpeed = humanoid.WalkSpeed
		end
	end)

	humanoid.Died:Connect(function()
		isRunning = false
	end)
end

local function onRunAction(_, inputState)
	if inputState == Enum.UserInputState.Begin then
		setRunning(true)
	elseif inputState == Enum.UserInputState.End or inputState == Enum.UserInputState.Cancel then
		setRunning(false)
	end

	return Enum.ContextActionResult.Sink
end

if enabled then
	ContextActionService:BindAction(RUN_ACTION, onRunAction, true, Enum.KeyCode.LeftShift, Enum.KeyCode.RightShift, Enum.KeyCode.ButtonL3)
	ContextActionService:SetTitle(RUN_ACTION, "RUN")
	ContextActionService:SetPosition(RUN_ACTION, UDim2.new(1, -92, 1, -168))
end

if player.Character then
	bindHumanoid(player.Character)
end

player.CharacterAdded:Connect(function(character)
	isRunning = false
	task.defer(bindHumanoid, character)
end)
]]></string>
          </Properties>
        </Item>
        <Item class="LocalScript" referent="98">
          <Properties>
            <string name="Name">SellUI</string>
            <string name="Source"><![CDATA[-- SellUI.client.luau
local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local TweenService = game:GetService("TweenService")

local player = Players.LocalPlayer
local UIManager = require(ReplicatedStorage:WaitForChild("UIManager"))
local PetData = require(ReplicatedStorage:WaitForChild("PetData"))
local ColorTraitData = require(ReplicatedStorage:WaitForChild("ColorTraitData"))
local ColorMutationData = require(ReplicatedStorage:WaitForChild("ColorMutationData"))
local UITheme = require(ReplicatedStorage:WaitForChild("UITheme"))
local ClientUIRoot = require(ReplicatedStorage:WaitForChild("ClientUIRoot"))
local SharedGameBalance = require(ReplicatedStorage:WaitForChild("GameBalance"))
local ColorData = require(ReplicatedStorage:WaitForChild("ColorData"))

local Events = ReplicatedStorage:WaitForChild("Events")
local sellEvent = Events:WaitForChild("TeleportToSell")

local GameBalance = SharedGameBalance

local DARK = Color3.fromRGB(35, 38, 45)
local WHITE = Color3.fromRGB(255, 255, 255)
local GREEN = Color3.fromRGB(116, 220, 125)
local RED = Color3.fromRGB(255, 105, 125)
local YELLOW = Color3.fromRGB(255, 220, 90)
local PANEL = Color3.fromRGB(255, 248, 252)
local PANEL_WIDTH = 560
local PANEL_HEIGHT = 390

local screenGui = ClientUIRoot.GetLayer(player.PlayerGui, "SellUI")

local overlay = UITheme.CreateDimOverlay(screenGui, 50)

local panel = Instance.new("Frame")
panel.Name = "SellPanel"
panel.AnchorPoint = Vector2.new(0.5, 0.5)
panel.Size = UDim2.new(0, PANEL_WIDTH, 0, PANEL_HEIGHT)
panel.Position = UDim2.fromScale(0.5, 0.5)
panel.BackgroundColor3 = PANEL
panel.BorderSizePixel = 0
panel.Visible = false
panel.ZIndex = 60
panel.Parent = screenGui
UITheme.ApplyResponsiveScale(panel, PANEL_WIDTH, PANEL_HEIGHT, 0.72, 28)
local corner = Instance.new("UICorner")
corner.CornerRadius = UDim.new(0, 22)
corner.Parent = panel
local stroke = Instance.new("UIStroke")
stroke.Color = DARK
stroke.Thickness = 5
stroke.Parent = panel

local header = Instance.new("Frame")
header.Size = UDim2.new(1, 0, 0, 62)
header.BackgroundColor3 = Color3.fromRGB(123, 232, 158)
header.BorderSizePixel = 0
header.Parent = panel
local headerCorner = Instance.new("UICorner")
headerCorner.CornerRadius = UDim.new(0, 22)
headerCorner.Parent = header

local title = Instance.new("TextLabel")
title.Size = UDim2.new(1, -76, 1, 0)
title.Position = UDim2.new(0, 20, 0, 0)
title.BackgroundTransparency = 1
title.Font = Enum.Font.LuckiestGuy
title.TextSize = 30
title.TextColor3 = WHITE
title.TextStrokeTransparency = 0
title.TextStrokeColor3 = DARK
title.TextXAlignment = Enum.TextXAlignment.Left
title.Text = "SELL COLOR"
title.Parent = header

local closeBtn = Instance.new("TextButton")
closeBtn.Size = UDim2.new(0, 42, 0, 42)
closeBtn.Position = UDim2.new(1, -54, 0.5, -21)
closeBtn.BackgroundColor3 = RED
closeBtn.Font = Enum.Font.LuckiestGuy
closeBtn.TextSize = 22
closeBtn.TextColor3 = WHITE
closeBtn.TextStrokeTransparency = 0
closeBtn.TextStrokeColor3 = DARK
closeBtn.Text = "X"
closeBtn.Parent = header
local closeCorner = Instance.new("UICorner")
closeCorner.CornerRadius = UDim.new(0, 12)
closeCorner.Parent = closeBtn

local colorLabel = Instance.new("TextLabel")
colorLabel.Size = UDim2.new(1, -40, 0, 42)
colorLabel.Position = UDim2.new(0, 20, 0, 88)
colorLabel.BackgroundTransparency = 1
colorLabel.Font = Enum.Font.LuckiestGuy
colorLabel.TextSize = 24
colorLabel.TextColor3 = DARK
colorLabel.TextXAlignment = Enum.TextXAlignment.Left
colorLabel.Text = "Color: 0 / 100"
colorLabel.Parent = panel

local estimateLabel = Instance.new("TextLabel")
estimateLabel.Size = UDim2.new(1, -40, 0, 50)
estimateLabel.Position = UDim2.new(0, 20, 0, 128)
estimateLabel.BackgroundTransparency = 1
estimateLabel.Font = Enum.Font.LuckiestGuy
estimateLabel.TextSize = 30
estimateLabel.TextColor3 = Color3.fromRGB(225, 150, 35)
estimateLabel.TextStrokeTransparency = 0.8
estimateLabel.TextXAlignment = Enum.TextXAlignment.Left
estimateLabel.Text = "+0 Coins"
estimateLabel.Parent = panel

local breakdownLabel = Instance.new("TextLabel")
breakdownLabel.Size = UDim2.new(1, -40, 0, 66)
breakdownLabel.Position = UDim2.new(0, 20, 0, 184)
breakdownLabel.BackgroundTransparency = 1
breakdownLabel.Font = Enum.Font.GothamBold
breakdownLabel.TextSize = 14
breakdownLabel.TextColor3 = Color3.fromRGB(80, 84, 104)
breakdownLabel.TextWrapped = true
breakdownLabel.TextXAlignment = Enum.TextXAlignment.Left
breakdownLabel.TextYAlignment = Enum.TextYAlignment.Top
breakdownLabel.Text = ""
breakdownLabel.Parent = panel

local sellBtn = Instance.new("TextButton")
sellBtn.Size = UDim2.new(0, 220, 0, 58)
sellBtn.Position = UDim2.new(0, 20, 1, -78)
sellBtn.BackgroundColor3 = GREEN
sellBtn.Font = Enum.Font.LuckiestGuy
sellBtn.TextSize = 26
sellBtn.TextColor3 = WHITE
sellBtn.TextStrokeTransparency = 0
sellBtn.TextStrokeColor3 = DARK
sellBtn.Text = "SELL"
sellBtn.Parent = panel
local sellCorner = Instance.new("UICorner")
sellCorner.CornerRadius = UDim.new(0, 16)
sellCorner.Parent = sellBtn
local sellStroke = Instance.new("UIStroke")
sellStroke.Color = DARK
sellStroke.Thickness = 4
sellStroke.Parent = sellBtn

local autoSell = Instance.new("TextLabel")
autoSell.Size = UDim2.new(0, 260, 0, 42)
autoSell.Position = UDim2.new(1, -280, 1, -70)
autoSell.BackgroundColor3 = Color3.fromRGB(235, 238, 248)
autoSell.BorderSizePixel = 0
autoSell.Font = Enum.Font.GothamBold
autoSell.TextSize = 13
autoSell.TextColor3 = Color3.fromRGB(90, 96, 120)
autoSell.Text = "Auto Sell: locked for a future update"
autoSell.Parent = panel
local autoCorner = Instance.new("UICorner")
autoCorner.CornerRadius = UDim.new(0, 12)
autoCorner.Parent = autoSell

local statusLabel = Instance.new("TextLabel")
statusLabel.Size = UDim2.new(1, -40, 0, 24)
statusLabel.Position = UDim2.new(0, 20, 1, -128)
statusLabel.BackgroundTransparency = 1
statusLabel.Font = Enum.Font.GothamBold
statusLabel.TextSize = 14
statusLabel.TextColor3 = Color3.fromRGB(80, 84, 104)
statusLabel.TextXAlignment = Enum.TextXAlignment.Left
statusLabel.Text = ""
statusLabel.Parent = panel

local isOpen = false

local function applyModalLayer()
	panel.ZIndex = 60
	for _, obj in ipairs(panel:GetDescendants()) do
		if obj:IsA("GuiObject") and obj.ZIndex < 61 then
			obj.ZIndex = 61
		end
	end
	closeBtn.ZIndex = 70
end

local function parseInventory(str)
	local inventory = {}
	if not str or str == "" then
		return inventory
	end

	for _, part in ipairs(string.split(str, ",")) do
		local segments = string.split(part, ":")
		local variantKey
		local petId
		local stackIndex
		if tonumber(segments[2]) then
			petId = segments[1]
			stackIndex = 2
		else
			variantKey = segments[1]
			petId = segments[2]
			stackIndex = 3
		end
		if petId and petId ~= "" then
			local traitId = PetData.normalizeTraitId(segments[stackIndex + 1])
			local personalityId = PetData.normalizePersonalityId(segments[stackIndex + 3] or "Neutral")
			local mutationId = PetData.normalizeMutationId(segments[stackIndex + 4] or "None")
			variantKey = variantKey or PetData.makeVariantKey(petId, personalityId, mutationId, traitId)
			inventory[variantKey] = {
				petId = petId,
				stackAmount = tonumber(segments[stackIndex]) or 1,
				traitId = traitId,
				isShiny = segments[stackIndex + 2] == "shiny" or segments[stackIndex + 2] == "true",
				personalityId = personalityId,
				mutationId = mutationId,
			}
		end
	end
	return inventory
end

local function getPetCoinMultiplier()
	local petFolder = player:FindFirstChild("PetData")
	local invVal = petFolder and petFolder:FindFirstChild("Inventory")
	local equippedVal = petFolder and petFolder:FindFirstChild("Equipped")
	if not invVal or not equippedVal or equippedVal.Value == "" then
		return 1
	end

	local inventory = parseInventory(invVal.Value)
	local multiplier = 1
	for _, variantKey in ipairs(string.split(equippedVal.Value, ",")) do
		local data = inventory[variantKey]
		if data then
			local entry = PetData.buildPetEntry(data.petId, data.stackAmount, data.isShiny, data.personalityId, data.mutationId, data.traitId)
			if entry then
				multiplier *= (entry.coinMult or 1)
				local trait = ColorTraitData.get(data.traitId)
				local mutation = ColorMutationData.get(data.mutationId)
				multiplier *= (trait.Effects and trait.Effects.SellCoinsMultiplier) or 1
				multiplier *= (mutation.Effects and mutation.Effects.SellCoinsMultiplier) or 1
			end
		end
	end
	return multiplier
end

local function getCoinBoostMultiplier()
	local boosts = player:FindFirstChild("Boosts")
	local coinBoost = boosts and boosts:FindFirstChild("coins")
	if coinBoost and os.time() < coinBoost.Value then
		return 2
	end
	return 1
end

local function getHighestUnlockedColor()
	local storage = player:FindFirstChild("ColorStorage")
	local unlockedValue = storage and storage:FindFirstChild("UnlockedColors")
	local unlocked = ColorData.getUnlockedColorSet(unlockedValue and unlockedValue.Value or "Red")
	local highest = "Red"
	for _, world in ipairs(ColorData.Worlds or {}) do
		if unlocked[world.primaryColor] then
			highest = world.primaryColor
		end
	end
	return highest
end

local function getStoredCurrentWorldColor()
	local storage = player:FindFirstChild("ColorStorage")
	local unlockedValue = storage and storage:FindFirstChild("UnlockedColors")
	local currentWorld = storage and storage:FindFirstChild("CurrentWorld")
	local colorType = currentWorld and currentWorld.Value or player:GetAttribute("ActiveWorldColor")
	local world = ColorData.getWorldByColor(colorType)
	if world and ColorData.isColorUnlocked(unlockedValue and unlockedValue.Value or "Red", world.primaryColor) then
		return world.primaryColor
	end
	return nil
end

local function isPointInside(part, worldPosition, margin)
	local localPoint = part.CFrame:PointToObjectSpace(worldPosition)
	local half = part.Size * 0.5 + Vector3.new(margin, margin, margin)
	return math.abs(localPoint.X) <= half.X
		and math.abs(localPoint.Y) <= half.Y
		and math.abs(localPoint.Z) <= half.Z
end

local function getCurrentWorldColor()
	local character = player.Character
	local root = character and character:FindFirstChild("HumanoidRootPart")
	local storedColor = getStoredCurrentWorldColor()
	if not root then
		return storedColor or getHighestUnlockedColor()
	end

	local storage = player:FindFirstChild("ColorStorage")
	local unlockedValue = storage and storage:FindFirstChild("UnlockedColors")
	local unlockedCsv = unlockedValue and unlockedValue.Value or "Red"
	local nearestColor = nil
	local nearestDistance = math.huge

	for _, obj in ipairs(workspace:GetDescendants()) do
		if obj:IsA("BasePart") and obj:GetAttribute("ColorZone") and obj:GetAttribute("ColorType") then
			local colorType = obj:GetAttribute("ColorType")
			if isPointInside(obj, root.Position, 8) then
				return colorType
			end
			if ColorData.isColorUnlocked(unlockedCsv, colorType) then
				local distance = (root.Position - obj.Position).Magnitude
				if distance < nearestDistance then
					nearestDistance = distance
					nearestColor = colorType
				end
			end
		end
	end

	return storedColor or nearestColor or getHighestUnlockedColor()
end

local function getZoneValueMultiplier()
	local colorType = getCurrentWorldColor()
	local world = ColorData.getWorldByColor(colorType)
	local configured = GameBalance.Sell
		and GameBalance.Sell.ColorValueMultipliers
		and GameBalance.Sell.ColorValueMultipliers[colorType]
	return tonumber(configured or (world and world.colorValueMultiplier)) or 1, colorType
end

local function setStatus(text, color)
	statusLabel.Text = text or ""
	statusLabel.TextColor3 = color or Color3.fromRGB(80, 84, 104)
end

local function refresh()
	local storage = player:FindFirstChild("ColorStorage")
	local held = storage and storage:FindFirstChild("ColorHeld")
	local maxCap = storage and storage:FindFirstChild("MaxCapacity")
	local colorHeld = held and held.Value or 0
	local capacity = maxCap and maxCap.Value or 0
	local petMult = getPetCoinMultiplier()
	local boostMult = getCoinBoostMultiplier()
	local zoneMult, zoneColor = getZoneValueMultiplier()
	local totalMult = zoneMult * petMult * boostMult
	local estimate = math.floor(colorHeld * GameBalance.Sell.BaseCoinsPerColor * totalMult)

	colorLabel.Text = "Color: " .. GameBalance.formatNumber(colorHeld) .. " / " .. GameBalance.formatNumber(capacity)
	estimateLabel.Text = "+" .. GameBalance.formatNumber(estimate) .. " Coins"
	breakdownLabel.Text = "Base: " .. GameBalance.Sell.BaseCoinsPerColor .. " coin per Color\nWorld: " .. tostring(zoneColor) .. " x" .. string.format("%.2f", zoneMult) .. "   Colors: x" .. string.format("%.2f", petMult) .. "   Boosts: x" .. string.format("%.2f", boostMult) .. "   Total: x" .. string.format("%.2f", totalMult)

	local canSell = colorHeld > 0
	sellBtn.Active = canSell
	sellBtn.AutoButtonColor = canSell
	sellBtn.BackgroundColor3 = canSell and GREEN or Color3.fromRGB(180, 186, 202)
	sellBtn.Text = canSell and "SELL" or "NO COLOR"
end

local function toggleSell(open)
	isOpen = open
	if open then
		refresh()
		overlay.Visible = true
		overlay.BackgroundTransparency = 1
		panel.Visible = true
		panel.Size = UDim2.new(0, 80, 0, 80)
		panel.Position = UDim2.fromScale(0.5, 0.5)
		applyModalLayer()
		TweenService:Create(overlay, TweenInfo.new(0.18), {
			BackgroundTransparency = 0.4,
		}):Play()
		TweenService:Create(panel, TweenInfo.new(0.25, Enum.EasingStyle.Back), {
			Size = UDim2.new(0, PANEL_WIDTH, 0, PANEL_HEIGHT),
			Position = UDim2.fromScale(0.5, 0.5),
		}):Play()
	else
		TweenService:Create(overlay, TweenInfo.new(0.16), {
			BackgroundTransparency = 1,
		}):Play()
		TweenService:Create(panel, TweenInfo.new(0.16), {
			Size = UDim2.new(0, 0, 0, 0),
			Position = UDim2.fromScale(0.5, 0.5),
		}):Play()
		task.delay(0.16, function()
			if not isOpen then
				panel.Visible = false
				overlay.Visible = false
			end
		end)
	end
end

sellBtn.MouseButton1Click:Connect(function()
	if not sellBtn.Active then
		setStatus("No Color to sell!", RED)
		return
	end
	setStatus("Selling Color...")
	sellEvent:FireServer("sell")
end)

closeBtn.MouseButton1Click:Connect(function()
	toggleSell(false)
end)

overlay.MouseButton1Click:Connect(function()
	toggleSell(false)
end)

sellEvent.OnClientEvent:Connect(function(success, result)
	if success then
		setStatus("Sold " .. GameBalance.formatNumber(result.colorSold) .. " Color for " .. GameBalance.formatNumber(result.coinsEarned) .. " Coins.", Color3.fromRGB(45, 150, 80))
	else
		setStatus(tostring(result or "Could not sell."), RED)
	end
	refresh()
end)

local storage = player:WaitForChild("ColorStorage", 10)
if storage then
	local held = storage:WaitForChild("ColorHeld", 10)
	local maxCap = storage:WaitForChild("MaxCapacity", 10)
	if held then held.Changed:Connect(refresh) end
	if maxCap then maxCap.Changed:Connect(refresh) end
end

local petFolder = player:WaitForChild("PetData", 10)
if petFolder then
	local inv = petFolder:WaitForChild("Inventory", 10)
	local equipped = petFolder:WaitForChild("Equipped", 10)
	if inv then inv.Changed:Connect(refresh) end
	if equipped then equipped.Changed:Connect(refresh) end
end

UIManager.register("Sell", function() toggleSell(true) end, function() toggleSell(false) end, function() return isOpen end)

local sellBtnEvent = ReplicatedStorage:WaitForChild("HudButton_SELL", 10)
if sellBtnEvent then
	sellBtnEvent.Event:Connect(function()
		UIManager.toggle("Sell")
	end)
end
]]></string>
          </Properties>
        </Item>
        <Item class="LocalScript" referent="99">
          <Properties>
            <string name="Name">ShopUI</string>
            <string name="Source"><![CDATA[-- Equipment shop for paintbrushes and rollers.
local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local TweenService = game:GetService("TweenService")
local ProximityPromptService = game:GetService("ProximityPromptService")

local player = Players.LocalPlayer
local UIManager = require(ReplicatedStorage:WaitForChild("UIManager"))
local ToolData = require(ReplicatedStorage:WaitForChild("ToolData"))
local ColorData = require(ReplicatedStorage:WaitForChild("ColorData"))
local UITheme = require(ReplicatedStorage:WaitForChild("UITheme"))
local ClientUIRoot = require(ReplicatedStorage:WaitForChild("ClientUIRoot"))

local Events = ReplicatedStorage:WaitForChild("Events")
local purchaseEvent = Events:WaitForChild("PurchasePaintTool")
local equipEvent = Events:WaitForChild("EquipPaintTool")

local openBrushShopEvent = ReplicatedStorage:FindFirstChild("OpenBrushShop")
if not openBrushShopEvent then
	openBrushShopEvent = Instance.new("BindableEvent")
	openBrushShopEvent.Name = "OpenBrushShop"
	openBrushShopEvent.Parent = ReplicatedStorage
end

local colorStorage = player:WaitForChild("ColorStorage", 10)
local unlockedColorsValue = colorStorage and colorStorage:WaitForChild("UnlockedColors", 10)

local DARK = Color3.fromRGB(35, 38, 45)
local WHITE = Color3.fromRGB(255, 255, 255)
local CYAN = Color3.fromRGB(118, 238, 244)
local GREEN = Color3.fromRGB(116, 245, 42)
local RED = Color3.fromRGB(255, 24, 96)
local YELLOW = Color3.fromRGB(255, 235, 105)
local LAVENDER = Color3.fromRGB(232, 234, 250)
local PANEL_WIDTH = 700
local PANEL_HEIGHT = 500

local screenGui = ClientUIRoot.GetLayer(player.PlayerGui, "EquipmentShopUI")

local overlay = UITheme.CreateDimOverlay(screenGui, 50)

local panel = Instance.new("Frame")
panel.Name = "EquipmentShopPanel"
panel.AnchorPoint = Vector2.new(0.5, 0.5)
panel.Size = UDim2.new(0, PANEL_WIDTH, 0, PANEL_HEIGHT)
panel.Position = UDim2.fromScale(0.5, 0.5)
panel.BackgroundColor3 = WHITE
panel.BorderSizePixel = 0
panel.Visible = false
panel.ZIndex = 60
panel.Parent = screenGui
UITheme.ApplyResponsiveScale(panel, PANEL_WIDTH, PANEL_HEIGHT, 0.66, 28)
Instance.new("UICorner", panel).CornerRadius = UDim.new(0, 24)
local panelStroke = Instance.new("UIStroke")
panelStroke.Color = DARK
panelStroke.Thickness = 5
panelStroke.Parent = panel

local header = Instance.new("Frame")
header.Size = UDim2.new(1, 0, 0, 66)
header.BackgroundColor3 = CYAN
header.BorderSizePixel = 0
header.Parent = panel
Instance.new("UICorner", header).CornerRadius = UDim.new(0, 24)

local title = Instance.new("TextLabel")
title.Size = UDim2.new(1, -82, 1, 0)
title.Position = UDim2.new(0, 22, 0, 0)
title.BackgroundTransparency = 1
title.Font = Enum.Font.LuckiestGuy
title.TextSize = 31
title.TextColor3 = WHITE
title.TextStrokeTransparency = 0
title.TextStrokeColor3 = DARK
title.TextXAlignment = Enum.TextXAlignment.Left
title.Text = "BRUSH SHOP"
title.Parent = header

local closeBtn = Instance.new("TextButton")
closeBtn.Size = UDim2.new(0, 44, 0, 44)
closeBtn.Position = UDim2.new(1, -58, 0.5, -22)
closeBtn.BackgroundColor3 = RED
closeBtn.AutoButtonColor = false
closeBtn.Font = Enum.Font.LuckiestGuy
closeBtn.TextSize = 25
closeBtn.TextColor3 = WHITE
closeBtn.TextStrokeTransparency = 0
closeBtn.TextStrokeColor3 = DARK
closeBtn.Text = "X"
closeBtn.Parent = header
Instance.new("UICorner", closeBtn).CornerRadius = UDim.new(0, 14)
local closeStroke = Instance.new("UIStroke")
closeStroke.Color = DARK
closeStroke.Thickness = 4
closeStroke.Parent = closeBtn

local status = Instance.new("TextLabel")
status.Size = UDim2.new(1, -36, 0, 32)
status.Position = UDim2.new(0, 18, 0, 74)
status.BackgroundTransparency = 1
status.Font = Enum.Font.GothamBold
status.TextSize = 14
status.TextColor3 = Color3.fromRGB(80, 84, 104)
status.TextXAlignment = Enum.TextXAlignment.Left
status.Text = "Buy better brushes to collect Color faster."
status.Parent = panel

local scroll = Instance.new("ScrollingFrame")
scroll.Size = UDim2.new(1, -34, 1, -124)
scroll.Position = UDim2.new(0, 17, 0, 112)
scroll.BackgroundTransparency = 1
scroll.BorderSizePixel = 0
scroll.ScrollBarThickness = 6
scroll.ScrollBarImageColor3 = DARK
scroll.CanvasSize = UDim2.new(0, 0, 0, 0)
scroll.Parent = panel

local grid = Instance.new("UIGridLayout")
grid.CellSize = UDim2.new(0, 314, 0, 172)
grid.CellPadding = UDim2.new(0, 14, 0, 14)
grid.SortOrder = Enum.SortOrder.LayoutOrder
grid.Parent = scroll

local pad = Instance.new("UIPadding")
pad.PaddingLeft = UDim.new(0, 4)
pad.PaddingTop = UDim.new(0, 4)
pad.PaddingBottom = UDim.new(0, 8)
pad.Parent = scroll

local function formatNum(value)
	value = tonumber(value) or 0
	if value >= 1000000 then
		return string.format("%.1fM", value / 1000000)
	elseif value >= 1000 then
		return string.format("%.1fK", value / 1000)
	end
	return tostring(value)
end

local function getToolValues()
	local folder = player:FindFirstChild("PaintTools")
	return folder and folder:FindFirstChild("Owned"), folder and folder:FindFirstChild("Equipped")
end

local function getOwnedSet()
	local ownedValue = getToolValues()
	local set = { StarterBrush = true }
	local csv = ownedValue and ownedValue.Value or "StarterBrush"
	for _, toolId in ipairs(string.split(csv, ",")) do
		if toolId ~= "" then
			set[toolId] = true
		end
	end
	return set
end

local function getEquippedToolId()
	local _, equippedValue = getToolValues()
	return equippedValue and equippedValue.Value ~= "" and equippedValue.Value or "StarterBrush"
end

local function isToolUnlocked(tool)
	local requiredColor = tool.RequiredColor or "Red"
	if requiredColor == "Red" then
		return true
	end
	return unlockedColorsValue and ColorData.isColorUnlocked(unlockedColorsValue.Value, requiredColor)
end

local function getToolWorldName(tool)
	local world = ColorData.getWorldByColor(tool.RequiredColor or "Red")
	return world and world.name or "Starter Field"
end

local function clearCards()
	for _, child in ipairs(scroll:GetChildren()) do
		if not child:IsA("UIGridLayout") and not child:IsA("UIPadding") then
			child:Destroy()
		end
	end
end

local function applyModalLayer()
	panel.ZIndex = 60
	for _, obj in ipairs(panel:GetDescendants()) do
		if obj:IsA("GuiObject") and obj.ZIndex < 61 then
			obj.ZIndex = 61
		end
	end
	closeBtn.ZIndex = 70
end

local refresh

local function buildCard(tool, layoutOrder)
	local ownedSet = getOwnedSet()
	local owned = ownedSet[tool.Id] == true
	local equipped = owned and getEquippedToolId() == tool.Id
	local rarityColor = ToolData.RarityColors[tool.Rarity or "Common"] or CYAN
	local unlocked = isToolUnlocked(tool)

	local card = Instance.new("Frame")
	card.LayoutOrder = layoutOrder
	card.BackgroundColor3 = equipped and Color3.fromRGB(236, 255, 252) or Color3.fromRGB(250, 255, 255)
	card.BorderSizePixel = 0
	card.Parent = scroll
	Instance.new("UICorner", card).CornerRadius = UDim.new(0, 18)
	local stroke = Instance.new("UIStroke")
	stroke.Color = equipped and rarityColor or DARK
	stroke.Thickness = equipped and 5 or 3
	stroke.Parent = card

	local icon = Instance.new("TextLabel")
	icon.Size = UDim2.new(0, 86, 1, 0)
	icon.BackgroundColor3 = rarityColor:Lerp(WHITE, 0.25)
	icon.Font = Enum.Font.LuckiestGuy
	icon.TextSize = 38
	icon.TextColor3 = WHITE
	icon.TextStrokeTransparency = 0
	icon.TextStrokeColor3 = DARK
	icon.Text = tool.ShortName or "BR"
	icon.Parent = card
	Instance.new("UICorner", icon).CornerRadius = UDim.new(0, 18)

	local name = Instance.new("TextLabel")
	name.Size = UDim2.new(1, -104, 0, 28)
	name.Position = UDim2.new(0, 98, 0, 14)
	name.BackgroundTransparency = 1
	name.Font = Enum.Font.LuckiestGuy
	name.TextSize = 20
	name.TextScaled = true
	name.TextColor3 = DARK
	name.TextXAlignment = Enum.TextXAlignment.Left
	name.Text = tool.DisplayName
	name.Parent = card
	UITheme.ApplyTextSizeConstraint(name, 12, 20)

	local rarity = Instance.new("TextLabel")
	rarity.Size = UDim2.new(1, -104, 0, 18)
	rarity.Position = UDim2.new(0, 98, 0, 43)
	rarity.BackgroundTransparency = 1
	rarity.Font = Enum.Font.GothamBold
	rarity.TextSize = 11
	rarity.TextColor3 = rarityColor
	rarity.TextXAlignment = Enum.TextXAlignment.Left
	rarity.Text = tostring(tool.Rarity or "Common") .. " | " .. getToolWorldName(tool)
	rarity.Parent = card

	local stats = Instance.new("TextLabel")
	stats.Size = UDim2.new(1, -104, 0, 36)
	stats.Position = UDim2.new(0, 98, 0, 66)
	stats.BackgroundTransparency = 1
	stats.Font = Enum.Font.GothamBold
	stats.TextSize = 12
	stats.TextColor3 = Color3.fromRGB(80, 84, 104)
	stats.TextXAlignment = Enum.TextXAlignment.Left
	stats.TextYAlignment = Enum.TextYAlignment.Top
	stats.TextWrapped = true
	stats.Text = "Range " .. tostring(tool.Range) .. " | Power x" .. tostring(tool.PowerMultiplier)
	stats.Parent = card

	local desc = Instance.new("TextLabel")
	desc.Size = UDim2.new(1, -104, 0, 38)
	desc.Position = UDim2.new(0, 98, 0, 96)
	desc.BackgroundTransparency = 1
	desc.Font = Enum.Font.Gotham
	desc.TextSize = 11
	desc.TextColor3 = Color3.fromRGB(80, 84, 104)
	desc.TextXAlignment = Enum.TextXAlignment.Left
	desc.TextYAlignment = Enum.TextYAlignment.Top
	desc.TextWrapped = true
	desc.Text = tool.Description or ""
	desc.Parent = card

	local button = Instance.new("TextButton")
	button.Size = UDim2.new(0, 178, 0, 28)
	button.Position = UDim2.new(0, 98, 1, -36)
	button.BackgroundColor3 = not unlocked and LAVENDER or equipped and LAVENDER or (owned and GREEN or YELLOW)
	button.AutoButtonColor = false
	button.Font = Enum.Font.LuckiestGuy
	button.TextSize = 14
	button.TextColor3 = WHITE
	button.TextStrokeTransparency = 0
	button.TextStrokeColor3 = DARK
	button.Text = not unlocked and ("UNLOCK " .. string.upper(tostring(tool.RequiredColor or ""))) or equipped and "EQUIPPED" or (owned and "EQUIP" or ("BUY " .. formatNum(tool.Cost) .. " COINS"))
	button.Parent = card
	Instance.new("UICorner", button).CornerRadius = UDim.new(0, 10)
	local buttonStroke = Instance.new("UIStroke")
	buttonStroke.Color = DARK
	buttonStroke.Thickness = 3
	buttonStroke.Parent = button

	button.MouseButton1Click:Connect(function()
		if not unlocked then
			status.Text = "Unlock " .. getToolWorldName(tool) .. " to buy this brush."
			status.TextColor3 = RED
		elseif equipped then
			status.Text = tool.DisplayName .. " is already equipped."
			status.TextColor3 = Color3.fromRGB(80, 84, 104)
		elseif owned then
			equipEvent:FireServer(tool.Id, true)
		else
			purchaseEvent:FireServer(tool.Id)
		end
	end)
end

function refresh()
	clearCards()
	for index, tool in ipairs(ToolData.getOrderedTools()) do
		buildCard(tool, index)
	end
	scroll.CanvasSize = UDim2.new(0, 0, 0, grid.AbsoluteContentSize.Y + 18)
	applyModalLayer()
end

local isOpen = false
local function toggleShop(open)
	isOpen = open
	if open then
		refresh()
		overlay.Visible = true
		overlay.BackgroundTransparency = 1
		panel.Visible = true
		panel.Size = UDim2.new(0, 80, 0, 80)
		panel.Position = UDim2.fromScale(0.5, 0.5)
		TweenService:Create(overlay, TweenInfo.new(0.18), {
			BackgroundTransparency = 0.4,
		}):Play()
		TweenService:Create(panel, TweenInfo.new(0.28, Enum.EasingStyle.Back), {
			Size = UDim2.new(0, PANEL_WIDTH, 0, PANEL_HEIGHT),
			Position = UDim2.fromScale(0.5, 0.5),
		}):Play()
	else
		TweenService:Create(overlay, TweenInfo.new(0.16), {
			BackgroundTransparency = 1,
		}):Play()
		TweenService:Create(panel, TweenInfo.new(0.16), {
			Size = UDim2.new(0, 0, 0, 0),
			Position = UDim2.fromScale(0.5, 0.5),
		}):Play()
		task.wait(0.16)
		panel.Visible = false
		overlay.Visible = false
	end
end

closeBtn.MouseButton1Click:Connect(function()
	toggleShop(false)
end)

overlay.MouseButton1Click:Connect(function()
	toggleShop(false)
end)

purchaseEvent.OnClientEvent:Connect(function(success, _toolId, message)
	status.Text = message or (success and "Brush purchased." or "Could not buy brush.")
	status.TextColor3 = success and Color3.fromRGB(35, 130, 55) or RED
	refresh()
end)

equipEvent.OnClientEvent:Connect(function(success, _toolId, message)
	status.Text = message or (success and "Brush equipped." or "Could not equip brush.")
	status.TextColor3 = success and Color3.fromRGB(35, 130, 55) or RED
	refresh()
end)

task.defer(function()
	local folder = player:WaitForChild("PaintTools", 10)
	if folder then
		local owned = folder:WaitForChild("Owned", 10)
		local equipped = folder:WaitForChild("Equipped", 10)
		if owned then owned:GetPropertyChangedSignal("Value"):Connect(refresh) end
		if equipped then equipped:GetPropertyChangedSignal("Value"):Connect(refresh) end
	end
end)

if unlockedColorsValue then
	unlockedColorsValue:GetPropertyChangedSignal("Value"):Connect(refresh)
end

UIManager.register("Shop", function() toggleShop(true) end, function() toggleShop(false) end, function() return isOpen end)

local shopBtn = ReplicatedStorage:WaitForChild("HudButton_SHOP", 10)
if shopBtn then
	shopBtn.Event:Connect(function() UIManager.toggle("Shop") end)
end

openBrushShopEvent.Event:Connect(function()
	UIManager.toggle("Shop")
end)

ProximityPromptService.PromptTriggered:Connect(function(prompt)
	if prompt:GetAttribute("BrushShopPrompt") or prompt.ObjectText == "Brush Shop" then
		UIManager.toggle("Shop")
	end
end)
]]></string>
          </Properties>
        </Item>
        <Item class="LocalScript" referent="100">
          <Properties>
            <string name="Name">SocialPanelsUI</string>
            <string name="Source"><![CDATA[-- SocialPanelsUI.client.luau
local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local SoundService = game:GetService("SoundService")
local TweenService = game:GetService("TweenService")

local player = Players.LocalPlayer
local UIManager = require(ReplicatedStorage:WaitForChild("UIManager"))
local UITheme = require(ReplicatedStorage:WaitForChild("UITheme"))
local ClientUIRoot = require(ReplicatedStorage:WaitForChild("ClientUIRoot"))
local SettingsData = require(ReplicatedStorage:WaitForChild("SettingsData"))
local Events = ReplicatedStorage:FindFirstChild("Events")
local requestSetSettingEvent = Events and Events:FindFirstChild("RequestSetSetting") or nil
local settingsUpdatedEvent = Events and Events:FindFirstChild("SettingsUpdated") or nil

local DARK = UITheme.Colors.OutlineDark
local CYAN = UITheme.Colors.PrimaryCyan
local PINK = UITheme.Colors.ErrorRed
local LIME = UITheme.Colors.PrimaryGreen
local LAVENDER = UITheme.Colors.PanelLavender

local screenGui = ClientUIRoot.GetLayer(player.PlayerGui, "SocialPanelsUI")

local overlay = UITheme.CreateDimOverlay(screenGui, 50)

local panel = Instance.new("Frame")
panel.Size = UDim2.new(0, 560, 0, 360)
panel.Position = UDim2.new(0.5, -280, 0.5, -180)
panel.BackgroundColor3 = UITheme.Colors.PanelCream
panel.BorderSizePixel = 0
panel.Visible = false
panel.ZIndex = 60
panel.Parent = screenGui

local corner = Instance.new("UICorner")
corner.CornerRadius = UDim.new(0, 22)
corner.Parent = panel

local stroke = Instance.new("UIStroke")
stroke.Color = DARK
stroke.Thickness = 5
stroke.Parent = panel

local title = Instance.new("TextLabel")
title.Size = UDim2.new(1, -86, 0, 72)
title.Position = UDim2.new(0, 24, 0, 8)
title.BackgroundTransparency = 1
title.Font = Enum.Font.LuckiestGuy
title.TextSize = 34
title.TextColor3 = Color3.new(1, 1, 1)
title.TextStrokeTransparency = 0
title.TextStrokeColor3 = DARK
title.TextXAlignment = Enum.TextXAlignment.Left
title.ZIndex = 61
title.Parent = panel

local content = Instance.new("Frame")
content.Size = UDim2.new(1, -54, 1, -110)
content.Position = UDim2.new(0, 27, 0, 90)
content.BackgroundTransparency = 1
content.ZIndex = 61
content.Parent = panel

local contentLayout = Instance.new("UIListLayout")
contentLayout.FillDirection = Enum.FillDirection.Vertical
contentLayout.SortOrder = Enum.SortOrder.LayoutOrder
contentLayout.Padding = UDim.new(0, 8)
contentLayout.Parent = content

local closeBtn = Instance.new("TextButton")
closeBtn.Size = UDim2.new(0, 42, 0, 42)
closeBtn.Position = UDim2.new(1, -64, 0, 16)
closeBtn.BackgroundColor3 = PINK
closeBtn.Font = Enum.Font.LuckiestGuy
closeBtn.TextSize = 28
closeBtn.TextColor3 = Color3.new(1, 1, 1)
closeBtn.TextStrokeTransparency = 0
closeBtn.TextStrokeColor3 = DARK
closeBtn.Text = "X"
closeBtn.ZIndex = 70
closeBtn.Parent = panel

local closeCorner = Instance.new("UICorner")
closeCorner.CornerRadius = UDim.new(0, 12)
closeCorner.Parent = closeBtn
local closeStroke = Instance.new("UIStroke")
closeStroke.Color = DARK
closeStroke.Thickness = 4
closeStroke.Parent = closeBtn

local backBtn = Instance.new("TextButton")
backBtn.Size = UDim2.new(0, 42, 0, 42)
backBtn.Position = UDim2.new(0, 18, 0, 16)
backBtn.BackgroundColor3 = UITheme.Colors.PanelCream
backBtn.Font = Enum.Font.LuckiestGuy
backBtn.TextSize = 26
backBtn.TextColor3 = DARK
backBtn.TextStrokeTransparency = 1
backBtn.Text = "<"
backBtn.Visible = false
backBtn.ZIndex = 70
backBtn.Parent = panel
local backCorner = Instance.new("UICorner")
backCorner.CornerRadius = UDim.new(0, 12)
backCorner.Parent = backBtn
local backStroke = Instance.new("UIStroke")
backStroke.Color = DARK
backStroke.Thickness = 4
backStroke.Parent = backBtn

local currentName = nil
local isOpen = false
local openedFromMenu = false
local savedSettings = SettingsData.Normalize(nil)
local settingsLoaded = false
local pendingSettings = {}
local settingButtons = {}
local settingsStatusLabel = nil

local SETTING_LABELS = {
	Music = "MUSIC",
	SFX = "SFX",
	Popups = "POPUPS",
	LowFX = "LOW FX",
}

local SETTING_ORDER = { "Music", "SFX", "Popups", "LowFX" }

local function isMusicSound(sound)
	local name = string.lower(sound.Name or "")
	return string.find(name, "music", 1, true)
		or string.find(name, "bgm", 1, true)
		or string.find(name, "theme", 1, true)
end

local function applyMusicSetting(enabled)
	for _, root in ipairs({ SoundService, workspace }) do
		for _, obj in ipairs(root:GetDescendants()) do
			if obj:IsA("Sound") and isMusicSound(obj) then
				if obj:GetAttribute("SettingsOriginalVolume") == nil then
					obj:SetAttribute("SettingsOriginalVolume", obj.Volume)
				end
				obj.Volume = enabled and (obj:GetAttribute("SettingsOriginalVolume") or 0.5) or 0
			end
		end
	end
end

local function applySettings(settings)
	savedSettings = SettingsData.Normalize(settings)
	settingsLoaded = true
	for key, value in pairs(savedSettings) do
		player:SetAttribute("Setting" .. key, value)
	end
	applyMusicSetting(savedSettings.Music)
	-- SFX/Popups/LowFX are read by the client systems that create those sounds/effects.
end

local function setSettingsStatus(text, color)
	if settingsStatusLabel then
		settingsStatusLabel.Text = text or ""
		settingsStatusLabel.TextColor3 = color or UITheme.Colors.TextMuted
	end
end

local function updateSettingButton(key)
	local button = settingButtons[key]
	if not button then
		return
	end

	local pending = pendingSettings[key] == true
	local value = savedSettings[key] == true
	button.Text = (SETTING_LABELS[key] or string.upper(key)) .. ": " .. (value and "ON" or "OFF")
	button.BackgroundColor3 = pending and LAVENDER or (value and CYAN or PINK)
	button.AutoButtonColor = settingsLoaded and requestSetSettingEvent ~= nil and not pending
end

local function updateAllSettingButtons()
	for _, key in ipairs(SETTING_ORDER) do
		updateSettingButton(key)
	end
end

local function readReplicatedSettings()
	local folder = player:FindFirstChild("Settings")
	if not folder then
		return false
	end

	local values = {}
	for key, defaultValue in pairs(SettingsData.Defaults) do
		local value = folder:FindFirstChild(key)
		values[key] = value and value:IsA("BoolValue") and value.Value or defaultValue
	end
	applySettings(values)
	updateAllSettingButtons()
	return true
end

local function clearContent()
	for _, child in ipairs(content:GetChildren()) do
		if child ~= contentLayout then
			child:Destroy()
		end
	end
end

local function makeLabel(text, size, color)
	local label = Instance.new("TextLabel")
	label.Size = UDim2.new(1, 0, 0, size + 8)
	label.BackgroundTransparency = 1
label.Font = Enum.Font.GothamBold
label.TextSize = size
label.TextColor3 = color or Color3.fromRGB(40, 48, 64)
label.TextStrokeTransparency = 0.7
label.TextStrokeColor3 = Color3.new(1, 1, 1)
	label.TextXAlignment = Enum.TextXAlignment.Left
	label.Text = text
	label.ZIndex = 62
	label.Parent = content
	return label
end

local function makeButton(text, color, onClick)
	local button = Instance.new("TextButton")
	button.Size = UDim2.new(1, 0, 0, 40)
button.BackgroundColor3 = color
	button.AutoButtonColor = true
	button.Font = Enum.Font.LuckiestGuy
button.TextSize = 28
button.TextColor3 = Color3.new(1, 1, 1)
button.TextStrokeTransparency = 0
	button.TextStrokeColor3 = DARK
	button.Text = text
	button.ZIndex = 62
	button.Parent = content
	local corner = Instance.new("UICorner")
corner.CornerRadius = UDim.new(0, 10)
corner.Parent = button
local stroke = Instance.new("UIStroke")
stroke.Color = DARK
stroke.Thickness = 4
stroke.Parent = button
	if onClick then
		button.MouseButton1Click:Connect(onClick)
	end
	return button
end

local function makeRow(left, right)
	local row = Instance.new("TextLabel")
row.Size = UDim2.new(1, 0, 0, 34)
row.BackgroundColor3 = Color3.fromRGB(236, 255, 253)
row.Font = Enum.Font.GothamBold
row.TextSize = 21
row.TextColor3 = Color3.fromRGB(30, 36, 48)
	row.TextXAlignment = Enum.TextXAlignment.Left
	row.Text = "  " .. left .. "    " .. right
	row.ZIndex = 62
	row.Parent = content
	local corner = Instance.new("UICorner")
corner.CornerRadius = UDim.new(0, 8)
corner.Parent = row
local stroke = Instance.new("UIStroke")
stroke.Color = DARK
stroke.Thickness = 3
stroke.Parent = row
	return row
end

local function buildContent(name)
	clearContent()

	if name == "Trading" then
		makeLabel("Trading is coming soon.", 24, CYAN)
		makeLabel("Trade Colors safely in a future update.", 17, UITheme.Colors.TextMuted)
		makeButton("COMING SOON", LAVENDER)
	elseif name == "Market" then
		makeLabel("Market is coming soon.", 24, CYAN)
		makeLabel("List rare Colors in a future update.", 17, UITheme.Colors.TextMuted)
		makeButton("COMING SOON", LAVENDER)
	elseif name == "Settings" then
		makeLabel("Options", 24, CYAN)
		table.clear(settingButtons)
		settingsStatusLabel = makeLabel(settingsLoaded and "Saved per player." or "Loading settings...", 16, UITheme.Colors.TextMuted)
		for _, key in ipairs(SETTING_ORDER) do
			local button = makeButton((SETTING_LABELS[key] or string.upper(key)) .. ": ...", LAVENDER, function()
				if not settingsLoaded or not requestSetSettingEvent then
					setSettingsStatus("Settings are still loading.", PINK)
					return
				end
				if pendingSettings[key] then
					return
				end

				local nextValue = not (savedSettings[key] == true)
				pendingSettings[key] = true
				updateSettingButton(key)
				setSettingsStatus("Saving " .. (SETTING_LABELS[key] or key) .. "...", UITheme.Colors.TextMuted)
				requestSetSettingEvent:FireServer(key, nextValue)

				task.delay(8, function()
					if pendingSettings[key] then
						pendingSettings[key] = nil
						updateSettingButton(key)
						setSettingsStatus("Setting save timed out. Try again.", PINK)
					end
				end)
			end)
			settingButtons[key] = button
			updateSettingButton(key)
		end
	end
end

local function openPanel(name, context)
	currentName = name
	isOpen = true
	openedFromMenu = context and context.from == "Menu" or false
	backBtn.Visible = openedFromMenu
	title.Position = openedFromMenu and UDim2.new(0, 72, 0, 8) or UDim2.new(0, 24, 0, 8)
	title.Size = openedFromMenu and UDim2.new(1, -134, 0, 72) or UDim2.new(1, -86, 0, 72)
	title.Text = string.upper(name)
	buildContent(name)
	overlay.Visible = true
	overlay.BackgroundTransparency = 1
	panel.Visible = true
	panel.Size = UDim2.new(0, 560, 0, 60)
	panel.Position = UDim2.new(0.5, -280, 0.5, -30)
	TweenService:Create(overlay, TweenInfo.new(0.18), {
		BackgroundTransparency = 0.4,
	}):Play()
	TweenService:Create(panel, TweenInfo.new(0.22, Enum.EasingStyle.Back), {
		Size = UDim2.new(0, 560, 0, 360),
		Position = UDim2.new(0.5, -280, 0.5, -180),
	}):Play()
end

local function closePanel(name, context)
	if name and currentName ~= name then
		return
	end
	isOpen = false
	openedFromMenu = false
	backBtn.Visible = false
	if context and context.immediate then
		panel.Visible = false
		overlay.Visible = false
		overlay.BackgroundTransparency = 1
		currentName = nil
		return
	end
	TweenService:Create(overlay, TweenInfo.new(0.14), {
		BackgroundTransparency = 1,
	}):Play()
	TweenService:Create(panel, TweenInfo.new(0.14), {
		Size = UDim2.new(0, 0, 0, 0),
		Position = UDim2.new(0.5, 0, 0.5, 0),
	}):Play()
	task.delay(0.14, function()
		if not isOpen then
			panel.Visible = false
			overlay.Visible = false
			currentName = nil
		end
	end)
end

backBtn.MouseButton1Click:Connect(function()
	if openedFromMenu then
		UIManager.open("Menu")
	end
end)

closeBtn.MouseButton1Click:Connect(function()
	if currentName then
		UIManager.close(currentName)
	else
		closePanel()
	end
end)

overlay.MouseButton1Click:Connect(function()
	if currentName then
		UIManager.close(currentName)
	else
		closePanel()
	end
end)

if settingsUpdatedEvent then
	settingsUpdatedEvent.OnClientEvent:Connect(function(settings, success, settingKey, message)
		applySettings(settings)
		if settingKey then
			pendingSettings[settingKey] = nil
			updateSettingButton(settingKey)
		else
			updateAllSettingButtons()
		end

		if currentName == "Settings" then
			if success == false then
				setSettingsStatus(message or "Setting was not saved.", PINK)
			else
				setSettingsStatus(message or "Saved.", LIME)
			end
		end
	end)
else
	-- Remotes can arrive shortly after this client script. Settings still registers immediately.
end

task.spawn(function()
	local eventsFolder = Events or ReplicatedStorage:WaitForChild("Events", 10)
	if not eventsFolder then
		return
	end

	if not requestSetSettingEvent then
		requestSetSettingEvent = eventsFolder:WaitForChild("RequestSetSetting", 10)
	end
	if not settingsUpdatedEvent then
		settingsUpdatedEvent = eventsFolder:WaitForChild("SettingsUpdated", 10)
		if settingsUpdatedEvent then
			settingsUpdatedEvent.OnClientEvent:Connect(function(settings, success, settingKey, message)
				applySettings(settings)
				if settingKey then
					pendingSettings[settingKey] = nil
					updateSettingButton(settingKey)
				else
					updateAllSettingButtons()
				end

				if currentName == "Settings" then
					if success == false then
						setSettingsStatus(message or "Setting was not saved.", PINK)
					else
						setSettingsStatus(message or "Saved.", LIME)
					end
				end
			end)
		end
	end
	updateAllSettingButtons()
end)

if not readReplicatedSettings() then
	task.spawn(function()
		local folder = player:WaitForChild("Settings", 10)
		if folder then
			readReplicatedSettings()
			for _, child in ipairs(folder:GetChildren()) do
				if child:IsA("BoolValue") then
					child:GetPropertyChangedSignal("Value"):Connect(readReplicatedSettings)
				end
			end
			folder.ChildAdded:Connect(function(child)
				if child:IsA("BoolValue") then
					child:GetPropertyChangedSignal("Value"):Connect(readReplicatedSettings)
					readReplicatedSettings()
				end
			end)
		end
	end)
end

for _, name in ipairs({ "Trading", "Market", "Settings" }) do
	UIManager.register(name,
		function(context) openPanel(name, context) end,
		function(context) closePanel(name, context) end,
		function() return isOpen and currentName == name end
	)
end
]]></string>
          </Properties>
        </Item>
        <Item class="LocalScript" referent="101">
          <Properties>
            <string name="Name">TextReadability</string>
            <string name="Source"><![CDATA[-- Light readability pass for player-facing UI text.
-- Keeps the simulator style, but stops small outlined labels from turning into blobs.
local Players = game:GetService("Players")
local TweenService = game:GetService("TweenService")

local player = Players.LocalPlayer
local playerGui = player:WaitForChild("PlayerGui")

local SAFE_GLOW_COLORS = {
	Color3.fromRGB(105, 226, 232), -- soft cyan
	Color3.fromRGB(164, 143, 238), -- soft lavender
	Color3.fromRGB(255, 201, 112), -- warm gold
	Color3.fromRGB(125, 224, 154), -- soft mint
	Color3.fromRGB(244, 147, 184), -- soft rose
}

local SAFE_HOVER_COLORS = {
	Color3.fromRGB(88, 255, 231),
	Color3.fromRGB(255, 218, 92),
	Color3.fromRGB(125, 255, 158),
	Color3.fromRGB(185, 155, 255),
	Color3.fromRGB(255, 136, 198),
}

local hoverOriginals = setmetatable({}, { __mode = "k" })

local function luminance(color)
	return color.R * 0.2126 + color.G * 0.7152 + color.B * 0.0722
end

local function colorDistance(a, b)
	local dr = a.R - b.R
	local dg = a.G - b.G
	local db = a.B - b.B
	return math.sqrt(dr * dr + dg * dg + db * db)
end

local function getParentBackground(gui)
	local parent = gui.Parent
	while parent do
		if parent:IsA("GuiObject") and parent.BackgroundTransparency < 0.92 then
			return parent.BackgroundColor3
		end
		parent = parent.Parent
	end
	return Color3.fromRGB(255, 255, 255)
end

local function chooseGlowColor(gui)
	local seedText = tostring(gui.Name) .. "|" .. tostring(gui.Text)
	local seed = 0
	for i = 1, #seedText do
		seed += string.byte(seedText, i) * i
	end

	local textColor = gui.TextColor3
	local bgColor = getParentBackground(gui)
	local bestColor = SAFE_GLOW_COLORS[1]
	local bestScore = -math.huge
	for i, color in ipairs(SAFE_GLOW_COLORS) do
		local candidate = SAFE_GLOW_COLORS[((seed + i - 1) % #SAFE_GLOW_COLORS) + 1]
		local score = colorDistance(candidate, textColor) * 0.55
			+ colorDistance(candidate, bgColor) * 0.45
			- math.abs(luminance(candidate) - 0.72) * 0.28
		if score > bestScore then
			bestScore = score
			bestColor = candidate
		end
	end

	return bestColor
end

local function chooseHoverColor(gui)
	local seedText = tostring(gui.Name) .. "|" .. tostring(gui.Text)
	local seed = 0
	for i = 1, #seedText do
		seed += string.byte(seedText, i) * i
	end

	local bgColor = getParentBackground(gui)
	local bestColor = SAFE_HOVER_COLORS[1]
	local bestScore = -math.huge
	for i = 1, #SAFE_HOVER_COLORS do
		local candidate = SAFE_HOVER_COLORS[((seed + i - 1) % #SAFE_HOVER_COLORS) + 1]
		local lum = luminance(candidate)
		local score = colorDistance(candidate, bgColor)
			- math.abs(lum - 0.78) * 0.35
		if score > bestScore then
			bestScore = score
			bestColor = candidate
		end
	end

	return bestColor
end

local function getTextConstraint(gui)
	for _, child in ipairs(gui:GetChildren()) do
		if child:IsA("UITextSizeConstraint") then
			return child
		end
	end
	return nil
end

local function shouldGlowText(gui)
	if gui:GetAttribute("NoTextGlow") or gui:GetAttribute("ReadabilityGlow") then
		return false
	end
	if gui:IsA("TextButton") or gui:IsA("TextBox") then
		return false
	end
	if gui.Text == nil or gui.Text == "" then
		return false
	end
	if gui.TextTransparency > 0.35 then
		return false
	end
	if gui.AbsoluteSize.X < 18 or gui.AbsoluteSize.Y < 10 then
		return false
	end
	local visibleTextSize = gui.TextScaled and gui.AbsoluteSize.Y or gui.TextSize
	if visibleTextSize < 20 then
		return false
	end
	return gui.Font == Enum.Font.LuckiestGuy or gui.TextScaled
end

local function ensureTextGlow(gui)
	if not shouldGlowText(gui) then
		local old = gui:FindFirstChild("SoftReadableGlow")
		if old then
			old:Destroy()
		end
		return
	end

	local glow = gui:FindFirstChild("SoftReadableGlow")
	if not glow then
		glow = Instance.new("TextLabel")
		glow.Name = "SoftReadableGlow"
		glow:SetAttribute("ReadabilityGlow", true)
		glow.BackgroundTransparency = 1
		glow.BorderSizePixel = 0
		glow.Active = false
		glow.Selectable = false
		glow.Parent = gui
	end

	local glowColor = chooseGlowColor(gui)
	glow.AnchorPoint = Vector2.new(0.5, 0.5)
	glow.Position = UDim2.new(0.5, 0, 0.5, 0)
	glow.Size = UDim2.new(1, 0, 1, 0)
	glow.Font = gui.Font
	glow.Text = gui.Text
	glow.TextSize = gui.TextSize
	glow.TextScaled = gui.TextScaled
	glow.TextWrapped = gui.TextWrapped
	glow.TextXAlignment = gui.TextXAlignment
	glow.TextYAlignment = gui.TextYAlignment
	glow.RichText = gui.RichText
	glow.TextColor3 = glowColor
	glow.TextTransparency = 0.78
	glow.TextStrokeColor3 = glowColor:Lerp(Color3.new(1, 1, 1), 0.18)
	glow.TextStrokeTransparency = 0.9
	glow.ZIndex = math.max(1, gui.ZIndex - 1)

	local constraint = getTextConstraint(gui)
	local glowConstraint = getTextConstraint(glow)
	if constraint then
		if not glowConstraint then
			glowConstraint = Instance.new("UITextSizeConstraint")
			glowConstraint.Parent = glow
		end
		glowConstraint.MinTextSize = constraint.MinTextSize
		glowConstraint.MaxTextSize = constraint.MaxTextSize + 2
	elseif glowConstraint then
		glowConstraint:Destroy()
	end
end

local function hasAncestorNamed(instance, name)
	local current = instance.Parent
	while current do
		if current.Name == name then
			return true
		end
		current = current.Parent
	end
	return false
end

local function rememberOriginal(instance, propertyName, value)
	local props = hoverOriginals[instance]
	if not props then
		props = {}
		hoverOriginals[instance] = props
	end
	if props[propertyName] == nil then
		props[propertyName] = value
	end
end

local function tweenColor(instance, propertyName, color)
	TweenService:Create(instance, TweenInfo.new(0.13, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
		[propertyName] = color,
	}):Play()
end

local function shouldTintIconPart(obj)
	if not obj:IsA("GuiObject") then
		return false
	end
	if not hasAncestorNamed(obj, "Icon") then
		return false
	end
	return obj.BackgroundTransparency < 1 and luminance(obj.BackgroundColor3) > 0.48
end

local function applyButtonHover(button, hovering)
	local hoverColor = chooseHoverColor(button)

	local function applyText(obj)
		if obj:GetAttribute("ReadabilityGlow") then
			return
		end
		if obj:IsA("TextLabel") or obj:IsA("TextButton") then
			if obj.Text ~= "" and obj.TextTransparency < 0.6 then
				rememberOriginal(obj, "TextColor3", obj.TextColor3)
				tweenColor(obj, "TextColor3", hovering and hoverColor or hoverOriginals[obj].TextColor3)
			end
		end
	end

	applyText(button)
	for _, obj in ipairs(button:GetDescendants()) do
		applyText(obj)

		if obj:IsA("ImageLabel") or obj:IsA("ImageButton") then
			rememberOriginal(obj, "ImageColor3", obj.ImageColor3)
			tweenColor(obj, "ImageColor3", hovering and hoverColor or hoverOriginals[obj].ImageColor3)
		elseif shouldTintIconPart(obj) then
			rememberOriginal(obj, "BackgroundColor3", obj.BackgroundColor3)
			tweenColor(obj, "BackgroundColor3", hovering and hoverColor or hoverOriginals[obj].BackgroundColor3)
		end
	end
end

local function setupHoverColor(button)
	if not button:IsA("TextButton") or button:GetAttribute("ReadableHoverWatched") then
		return
	end
	button:SetAttribute("ReadableHoverWatched", true)

	button.MouseEnter:Connect(function()
		applyButtonHover(button, true)
	end)

	button.MouseLeave:Connect(function()
		applyButtonHover(button, false)
	end)
end

local function improveText(gui)
	if gui:GetAttribute("ReadabilityGlow") then
		return
	end
	if not (gui:IsA("TextLabel") or gui:IsA("TextButton") or gui:IsA("TextBox")) then
		return
	end

	if gui:IsA("TextButton") then
		setupHoverColor(gui)
	end

	local textLum = luminance(gui.TextColor3)
	local strokeLum = luminance(gui.TextStrokeColor3)
	local smallControl = (gui:IsA("TextButton") or gui:IsA("TextBox")) and gui.AbsoluteSize.Y <= 42

	if gui.TextStrokeTransparency < 1 then
		if smallControl and textLum < 0.62 then
			gui.TextStrokeTransparency = 1
		elseif textLum < 0.5 and strokeLum > 0.78 then
			gui.TextStrokeTransparency = 1
		else
			gui.TextStrokeTransparency = math.max(gui.TextStrokeTransparency, 0.35)
		end
	end

	if gui.Font == Enum.Font.LuckiestGuy and gui.TextSize > 0 and gui.TextSize <= 14 then
		gui.Font = Enum.Font.GothamBold
	end

	if gui.TextSize > 0 then
		if gui:IsA("TextButton") or gui:IsA("TextBox") then
			gui.TextSize = math.max(gui.TextSize, 13)
		else
			gui.TextSize = math.max(gui.TextSize, 12)
		end
	end

	if gui.TextScaled then
		local constraint = getTextConstraint(gui)
		if not constraint then
			constraint = Instance.new("UITextSizeConstraint")
			constraint.Parent = gui
		end
		constraint.MinTextSize = math.max(constraint.MinTextSize, 12)
		if constraint.MaxTextSize <= 0 then
			constraint.MaxTextSize = math.max(gui.TextSize, 18)
		end
	end

	ensureTextGlow(gui)

	if not gui:GetAttribute("ReadabilityWatched") then
		gui:SetAttribute("ReadabilityWatched", true)
		gui:GetPropertyChangedSignal("Text"):Connect(function()
			ensureTextGlow(gui)
		end)
		gui:GetPropertyChangedSignal("TextColor3"):Connect(function()
			ensureTextGlow(gui)
		end)
		gui:GetPropertyChangedSignal("TextTransparency"):Connect(function()
			ensureTextGlow(gui)
		end)
		gui:GetPropertyChangedSignal("Visible"):Connect(function()
			ensureTextGlow(gui)
		end)
	end
end

for _, obj in ipairs(playerGui:GetDescendants()) do
	improveText(obj)
end

playerGui.DescendantAdded:Connect(function(obj)
	task.defer(improveText, obj)
end)
]]></string>
          </Properties>
        </Item>
        <Item class="LocalScript" referent="102">
          <Properties>
            <string name="Name">UpgradesUI</string>
            <string name="Source"><![CDATA[-- UpgradesUI.client.luau
local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local TweenService = game:GetService("TweenService")
local ProximityPromptService = game:GetService("ProximityPromptService")

local player = Players.LocalPlayer
local UIManager = require(ReplicatedStorage:WaitForChild("UIManager"))
local UpgradeData = require(ReplicatedStorage:WaitForChild("UpgradeData"))
local UITheme = require(ReplicatedStorage:WaitForChild("UITheme"))
local ClientUIRoot = require(ReplicatedStorage:WaitForChild("ClientUIRoot"))

local Events = ReplicatedStorage:WaitForChild("Events")
local purchaseEvent = Events:WaitForChild("PurchaseUpgrade")
local PANEL_WIDTH = 620
local PANEL_HEIGHT = 430

local screenGui = ClientUIRoot.GetLayer(player.PlayerGui, "UpgradesUI")

local overlay = UITheme.CreateDimOverlay(screenGui, 50)

local panel = Instance.new("Frame")
panel.Name = "UpgradesPanel"
panel.AnchorPoint = Vector2.new(0.5, 0.5)
panel.Size = UDim2.new(0, PANEL_WIDTH, 0, PANEL_HEIGHT)
panel.Position = UDim2.fromScale(0.5, 0.5)
panel.BackgroundColor3 = UITheme.Colors.PanelCream
panel.BorderSizePixel = 0
panel.Visible = false
panel.ZIndex = 60
panel.Parent = screenGui
UITheme.ApplyResponsiveScale(panel, PANEL_WIDTH, PANEL_HEIGHT, 0.7, 28)

local panelCorner = Instance.new("UICorner")
panelCorner.CornerRadius = UDim.new(0, 16)
panelCorner.Parent = panel

local panelStroke = Instance.new("UIStroke")
panelStroke.Color = UITheme.Colors.OutlineDark
panelStroke.Thickness = 5
panelStroke.Parent = panel

local header = Instance.new("Frame")
header.Size = UDim2.new(1, 0, 0, 64)
header.BackgroundColor3 = UITheme.Colors.PrimaryPurple
header.BorderSizePixel = 0
header.ZIndex = 61
header.Parent = panel
local headerCorner = Instance.new("UICorner")
headerCorner.CornerRadius = UDim.new(0, 16)
headerCorner.Parent = header

local title = Instance.new("TextLabel")
title.Size = UDim2.new(1, -70, 1, 0)
title.Position = UDim2.new(0, 20, 0, 0)
title.BackgroundTransparency = 1
title.Font = Enum.Font.LuckiestGuy
title.TextSize = 30
title.TextColor3 = UITheme.Colors.TextWhite
title.TextStrokeTransparency = 0
title.TextStrokeColor3 = UITheme.Colors.OutlineDark
title.TextXAlignment = Enum.TextXAlignment.Left
title.Text = "UPGRADES"
title.ZIndex = 62
title.Parent = header

local closeBtn = Instance.new("TextButton")
closeBtn.Size = UDim2.new(0, 42, 0, 42)
closeBtn.Position = UDim2.new(1, -54, 0.5, -21)
closeBtn.BackgroundColor3 = UITheme.Colors.ErrorRed
closeBtn.Font = Enum.Font.LuckiestGuy
closeBtn.TextSize = 22
closeBtn.TextColor3 = Color3.new(1, 1, 1)
closeBtn.TextStrokeTransparency = 0
closeBtn.TextStrokeColor3 = UITheme.Colors.OutlineDark
closeBtn.Text = "X"
closeBtn.ZIndex = 70
closeBtn.Parent = header

local closeCorner = Instance.new("UICorner")
closeCorner.CornerRadius = UDim.new(0, 12)
closeCorner.Parent = closeBtn

local statusLabel = Instance.new("TextLabel")
statusLabel.Size = UDim2.new(1, -40, 0, 24)
statusLabel.Position = UDim2.new(0, 20, 1, -34)
statusLabel.BackgroundTransparency = 1
statusLabel.Font = Enum.Font.GothamBold
statusLabel.TextSize = 14
statusLabel.TextColor3 = Color3.fromRGB(90, 100, 130)
statusLabel.Text = ""
statusLabel.TextXAlignment = Enum.TextXAlignment.Left
statusLabel.ZIndex = 61
statusLabel.Parent = panel

local scroll = Instance.new("ScrollingFrame")
scroll.Size = UDim2.new(1, -36, 1, -108)
scroll.Position = UDim2.new(0, 18, 0, 66)
scroll.BackgroundTransparency = 1
scroll.BorderSizePixel = 0
scroll.ScrollBarThickness = 6
scroll.CanvasSize = UDim2.new(0, 0, 0, 0)
scroll.ZIndex = 61
scroll.Parent = panel

local layout = Instance.new("UIListLayout")
layout.Padding = UDim.new(0, 10)
layout.SortOrder = Enum.SortOrder.LayoutOrder
layout.Parent = scroll
local scrollPad = Instance.new("UIPadding")
scrollPad.PaddingTop = UDim.new(0, 8)
scrollPad.PaddingBottom = UDim.new(0, 12)
scrollPad.PaddingLeft = UDim.new(0, 2)
scrollPad.PaddingRight = UDim.new(0, 2)
scrollPad.Parent = scroll

local isOpen = false
local cardsById = {}
local pendingUpgradeId = nil
local pendingPurchaseTicket = 0
local refresh

local function getUpgradeLevel(upgradeId)
	local folder = player:FindFirstChild("Upgrades")
	if not folder then
		return 0
	end

	local levelValue = folder:FindFirstChild(upgradeId .. "_Level")
	if levelValue then
		return levelValue.Value
	end

	return 0
end

local function setStatus(text, color)
	statusLabel.Text = text or ""
	statusLabel.TextColor3 = color or Color3.fromRGB(90, 100, 130)
end

local function updateCard(upg)
	local card = cardsById[upg.id]
	if not card then
		return
	end

	local level = getUpgradeLevel(upg.id)
	local maxLevel = #upg.levels
	local valueLabel = card:FindFirstChild("ValueLabel")
	local costLabel = card:FindFirstChild("CostLabel")
	local buyBtn = card:FindFirstChild("BuyButton")

	if valueLabel then
		valueLabel.Text = "Level " .. level .. "/" .. maxLevel .. "  |  " .. UpgradeData.getValueDisplay(upg.id, level)
	end

	if level >= maxLevel then
		if costLabel then costLabel.Text = "MAXED" end
		if buyBtn then
			buyBtn.Text = "MAX"
			buyBtn.BackgroundColor3 = Color3.fromRGB(160, 170, 185)
			buyBtn.Active = false
			buyBtn.AutoButtonColor = false
		end
	elseif pendingUpgradeId == upg.id then
		if costLabel then
			costLabel.Text = "Waiting for server..."
		end
		if buyBtn then
			buyBtn.Text = "BUYING..."
			buyBtn.BackgroundColor3 = Color3.fromRGB(160, 170, 185)
			buyBtn.Active = false
			buyBtn.AutoButtonColor = false
		end
	else
		local nextLevel = level + 1
		local cost = upg.levels[nextLevel].cost
		if costLabel then
			costLabel.Text = "Next: " .. UpgradeData.getValueDisplay(upg.id, nextLevel) .. "  |  Cost: " .. UpgradeData.formatNumber(cost) .. " Coins"
		end
		if buyBtn then
			buyBtn.Text = "BUY"
			buyBtn.BackgroundColor3 = UITheme.Colors.PrimaryGreen
			buyBtn.Active = true
			buyBtn.AutoButtonColor = true
		end
	end
end

local function buildCard(upg, index)
	local card = Instance.new("Frame")
	card.Name = upg.id
	card.Size = UDim2.new(1, -8, 0, 100)
	card.BackgroundColor3 = UITheme.Colors.PanelBlueSoft
	card.BorderSizePixel = 0
	card.LayoutOrder = index
	card.ZIndex = 61
	card.Parent = scroll
	cardsById[upg.id] = card

	local corner = Instance.new("UICorner")
	corner.CornerRadius = UDim.new(0, 12)
	corner.Parent = card

	local stroke = Instance.new("UIStroke")
	stroke.Color = UITheme.Colors.OutlineDark
	stroke.Thickness = 3
	stroke.Parent = card

	local nameLabel = Instance.new("TextLabel")
	nameLabel.Size = UDim2.new(1, -140, 0, 26)
	nameLabel.Position = UDim2.new(0, 14, 0, 8)
	nameLabel.BackgroundTransparency = 1
	nameLabel.Font = Enum.Font.GothamBold
	nameLabel.TextSize = 18
	nameLabel.TextColor3 = Color3.fromRGB(45, 55, 90)
	nameLabel.TextXAlignment = Enum.TextXAlignment.Left
	nameLabel.Text = upg.displayName
	nameLabel.ZIndex = 62
	nameLabel.Parent = card

	local descLabel = Instance.new("TextLabel")
	descLabel.Size = UDim2.new(1, -150, 0, 20)
	descLabel.Position = UDim2.new(0, 14, 0, 34)
	descLabel.BackgroundTransparency = 1
	descLabel.Font = Enum.Font.Gotham
	descLabel.TextSize = 13
	descLabel.TextColor3 = Color3.fromRGB(90, 100, 125)
	descLabel.TextXAlignment = Enum.TextXAlignment.Left
	descLabel.TextTruncate = Enum.TextTruncate.AtEnd
	descLabel.Text = upg.description
	descLabel.ZIndex = 62
	descLabel.Parent = card

	local valueLabel = Instance.new("TextLabel")
	valueLabel.Name = "ValueLabel"
	valueLabel.Size = UDim2.new(1, -150, 0, 18)
	valueLabel.Position = UDim2.new(0, 14, 0, 56)
	valueLabel.BackgroundTransparency = 1
	valueLabel.Font = Enum.Font.GothamBold
	valueLabel.TextSize = 13
	valueLabel.TextColor3 = Color3.fromRGB(65, 80, 130)
	valueLabel.TextXAlignment = Enum.TextXAlignment.Left
	valueLabel.ZIndex = 62
	valueLabel.Parent = card

	local costLabel = Instance.new("TextLabel")
	costLabel.Name = "CostLabel"
	costLabel.Size = UDim2.new(1, -150, 0, 18)
	costLabel.Position = UDim2.new(0, 14, 0, 76)
	costLabel.BackgroundTransparency = 1
	costLabel.Font = Enum.Font.GothamBold
	costLabel.TextSize = 13
	costLabel.TextColor3 = Color3.fromRGB(130, 100, 40)
	costLabel.TextXAlignment = Enum.TextXAlignment.Left
	costLabel.TextTruncate = Enum.TextTruncate.AtEnd
	costLabel.ZIndex = 62
	costLabel.Parent = card

	local buyBtn = Instance.new("TextButton")
	buyBtn.Name = "BuyButton"
	buyBtn.Size = UDim2.new(0, 92, 0, 42)
	buyBtn.Position = UDim2.new(1, -106, 0.5, -21)
	buyBtn.BackgroundColor3 = UITheme.Colors.PrimaryGreen
	buyBtn.Font = Enum.Font.LuckiestGuy
	buyBtn.TextSize = 18
	buyBtn.TextColor3 = Color3.new(1, 1, 1)
	buyBtn.TextStrokeTransparency = 0
	buyBtn.TextStrokeColor3 = UITheme.Colors.OutlineDark
	buyBtn.Text = "BUY"
	buyBtn.ZIndex = 62
	buyBtn.Parent = card

	local buyCorner = Instance.new("UICorner")
	buyCorner.CornerRadius = UDim.new(0, 12)
	buyCorner.Parent = buyBtn

	buyBtn.MouseButton1Click:Connect(function()
		if pendingUpgradeId then
			return
		end
		setStatus("Buying " .. upg.displayName .. "...")
		pendingUpgradeId = upg.id
		pendingPurchaseTicket += 1
		local ticket = pendingPurchaseTicket
		updateCard(upg)
		print("Upgrade purchase requested: " .. upg.id)
		purchaseEvent:FireServer(upg.id)

		task.delay(8, function()
			if pendingUpgradeId == upg.id and pendingPurchaseTicket == ticket then
				pendingUpgradeId = nil
				setStatus("Purchase failed. Try again.", Color3.fromRGB(210, 70, 80))
				refresh()
				warn("Upgrade purchase failed: timeout")
			end
		end)
	end)

	updateCard(upg)
end

for index, upg in ipairs(UpgradeData.Upgrades) do
	buildCard(upg, index)
end

layout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
	scroll.CanvasSize = UDim2.new(0, 0, 0, layout.AbsoluteContentSize.Y + 10)
end)

function refresh()
	for _, upg in ipairs(UpgradeData.Upgrades) do
		updateCard(upg)
	end
end

local function isLevelValue(child)
	return child:IsA("IntValue") or child:IsA("NumberValue")
end

local function toggleUpgrades(open)
	isOpen = open
	if open then
		refresh()
		overlay.Visible = true
		overlay.BackgroundTransparency = 1
		panel.Visible = true
		panel.Size = UDim2.new(0, PANEL_WIDTH, 0, 60)
		panel.Position = UDim2.fromScale(0.5, 0.5)
		TweenService:Create(overlay, TweenInfo.new(0.18), {
			BackgroundTransparency = 0.4,
		}):Play()
		TweenService:Create(panel, TweenInfo.new(0.25, Enum.EasingStyle.Back), {
			Size = UDim2.new(0, PANEL_WIDTH, 0, PANEL_HEIGHT),
			Position = UDim2.fromScale(0.5, 0.5),
		}):Play()
	else
		TweenService:Create(overlay, TweenInfo.new(0.16), {
			BackgroundTransparency = 1,
		}):Play()
		TweenService:Create(panel, TweenInfo.new(0.16), {
			Size = UDim2.new(0, 0, 0, 0),
			Position = UDim2.fromScale(0.5, 0.5),
		}):Play()
		task.delay(0.16, function()
			if not isOpen then
				panel.Visible = false
				overlay.Visible = false
			end
		end)
	end
end

closeBtn.MouseButton1Click:Connect(function()
	toggleUpgrades(false)
end)

overlay.MouseButton1Click:Connect(function()
	toggleUpgrades(false)
end)

purchaseEvent.OnClientEvent:Connect(function(success, upgradeId, valueOrMessage)
	if pendingUpgradeId == upgradeId then
		pendingUpgradeId = nil
	end
	refresh()
	if success then
		local upg = UpgradeData.getUpgrade(upgradeId)
		local level = tonumber(valueOrMessage) or getUpgradeLevel(upgradeId)
		setStatus((upg and upg.displayName or upgradeId) .. " upgraded to level " .. level .. ".", Color3.fromRGB(45, 150, 80))
		print("Upgrade purchase success")
	else
		setStatus(tostring(valueOrMessage or "Could not buy upgrade."), Color3.fromRGB(210, 70, 80))
		warn("Upgrade purchase failed: " .. tostring(valueOrMessage or "unknown"))
	end
end)

local upgradeFolder = player:WaitForChild("Upgrades", 10)
if upgradeFolder then
	upgradeFolder.ChildAdded:Connect(refresh)
	upgradeFolder.ChildRemoved:Connect(refresh)
	for _, child in ipairs(upgradeFolder:GetChildren()) do
		if isLevelValue(child) then
			child.Changed:Connect(refresh)
		end
	end
	upgradeFolder.ChildAdded:Connect(function(child)
		if isLevelValue(child) then
			child.Changed:Connect(refresh)
		end
	end)
end

UIManager.register("Upgrades", function() toggleUpgrades(true) end, function() toggleUpgrades(false) end, function() return isOpen end)

local upgradesBtn = ReplicatedStorage:WaitForChild("HudButton_UPGRADES", 10)
if upgradesBtn then
	upgradesBtn.Event:Connect(function() UIManager.toggle("Upgrades") end)
end

ProximityPromptService.PromptTriggered:Connect(function(prompt)
	if prompt:GetAttribute("UpgradeStationPrompt") or prompt.ObjectText == "Upgrade Station" then
		UIManager.toggle("Upgrades")
	end
end)
]]></string>
          </Properties>
        </Item>
        <Item class="LocalScript" referent="103">
          <Properties>
            <string name="Name">WorldUI</string>
            <string name="Source"><![CDATA[-- WorldUI.client.luau
local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local TweenService = game:GetService("TweenService")

local player = Players.LocalPlayer
local ColorData = require(ReplicatedStorage:WaitForChild("ColorData"))
local GameBalance = require(ReplicatedStorage:WaitForChild("GameBalance"))
local UIManager = require(ReplicatedStorage:WaitForChild("UIManager"))
local UITheme = require(ReplicatedStorage:WaitForChild("UITheme"))
local ClientUIRoot = require(ReplicatedStorage:WaitForChild("ClientUIRoot"))

local Events = ReplicatedStorage:WaitForChild("Events")
local unlockEvent = Events:WaitForChild("UnlockArea")

local UI_DARK = Color3.fromRGB(35, 38, 45)
local UI_WHITE = Color3.fromRGB(255, 255, 255)
local UI_CYAN = Color3.fromRGB(118, 238, 244)
local UI_GREEN = Color3.fromRGB(116, 245, 42)
local UI_RED = Color3.fromRGB(255, 24, 96)
local UI_YELLOW = Color3.fromRGB(255, 235, 105)
local PANEL_WIDTH = 620
local PANEL_HEIGHT = 470

local unlockedCsv = "Red"
local unlockedSet = { Red = true }
local currentWorldColor = "Red"
local rows = {}
local soonRow

local screenGui = ClientUIRoot.GetLayer(player.PlayerGui, "WorldUI")

local overlay = UITheme.CreateDimOverlay(screenGui, 50)

local panel = Instance.new("Frame")
panel.Name = "WorldPanel"
panel.AnchorPoint = Vector2.new(0.5, 0.5)
panel.Size = UDim2.new(0, PANEL_WIDTH, 0, PANEL_HEIGHT)
panel.Position = UDim2.fromScale(0.5, 0.5)
panel.BackgroundColor3 = UI_WHITE
panel.BorderSizePixel = 0
panel.Visible = false
panel.ZIndex = 60
panel.Parent = screenGui
UITheme.ApplyResponsiveScale(panel, PANEL_WIDTH, PANEL_HEIGHT, 0.68, 28)
local corner = Instance.new("UICorner")
corner.CornerRadius = UDim.new(0, 24)
corner.Parent = panel
local stroke = Instance.new("UIStroke")
stroke.Color = UI_DARK
stroke.Thickness = 5
stroke.Parent = panel

local header = Instance.new("Frame")
header.Size = UDim2.new(1, 0, 0, 60)
header.BackgroundColor3 = UI_CYAN
header.BorderSizePixel = 0
header.Parent = panel
local headerCorner = Instance.new("UICorner")
headerCorner.CornerRadius = UDim.new(0, 24)
headerCorner.Parent = header

local title = Instance.new("TextLabel")
title.Size = UDim2.new(1, -70, 1, 0)
title.Position = UDim2.new(0, 20, 0, 0)
title.BackgroundTransparency = 1
title.Font = Enum.Font.LuckiestGuy
title.TextSize = 28
title.TextColor3 = UI_WHITE
title.TextStrokeTransparency = 0
title.TextStrokeColor3 = UI_DARK
title.TextXAlignment = Enum.TextXAlignment.Left
title.Text = "WORLDS"
title.Parent = header

local closeBtn = Instance.new("TextButton")
closeBtn.Size = UDim2.new(0, 42, 0, 42)
closeBtn.Position = UDim2.new(1, -52, 0.5, -21)
closeBtn.BackgroundColor3 = UI_RED
closeBtn.AutoButtonColor = false
closeBtn.Font = Enum.Font.LuckiestGuy
closeBtn.TextSize = 22
closeBtn.TextColor3 = UI_WHITE
closeBtn.TextStrokeTransparency = 0
closeBtn.TextStrokeColor3 = UI_DARK
closeBtn.Text = "X"
closeBtn.Parent = header
local closeCorner = Instance.new("UICorner")
closeCorner.CornerRadius = UDim.new(0, 14)
closeCorner.Parent = closeBtn
local closeStroke = Instance.new("UIStroke")
closeStroke.Color = UI_DARK
closeStroke.Thickness = 4
closeStroke.Parent = closeBtn

local statusLabel = Instance.new("TextLabel")
statusLabel.Size = UDim2.new(1, -30, 0, 30)
statusLabel.Position = UDim2.new(0, 15, 0, 68)
statusLabel.BackgroundTransparency = 1
statusLabel.Font = Enum.Font.GothamBold
statusLabel.TextSize = 13
statusLabel.TextColor3 = Color3.fromRGB(80, 84, 104)
statusLabel.TextXAlignment = Enum.TextXAlignment.Left
statusLabel.Text = "Unlock new Color worlds to collect better Color drops."
statusLabel.Parent = panel

local list = Instance.new("ScrollingFrame")
list.Size = UDim2.new(1, -30, 1, -112)
list.Position = UDim2.new(0, 15, 0, 100)
list.BackgroundTransparency = 1
list.BorderSizePixel = 0
list.ScrollBarThickness = 6
list.ScrollBarImageColor3 = UI_DARK
list.CanvasSize = UDim2.new(0, 0, 0, 0)
list.Parent = panel
local layout = Instance.new("UIListLayout")
layout.Padding = UDim.new(0, 10)
layout.SortOrder = Enum.SortOrder.LayoutOrder
layout.Parent = list

local function formatNum(value)
	value = tonumber(value) or 0
	return GameBalance and GameBalance.formatNumber and GameBalance.formatNumber(value) or tostring(value)
end

local function setStatus(text, color)
	statusLabel.Text = text
	statusLabel.TextColor3 = color or Color3.fromRGB(80, 84, 104)
end

local function applyModalLayer()
	panel.ZIndex = 60
	for _, obj in ipairs(panel:GetDescendants()) do
		if obj:IsA("GuiObject") and obj.ZIndex < 61 then
			obj.ZIndex = 61
		end
	end
	closeBtn.ZIndex = 70
end

local function isUnlocked(colorType)
	return unlockedSet[colorType] == true
end

local function canTryUnlock(world)
	local previous = ColorData.getPreviousWorld(world.primaryColor)
	return not previous or isUnlocked(previous.primaryColor)
end

local function getVisibleWorldSet()
	local visible = {}
	local highestUnlockedIndex = 1
	local allUnlocked = true

	for index, world in ipairs(ColorData.Worlds) do
		if isUnlocked(world.primaryColor) then
			highestUnlockedIndex = index
		else
			allUnlocked = false
			break
		end
	end

	if allUnlocked then
		for _, world in ipairs(ColorData.Worlds) do
			visible[world.primaryColor] = true
		end
		return visible, true
	end

	local currentWorld = ColorData.Worlds[highestUnlockedIndex] or ColorData.Worlds[1]
	local nextWorld = ColorData.Worlds[highestUnlockedIndex + 1]
	if currentWorld then
		visible[currentWorld.primaryColor] = true
	end
	if nextWorld then
		visible[nextWorld.primaryColor] = true
	end

	return visible, false
end

local function getWorldColor(world)
	local colorInfo = ColorData.Colors[world.primaryColor]
	return colorInfo and colorInfo.color or UI_CYAN
end

local function updateGateSign(sign, world, open)
	for _, surface in ipairs(sign:GetChildren()) do
		if surface:IsA("SurfaceGui") then
			local title = surface:FindFirstChild("Title", true)
			local status = surface:FindFirstChild("Status", true)
			local backing = surface:FindFirstChild("Backing")
			if title and title:IsA("TextLabel") then
				title.Text = world.name
				title.TextColor3 = Color3.fromRGB(242, 248, 255)
			end
			if status and status:IsA("TextLabel") then
				status.Text = open and "Unlocked - Go" or (formatNum(world.unlockCost) .. " Coins")
				status.TextColor3 = open and Color3.fromRGB(145, 245, 170) or Color3.fromRGB(255, 216, 122)
			end
			if backing and backing:IsA("Frame") then
				backing.BackgroundTransparency = open and 0.24 or 0.12
			end
		end
	end
end

local function applyGateVisualState(gate, world, open)
	local worldColor = getWorldColor(world)
	local lockedPanel = worldColor:Lerp(Color3.fromRGB(35, 38, 45), 0.62)
	local openPanel = worldColor:Lerp(Color3.fromRGB(190, 245, 245), 0.2)
	gate.Color = open and openPanel or lockedPanel
	gate.Material = open and Enum.Material.Glass or Enum.Material.SmoothPlastic
	gate.LocalTransparencyModifier = open and 0.58 or 0

	for _, child in ipairs(gate:GetChildren()) do
		if child:IsA("BasePart") and child:GetAttribute("GateDecor") then
			local role = child:GetAttribute("GateVisualRole") or child.Name
			if role == "GateVisualSign" then
				child.Color = Color3.fromRGB(24, 27, 34)
				child.LocalTransparencyModifier = open and 0.12 or 0
				updateGateSign(child, world, open)
			elseif string.find(role, "Glow") then
				child.Color = open and worldColor:Lerp(Color3.fromRGB(255, 255, 255), 0.2) or Color3.fromRGB(255, 96, 116)
				child.LocalTransparencyModifier = open and 0.12 or 0.2
			elseif role == "GateVisualStatusLight" then
				child.Color = open and Color3.fromRGB(125, 255, 150) or Color3.fromRGB(255, 104, 118)
				child.LocalTransparencyModifier = 0
			else
				child.Color = open and Color3.fromRGB(42, 50, 58) or Color3.fromRGB(24, 27, 34)
				child.LocalTransparencyModifier = open and 0.18 or 0
			end
		end
	end
end

local function refreshGates()
	for _, obj in ipairs(workspace:GetDescendants()) do
		if obj:IsA("BasePart") then
			local gateColor = obj:GetAttribute("GateColor") or obj:GetAttribute("UnlockColor")
			if obj:GetAttribute("AreaGate") then
				gateColor = gateColor or obj:GetAttribute("ColorType")
			end

			if gateColor and ColorData.getWorldByColor(gateColor) then
				local world = ColorData.getWorldByColor(gateColor)
				local open = isUnlocked(gateColor)
				if obj:GetAttribute("GateInteraction") then
					obj.LocalTransparencyModifier = 1
					obj.CanCollide = false
					local prompt = obj:FindFirstChild("GatePrompt")
					if prompt and prompt:IsA("ProximityPrompt") then
						prompt.ActionText = open and ("Go to " .. world.name) or ("Unlock " .. world.name)
						prompt.ObjectText = open and "Unlocked" or (formatNum(world.unlockCost) .. " Coins")
						prompt.MaxActivationDistance = 30
						prompt.HoldDuration = 0.1
						prompt.RequiresLineOfSight = false
					end
				elseif obj:GetAttribute("AreaGate") then
					applyGateVisualState(obj, world, open)
					obj.CanCollide = not open
					local prompt = obj:FindFirstChild("GatePrompt")
					if prompt and prompt:IsA("ProximityPrompt") then
						prompt.ActionText = open and ("Go to " .. world.name) or ("Unlock " .. world.name)
						prompt.ObjectText = open and "Unlocked" or (formatNum(world.unlockCost) .. " Coins")
					end

					local billboard = obj:FindFirstChild("GateBillboard")
					if billboard and billboard:IsA("BillboardGui") then
						billboard.Enabled = false
					end
				elseif obj:GetAttribute("GateDecor") then
					obj.LocalTransparencyModifier = open and 0.2 or 0
					obj.CanCollide = false
				else
					obj.LocalTransparencyModifier = open and 0.75 or 0
					obj.CanCollide = not open
				end
			end
		end
	end
end

local function refreshRows()
	unlockedSet = ColorData.getUnlockedColorSet(unlockedCsv)
	local allUnlocked = true

	for _, row in pairs(rows) do
		local world = row.world
		local unlocked = isUnlocked(world.primaryColor)
		local canUnlock = canTryUnlock(world)
		local current = unlocked and currentWorldColor == world.primaryColor
		local previous = ColorData.getPreviousWorld(world.primaryColor)
		if not unlocked then
			allUnlocked = false
		end

		row.frame.Visible = true
		row.frame.BackgroundColor3 = current and Color3.fromRGB(236, 255, 252) or (unlocked and Color3.fromRGB(250, 255, 255) or Color3.fromRGB(244, 246, 252))
		if row.stroke then
			row.stroke.Color = current and UI_GREEN or UI_DARK
			row.stroke.Thickness = current and 4 or 3
		end
		if current then
			row.status.Text = "CURRENT WORLD"
		elseif unlocked then
			row.status.Text = "UNLOCKED"
		elseif previous and not isUnlocked(previous.primaryColor) then
			row.status.Text = "Requires " .. previous.name
		else
			row.status.Text = "Requires " .. formatNum(world.unlockCost) .. " Coins"
		end
		row.status.TextColor3 = unlocked and Color3.fromRGB(35, 130, 55) or Color3.fromRGB(120, 90, 30)
		row.button.Visible = not unlocked
		row.button.Active = canUnlock
		row.button.BackgroundColor3 = canUnlock and UI_GREEN or Color3.fromRGB(210, 214, 225)
		row.button.Text = canUnlock and "UNLOCK" or "LOCKED"
		row.teleport.Visible = unlocked
		row.teleport.Active = unlocked and not current
		row.teleport.BackgroundColor3 = current and UI_GREEN or UI_CYAN
		row.teleport.Text = current and "HERE" or "TELEPORT"
		row.teleport.TextSize = current and 17 or 13
	end

	if soonRow then
		soonRow.Visible = allUnlocked
	end

	list.CanvasSize = UDim2.new(0, 0, 0, layout.AbsoluteContentSize.Y + 12)
	refreshGates()
end

local function buildRows()
	for _, child in ipairs(list:GetChildren()) do
		if not child:IsA("UIListLayout") then
			child:Destroy()
		end
	end
	rows = {}

	for order, world in ipairs(ColorData.Worlds) do
		local row = Instance.new("Frame")
		row.Size = UDim2.new(1, -6, 0, 76)
		row.LayoutOrder = order
		row.BackgroundColor3 = Color3.fromRGB(250, 255, 255)
		row.BorderSizePixel = 0
		row.Parent = list
		local rowCorner = Instance.new("UICorner")
		rowCorner.CornerRadius = UDim.new(0, 14)
		rowCorner.Parent = row
		local rowStroke = Instance.new("UIStroke")
		rowStroke.Color = UI_DARK
		rowStroke.Thickness = 3
		rowStroke.Parent = row

		local swatch = Instance.new("Frame")
		swatch.Size = UDim2.new(0, 44, 0, 44)
		swatch.Position = UDim2.new(0, 14, 0.5, -22)
		swatch.BackgroundColor3 = ColorData.Colors[world.primaryColor] and ColorData.Colors[world.primaryColor].color or UI_CYAN
		swatch.BorderSizePixel = 0
		swatch.Parent = row
		local swatchCorner = Instance.new("UICorner")
		swatchCorner.CornerRadius = UDim.new(1, 0)
		swatchCorner.Parent = swatch
		local swatchStroke = Instance.new("UIStroke")
		swatchStroke.Color = UI_DARK
		swatchStroke.Thickness = 3
		swatchStroke.Parent = swatch

		local name = Instance.new("TextLabel")
		name.Size = UDim2.new(1, -230, 0, 30)
		name.Position = UDim2.new(0, 72, 0, 10)
		name.BackgroundTransparency = 1
		name.Font = Enum.Font.LuckiestGuy
		name.TextSize = 19
		name.TextColor3 = UI_DARK
		name.TextXAlignment = Enum.TextXAlignment.Left
		name.Text = world.name
		name.Parent = row

		local status = Instance.new("TextLabel")
		status.Size = UDim2.new(1, -230, 0, 24)
		status.Position = UDim2.new(0, 72, 0, 40)
		status.BackgroundTransparency = 1
		status.Font = Enum.Font.GothamBold
		status.TextSize = 13
		status.TextXAlignment = Enum.TextXAlignment.Left
		status.Text = ""
		status.Parent = row

		local button = Instance.new("TextButton")
		button.Size = UDim2.new(0, 118, 0, 42)
		button.Position = UDim2.new(1, -132, 0.5, -21)
		button.AutoButtonColor = false
		button.Font = Enum.Font.LuckiestGuy
		button.TextSize = 15
		button.TextColor3 = UI_WHITE
		button.TextStrokeTransparency = 0
		button.TextStrokeColor3 = UI_DARK
		button.Text = "UNLOCK"
		button.Parent = row
		local buttonCorner = Instance.new("UICorner")
		buttonCorner.CornerRadius = UDim.new(0, 12)
		buttonCorner.Parent = button
		local buttonStroke = Instance.new("UIStroke")
		buttonStroke.Color = UI_DARK
		buttonStroke.Thickness = 3
		buttonStroke.Parent = button

		local teleportButton = Instance.new("TextButton")
		teleportButton.Size = UDim2.new(0, 118, 0, 42)
		teleportButton.Position = UDim2.new(1, -132, 0.5, -21)
		teleportButton.BackgroundColor3 = UI_CYAN
		teleportButton.AutoButtonColor = false
		teleportButton.Font = Enum.Font.LuckiestGuy
		teleportButton.TextSize = 17
		teleportButton.TextColor3 = UI_WHITE
		teleportButton.TextStrokeTransparency = 0
		teleportButton.TextStrokeColor3 = UI_DARK
		teleportButton.Text = "GO"
		teleportButton.Visible = false
		teleportButton.Parent = row
		local teleportCorner = Instance.new("UICorner")
		teleportCorner.CornerRadius = UDim.new(0, 12)
		teleportCorner.Parent = teleportButton
		local teleportStroke = Instance.new("UIStroke")
		teleportStroke.Color = UI_DARK
		teleportStroke.Thickness = 3
		teleportStroke.Parent = teleportButton

		button.MouseButton1Click:Connect(function()
			if button.Active then
				unlockEvent:FireServer(world.primaryColor)
			end
		end)

		teleportButton.MouseButton1Click:Connect(function()
			if teleportButton.Active then
				unlockEvent:FireServer("teleport", world.primaryColor)
			end
		end)

		rows[world.primaryColor] = { world = world, frame = row, stroke = rowStroke, status = status, button = button, teleport = teleportButton }
	end

	soonRow = Instance.new("Frame")
	soonRow.Size = UDim2.new(1, -6, 0, 76)
	soonRow.LayoutOrder = #ColorData.Worlds + 1
	soonRow.BackgroundColor3 = Color3.fromRGB(246, 242, 255)
	soonRow.BorderSizePixel = 0
	soonRow.Parent = list
	local soonCorner = Instance.new("UICorner")
	soonCorner.CornerRadius = UDim.new(0, 14)
	soonCorner.Parent = soonRow
	local soonStroke = Instance.new("UIStroke")
	soonStroke.Color = UI_DARK
	soonStroke.Thickness = 3
	soonStroke.Parent = soonRow

	local soonSwatch = Instance.new("Frame")
	soonSwatch.Size = UDim2.new(0, 44, 0, 44)
	soonSwatch.Position = UDim2.new(0, 14, 0.5, -22)
	soonSwatch.BackgroundColor3 = Color3.fromRGB(202, 176, 255)
	soonSwatch.BorderSizePixel = 0
	soonSwatch.Parent = soonRow
	local soonSwatchCorner = Instance.new("UICorner")
	soonSwatchCorner.CornerRadius = UDim.new(1, 0)
	soonSwatchCorner.Parent = soonSwatch
	local soonSwatchStroke = Instance.new("UIStroke")
	soonSwatchStroke.Color = UI_DARK
	soonSwatchStroke.Thickness = 3
	soonSwatchStroke.Parent = soonSwatch

	local soonName = Instance.new("TextLabel")
	soonName.Size = UDim2.new(1, -230, 0, 30)
	soonName.Position = UDim2.new(0, 72, 0, 10)
	soonName.BackgroundTransparency = 1
	soonName.Font = Enum.Font.LuckiestGuy
	soonName.TextSize = 19
	soonName.TextColor3 = UI_DARK
	soonName.TextXAlignment = Enum.TextXAlignment.Left
	soonName.Text = "MORE COMING SOON"
	soonName.Parent = soonRow

	local soonStatus = Instance.new("TextLabel")
	soonStatus.Size = UDim2.new(1, -230, 0, 24)
	soonStatus.Position = UDim2.new(0, 72, 0, 40)
	soonStatus.BackgroundTransparency = 1
	soonStatus.Font = Enum.Font.GothamBold
	soonStatus.TextSize = 13
	soonStatus.TextXAlignment = Enum.TextXAlignment.Left
	soonStatus.TextColor3 = Color3.fromRGB(92, 78, 130)
	soonStatus.Text = "New Color worlds are being mixed."
	soonStatus.Parent = soonRow

	local soonBadge = Instance.new("TextLabel")
	soonBadge.Size = UDim2.new(0, 118, 0, 42)
	soonBadge.Position = UDim2.new(1, -132, 0.5, -21)
	soonBadge.BackgroundColor3 = Color3.fromRGB(202, 176, 255)
	soonBadge.Font = Enum.Font.LuckiestGuy
	soonBadge.TextSize = 17
	soonBadge.TextColor3 = UI_WHITE
	soonBadge.TextStrokeTransparency = 0
	soonBadge.TextStrokeColor3 = UI_DARK
	soonBadge.Text = "SOON"
	soonBadge.Parent = soonRow
	local soonBadgeCorner = Instance.new("UICorner")
	soonBadgeCorner.CornerRadius = UDim.new(0, 12)
	soonBadgeCorner.Parent = soonBadge
	local soonBadgeStroke = Instance.new("UIStroke")
	soonBadgeStroke.Color = UI_DARK
	soonBadgeStroke.Thickness = 3
	soonBadgeStroke.Parent = soonBadge

	refreshRows()
end

local isOpen = false
local function toggleWorld(open)
	isOpen = open
	if open then
		overlay.Visible = true
		overlay.BackgroundTransparency = 1
		panel.Visible = true
		panel.Size = UDim2.new(0, 80, 0, 80)
		panel.Position = UDim2.fromScale(0.5, 0.5)
		applyModalLayer()
		TweenService:Create(overlay, TweenInfo.new(0.18), {
			BackgroundTransparency = 0.4,
		}):Play()
		TweenService:Create(panel, TweenInfo.new(0.3, Enum.EasingStyle.Back), {
			Size = UDim2.new(0, PANEL_WIDTH, 0, PANEL_HEIGHT),
			Position = UDim2.fromScale(0.5, 0.5),
		}):Play()
		refreshRows()
	else
		TweenService:Create(overlay, TweenInfo.new(0.18), {
			BackgroundTransparency = 1,
		}):Play()
		TweenService:Create(panel, TweenInfo.new(0.2), {
			Size = UDim2.new(0, 60, 0, 60),
			Position = UDim2.fromScale(0.5, 0.5),
		}):Play()
		task.wait(0.2)
		panel.Visible = false
		overlay.Visible = false
	end
end

unlockEvent.OnClientEvent:Connect(function(kind, arg1, arg2, arg3)
	if kind == "state" then
		unlockedCsv = arg1 or "Red"
		currentWorldColor = arg3 or currentWorldColor
		refreshRows()
	elseif kind == "unlocked" then
		local world = arg2
		if world then
			currentWorldColor = arg1 or currentWorldColor
			setStatus(world.name .. " unlocked!", Color3.fromRGB(35, 130, 55))
		end
		refreshRows()
	elseif kind == "teleported" then
		local world = arg2
		if world then
			currentWorldColor = arg1 or currentWorldColor
			setStatus("Traveled to " .. world.name .. ".", Color3.fromRGB(35, 130, 55))
		end
		refreshRows()
	elseif kind == "error" then
		setStatus(tostring(arg2 or "Could not unlock area."), UI_RED)
	end
end)

local storage = player:WaitForChild("ColorStorage", 10)
local unlockedValue = storage and storage:WaitForChild("UnlockedColors", 10)
local currentWorldValue = storage and storage:WaitForChild("CurrentWorld", 10)
if unlockedValue then
	unlockedCsv = unlockedValue.Value
	unlockedValue:GetPropertyChangedSignal("Value"):Connect(function()
		unlockedCsv = unlockedValue.Value
		refreshRows()
	end)
end
if currentWorldValue then
	currentWorldColor = currentWorldValue.Value ~= "" and currentWorldValue.Value or currentWorldColor
	currentWorldValue:GetPropertyChangedSignal("Value"):Connect(function()
		currentWorldColor = currentWorldValue.Value ~= "" and currentWorldValue.Value or "Red"
		refreshRows()
	end)
end

closeBtn.MouseButton1Click:Connect(function()
	toggleWorld(false)
end)

overlay.MouseButton1Click:Connect(function()
	toggleWorld(false)
end)

workspace.DescendantAdded:Connect(function(obj)
	if obj:IsA("BasePart") then
		task.defer(refreshGates)
	end
end)

buildRows()
refreshRows()

UIManager.register("World", function() toggleWorld(true) end, function() toggleWorld(false) end, function() return isOpen end)

local worldBtn = ReplicatedStorage:WaitForChild("HudButton_WORLD", 10)
if worldBtn then
	worldBtn.Event:Connect(function() UIManager.toggle("World") end)
end
]]></string>
          </Properties>
        </Item>
      </Item>
    </Item>
  </Item>
</roblox>