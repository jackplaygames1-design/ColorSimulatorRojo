		description = "Equip 3 extra Colors for more power and better bonuses.",
		icon = "+3",
		iconImage = "rbxthumb://type=GamePass&id=1825682519&w=150&h=150",
		price = 199,
		color = Color3.fromRGB(114, 203, 255),
