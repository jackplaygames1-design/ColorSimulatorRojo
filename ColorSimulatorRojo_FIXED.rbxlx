      <Item class="Script" referent="74">
        <Properties>
          <string name="Name">UpdateBoardHandler</string>
          <token name="RunContext">0</token>
          <string name="Source"><![CDATA[local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Workspace = game:GetService("Workspace")

local ok, UpdateLogData = pcall(function()
	return require(ReplicatedStorage:WaitForChild("UpdateLogData"))
end)

if not ok then
	warn("UpdateBoard: missing UpdateLogData")
	return
end

local MAP_NAME = "ColorSimulatorMap"
local LOBBY_NAME = "Lobby"
local BOARD_NAME = "UpdateBoard"
local SURFACE_GUI_NAME = "UpdateBoardSurfaceGui"

local COLORS = {
	dark = Color3.fromRGB(34, 31, 42),
	cream = Color3.fromRGB(255, 250, 238),
	white = Color3.fromRGB(255, 255, 255),
	cyan = Color3.fromRGB(91, 230, 235),
	yellow = Color3.fromRGB(255, 218, 74),
	pink = Color3.fromRGB(255, 105, 165),
	green = Color3.fromRGB(91, 228, 126),
	purple = Color3.fromRGB(177, 141, 255),
	textDark = Color3.fromRGB(42, 37, 56),
	textMuted = Color3.fromRGB(116, 101, 139),
	orange = Color3.fromRGB(255, 174, 72),
}

local FACE_BY_NAME = {
	Front = Enum.NormalId.Front,
	Back = Enum.NormalId.Back,
	Left = Enum.NormalId.Left,
	Right = Enum.NormalId.Right,
	Top = Enum.NormalId.Top,
	Bottom = Enum.NormalId.Bottom,
}

local function getOrCreateMap()
	local map = Workspace:FindFirstChild(MAP_NAME)
	if not map then
		map = Instance.new("Folder")
		map.Name = MAP_NAME
		map.Parent = Workspace
	end
	return map
end

local function getOrCreateLobby(map)
	local lobby = map:FindFirstChild(LOBBY_NAME)
	if not lobby then
		lobby = Instance.new("Folder")
		lobby.Name = LOBBY_NAME
		lobby.Parent = map
	end
	return lobby
end

local function findNamedBoard(map)
	local lobby = map and map:FindFirstChild(LOBBY_NAME)
	local lobbyBoard = lobby and lobby:FindFirstChild(BOARD_NAME)
	if lobbyBoard then
		return lobbyBoard
	end

	local rootBoard = map and map:FindFirstChild(BOARD_NAME)
	if rootBoard then
		return rootBoard
	end

	if map then
		return map:FindFirstChild(BOARD_NAME, true)
	end

	return nil
end

local function getLargestBasePart(root)
	local best = nil
	local bestVolume = -math.huge
	for _, obj in ipairs(root:GetDescendants()) do
		if obj:IsA("BasePart") then
			local volume = obj.Size.X * obj.Size.Y * obj.Size.Z
			if volume > bestVolume then
				bestVolume = volume
				best = obj
			end
		end
	end
	return best
end

local function getBoardPart(board)
	if board:IsA("BasePart") then
		return board
	end

	local largest = getLargestBasePart(board)
	for _, name in ipairs({ "Board", "Screen", "Display", "Panel", "UpdateBoard" }) do
		local found = board:FindFirstChild(name, true)
		if found and found:IsA("BasePart") then
			if largest and (largest.Size.X * largest.Size.Y) > (found.Size.X * found.Size.Y * 1.35) then
				return largest
			end
			return found
		end
	end

	if largest then
		return largest
	end

	local part = Instance.new("Part")
	part.Name = "Board"
	part.Size = Vector3.new(18, 11, 1)
	part.CFrame = CFrame.new(-184, 7.5, -10) * CFrame.Angles(0, math.rad(-24), 0)
	part.Color = COLORS.purple
	part.Material = Enum.Material.SmoothPlastic
	part.Anchored = true
	part.CanCollide = true
	part.Parent = board
	return part
end

local function cleanupOldBoardUi(boardRoot, boardPart)
	local roots = { boardPart }
	if boardRoot ~= boardPart then
		table.insert(roots, boardRoot)
	end

	local seen = {}
	for _, root in ipairs(roots) do
		for _, obj in ipairs(root:GetDescendants()) do
			if not seen[obj] then
				seen[obj] = true
				if obj:IsA("SurfaceGui") and obj.Name == SURFACE_GUI_NAME then
					obj:Destroy()
				elseif obj:IsA("BillboardGui")
					and (obj.Name == "UpdateLabel"
						or obj.Name == "UpdateBoardLabel"
						or obj.Name == "UpdateBoardBillboard"
						or obj:GetAttribute("UpdateBoardLabel") == true)
				then
					obj:Destroy()
				end
			end
		end
	end

	local directBillboard = boardPart:FindFirstChild("UpdateLabel")
	if directBillboard and directBillboard:IsA("BillboardGui") then
		directBillboard:Destroy()
	end
end

local function createPlaceholderBoard(map)
	local lobby = getOrCreateLobby(map)
	local spawn = lobby:FindFirstChild("LobbySpawnPad", true)
	local position = Vector3.new(-184, 7.5, -10)
	local cframe = CFrame.new(position) * CFrame.Angles(0, math.rad(-24), 0)
	if spawn and spawn:IsA("BasePart") then
		position = spawn.Position + Vector3.new(52, 7, -28)
		cframe = CFrame.lookAt(position, spawn.Position + Vector3.new(0, 4, 0))
	end

	local board = Instance.new("Part")
	board.Name = BOARD_NAME
	board.Size = Vector3.new(18, 11, 1)
	board.CFrame = cframe
	board.Color = COLORS.purple
	board.Material = Enum.Material.SmoothPlastic
	board.Anchored = true
	board.CanCollide = true
	board.Archivable = true
	board:SetAttribute("BoardType", "Updates")
	board:SetAttribute("GeneratedBy", "UpdateBoardHandler")
	board:SetAttribute("EditablePlaceholder", true)
	board.Parent = lobby

	print("UpdateBoard: created placeholder board")
	return board
end

local function findOrCreateBoard()
	local map = getOrCreateMap()
	local board = findNamedBoard(map)
	if board then
		print("UpdateBoard: found existing board")
		return board
	end

	return createPlaceholderBoard(map)
end

local function getSurfaceFace(boardPart)
	local faceName = boardPart:GetAttribute("UpdateBoardFace")
	local face = FACE_BY_NAME[tostring(faceName or "")]
	if not face then
		face = Enum.NormalId.Front
		boardPart:SetAttribute("UpdateBoardFace", "Front")
	end
	return face
end

local function addCorner(parent, radius)
	local corner = Instance.new("UICorner")
	corner.CornerRadius = UDim.new(0, radius)
	corner.Parent = parent
	return corner
end

local function addStroke(parent, color, thickness, transparency)
	local stroke = Instance.new("UIStroke")
	stroke.Color = color
	stroke.Thickness = thickness
	stroke.Transparency = transparency or 0
	stroke.Parent = parent
	return stroke
end

local function addPadding(parent, left, right, top, bottom)
	local padding = Instance.new("UIPadding")
	padding.PaddingLeft = UDim.new(0, left)
	padding.PaddingRight = UDim.new(0, right or left)
	padding.PaddingTop = UDim.new(0, top or left)
	padding.PaddingBottom = UDim.new(0, bottom or top or left)
	padding.Parent = parent
	return padding
end

local function addText(parent, name, text, size, position, textColor, font, textSize, wrapped)
	local label = Instance.new("TextLabel")
	label.Name = name
	label.BackgroundTransparency = 1
	label.Size = size
	label.Position = position or UDim2.fromScale(0, 0)
	label.Font = font or Enum.Font.GothamBold
	label.Text = text or ""
	label.TextColor3 = textColor or COLORS.textDark
	label.TextSize = textSize or 24
	label.TextWrapped = wrapped == true
	label.TextXAlignment = Enum.TextXAlignment.Left
	label.TextYAlignment = Enum.TextYAlignment.Center
	label.Parent = parent
	return label
end

local function addTextConstraint(label, minSize, maxSize)
	local constraint = Instance.new("UITextSizeConstraint")
	constraint.MinTextSize = minSize
	constraint.MaxTextSize = maxSize
	constraint.Parent = label
	return constraint
end

local function makePill(parent, name, text, color, position, size)
	local pill = Instance.new("Frame")
	pill.Name = name
	pill.BackgroundColor3 = color
	pill.BorderSizePixel = 0
	pill.Position = position
	pill.Size = size
	pill.Parent = parent
	addCorner(pill, 22)
	addStroke(pill, COLORS.dark, 3)

	local label = addText(pill, "Text", text, UDim2.new(1, -24, 1, 0), UDim2.new(0, 12, 0, 0), COLORS.dark, Enum.Font.GothamBlack, 22, false)
	label.TextXAlignment = Enum.TextXAlignment.Center
	addTextConstraint(label, 12, 22)
	return pill
end

local function makeSection(parent, name, title, color, position, size)
	local section = Instance.new("Frame")
	section.Name = name
	section.BackgroundColor3 = COLORS.white
	section.BorderSizePixel = 0
	section.Position = position
	section.Size = size
	section.Parent = parent
	addCorner(section, 18)
	addStroke(section, COLORS.dark, 3)

	local header = Instance.new("Frame")
	header.Name = "Header"
	header.BackgroundColor3 = color
	header.BorderSizePixel = 0
	header.Size = UDim2.new(1, 0, 0, 48)
	header.Parent = section
	addCorner(header, 18)

	local titleLabel = addText(header, "Title", title, UDim2.new(1, -28, 1, 0), UDim2.new(0, 14, 0, 0), COLORS.dark, Enum.Font.GothamBlack, 22, false)
	addTextConstraint(titleLabel, 14, 22)

	return section
end

local function formatList(items, limit)
	local lines = {}
	for index, item in ipairs(items or {}) do
		if index > limit then
			break
		end
		table.insert(lines, "- " .. tostring(item))
	end
	return table.concat(lines, "\n")
end

local function rebuildSurfaceGui(boardPart)
	local old = boardPart:FindFirstChild(SURFACE_GUI_NAME)
	if old then
		old:Destroy()
	end

	local surface = Instance.new("SurfaceGui")
	surface.Name = SURFACE_GUI_NAME
	surface.Face = getSurfaceFace(boardPart)
	surface.SizingMode = Enum.SurfaceGuiSizingMode.PixelsPerStud
	surface.PixelsPerStud = 50
	surface.CanvasSize = Vector2.new(1000, 600)
	surface.LightInfluence = 0
	surface.AlwaysOnTop = false
	surface.Parent = boardPart

	local outer = Instance.new("Frame")
	outer.Name = "Outer"
	outer.BackgroundColor3 = COLORS.dark
	outer.BorderSizePixel = 0
	outer.Size = UDim2.fromScale(1, 1)
	outer.Parent = surface
	addCorner(outer, 28)

	local main = Instance.new("Frame")
	main.Name = "MainPanel"
	main.BackgroundColor3 = COLORS.cream
	main.BorderSizePixel = 0
	main.Position = UDim2.new(0, 8, 0, 8)
	main.Size = UDim2.new(1, -16, 1, -16)
	main.Parent = outer
	addCorner(main, 18)
	addPadding(main, 0)

	local header = Instance.new("Frame")
	header.Name = "Header"
	header.BackgroundColor3 = COLORS.cyan
	header.BorderSizePixel = 0
	header.Size = UDim2.new(1, 0, 0, 92)
	header.Parent = main
	addCorner(header, 18)

	local title = addText(header, "Title", "LATEST UPDATES", UDim2.new(0.68, -28, 1, 0), UDim2.new(0, 28, 0, 0), COLORS.white, Enum.Font.LuckiestGuy, 52, false)
	title.TextStrokeColor3 = COLORS.dark
	title.TextStrokeTransparency = 0.12
	addTextConstraint(title, 28, 52)

	makePill(
		header,
		"StatusBadge",
		tostring(UpdateLogData.Status or "BETA"),
		COLORS.yellow,
		UDim2.new(1, -226, 0, 22),
		UDim2.new(0, 196, 0, 50)
	)

	local versionText = tostring(UpdateLogData.CurrentVersion or "Beta") .. " - " .. tostring(UpdateLogData.LastUpdated or "")
	local version = addText(main, "Version", versionText, UDim2.new(1, -44, 0, 34), UDim2.new(0, 22, 0, 102), COLORS.textMuted, Enum.Font.GothamBlack, 24, false)
	version.TextXAlignment = Enum.TextXAlignment.Center
	addTextConstraint(version, 16, 24)

	local latest = UpdateLogData.Latest or {}
	local updateTitle = addText(main, "UpdateTitle", string.upper(tostring(latest.Title or "Latest Update")), UDim2.new(1, -60, 0, 58), UDim2.new(0, 30, 0, 134), COLORS.textDark, Enum.Font.LuckiestGuy, 44, false)
	updateTitle.TextXAlignment = Enum.TextXAlignment.Center
	addTextConstraint(updateTitle, 24, 44)

	local subtitle = addText(main, "Subtitle", tostring(latest.Subtitle or ""), UDim2.new(1, -80, 0, 32), UDim2.new(0, 40, 0, 190), COLORS.textMuted, Enum.Font.GothamBlack, 22, true)
	subtitle.TextXAlignment = Enum.TextXAlignment.Center
	addTextConstraint(subtitle, 14, 22)

	local mainSection = Instance.new("Frame")
	mainSection.Name = "LatestSection"
	mainSection.BackgroundColor3 = COLORS.white
	mainSection.BorderSizePixel = 0
	mainSection.Position = UDim2.new(0, 34, 0, 236)
	mainSection.Size = UDim2.new(0.63, -44, 0, 214)
	mainSection.Parent = main
	addCorner(mainSection, 18)
	addStroke(mainSection, COLORS.dark, 3)

	local changes = addText(mainSection, "Changes", formatList(latest.Changes, 5), UDim2.new(1, -34, 1, -28), UDim2.new(0, 18, 0, 14), COLORS.textDark, Enum.Font.GothamBlack, 27, true)
	changes.TextYAlignment = Enum.TextYAlignment.Top
	changes.LineHeight = 1.05
	addTextConstraint(changes, 18, 27)

	local codeSection = makeSection(main, "CodeSection", "ACTIVE CODE", COLORS.green, UDim2.new(0.63, 8, 0, 236), UDim2.new(0.37, -42, 0, 126))
	local codeData = UpdateLogData.FeaturedCode or {}
	local codeText = addText(codeSection, "Code", "CODE: " .. tostring(codeData.Code or "NONE"), UDim2.new(1, -32, 0, 38), UDim2.new(0, 16, 0, 58), COLORS.pink, Enum.Font.LuckiestGuy, 28, false)
	codeText.TextXAlignment = Enum.TextXAlignment.Center
	codeText.TextStrokeColor3 = COLORS.dark
	codeText.TextStrokeTransparency = 0.45
	addTextConstraint(codeText, 18, 28)
	local reward = addText(codeSection, "Reward", tostring(codeData.Reward or ""), UDim2.new(1, -32, 0, 24), UDim2.new(0, 16, 0, 94), COLORS.textMuted, Enum.Font.GothamBold, 16, true)
	reward.TextXAlignment = Enum.TextXAlignment.Center
	addTextConstraint(reward, 12, 16)

	local soonSection = makeSection(main, "ComingSoonSection", "COMING SOON", COLORS.yellow, UDim2.new(0.63, 8, 0, 376), UDim2.new(0.37, -42, 0, 126))
	local soon = addText(soonSection, "List", formatList(UpdateLogData.ComingSoon, 4), UDim2.new(1, -30, 0, 66), UDim2.new(0, 15, 0, 54), COLORS.textDark, Enum.Font.GothamBlack, 17, true)
	soon.TextYAlignment = Enum.TextYAlignment.Top
	soon.LineHeight = 1.05
	addTextConstraint(soon, 12, 17)

	local footer = addText(main, "Footer", tostring(UpdateLogData.Footer or ""), UDim2.new(1, -68, 0, 56), UDim2.new(0, 34, 0, 516), COLORS.textMuted, Enum.Font.GothamBlack, 22, true)
	footer.TextXAlignment = Enum.TextXAlignment.Center
	addTextConstraint(footer, 14, 22)

	print("UpdateBoard: SurfaceGui updated")
end

local board = findOrCreateBoard()
local boardPart = getBoardPart(board)
if not boardPart then
	warn("UpdateBoard: could not find a BasePart for the board display")
	return
end

boardPart:SetAttribute("BoardType", "Updates")
cleanupOldBoardUi(board, boardPart)
rebuildSurfaceGui(boardPart)
]]></string>
        </Properties>
      </Item>
      <Item class="Script" referent="75">
        <Properties>
          <string name="Name">UpgradeHandler</string>
          <token name="RunContext">0</token>
          <string name="Source"><![CDATA[-- Script in ServerScriptService named "UpgradeHandler"
local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")

local UpgradeData = require(ReplicatedStorage:WaitForChild("UpgradeData"))

local Events         = ReplicatedStorage:WaitForChild("Events")
local purchaseEvent  = Events:WaitForChild("PurchaseUpgrade")

-- Store upgrade levels per player
local playerUpgrades = {}
local warnedUnexpectedRequests = {}

local function warnUnexpectedOnce(player, upgradeId)
	local key = tostring(player and player.UserId) .. ":" .. tostring(upgradeId)
	if warnedUnexpectedRequests[key] then
		return
	end
	warnedUnexpectedRequests[key] = true
	warn("Upgrade purchase ignored unexpected client value fields for " .. tostring(upgradeId))
end

local function respond(player, success, upgradeId, valueOrMessage)
	purchaseEvent:FireClient(player, success == true, upgradeId, valueOrMessage)
end

-- ========================
--   APPLY UPGRADE EFFECTS
-- ========================
local function applyUpgrades(player)
	local upgrades = playerUpgrades[player]
	if not upgrades then return end

	local char = player.Character
	local storage = player:FindFirstChild("ColorStorage")

	-- Color Storage
	local storageLevel = upgrades["ColorStorage"] or 0
	if storage then
		local maxCap = storage:FindFirstChild("MaxCapacity")
		if maxCap then
			local upg = UpgradeData.getUpgrade("ColorStorage")
			maxCap.Value = storageLevel == 0 and upg.baseValue or upg.levels[storageLevel].value
		end
	end

	-- Walk Speed
	local speedLevel = upgrades["WalkSpeed"] or 0
	if char then
		local hum = char:FindFirstChildOfClass("Humanoid")
		if hum then
			local upg = UpgradeData.getUpgrade("WalkSpeed")
			hum.WalkSpeed = speedLevel == 0 and upg.baseValue or upg.levels[speedLevel].value
		end
	end

	-- Pet Slots — stored as a value so PetHandler can read it
	local petSlotsLevel = upgrades["PetSlots"] or 0
	local petFolder = player:FindFirstChild("PetData")
	if petFolder then
		local slotVal = petFolder:FindFirstChild("MaxSlots")
		if not slotVal then
			slotVal = Instance.new("IntValue")
			slotVal.Name   = "MaxSlots"
			slotVal.Parent = petFolder
		end
		local upg = UpgradeData.getUpgrade("PetSlots")
		slotVal.Value = petSlotsLevel == 0 and upg.baseValue or upg.levels[petSlotsLevel].value
	end

	-- Other upgrades (PickupRange, ColorMultiplier, HatchSpeed)
	-- stored as values so client/other scripts can read them
	local upgradeFolder = player:FindFirstChild("Upgrades")
	if not upgradeFolder then
		upgradeFolder = Instance.new("Folder")
		upgradeFolder.Name   = "Upgrades"
		upgradeFolder.Parent = player
	end

	local function setUpgradeValue(id, default)
		local existing = upgradeFolder:FindFirstChild(id)
		if not existing then
			existing = Instance.new("NumberValue")
			existing.Name   = id
			existing.Parent = upgradeFolder
		end
		local level = upgrades[id] or 0
		local upg   = UpgradeData.getUpgrade(id)
		existing.Value = level == 0 and (upg and upg.baseValue or default) or upg.levels[level].value
	end

	setUpgradeValue("PickupRange",      8)
	setUpgradeValue("ColorMultiplier",  1.0)
	setUpgradeValue("HatchSpeed",       1.0)
	setUpgradeValue("ColorStorage",     300)
	setUpgradeValue("WalkSpeed",        44)
	setUpgradeValue("PetSlots",         3)
end

-- ========================
--   LOAD UPGRADE LEVELS FROM SAVED DATA
-- ========================
local function loadUpgrades(player)
	playerUpgrades[player] = {}

	local upgradeFolder = player:FindFirstChild("Upgrades")
	if upgradeFolder then
		for _, upg in ipairs(UpgradeData.Upgrades) do
			local val = upgradeFolder:FindFirstChild(upg.id .. "_Level")
			if val then
				playerUpgrades[player][upg.id] = val.Value
			else
				playerUpgrades[player][upg.id] = 0
			end
		end
	else
		for _, upg in ipairs(UpgradeData.Upgrades) do
			playerUpgrades[player][upg.id] = 0
		end
	end
end

-- ========================
--   SAVE UPGRADE LEVELS
-- ========================
local function saveUpgrades(player)
	local upgrades = playerUpgrades[player]
	if not upgrades then return end

	local upgradeFolder = player:FindFirstChild("Upgrades")
	if not upgradeFolder then
		upgradeFolder = Instance.new("Folder")
		upgradeFolder.Name   = "Upgrades"
		upgradeFolder.Parent = player
	end

	for id, level in pairs(upgrades) do
		local existing = upgradeFolder:FindFirstChild(id .. "_Level")
		if not existing then
			existing = Instance.new("IntValue")
			existing.Name   = id .. "_Level"
			existing.Parent = upgradeFolder
		end
		existing.Value = level
	end
end

-- ========================
--   PURCHASE UPGRADE
-- ========================
local function handlePurchase(player, upgradeId, ...)
	if select("#", ...) > 0 then
		warnUnexpectedOnce(player, upgradeId)
	end

	upgradeId = tostring(upgradeId or "")
	print("Upgrade purchase requested: " .. upgradeId)

	local upgrades = playerUpgrades[player]
	if not upgrades then
		respond(player, false, upgradeId, "Player data is not ready.")
		print("Upgrade purchase failed: data missing")
		return
	end

	local upg = UpgradeData.getUpgrade(upgradeId)
	if not upg then
		respond(player, false, upgradeId, "Invalid upgrade.")
		print("Upgrade purchase failed: invalid upgrade")
		return
	end

	local currentLevel = upgrades[upgradeId] or 0
	local maxLevel     = #upg.levels

	if currentLevel >= maxLevel then
		respond(player, false, upgradeId, "Already max level!")
		print("Upgrade purchase failed: maxed")
		return
	end

	local nextLevel = currentLevel + 1
	local cost      = upg.levels[nextLevel].cost

	local stats = player:FindFirstChild("leaderstats")
	if not stats then
		respond(player, false, upgradeId, "Player stats are not ready.")
		print("Upgrade purchase failed: stats missing")
		return
	end
	local coins = stats:FindFirstChild("Coins")
	if not coins or coins.Value < cost then
		respond(player, false, upgradeId, "Not enough coins!")
		print("Upgrade purchase failed: not enough coins")
		return
	end

	-- Deduct coins, level up, apply, save
	coins.Value = coins.Value - cost
	upgrades[upgradeId] = nextLevel

	applyUpgrades(player)
	saveUpgrades(player)

	respond(player, true, upgradeId, nextLevel)
	print("Upgrade purchase success")
	print(player.Name .. " upgraded " .. upgradeId .. " to level " .. nextLevel)
end

purchaseEvent.OnServerEvent:Connect(function(player, upgradeId, ...)
	local ok, err = pcall(handlePurchase, player, upgradeId, ...)
	if not ok then
		warn("Upgrade purchase failed: " .. tostring(err))
		respond(player, false, upgradeId, "Purchase failed. Try again.")
	end
end)

-- ========================
--   PLAYER SETUP
-- ========================
Players.PlayerAdded:Connect(function(player)
	-- Wait for DataManager to load player data first
	local upgradeFolder = player:WaitForChild("Upgrades", 10)

	loadUpgrades(player)

	-- Apply on spawn and re-apply on respawn
	local function onCharacterAdded(char)
		task.wait(0.5)
		applyUpgrades(player)
	end

	player.CharacterAdded:Connect(onCharacterAdded)
	if player.Character then
		onCharacterAdded(player.Character)
	end
end)

Players.PlayerRemoving:Connect(function(player)
	saveUpgrades(player)
	playerUpgrades[player] = nil
end)

-- Expose for other scripts
return {
	getPlayerUpgradeLevel = function(player, id)
		return playerUpgrades[player] and playerUpgrades[player][id] or 0
	end
}
]]></string>
