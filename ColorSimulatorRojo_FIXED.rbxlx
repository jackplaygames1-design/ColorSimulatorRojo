menuGridLayout.VerticalAlignment     = Enum.VerticalAlignment.Top
menuGridLayout.Parent                = menuGrid

-- ========================
--   MENU BUTTON ITEMS
-- ========================
local MENU_ITEMS = {
	{ key = "INVENTORY", label = "INVENTORY", color = Color3.fromRGB(246, 196, 138), accent = Color3.fromRGB(255, 221, 188) },
	{ key = "TRADING",   label = "TRADING",  color = Color3.fromRGB(129, 223, 244), accent = Color3.fromRGB(193, 242, 255) },
	{ key = "SETTINGS",  label = "SETTINGS", color = Color3.fromRGB(214, 211, 239), accent = Color3.fromRGB(235, 232, 248) },
	{ key = "GAMEPASS",  label = "MARKET",   color = Color3.fromRGB(246, 227, 99), accent = Color3.fromRGB(255, 243, 167) },
}

-- Store grid buttons by key for UIManagerClient to find
local gridButtons = {}
local gridButtonScales = {}
local gridButtonStrokes = {}

for order, item in ipairs(MENU_ITEMS) do
	local btn = Instance.new("TextButton")
	btn.Name             = "MenuBtn_" .. item.key  -- Named so UIManagerClient can find them
	btn.Size             = UDim2.new(0, 150, 0, 94)
	btn.LayoutOrder      = order
	btn.BackgroundColor3 = item.color
	btn.AutoButtonColor  = false
	btn.Active           = true
	btn.Text             = ""
	btn.ZIndex           = 62
	btn.Parent           = menuGrid
	local tileScale = Instance.new("UIScale")
	tileScale.Scale = 1
	tileScale.Parent = btn

	local bc = Instance.new("UICorner")
	bc.CornerRadius = UDim.new(0, 18)
	bc.Parent       = btn

	local bs = Instance.new("UIStroke")
	bs.Color     = Color3.fromRGB(36, 32, 44)
	bs.Thickness = 3
	bs.Parent    = btn

	local bottomShade = Instance.new("Frame")
	bottomShade.Name = "BottomShade"
	bottomShade.Size = UDim2.new(1, -10, 0, 20)
	bottomShade.Position = UDim2.new(0, 5, 1, -25)
	bottomShade.BackgroundColor3 = Color3.fromRGB(36, 32, 44)
	bottomShade.BackgroundTransparency = 0.88
	bottomShade.BorderSizePixel = 0
	bottomShade.ZIndex = 63
	bottomShade.Active = false
	bottomShade.Parent = btn
	local bottomShadeCorner = Instance.new("UICorner")
	bottomShadeCorner.CornerRadius = UDim.new(0, 14)
	bottomShadeCorner.Parent = bottomShade

	local hl = Instance.new("Frame")
	hl.Name             = "TopHighlight"
	hl.Size             = UDim2.new(1, -12, 0, 30)
	hl.Position         = UDim2.new(0, 6, 0, 6)
	hl.BackgroundColor3 = item.accent
	hl.BackgroundTransparency = 0.08
	hl.BorderSizePixel  = 0
	hl.ZIndex           = 63
	hl.Active           = false  -- don't block clicks!
	hl.Parent           = btn
	local hlCorner = Instance.new("UICorner")
	hlCorner.CornerRadius = UDim.new(0, 14)
	hlCorner.Parent = hl

	local lblL = Instance.new("TextLabel")
	lblL.Name                   = "Label"
	lblL.Size                   = UDim2.new(1, -12, 1, -8)
	lblL.Position               = UDim2.new(0, 6, 0, 4)
	lblL.BackgroundTransparency = 1
	lblL.Font                   = Enum.Font.LuckiestGuy
	lblL.TextSize               = 22
	lblL.TextColor3             = Color3.fromRGB(255, 247, 235)
	lblL.TextStrokeTransparency = 0.12
	lblL.TextStrokeColor3       = Color3.fromRGB(60, 52, 72)
	lblL.Text                   = item.label
	lblL.TextXAlignment         = Enum.TextXAlignment.Center
	lblL.TextYAlignment         = Enum.TextYAlignment.Center
	lblL.ZIndex                 = 66
	lblL.Active                 = false  -- don't block clicks!
	lblL:SetAttribute("NoTextGlow", true)
	lblL.Parent                 = btn
	UITheme.ApplyTextSizeConstraint(lblL, 15, 23)

	gridButtons[item.key] = btn
	gridButtonScales[item.key] = tileScale
	gridButtonStrokes[item.key] = bs
end

-- ========================
--   MENU OPEN / CLOSE LOGIC
-- ========================
local PANEL_FULL_HEIGHT = MENU_PANEL_HEIGHT

local menuOpen = false
local function isAnotherModalOpen()
	local activeWindow = UIManager.GetActiveWindow and UIManager.GetActiveWindow() or UIManager.getCurrent()
	return activeWindow ~= nil and activeWindow ~= "Menu"
end

local function setMenuButtonDisabled(disabled)
	menuBtn.AutoButtonColor = not disabled
	menuBtn.BackgroundTransparency = disabled and 0.28 or 0
	menuBtn.Active = not disabled
end

local function applyMenuLayer()
	menuPanel.ZIndex = 60
	for _, obj in ipairs(menuPanel:GetDescendants()) do
		if obj:IsA("GuiObject") and obj.ZIndex < 61 then
			obj.ZIndex = 61
		end
	end
	menuCloseBtn.ZIndex = 70
end

local function openMenu()
	if isAnotherModalOpen() then
		setMenuButtonDisabled(true)
		return
	end
	menuOpen = true
	setMenuButtonDisabled(false)
	menuBackdrop.Visible = true
	menuBackdrop.BackgroundTransparency = 1
	menuPanelShadow.Visible = true
	menuPanel.Visible          = true
	menuPanel.ClipsDescendants = false
	menuPanel.Size             = UDim2.new(0, MENU_PANEL_WIDTH, 0, 0)
	menuPanel.Position         = UDim2.fromScale(0.5, 0.5)
	menuPanelShadow.Size       = UDim2.new(0, MENU_PANEL_WIDTH, 0, 0)
	menuPanelShadow.Position   = UDim2.new(0.5, 7, 0.5, 7)
	applyMenuLayer()

	TweenService:Create(menuBackdrop, TweenInfo.new(0.18), {
		BackgroundTransparency = 0.4
	}):Play()
	TweenService:Create(menuPanel, TweenInfo.new(0.3, Enum.EasingStyle.Back), {
		Size = UDim2.new(0, MENU_PANEL_WIDTH, 0, PANEL_FULL_HEIGHT)
	}):Play()
	TweenService:Create(menuPanelShadow, TweenInfo.new(0.3, Enum.EasingStyle.Back), {
		Size = UDim2.new(0, MENU_PANEL_WIDTH, 0, PANEL_FULL_HEIGHT),
		Position = UDim2.new(0.5, 7, 0.5, 7),
	}):Play()

	TweenService:Create(menuBtn, TweenInfo.new(0.15), {
		BackgroundColor3 = UI_CYAN
	}):Play()
end

local function closeMenu(instant)
	menuOpen = false
	menuPanel.ClipsDescendants = true
	if instant then
		menuPanel.Visible = false
		menuPanelShadow.Visible = false
		menuBackdrop.Visible = false
		menuBackdrop.BackgroundTransparency = 1
		menuPanel.Size = UDim2.new(0, MENU_PANEL_WIDTH, 0, 0)
		menuPanelShadow.Size = UDim2.new(0, MENU_PANEL_WIDTH, 0, 0)
		menuBtn.BackgroundColor3 = UI_WHITE
		return
	end
	TweenService:Create(menuBackdrop, TweenInfo.new(0.18), {
		BackgroundTransparency = 1
	}):Play()
	TweenService:Create(menuPanel, TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {
		Size = UDim2.new(0, MENU_PANEL_WIDTH, 0, 0)
	}):Play()
	TweenService:Create(menuPanelShadow, TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {
		Size = UDim2.new(0, MENU_PANEL_WIDTH, 0, 0)
	}):Play()
	task.delay(0.2, function()
		if not menuOpen then
			menuPanel.Visible = false
			menuPanelShadow.Visible = false
			menuBackdrop.Visible = false
		end
	end)
	TweenService:Create(menuBtn, TweenInfo.new(0.15), {
		BackgroundColor3 = UI_WHITE
	}):Play()
end

UIManager.register("Menu", openMenu, function() closeMenu(true) end, function() return menuOpen end)

-- Menu button click
menuBtn.MouseButton1Down:Connect(function()
	if isAnotherModalOpen() then
		setMenuButtonDisabled(true)
		return
	end
	local size, position = getMenuTargetLayout(-10)
	TweenService:Create(menuBtn, TweenInfo.new(0.08), {
		Size     = size,
		Position = position,
	}):Play()
end)

menuBtn.MouseButton1Up:Connect(function()
	if isAnotherModalOpen() then
		setMenuButtonDisabled(true)
		return
	end
	local size, position = getMenuTargetLayout(0)
	TweenService:Create(menuBtn, TweenInfo.new(0.2, Enum.EasingStyle.Back), {
		Size     = size,
		Position = position,
	}):Play()
	if menuOpen then
		UIManager.close("Menu")
	else
		UIManager.open("Menu")
	end
end)

menuBtn.MouseEnter:Connect(function()
	if isAnotherModalOpen() then
		setMenuButtonDisabled(true)
		return
	end
	local size, position = getMenuTargetLayout(8)
	TweenService:Create(menuBtn, TweenInfo.new(0.15, Enum.EasingStyle.Back), {
		Size     = size,
		Position = position,
	}):Play()
end)
menuBtn.MouseLeave:Connect(function()
	if isAnotherModalOpen() then
		setMenuButtonDisabled(true)
		return
	end
	local size, position = getMenuTargetLayout(0)
	TweenService:Create(menuBtn, TweenInfo.new(0.15), {
		Size     = size,
		Position = position,
	}):Play()
end)

menuCloseBtn.MouseButton1Down:Connect(function()
	TweenService:Create(menuCloseBtn, TweenInfo.new(0.08), {
		Size = UDim2.new(0, 40, 0, 40),
		Position = UDim2.new(1, -56, 0.5, -20),
		BackgroundColor3 = Color3.fromRGB(224, 68, 96),
	}):Play()
end)

menuCloseBtn.MouseButton1Up:Connect(function()
	TweenService:Create(menuCloseBtn, TweenInfo.new(0.14, Enum.EasingStyle.Back), {
		Size = UDim2.new(0, 44, 0, 44),
		Position = UDim2.new(1, -58, 0.5, -22),
		BackgroundColor3 = Color3.fromRGB(255, 98, 123),
	}):Play()
end)

menuCloseBtn.MouseEnter:Connect(function()
	TweenService:Create(menuCloseBtn, TweenInfo.new(0.12), {
		BackgroundColor3 = Color3.fromRGB(255, 120, 145),
	}):Play()
end)

menuCloseBtn.MouseLeave:Connect(function()
	TweenService:Create(menuCloseBtn, TweenInfo.new(0.12), {
		Size = UDim2.new(0, 44, 0, 44),
		Position = UDim2.new(1, -58, 0.5, -22),
		BackgroundColor3 = Color3.fromRGB(255, 98, 123),
	}):Play()
end)

menuCloseBtn.MouseButton1Click:Connect(function()
	UIManager.close("Menu")
end)

menuBackdrop.MouseButton1Click:Connect(function()
	UIManager.close("Menu")
end)

-- ========================
--   GRID BUTTON EVENTS
--   Fire BindableEvents that UIManagerClient listens to
-- ========================
local buttonBindables = {
	PETS      = ReplicatedStorage:FindFirstChild("HudButton_PETS")      or HudButton_PETS,
	UPGRADES  = ReplicatedStorage:FindFirstChild("HudButton_UPGRADES")  or HudButton_UPGRADES,
	WORLD     = ReplicatedStorage:FindFirstChild("HudButton_WORLD")     or HudButton_WORLD,
	GAMEPASS  = ReplicatedStorage:FindFirstChild("HudButton_GAMEPASS")  or HudButton_GAMEPASS,
	INVENTORY = ReplicatedStorage:FindFirstChild("HudButton_INVENTORY") or HudButton_INVENTORY,
	SHOP      = ReplicatedStorage:FindFirstChild("HudButton_SHOP")      or HudButton_SHOP,
	SELL      = ReplicatedStorage:FindFirstChild("HudButton_SELL")      or HudButton_SELL,
	CODES     = ReplicatedStorage:FindFirstChild("HudButton_CODES")     or HudButton_CODES,
}

local function toggleWindowWhenReady(windowName, fallbackBindable)
	if UIManager.isRegistered(windowName) then
		UIManager.open(windowName, { from = "Menu" })
		return
	end

	task.spawn(function()
		local startedAt = os.clock()
		while os.clock() - startedAt < 2 do
			task.wait(0.1)
			if UIManager.isRegistered(windowName) then
				UIManager.open(windowName, { from = "Menu" })
				return
			end
		end

		if fallbackBindable then
			fallbackBindable:Fire()
			task.wait(0.1)
			if UIManager.isRegistered(windowName) then
				UIManager.open(windowName, { from = "Menu" })
				return
			end
		end

		showComingSoon(windowName)
	end)
end

for key, btn in pairs(gridButtons) do
	local be = buttonBindables[key]
	local tileScale = gridButtonScales[key]
	local tileStroke = gridButtonStrokes[key]

	btn.MouseButton1Down:Connect(function()
		TweenService:Create(tileScale, TweenInfo.new(0.07), {
			Scale = 0.94
		}):Play()
	end)

	btn.MouseButton1Up:Connect(function()
		TweenService:Create(tileScale, TweenInfo.new(0.18, Enum.EasingStyle.Back), {
			Scale = 1
		}):Play()

		local windowName = ({
			UPGRADES = "Upgrades",
			WORLD = "World",
			GAMEPASS = "Gamepass",
			INVENTORY = "Inventory",
			SHOP = "Shop",
			SELL = "Sell",
			CODES = "Codes",
			SETTINGS = "Settings",
			TRADING = "Trading",
			PETS = "Inventory",
		})[key]

		if windowName then
			closeMenu(true)
			toggleWindowWhenReady(windowName, be)
		elseif be then
			closeMenu(true)
			task.wait(0.05)
			be:Fire()
		end
	end)

	btn.MouseEnter:Connect(function()
		if tileStroke then
			tileStroke.Thickness = 4
		end
		TweenService:Create(tileScale, TweenInfo.new(0.12, Enum.EasingStyle.Back), {
			Scale = 1.02
		}):Play()
		TweenService:Create(btn, TweenInfo.new(0.1), {
			BackgroundColor3 = btn.BackgroundColor3:Lerp(Color3.new(1,1,1), 0.15)
		}):Play()
	end)
	btn.MouseLeave:Connect(function()
		if tileStroke then
			tileStroke.Thickness = 3
		end
		TweenService:Create(tileScale, TweenInfo.new(0.12), {
			Scale = 1
		}):Play()
		-- Find original color from MENU_ITEMS
		for _, item in ipairs(MENU_ITEMS) do
			if item.key == key then
				TweenService:Create(btn, TweenInfo.new(0.1), {
					BackgroundColor3 = item.color
				}):Play()
				break
			end
		end
	end)
end

local function printHudDebugCounts()
	if screenGui:GetAttribute("HUDDebugPrinted") == true then
		return
	end
	cleanupDuplicateHudElements(screenGui)
	screenGui:SetAttribute("HUDDebugPrinted", true)
	local colorBars = countNamedDescendants(screenGui, "ColorBarContainer")
	local currencies = countNamedDescendants(screenGui, "CurrencyContainer")
	local quickButtons = countNamedDescendants(screenGui, "QuickButtonsContainer")
	print(
		"HUD Debug: ColorBarContainers = " .. colorBars
			.. ", CurrencyContainers = " .. currencies
			.. ", QuickButtonsContainers = " .. quickButtons
	)
	if colorBars > 1 then
		warnHudCleanupOnce("HUD cleanup: duplicate ColorBarContainer count after build")
	end
	if currencies > 1 then
		warnHudCleanupOnce("HUD cleanup: duplicate CurrencyContainer count after build")
	end
	if quickButtons > 1 then
		warnHudCleanupOnce("HUD cleanup: duplicate QuickButtonsContainer count after build")
	end
end

printHudDebugCounts()
applyHatchFocusHud()
hatchFocusActive:GetPropertyChangedSignal("Value"):Connect(applyHatchFocusHud)
autoHatchActive:GetPropertyChangedSignal("Value"):Connect(applyHatchFocusHud)

-- ========================
--   UPDATE LOOP
-- ========================
RunService.Heartbeat:Connect(function()
	setMenuButtonDisabled(isAnotherModalOpen())
	local held = colorHeld.Value
	local max  = math.max(maxCapacity.Value, 1)
	local pct  = held / max

	barFill.Size = UDim2.new(math.clamp(pct, 0, 1), pct > 0 and -8 or 0, 1, -8)
	barLabel.Text = "COLOR " .. held .. " / " .. max

	barFill.BackgroundColor3 = Color3.fromRGB(
		math.floor(130 + 125 * pct),
		math.floor(80  -  40 * pct),
		math.floor(255 -  30 * pct)
	)

	if pct >= 1 then
		barFill.BackgroundTransparency = math.abs(math.sin(tick() * 3)) * 0.2
	else
		barFill.BackgroundTransparency = 0
	end

	local stats = player:FindFirstChild("leaderstats")
	if stats then
		local coins = stats:FindFirstChild("Coins")
		local gems  = stats:FindFirstChild("Gems")
		if coins then coinsLabel.Text = formatCompact(coins.Value) end
		if gems  then gemsLabel.Text  = formatCompact(gems.Value)  end
		fitCurrencyPill(coinPill, coinsLabel)
		fitCurrencyPill(gemPill, gemsLabel)
	end
end)







]]></string>
          </Properties>
        </Item>
        <Item class="LocalScript" referent="89">
          <Properties>
            <string name="Name">InputHandler</string>
            <string name="Source"><![CDATA[-- LocalScript in StarterPlayerScripts named "InputHandler"
local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local RunService = game:GetService("RunService")
local TweenService = game:GetService("TweenService")
local Debris = game:GetService("Debris")

local player = Players.LocalPlayer
local mouse  = player:GetMouse()

local PetData = require(ReplicatedStorage:WaitForChild("PetData"))
local ColorTraitData = require(ReplicatedStorage:WaitForChild("ColorTraitData"))
local ColorMutationData = require(ReplicatedStorage:WaitForChild("ColorMutationData"))
local ClientUIRoot = require(ReplicatedStorage:WaitForChild("ClientUIRoot"))

local Events       = ReplicatedStorage:WaitForChild("Events", 10)
if not Events then
	warn("Collection remote missing, using touch fallback only.")
	return
end
local collectEvent = Events:WaitForChild("CollectColor", 10)
local hatchEvent   = Events:WaitForChild("HatchEgg", 10)
if not collectEvent then
	warn("Collection remote missing, using touch fallback only.")
	return
end
local openEggShopEvent = ReplicatedStorage:FindFirstChild("OpenEggShop")
if not openEggShopEvent then
	openEggShopEvent = Instance.new("BindableEvent")
	openEggShopEvent.Name = "OpenEggShop"
	openEggShopEvent.Parent = ReplicatedStorage
end

local DEFAULT_HOVER_RANGE = 20
local pendingCollectPart = nil

local function getClientSetting(key, defaultValue)
	local value = player:GetAttribute("Setting" .. key)
	return type(value) == "boolean" and value or defaultValue
end

local function parseInventory(str)
	local inventory = {}
	if not str or str == "" then
		return inventory
	end

	for _, part in ipairs(string.split(str, ",")) do
		local segments = string.split(part, ":")
		local variantKey
		local petId
		local stackIndex
		if tonumber(segments[2]) then
			petId = segments[1]
			stackIndex = 2
		else
			variantKey = segments[1]
			petId = segments[2]
			stackIndex = 3
		end
		if petId and petId ~= "" then
			local traitId = PetData.normalizeTraitId(segments[stackIndex + 1])
			local personalityId = PetData.normalizePersonalityId(segments[stackIndex + 3] or "Neutral")
			local mutationId = PetData.normalizeMutationId(segments[stackIndex + 4] or "None")
			variantKey = variantKey or PetData.makeVariantKey(petId, personalityId, mutationId, traitId)
			inventory[variantKey] = {
				traitId = traitId,
				personalityId = personalityId,
				mutationId = mutationId,
			}
		end
	end

	return inventory
end

local function getEquippedPickupMultiplier()
	local petFolder = player:FindFirstChild("PetData")
	local invVal = petFolder and petFolder:FindFirstChild("Inventory")
	local equippedVal = petFolder and petFolder:FindFirstChild("Equipped")
	if not invVal or not equippedVal or equippedVal.Value == "" then
		return 1
	end

	local multiplier = 1
	local inventory = parseInventory(invVal.Value)
	for _, variantKey in ipairs(string.split(equippedVal.Value, ",")) do
		local data = inventory[variantKey]
		if data then
			local trait = ColorTraitData.get(data.traitId)
			local mutation = ColorMutationData.get(data.mutationId)
			multiplier *= (trait.Effects and trait.Effects.BrushRangeMultiplier) or 1
			multiplier *= (mutation.Effects and mutation.Effects.BrushRangeMultiplier) or 1
		end
	end

	return multiplier
end

local function getHoverRange()
	local range = DEFAULT_HOVER_RANGE
	local upgrades = player:FindFirstChild("Upgrades")
	local pickupRange = upgrades and upgrades:FindFirstChild("PickupRange")
	if pickupRange then
		range = pickupRange.Value
	end

	local boostFolder = player:FindFirstChild("Boosts")
	local rangeBoost = boostFolder and boostFolder:FindFirstChild("range")
	if rangeBoost and os.time() < rangeBoost.Value then
		range *= 1.5
	end

	range *= getEquippedPickupMultiplier()
	return range
end

local function hasPaintToolEquipped()
	local character = player.Character
	if not character then
		return false
	end

	for _, child in ipairs(character:GetChildren()) do
		if child:IsA("Tool") and child:GetAttribute("PaintToolId") then
			return true
		end
	end

	return false
end

local feedbackGui = ClientUIRoot.GetLayer(player:WaitForChild("PlayerGui"), "CollectFeedbackUI")

local function playWorldCollectBurst(part)
	if not getClientSetting("Popups", true) then
		return
	end
	if not part or not part.Parent or not part:IsA("BasePart") then
		return
	end

	local attachment = Instance.new("Attachment")
	attachment.Name = "CollectBurst"
	attachment.Parent = part

	local particles = Instance.new("ParticleEmitter")
	particles.Texture = "rbxasset://textures/particles/sparkles_main.dds"
	particles.Color = ColorSequence.new(part.Color, Color3.new(1, 1, 1))
	particles.LightEmission = 0.8
	particles.Size = NumberSequence.new({
		NumberSequenceKeypoint.new(0, 0.35),
		NumberSequenceKeypoint.new(1, 0),
	})
	particles.Speed = NumberRange.new(8, 16)
	particles.SpreadAngle = Vector2.new(180, 180)
	particles.Lifetime = NumberRange.new(0.35, 0.65)
	particles.Rate = 0
	particles.Parent = attachment
	particles:Emit(getClientSetting("LowFX", false) and 8 or 28)

	Debris:AddItem(attachment, 1)
end

local function showCollectFeedback(success, amount, message)
	if success and amount and amount > 0 then
		playWorldCollectBurst(pendingCollectPart)
	end
	pendingCollectPart = nil

	local text
	local color

	if success then
		if amount and amount > 0 then
			text = "+" .. amount .. " COLOR"
			color = Color3.fromRGB(120, 245, 255)
		else
			text = message == "Storage Full! Sell your Color." and message or "FULL"
			color = Color3.fromRGB(255, 220, 90)
		end
	elseif message == "Slow down." or message == "Already collected." then
		return
	else
		text = message or "CAN'T COLLECT"
		color = Color3.fromRGB(255, 110, 140)
	end

	if not getClientSetting("Popups", true) and text ~= "Storage Full! Sell your Color." then
		return
	end

	local label = Instance.new("TextLabel")
	label.AnchorPoint = Vector2.new(0.5, 0.5)
	label.Size = UDim2.new(0, 170, 0, 36)
	label.Position = UDim2.new(0, mouse.X, 0, mouse.Y - 24)
	label.BackgroundTransparency = 1
	label.Font = Enum.Font.LuckiestGuy
	label.TextSize = 22
	label.TextColor3 = color
	label.TextStrokeTransparency = 0
	label.TextStrokeColor3 = Color3.fromRGB(35, 38, 45)
	label.Text = text
	label.ZIndex = 100
	label.Parent = feedbackGui

	TweenService:Create(label, TweenInfo.new(0.45, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
		Position = label.Position - UDim2.new(0, 0, 0, 42),
		TextTransparency = 1,
		TextStrokeTransparency = 1,
	}):Play()

	task.delay(0.5, function()
		if label and label.Parent then
			label:Destroy()
		end
	end)
end

-- ========================
--   HOVER OUTLINE
-- ========================
local currentHover = nil
local currentHighlights = {}

local function clearHighlight()
	for _, hl in ipairs(currentHighlights) do
		if hl and hl.Parent then
			hl:Destroy()
		end
	end
	table.clear(currentHighlights)
	currentHover = nil
end

local function addHoverHighlight(adornee)
	local hl = Instance.new("Highlight")
	hl.Name             = "HoverHighlight"
	hl.FillColor        = Color3.fromRGB(255, 255, 255)
	hl.OutlineColor     = Color3.fromRGB(255, 255, 255)
	hl.FillTransparency = 0.82
	hl.OutlineTransparency = 0
	hl.DepthMode        = Enum.HighlightDepthMode.AlwaysOnTop
	hl.Adornee          = adornee
	hl.Parent           = adornee
	table.insert(currentHighlights, hl)
end

local function setHighlight(part)
	if currentHover == part then return end
	clearHighlight()
	if not part then return end

	addHoverHighlight(part)
	for _, child in ipairs(part:GetDescendants()) do
		if child:IsA("BasePart") and child:GetAttribute("PuddleDetail") and child.Transparency < 1 then
			addHoverHighlight(child)
		end
	end

	currentHover = part
end

-- Update hover every frame
RunService.Heartbeat:Connect(function()
	local target = mouse.Target
	if not target then
		clearHighlight()
		return
	end

	local char = player.Character
	if not char then return end
	local root = char:FindFirstChild("HumanoidRootPart")
	if not root then return end

	-- Only highlight breakables that are in range
	if target:GetAttribute("BreakableType") then
		local dist = (root.Position - target.Position).Magnitude
		if dist <= getHoverRange() then
			setHighlight(target)
			return
		end
	end

	clearHighlight()
end)

-- ========================
--   CLICK TO BREAK / HATCH
-- ========================
mouse.Button1Down:Connect(function()
	local target = mouse.Target
	if not target then return end

	if target:GetAttribute("BreakableType") then
		if hasPaintToolEquipped() then
			return
		end
		pendingCollectPart = target
		collectEvent:FireServer(target)
	elseif target:GetAttribute("EggId") then
		openEggShopEvent:Fire(target:GetAttribute("EggId"))
	end
end)

collectEvent.OnClientEvent:Connect(showCollectFeedback)
]]></string>
          </Properties>
        </Item>
