quickStatus.TextStrokeTransparency = 0.15
quickStatus.TextStrokeColor3 = UI_DARK
quickStatus.Text = ""
quickStatus.Visible = false
quickStatus.ZIndex = 12
quickStatus.Parent = quickButtonsContainer

local function showQuickStatus(text, color)
	quickStatus.Text = text or ""
	quickStatus.TextColor3 = color or UI_WHITE
	quickStatus.Visible = quickStatus.Text ~= ""
	local token = os.clock()
	quickStatus:SetAttribute("Token", token)
	task.delay(1.7, function()
		if quickStatus:GetAttribute("Token") == token then
			quickStatus.Visible = false
		end
	end)
end

local function makeQuickTravelButton(label, color, destinationType)
	local btn = Instance.new("TextButton")
	btn.Name = "Travel" .. label
	btn.LayoutOrder = destinationType == "egg" and 1
		or destinationType == "sell" and 2
		or destinationType == "shop" and 3
		or destinationType == "upgrade" and 4
		or destinationType == "world" and 5
		or 10
	btn.Size = UDim2.new(0, 84, 0, 42)
	btn.BackgroundColor3 = color
	btn.BorderSizePixel = 0
	btn.AutoButtonColor = false
	btn.Text = ""
	btn.ZIndex = 12
	btn.Parent = quickTravel

	local corner = Instance.new("UICorner")
	corner.CornerRadius = UDim.new(0, 14)
	corner.Parent = btn

	local stroke = Instance.new("UIStroke")
	stroke.Color = UI_DARK
	stroke.Thickness = 4
	stroke.Parent = btn

	local text = Instance.new("TextLabel")
	text.Size = UDim2.new(1, -10, 1, 0)
	text.Position = UDim2.new(0, 5, 0, 0)
	text.BackgroundTransparency = 1
	text.Font = Enum.Font.GothamBold
	text.TextSize = #label > 5 and 11 or 13
	text.TextColor3 = UI_WHITE
	text.TextStrokeTransparency = 0.35
	text.TextStrokeColor3 = UI_DARK
	text.Text = label
	text.TextXAlignment = Enum.TextXAlignment.Center
	text.ZIndex = 13
	text.Active = false
	text.Parent = btn

	btn.MouseButton1Down:Connect(function()
		TweenService:Create(btn, TweenInfo.new(0.07), {
			Size = UDim2.new(0, 78, 0, 38),
		}):Play()
	end)

	btn.MouseButton1Up:Connect(function()
		TweenService:Create(btn, TweenInfo.new(0.16, Enum.EasingStyle.Back), {
			Size = UDim2.new(0, 84, 0, 42),
		}):Play()
		if destinationType == "world" then
			showQuickStatus("", UI_CYAN)
			UIManager.toggle("World")
		else
			showQuickStatus("Traveling...", UI_CYAN)
			travelEvent:FireServer(destinationType)
		end
	end)

	return btn
end

makeQuickTravelButton("SELL", Color3.fromRGB(94, 228, 151), "sell")
makeQuickTravelButton("EGG", Color3.fromRGB(255, 196, 116), "egg")
makeQuickTravelButton("SHOP", Color3.fromRGB(255, 224, 104), "shop")
makeQuickTravelButton("UPGRADE", Color3.fromRGB(192, 154, 255), "upgrade")
makeQuickTravelButton("WORLD", Color3.fromRGB(145, 209, 255), "world")

local function refreshTutorialHudVisibility()
	quickTravel.Visible = not tutorialActive.Value
	quickStatus.Visible = quickStatus.Visible and not tutorialActive.Value
end
tutorialActive:GetPropertyChangedSignal("Value"):Connect(refreshTutorialHudVisibility)
refreshTutorialHudVisibility()

travelEvent.OnClientEvent:Connect(function(success, _, message)
	showQuickStatus(message or (success and "Traveling" or "Can't travel"), success and UI_CYAN or UI_PINK)
end)

