      <Item class="Script" referent="59">
        <Properties>
          <string name="Name">EarlySupporterHandler</string>
          <token name="RunContext">0</token>
          <string name="Source"><![CDATA[-- Marks players who own the Support Dev gamepass so chat can show an Early Supporter tag.
local MarketplaceService = game:GetService("MarketplaceService")
local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")

local RobuxShopConfig = require(ReplicatedStorage:WaitForChild("RobuxShopConfig"))
local AdminConfig = require(ReplicatedStorage:WaitForChild("AdminConfig"))

local SUPPORT_PASS_ID
for _, pass in ipairs(RobuxShopConfig.Gamepasses or {}) do
	if pass.id == "SupportDev" or pass.earlySupporterTag then
		SUPPORT_PASS_ID = pass.gamepassId
		break
	end
end

local function setSupporter(player, owns)
	player:SetAttribute("EarlySupporter", owns == true)
end

local function refreshSupporter(player)
	if AdminConfig.isEarlyTesterName(player.Name) then
		setSupporter(player, true)
		return
	end

	if not SUPPORT_PASS_ID or SUPPORT_PASS_ID <= 0 then
		setSupporter(player, false)
		return
	end

	local ok, owns = pcall(function()
		return MarketplaceService:UserOwnsGamePassAsync(player.UserId, SUPPORT_PASS_ID)
	end)
	setSupporter(player, ok and owns == true)
end

Players.PlayerAdded:Connect(function(player)
	setSupporter(player, false)
	task.defer(function()
		refreshSupporter(player)
	end)
end)

MarketplaceService.PromptGamePassPurchaseFinished:Connect(function(player, gamepassId, wasPurchased)
	if gamepassId == SUPPORT_PASS_ID and wasPurchased then
		setSupporter(player, true)
	end
end)
]]></string>
        </Properties>
      </Item>
      <Item class="Script" referent="60">
        <Properties>
          <string name="Name">EmergencyWorldBootstrap</string>
          <token name="RunContext">0</token>
          <string name="Source"><![CDATA[-- Non-destructive runtime map safety net.
-- If the saved Studio place is missing world floors/spawns/stations, this creates
-- a playable set of world parts. It never deletes or renames existing objects.
local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local ServerScriptService = game:GetService("ServerScriptService")

local ColorData = require(ReplicatedStorage:WaitForChild("ColorData"))
local PetData = require(ReplicatedStorage:WaitForChild("PetData"))

local MAP_NAME = "ColorSimulatorMap"
local ROOT_NAME = "RuntimeEmergencyWorld"
local WORLD_SPACING = 390
local ZONE_SIZE = Vector3.new(320, 1, 320)

local function getMap()
	local map = workspace:FindFirstChild(MAP_NAME)
	if not map then
		map = Instance.new("Folder")
		map.Name = MAP_NAME
		map:SetAttribute("RuntimeGenerated", true)
		map.Parent = workspace
	end
	return map
end

local function getRoot()
	local map = getMap()
	local root = map:FindFirstChild(ROOT_NAME)
	if not root then
		root = Instance.new("Folder")
		root.Name = ROOT_NAME
		root:SetAttribute("RuntimeGenerated", true)
		root.Parent = map
	end
	return root
end

local function getOrCreateFolder(parent, name)
	local folder = parent:FindFirstChild(name)
	if not folder then
		folder = Instance.new("Folder")
		folder.Name = name
		folder:SetAttribute("RuntimeGenerated", true)
		folder.Parent = parent
	end
	return folder
end

local function getStringAttribute(instance, ...)
	for _, name in ipairs({ ... }) do
		local value = instance:GetAttribute(name)
		if typeof(value) == "string" and value ~= "" then
			return value
		end
	end
	return nil
end

local function partColor(part)
	return getStringAttribute(part, "ColorType", "AreaColor", "SellColor", "AreaSpawnColor", "TeleportColor")
end

local function findPart(colorType, predicate)
	for _, obj in ipairs(workspace:GetDescendants()) do
		if obj:IsA("BasePart") and predicate(obj) and partColor(obj) == colorType then
			return obj
		end
	end
	return nil
end

local function findColorZone(colorType)
	return findPart(colorType, function(part)
		return part:GetAttribute("ColorZone") == true
	end)
end

local function findSpawn(colorType)
	return findPart(colorType, function(part)
		return part:GetAttribute("AreaSpawn") == true or part:GetAttribute("WorldSpawn") == true
	end)
end

local function findEgg(colorType)
	return findPart(colorType, function(part)
		return part:GetAttribute("EggId") ~= nil
	end)
end

local function findSell(colorType)
	return findPart(colorType, function(part)
		return part:GetAttribute("SellZone") == true or part:GetAttribute("SellLocation") == true
	end)
end

local function findShop(colorType)
	return findPart(colorType, function(part)
		return part:GetAttribute("BrushShop") == true
	end)
end

local function findUpgrade(colorType)
	return findPart(colorType, function(part)
		return part:GetAttribute("UpgradeStation") == true
	end)
end

local function makePart(parent, name, size, cframe, color, material, canCollide)
	local part = parent:FindFirstChild(name)
	if not part then
		part = Instance.new("Part")
		part.Name = name
		part.Parent = parent
	end
	part.Size = size
	part.CFrame = cframe
	part.Color = color
	part.Material = material or Enum.Material.SmoothPlastic
	part.Anchored = true
	part.CanCollide = canCollide ~= false
	part.CanTouch = false
	part.TopSurface = Enum.SurfaceType.Smooth
	part.BottomSurface = Enum.SurfaceType.Smooth
	part:SetAttribute("RuntimeGenerated", true)
	return part
end

local function addPrompt(parent, name, objectText, actionText, attributeName)
	local prompt = parent:FindFirstChild(name)
	if not prompt then
		prompt = Instance.new("ProximityPrompt")
		prompt.Name = name
		prompt.Parent = parent
	end
	prompt.ObjectText = objectText
	prompt.ActionText = actionText or "Open"
	prompt.HoldDuration = 0
	prompt.MaxActivationDistance = 16
	prompt.RequiresLineOfSight = false
	if attributeName then
		prompt:SetAttribute(attributeName, true)
	end
	return prompt
end

local function getEggIdForColor(colorType)
	for eggId, egg in pairs(PetData.Eggs or {}) do
		if egg.areaColor == colorType then
			return eggId, egg
		end
	end
	return nil, nil
end

local function worldCenter(index)
	return Vector3.new((index - 1) * WORLD_SPACING, 0, 0)
end

local function ensureWorld(world, index)
	local colorType = world.primaryColor
	local colorInfo = ColorData.Colors[colorType]
	local accent = colorInfo and colorInfo.color or Color3.fromRGB(118, 238, 244)
	local root = getRoot()
	local zones = getOrCreateFolder(root, "Zones")
	local spawns = getOrCreateFolder(root, "Spawns")
	local eggs = getOrCreateFolder(root, "Eggs")
	local sells = getOrCreateFolder(root, "SellStations")
	local shops = getOrCreateFolder(root, "BrushShops")
	local upgrades = getOrCreateFolder(root, "UpgradeStations")
	local gates = getOrCreateFolder(root, "Gates")
	local center = worldCenter(index)
	local created = false

	local zone = findColorZone(colorType)
	if not zone then
		zone = makePart(
			zones,
			colorType .. "EmergencyZone",
			ZONE_SIZE,
			CFrame.new(center),
			accent:Lerp(Color3.fromRGB(255, 255, 255), 0.2),
			Enum.Material.SmoothPlastic,
			true
		)
		zone:SetAttribute("ColorZone", true)
		zone:SetAttribute("ColorType", colorType)
		zone:SetAttribute("RewardMultiplier", world.rewardMultiplier or 1)
		zone:SetAttribute("BlobCount", world.blobCount or 80)
		created = true
	end
	zone.CanCollide = true

	local spawn = findSpawn(colorType)
	if not spawn then
		spawn = makePart(
			spawns,
			colorType .. "EmergencySpawn",
			Vector3.new(28, 1, 28),
			CFrame.new(center + Vector3.new(-92, 1.1, -92)),
			accent:Lerp(Color3.fromRGB(255, 255, 255), 0.45),
			Enum.Material.SmoothPlastic,
			true
		)
		spawn:SetAttribute("AreaSpawn", true)
		spawn:SetAttribute("WorldSpawn", true)
		spawn:SetAttribute("AreaSpawnColor", colorType)
		spawn:SetAttribute("SpawnColor", colorType)
		spawn:SetAttribute("TeleportColor", colorType)
		spawn:SetAttribute("ColorType", colorType)
		created = true
	end
	spawn.CanCollide = true

	local eggId, eggData = getEggIdForColor(colorType)
	if eggId and not findEgg(colorType) then
		local egg = makePart(
			eggs,
			colorType .. "EmergencyEgg",
			Vector3.new(12, 15, 12),
			CFrame.new(center + Vector3.new(76, 8, 88)),
			eggData and eggData.color or accent,
			Enum.Material.SmoothPlastic,
			true
		)
		egg.Shape = Enum.PartType.Ball
		egg:SetAttribute("EggId", eggId)
		egg:SetAttribute("ColorType", colorType)
		egg:SetAttribute("AreaColor", colorType)
		addPrompt(egg, "EggShopPrompt", "Egg", "Open", "EggShopPrompt")
		makePart(
			eggs,
			colorType .. "EmergencyEggPedestal",
			Vector3.new(30, 2, 30),
			CFrame.new(center + Vector3.new(76, 1.2, 88)),
			Color3.fromRGB(35, 38, 45),
			Enum.Material.SmoothPlastic,
			true
		)
		created = true
	end

	if not findSell(colorType) then
		local sell = makePart(
			sells,
			"World" .. tostring(index) .. "_Sell",
			Vector3.new(42, 1.2, 30),
			CFrame.new(center + Vector3.new(-74, 1.05, 82)),
			accent:Lerp(Color3.fromRGB(98, 255, 190), 0.55),
			Enum.Material.Neon,
			false
		)
		sell.CanTouch = true
		sell:SetAttribute("SellZone", true)
		sell:SetAttribute("SellLocation", true)
		sell:SetAttribute("ColorType", colorType)
		sell:SetAttribute("AreaColor", colorType)
		sell:SetAttribute("SellColor", colorType)
		addPrompt(sell, "SellPrompt", "Sell Station", "Sell Color", nil)
		created = true
	end

	if not findShop(colorType) then
		local shop = makePart(
			shops,
			colorType .. "EmergencyBrushShop",
			Vector3.new(34, 1.4, 24),
			CFrame.new(center + Vector3.new(80, 1.05, -58)),
			accent:Lerp(Color3.fromRGB(255, 235, 105), 0.35),
			Enum.Material.Neon,
			false
		)
		shop:SetAttribute("BrushShop", true)
		shop:SetAttribute("ColorType", colorType)
		shop:SetAttribute("AreaColor", colorType)
		addPrompt(shop, "BrushShopPrompt", "Brush Shop", "Open", "BrushShopPrompt")
		created = true
	end

	if not findUpgrade(colorType) then
		local upgrade = makePart(
			upgrades,
			colorType .. "EmergencyUpgradeStation",
			Vector3.new(34, 1.4, 24),
			CFrame.new(center + Vector3.new(80, 1.05, -14)),
			accent:Lerp(Color3.fromRGB(192, 154, 255), 0.45),
			Enum.Material.SmoothPlastic,
			false
		)
		upgrade:SetAttribute("UpgradeStation", true)
		upgrade:SetAttribute("ColorType", colorType)
		upgrade:SetAttribute("AreaColor", colorType)
		addPrompt(upgrade, "UpgradeStationPrompt", "Upgrade Station", "Open", "UpgradeStationPrompt")
		created = true
	end

	local nextWorld = ColorData.Worlds[index + 1]
	if nextWorld then
		local gateName = colorType .. "To" .. nextWorld.primaryColor .. "EmergencyGate"
		local gate = gates:FindFirstChild(gateName)
		if not gate then
			gate = makePart(
				gates,
				gateName,
				Vector3.new(24, 28, 4),
				CFrame.new(center + Vector3.new(150, 14, 0)),
				accent:Lerp(Color3.fromRGB(35, 38, 45), 0.35),
				Enum.Material.SmoothPlastic,
				true
			)
			gate:SetAttribute("AreaGate", true)
			gate:SetAttribute("GateColor", nextWorld.primaryColor)
			gate:SetAttribute("UnlockColor", nextWorld.primaryColor)
			gate:SetAttribute("ColorType", nextWorld.primaryColor)
			addPrompt(gate, "GatePrompt", nextWorld.name, "Unlock " .. nextWorld.name, "AreaGatePrompt")
		end
	end

	return zone, spawn, created
end

local function ensureEmergencyWorlds()
	local redZone
	local redSpawn
	local createdAny = false
	for index, world in ipairs(ColorData.Worlds or {}) do
		local zone, spawn, created = ensureWorld(world, index)
		if world.primaryColor == "Red" then
			redZone = zone
			redSpawn = spawn
		end
		createdAny = createdAny or created
	end

	if createdAny then
		warn("EmergencyWorldBootstrap: restored missing runtime world floors/spawns/stations.")
	end
	return redZone, redSpawn
end

local function restoreCharacter(player)
	local _, spawn = ensureEmergencyWorlds()
	local character = player.Character
	local root = character and character:FindFirstChild("HumanoidRootPart")
	local humanoid = character and character:FindFirstChildOfClass("Humanoid")
	if root then
		root.Anchored = false
		root.AssemblyLinearVelocity = Vector3.zero
		root.AssemblyAngularVelocity = Vector3.zero
		if spawn and (root.Position.Y < -10 or root.Position.Y > 600) then
			root.CFrame = spawn.CFrame + Vector3.new(0, 5, 0)
		end
	end
	if humanoid then
		humanoid.PlatformStand = false
		humanoid.Sit = false
		humanoid.AutoRotate = true
		if humanoid.WalkSpeed <= 0 then
			humanoid.WalkSpeed = 44
		end
	end
end

ensureEmergencyWorlds()
task.delay(1, ensureEmergencyWorlds)
task.delay(3, function()
	ensureEmergencyWorlds()
	local populateRequest = ServerScriptService:FindFirstChild("RequestPopulateColorZone")
	if populateRequest and populateRequest:IsA("BindableEvent") then
		populateRequest:Fire("Red")
	end
end)

Players.PlayerAdded:Connect(function(player)
	player.CharacterAdded:Connect(function()
		task.wait(0.75)
		restoreCharacter(player)
		task.wait(2.5)
		restoreCharacter(player)
	end)
end)

for _, player in ipairs(Players:GetPlayers()) do
	if player.Character then
		task.defer(restoreCharacter, player)
	end
end
]]></string>
        </Properties>
      </Item>
      <Item class="Script" referent="61">
        <Properties>
          <string name="Name">EnsureSellPlace</string>
          <token name="RunContext">0</token>
          <string name="Source"><![CDATA[-- Ensures the starter sell pad exists so HUD quick travel and touch selling have a target.
local workspace = game:GetService("Workspace")
local ReplicatedStorage = game:GetService("ReplicatedStorage")

local ColorData = require(ReplicatedStorage:WaitForChild("ColorData"))

local MAP_NAME = "ColorSimulatorMap"

local SELL_COLOR = Color3.fromRGB(98, 255, 190)
local DARK = Color3.fromRGB(35, 38, 45)

local function findPart(root, predicate)
	for _, obj in ipairs(root:GetDescendants()) do
		if obj:IsA("BasePart") and predicate(obj) then
			return obj
		end
	end
	return nil
end

local function getOrCreateMap()
	local map = workspace:FindFirstChild(MAP_NAME)
	if not map then
		map = Instance.new("Folder")
		map.Name = MAP_NAME
		map.Parent = workspace
	end
	return map
end

local function findZoneForColor(map, colorType)
	return findPart(map, function(part)
		return part:GetAttribute("ColorZone") and part:GetAttribute("ColorType") == colorType
	end)
end

local function findRedCenter(map)
	local zone = findPart(map, function(part)
		return part:GetAttribute("ColorZone") and part:GetAttribute("ColorType") == "Red"
	end)

	if zone then
		return zone.Position
	end

	local redZone = map:FindFirstChild("RedZone")
	if redZone then
		local floor = findPart(redZone, function(part)
			return part.Name == "RedZoneFloor" or part:GetAttribute("ZoneId") == "RedZone"
		end)
		if floor then
			return floor.Position
		end
	end

	return Vector3.new(0, 0, 0)
end

local function getSellColor(part)
	return part:GetAttribute("ColorType")
		or part:GetAttribute("AreaColor")
		or part:GetAttribute("SellColor")
end

local function isSellPart(part)
	return part:GetAttribute("SellZone")
		or part:GetAttribute("SellLocation")
		or part.Name == "SellZone"
		or part.Name == "Sell"
		or part.Name == "SellPart"
		or part.Name == "SellArea"
		or part.Name == "SellPad"
		or part.Name == "RedZoneSellStation"
		or string.match(part.Name, "^World%d+_Sell$")
		or string.match(part.Name, "SellStation$")
end

local function findExistingSell(map, colorType)
	return findPart(map, function(part)
		if not isSellPart(part) then
			return false
		end

		local sellColor = getSellColor(part)
		if sellColor then
			return sellColor == colorType
		end

		return colorType == "Red"
	end)
end

local function ensureLabel(sell)
	local label = sell:FindFirstChild("SellColorLabel") or sell:FindFirstChild("SellZoneLabel")
	if not label then
		label = Instance.new("BillboardGui")
		label.Name = "SellColorLabel"
		label.AlwaysOnTop = true
		label.LightInfluence = 0
		label.MaxDistance = 120
		label.Size = UDim2.new(0, 220, 0, 70)
		label.StudsOffset = Vector3.new(0, 6.4, 0)
		label.Parent = sell
	end

	local title = label:FindFirstChild("Title")
	if not title then
		title = Instance.new("TextLabel")
		title.Name = "Title"
		title.BackgroundTransparency = 1
		title.Size = UDim2.new(1, 0, 1, 0)
		title.Font = Enum.Font.LuckiestGuy
		title.TextSize = 28
		title.TextColor3 = Color3.new(1, 1, 1)
		title.TextStrokeTransparency = 0
		title.TextStrokeColor3 = DARK
		title.Parent = label
	end
	title.Text = "SELL COLOR"
end

local function getSellCFrameForZone(zone, colorType)
	if zone then
		local offset = Vector3.new(
			-math.max(34, zone.Size.X * 0.22),
			zone.Size.Y * 0.5 + 0.8,
			math.max(32, zone.Size.Z * 0.24)
		)
		return zone.CFrame * CFrame.new(offset)
	end

	local center = colorType == "Red" and Vector3.new(0, 0, 0) or nil
	return center and CFrame.new(center + Vector3.new(-67, 1.3, 32)) or nil
end

local function getSellFolder(map)
	local folder = map:FindFirstChild("SellStations") or map:FindFirstChild("FunctionalParts")
	if not folder then
		folder = Instance.new("Folder")
		folder.Name = "SellStations"
		folder.Parent = map
	end
	return folder
end

local function ensureWorldSellPlace(map, world, index)
	local colorType = world.primaryColor
	local sell = findExistingSell(map, colorType)

	if not sell then
		local zone = findZoneForColor(map, colorType)
		if not zone and colorType ~= "Red" then
			return nil
		end

		local cframe = getSellCFrameForZone(zone, colorType)
		if not cframe then
			return nil
		end

		local folder = getSellFolder(map)
		sell = Instance.new("Part")
		sell.Name = "World" .. tostring(index) .. "_Sell"
		sell.Size = Vector3.new(42, 1.2, 30)
		sell.CFrame = cframe
		sell.Color = SELL_COLOR
		sell.Material = Enum.Material.Neon
		sell.Transparency = 0.08
		sell.Parent = folder
	end

	sell.Anchored = true
	sell.CanCollide = false
	sell.CanTouch = true
	sell:SetAttribute("SellZone", true)
	sell:SetAttribute("SellLocation", true)
	sell:SetAttribute("ColorType", colorType)
	sell:SetAttribute("AreaColor", colorType)
	sell:SetAttribute("SellColor", colorType)
	ensureLabel(sell)
	return sell
end

local function ensureSellPlace()
	local map = getOrCreateMap()
	local ensured = 0
	local firstSell = nil

	for index, world in ipairs(ColorData.Worlds or {}) do
		local sell = ensureWorldSellPlace(map, world, index)
		if sell then
			ensured += 1
			firstSell = firstSell or sell
		end
	end

	if not firstSell then
		local center = findRedCenter(map)
		local folder = getSellFolder(map)
		local sell = Instance.new("Part")
		sell.Name = "World1_Sell"
		sell.Size = Vector3.new(42, 1.2, 30)
		sell.CFrame = CFrame.new(center + Vector3.new(-67, 1.3, 32))
		sell.Color = SELL_COLOR
		sell.Material = Enum.Material.Neon
		sell.Transparency = 0.08
		sell.Parent = folder
		firstSell = ensureWorldSellPlace(map, ColorData.Worlds[1] or { primaryColor = "Red" }, 1)
		ensured = firstSell and 1 or ensured
	end

	print("EnsureSellPlace: " .. tostring(ensured) .. " world sell places ready.")
	return firstSell
end

task.defer(ensureSellPlace)
task.delay(3, ensureSellPlace)
]]></string>
        </Properties>
      </Item>
      <Item class="ModuleScript" referent="62">
        <Properties>
          <string name="Name">GamepassBenefits</string>
          <string name="Source"><![CDATA[local MarketplaceService = game:GetService("MarketplaceService")
local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local RunService = game:GetService("RunService")

local RobuxShopConfig = require(ReplicatedStorage:WaitForChild("RobuxShopConfig"))

local GamepassBenefits = {}
local ownershipCache = {}

local function getCache(player)
	ownershipCache[player] = ownershipCache[player] or {}
	return ownershipCache[player]
end

local function hasRealId(pass)
	return pass and tonumber(pass.gamepassId) and tonumber(pass.gamepassId) > 0
end

function GamepassBenefits.owns(player, passId)
	if not player then
		return false
	end

	local pass = RobuxShopConfig.getGamepass(passId)
	if not hasRealId(pass) then
		return player:GetAttribute("Pass_" .. tostring(passId)) == true
	end

	local cache = getCache(player)
	if cache[passId] ~= nil then
		return cache[passId]
	end

	local ok, owns = pcall(function()
		return MarketplaceService:UserOwnsGamePassAsync(player.UserId, pass.gamepassId)
	end)

	cache[passId] = ok and owns == true
	player:SetAttribute("Pass_" .. passId, cache[passId])
	return cache[passId]
end

function GamepassBenefits.invalidate(player, passId)
	if not player then
		return
	end
	local cache = getCache(player)
	cache[passId] = nil
end

function GamepassBenefits.refreshPlayer(player)
	if not player then
		return
	end

	for _, pass in ipairs(RobuxShopConfig.Gamepasses or {}) do
		local owns = GamepassBenefits.owns(player, pass.id)
		player:SetAttribute("Pass_" .. pass.id, owns)
	end
	player:SetAttribute("IsVIP", GamepassBenefits.owns(player, "VIP"))
	if GamepassBenefits.owns(player, "SupportDev") then
		player:SetAttribute("EarlySupporter", true)
	end
end

function GamepassBenefits.getCoinMultiplier(player)
	local multiplier = 1
	if GamepassBenefits.owns(player, "DoubleCoins") then
		multiplier *= 2
	end
	return multiplier
end

function GamepassBenefits.getLuckMultiplier(player)
	local multiplier = 1
	if GamepassBenefits.owns(player, "LuckyHatch") then
		multiplier *= 1.35
	end
	if GamepassBenefits.owns(player, "VIP") then
		multiplier *= 1.1
	end
	return multiplier
end

function GamepassBenefits.getExtraEquippedColorSlots(player)
	local extra = 0
	if GamepassBenefits.owns(player, "Plus3Colors") then
		extra += 3
	end
	if GamepassBenefits.owns(player, "VIP") then
		extra += 1
	end
	return extra
end

function GamepassBenefits.hasAutoSell(player)
	return GamepassBenefits.owns(player, "AutoSell")
end

Players.PlayerAdded:Connect(function(player)
	for _, pass in ipairs(RobuxShopConfig.Gamepasses or {}) do
		player:SetAttribute("Pass_" .. pass.id, false)
	end
	player:SetAttribute("IsVIP", false)
	player:SetAttribute("EarlySupporter", false)
	task.defer(function()
		GamepassBenefits.refreshPlayer(player)
	end)
end)

Players.PlayerRemoving:Connect(function(player)
	ownershipCache[player] = nil
end)

MarketplaceService.PromptGamePassPurchaseFinished:Connect(function(player, gamepassId, wasPurchased)
	if not wasPurchased then
		return
	end

	local pass = RobuxShopConfig.getGamepassByRobloxId(gamepassId)
	if not pass then
		return
	end

	local cache = getCache(player)
	cache[pass.id] = true
	player:SetAttribute("Pass_" .. pass.id, true)
	if pass.id == "VIP" then
		player:SetAttribute("IsVIP", true)
	end
	if pass.id == "SupportDev" or pass.earlySupporterTag == true then
		player:SetAttribute("EarlySupporter", true)
	end

	print("GamepassBenefits: " .. player.Name .. " unlocked " .. pass.id)
end)

if RunService:IsStudio() then
	ReplicatedStorage:SetAttribute("GamepassBenefitsReady", true)
end

return GamepassBenefits
]]></string>
        </Properties>
      </Item>
      <Item class="Script" referent="63">
        <Properties>
          <string name="Name">ItemsHandler</string>
          <token name="RunContext">0</token>
          <string name="Source"><![CDATA[-- Script in ServerScriptService named "ItemsHandler"
local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local ItemsData = require(ReplicatedStorage:WaitForChild("ItemsData"))

local Events    = ReplicatedStorage:WaitForChild("Events")
local useEvent  = Events:WaitForChild("UseItem")

-- Track active boosts per player
-- { [player] = { [boostType] = expiresAt } }
local activeBoosts = {}

-- Track inventory per player
-- { [player] = { [itemId] = quantity } }
local playerInventory = {}

-- Cooldowns to prevent spam
local cooldowns = {}
local COOLDOWN  = 0.5

local MATERIAL_ITEMS = {}
local START_CLEARED_CATEGORIES = {
	Items = true,
	Boosts = true,
	Materials = true,
}

for itemId, item in pairs(ItemsData.Items) do
	if item.category == "Materials" then
		MATERIAL_ITEMS[itemId] = true
	end
end

local function getInventory(player)
	if not playerInventory[player] then
		playerInventory[player] = {}
	end
	return playerInventory[player]
end

local function getBoosts(player)
	if not activeBoosts[player] then
		activeBoosts[player] = {}
	end
	return activeBoosts[player]
end

-- ========================
--   GIVE ITEM TO PLAYER
--   Called by other scripts (e.g. dev products, rewards)
-- ========================
local function giveItem(player, itemId, quantity)
	if MATERIAL_ITEMS[itemId] then
		print("ItemsHandler: material item grant ignored for now -> " .. tostring(itemId))
		return
	end

	quantity = quantity or 1
	local inv = getInventory(player)
	inv[itemId] = (inv[itemId] or 0) + quantity

	-- Notify client
	useEvent:FireClient(player, "update", itemId, inv[itemId])
	print(player.Name .. " received " .. quantity .. "x " .. itemId)
end

local function clearMaterials(inv)
	for itemId in pairs(MATERIAL_ITEMS) do
		inv[itemId] = nil
	end
end

local function clearStartClearedItems(inv)
	for itemId, item in pairs(ItemsData.Items) do
		if START_CLEARED_CATEGORIES[item.category] then
			inv[itemId] = nil
		end
	end
end

local function clearFolderChildren(folder)
	if not folder then
		return
	end

	for _, child in ipairs(folder:GetChildren()) do
		child:Destroy()
	end
end

local function clearActiveBoostInstances(player)
	clearFolderChildren(player:FindFirstChild("Boosts"))
	clearFolderChildren(player:FindFirstChild("ItemFlags"))
end

-- ========================
--   APPLY BOOST EFFECT
-- ========================
local function applyBoost(player, boostType, duration)
	local boosts = getBoosts(player)
	local now    = os.time()

	-- Stack with existing boost time
	local current = boosts[boostType] or now
	boosts[boostType] = math.max(current, now) + duration

	-- Store in player folder so other scripts can read it
	local boostFolder = player:FindFirstChild("Boosts")
	if not boostFolder then
		boostFolder = Instance.new("Folder")
		boostFolder.Name   = "Boosts"
		boostFolder.Parent = player
	end

	local val = boostFolder:FindFirstChild(boostType)
	if not val then
		val = Instance.new("NumberValue")
		val.Name   = boostType
		val.Parent = boostFolder
	end
	val.Value = boosts[boostType]

	print(player.Name .. " boost applied: " .. boostType .. " until " .. boosts[boostType])
end

-- ========================
--   USE ITEM LOGIC
-- ========================
local function useItem(player, itemId, requestedAmount)
	local item = ItemsData.Items[itemId]
	if not item then
		useEvent:FireClient(player, "error", itemId, "Unknown item!")
		return
	end

	if not item.usable then
		useEvent:FireClient(player, "error", itemId, "This item can't be used!")
		return
	end

	local inv = getInventory(player)
	if not inv[itemId] or inv[itemId] <= 0 then
		useEvent:FireClient(player, "error", itemId, "You don't have any " .. item.displayName .. "!")
		return
	end

	-- Deduct one
	local amount = 1
	if item.boostType and item.boostDuration then
		amount = math.clamp(math.floor(tonumber(requestedAmount) or 1), 1, inv[itemId])
	end

	inv[itemId] = inv[itemId] - amount
	if inv[itemId] <= 0 then inv[itemId] = nil end

	-- Apply effect
	if item.boostType and item.boostDuration then
		applyBoost(player, item.boostType, item.boostDuration * amount)

		-- Tell client: item used successfully + boost info
		useEvent:FireClient(player, "boosted", itemId, inv[itemId] or 0, {
			boostType    = item.boostType,
			boostDuration = item.boostDuration * amount,
			usedAmount = amount,
			expiresAt    = (activeBoosts[player] or {})[item.boostType],
		})

	elseif itemId == "TripleHatchTicket" then
		-- Store flag for egg shop to read
		local flagFolder = player:FindFirstChild("ItemFlags")
		if not flagFolder then
			flagFolder = Instance.new("Folder")
			flagFolder.Name   = "ItemFlags"
			flagFolder.Parent = player
		end
		local flag = flagFolder:FindFirstChild("TripleHatch")
		if not flag then
			flag = Instance.new("IntValue")
			flag.Name   = "TripleHatch"
			flag.Parent = flagFolder
		end
		flag.Value = (flag.Value or 0) + 1

		useEvent:FireClient(player, "used", itemId, inv[itemId] or 0, {
			message = "Triple Hatch activated! Next 3 hatches are free!"
		})

	elseif itemId == "RainbowKey" then
		-- Give a big coin reward as placeholder for chest
		local stats = player:FindFirstChild("leaderstats")
		if stats then
			local coins = stats:FindFirstChild("Coins")
			if coins then
				local reward = math.random(5000, 15000)
				coins.Value  = coins.Value + reward
				useEvent:FireClient(player, "used", itemId, inv[itemId] or 0, {
					message = "Rainbow Chest opened! +" .. reward .. " Coins!"
				})
			end
		end

	elseif itemId == "MysteryCrate" then
		-- Random item reward
		local possibleRewards = {
			{ itemId = "LuckPotion",  qty = 1 },
			{ itemId = "CoinPotion",  qty = 1 },
			{ itemId = "SpeedPotion", qty = 1 },
			{ itemId = "RangePotion", qty = 1 },
		}
		local reward = possibleRewards[math.random(1, #possibleRewards)]
		giveItem(player, reward.itemId, reward.qty)

		useEvent:FireClient(player, "used", itemId, inv[itemId] or 0, {
			message = "Mystery Crate opened! Got " .. reward.qty .. "x " .. (ItemsData.Items[reward.itemId] and ItemsData.Items[reward.itemId].displayName or reward.itemId) .. "!"
		})

	else
		-- Generic usable
		useEvent:FireClient(player, "used", itemId, inv[itemId] or 0, {
			message = item.displayName .. " used!"
		})
	end
end

-- ========================
--   LISTEN FOR USE REQUESTS
-- ========================
useEvent.OnServerEvent:Connect(function(player, itemId, requestedAmount)
	local now = tick()
	if cooldowns[player] and (now - cooldowns[player]) < COOLDOWN then return end
	cooldowns[player] = now

	useItem(player, itemId, requestedAmount)
end)

-- ========================
--   BOOST EXPIRY CHECKER
-- ========================
task.spawn(function()
	while true do
		task.wait(5)
		local now = os.time()
		for player, boosts in pairs(activeBoosts) do
			for boostType, expiresAt in pairs(boosts) do
				if now >= expiresAt then
					boosts[boostType] = nil

					-- Clear from player folder
					local boostFolder = player:FindFirstChild("Boosts")
					if boostFolder then
						local val = boostFolder:FindFirstChild(boostType)
						if val then val.Value = 0 end
					end

					-- Notify client boost expired
					useEvent:FireClient(player, "boostExpired", boostType)
					print(player.Name .. " boost expired: " .. boostType)
				end
			end
		end
	end
end)

local function setupPlayer(player)
	playerInventory[player] = {}
	activeBoosts[player]    = {}
	task.defer(function()
		local inv = getInventory(player)
		clearStartClearedItems(inv)
		clearMaterials(inv)
		clearActiveBoostInstances(player)
		useEvent:FireClient(player, "sync", inv)
	end)
end

-- ========================
--   PLAYER SETUP / CLEANUP
-- ========================
Players.PlayerAdded:Connect(setupPlayer)

for _, player in ipairs(Players:GetPlayers()) do
	setupPlayer(player)
end

Players.PlayerRemoving:Connect(function(player)
	playerInventory[player] = nil
	activeBoosts[player]    = nil
	cooldowns[player]       = nil
end)

-- Expose for other scripts
return {
	giveItem   = giveItem,
	applyBoost = applyBoost,
	getBoosts  = function(player) return getBoosts(player) end,
}
]]></string>
        </Properties>
      </Item>
      <Item class="Script" referent="64">
