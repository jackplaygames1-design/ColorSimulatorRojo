      <Item class="Script" referent="65">
        <Properties>
          <string name="Name">LobbyPortalHandler</string>
          <token name="RunContext">0</token>
          <string name="Source"><![CDATA[-- Server-owned lobby portal travel for baked/editable maps.
local Players = game:GetService("Players")
local Workspace = game:GetService("Workspace")

local MAP_NAME = "ColorSimulatorMap"
local COOLDOWN = 0.75
local cooldowns = {}

local function getRoot(player)
	local character = player.Character
	return character and character:FindFirstChild("HumanoidRootPart")
end

local function getPlayerFromHit(hit)
	local character = hit and hit:FindFirstAncestorOfClass("Model")
	return character and Players:GetPlayerFromCharacter(character)
end

local function isPortalPart(part)
	return part:IsA("BasePart")
		and (part:GetAttribute("LobbyRedZonePortal") == true or part.Name == "RedZonePortal")
end

local function getRedZoneDestination()
	local map = Workspace:FindFirstChild(MAP_NAME)
	if not map then
		return nil
	end

	local named = map:FindFirstChild("RedZoneArrivalSpawn", true)
	if named and named:IsA("BasePart") then
		return named
	end

	for _, obj in ipairs(map:GetDescendants()) do
		if obj:IsA("BasePart") and obj:GetAttribute("LobbyPortalArrival") == true then
			return obj
		end
	end

	for _, obj in ipairs(map:GetDescendants()) do
		if obj:IsA("BasePart") then
			local spawnColor = obj:GetAttribute("AreaSpawnColor") or obj:GetAttribute("SpawnColor") or obj:GetAttribute("TeleportColor")
			if spawnColor == "Red" then
				return obj
			end
		end
	end

	return nil
end

local function useCooldown(player)
	local now = os.clock()
	if cooldowns[player] and now - cooldowns[player] < COOLDOWN then
		return false
	end
	cooldowns[player] = now
	return true
end

local function teleportToRedZone(player)
	if not useCooldown(player) then
		return
	end

	local root = getRoot(player)
	local destination = getRedZoneDestination()
	if not root or not destination then
		warn("LobbyPortalHandler: missing character root or RedZoneArrivalSpawn.")
		return
	end

	root.CFrame = destination.CFrame + Vector3.new(0, 5, 0)
	print(player.Name .. " entered Red Zone from Lobby")
end

local function hookPrompt(prompt)
	if not prompt:IsA("ProximityPrompt") then
		return
	end

	local parent = prompt.Parent
	if not parent or not isPortalPart(parent) then
		return
	end
	if prompt:GetAttribute("LobbyPortalHooked") then
		return
	end

	prompt:SetAttribute("LobbyPortalHooked", true)
	prompt.Triggered:Connect(teleportToRedZone)
end

local function hookPortal(part)
	if not isPortalPart(part) then
		return
	end
	if part:GetAttribute("LobbyPortalTouchedHooked") then
		return
	end

	part:SetAttribute("LobbyPortalTouchedHooked", true)
	part.Touched:Connect(function(hit)
		local player = getPlayerFromHit(hit)
		if player then
			teleportToRedZone(player)
		end
	end)

	for _, child in ipairs(part:GetChildren()) do
		hookPrompt(child)
	end
end

for _, obj in ipairs(Workspace:GetDescendants()) do
	if obj:IsA("BasePart") then
		hookPortal(obj)
	elseif obj:IsA("ProximityPrompt") then
		hookPrompt(obj)
	end
end

Workspace.DescendantAdded:Connect(function(obj)
	if obj:IsA("BasePart") then
		hookPortal(obj)
	elseif obj:IsA("ProximityPrompt") then
		hookPrompt(obj)
	end
end)

Players.PlayerRemoving:Connect(function(player)
	cooldowns[player] = nil
end)
]]></string>
        </Properties>
      </Item>
      <Item class="Script" referent="66">
        <Properties>
          <string name="Name">MarketHandler</string>
          <token name="RunContext">0</token>
          <string name="Source"><![CDATA[-- Builds and manages the shared Trade Market plaza.
local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")

local Events = ReplicatedStorage:WaitForChild("Events")
local travelEvent = Events:FindFirstChild("TravelToMarket")
if not travelEvent then
	travelEvent = Instance.new("RemoteEvent")
	travelEvent.Name = "TravelToMarket"
	travelEvent.Parent = Events
end

local MARKET_NAME = "TradeMarket"
local COOLDOWN = 1
local MARKET_ENABLED = false
local cooldowns = {}
local claimedBooths = {}

local COLORS = {
	dark = Color3.fromRGB(35, 38, 45),
	cyan = Color3.fromRGB(118, 238, 244),
	pink = Color3.fromRGB(255, 130, 188),
	yellow = Color3.fromRGB(255, 235, 105),
	green = Color3.fromRGB(116, 232, 158),
	lavender = Color3.fromRGB(226, 222, 255),
	floor = Color3.fromRGB(255, 194, 225),
}

local function getRoot(player)
	local character = player.Character
	return character and character:FindFirstChild("HumanoidRootPart")
end

local function getMap()
	local map = workspace:FindFirstChild("ColorSimulatorMap")
	if not map then
		map = Instance.new("Folder")
		map.Name = "ColorSimulatorMap"
		map.Parent = workspace
	end
	return map
end

local function createPart(parent, name, size, cframe, color, material)
	local part = Instance.new("Part")
	part.Name = name
	part.Size = size
	part.CFrame = cframe
	part.Color = color
	part.Material = material or Enum.Material.SmoothPlastic
	part.Anchored = true
	part.CanCollide = true
	part.TopSurface = Enum.SurfaceType.Smooth
	part.BottomSurface = Enum.SurfaceType.Smooth
	part.Parent = parent
	return part
end

local function addBillboard(parent, title, subtitle)
	local billboard = Instance.new("BillboardGui")
	billboard.Name = "BoothLabel"
	billboard.Size = UDim2.new(0, 220, 0, 72)
	billboard.StudsOffset = Vector3.new(0, 4.2, 0)
	billboard.AlwaysOnTop = true
	billboard.MaxDistance = 90
	billboard.Parent = parent

	local titleLabel = Instance.new("TextLabel")
	titleLabel.Size = UDim2.new(1, 0, 0, 36)
	titleLabel.BackgroundTransparency = 1
	titleLabel.Font = Enum.Font.LuckiestGuy
	titleLabel.TextSize = 26
	titleLabel.TextColor3 = Color3.new(1, 1, 1)
	titleLabel.TextStrokeTransparency = 0
	titleLabel.TextStrokeColor3 = COLORS.dark
	titleLabel.Text = title
	titleLabel.Parent = billboard

	local subLabel = Instance.new("TextLabel")
	subLabel.Size = UDim2.new(1, 0, 0, 24)
	subLabel.Position = UDim2.new(0, 0, 0, 34)
	subLabel.BackgroundTransparency = 1
	subLabel.Font = Enum.Font.GothamBold
	subLabel.TextSize = 14
	subLabel.TextColor3 = COLORS.cyan
	subLabel.TextStrokeTransparency = 0.15
	subLabel.TextStrokeColor3 = COLORS.dark
	subLabel.Text = subtitle
	subLabel.Parent = billboard

	return titleLabel, subLabel
end

local function getMarketCenter()
	local map = getMap()
	local currentMarket = map:FindFirstChild(MARKET_NAME)
	local minX = math.huge
	local maxX = -math.huge
	local minZ = math.huge
	local maxZ = -math.huge
	local floorY = 0
	local found = false

	for _, obj in ipairs(map:GetDescendants()) do
		if obj:IsA("BasePart") and (not currentMarket or not obj:IsDescendantOf(currentMarket)) then
			found = true
			minX = math.min(minX, obj.Position.X - obj.Size.X * 0.5)
			maxX = math.max(maxX, obj.Position.X + obj.Size.X * 0.5)
			minZ = math.min(minZ, obj.Position.Z - obj.Size.Z * 0.5)
			maxZ = math.max(maxZ, obj.Position.Z + obj.Size.Z * 0.5)
			if obj:GetAttribute("ColorZone") then
				floorY = obj.Position.Y + obj.Size.Y * 0.5
			end
		end
	end

	if not found then
		return Vector3.new(260, 0, 0)
	end

	return Vector3.new(maxX + 130, floorY, (minZ + maxZ) * 0.5)
end

local function findMainWorldCFrame()
	local map = workspace:FindFirstChild("ColorSimulatorMap")
	if not map then
		return nil
	end

	local currentMarket = map:FindFirstChild(MARKET_NAME)
	local fallback
	for _, obj in ipairs(map:GetDescendants()) do
		if obj:IsA("BasePart") and (not currentMarket or not obj:IsDescendantOf(currentMarket)) then
			local colorType = obj:GetAttribute("ColorType") or obj:GetAttribute("TeleportColor")
			if obj:GetAttribute("AreaSpawn") or obj:GetAttribute("WorldSpawn") then
				fallback = fallback or obj
				if colorType == "Red" then
					return obj.CFrame + Vector3.new(0, 5, 0)
				end
			elseif obj:GetAttribute("ColorZone") and colorType == "Red" then
				fallback = fallback or obj
			end
		end
	end

	return fallback and (fallback.CFrame + Vector3.new(0, 5, 0)) or nil
end

local function updateBoothLabel(booth, owner)
	local sign = booth:FindFirstChild("Sign")
	if not sign then
		return
	end
	local billboard = sign:FindFirstChild("BoothLabel")
	local titleLabel = billboard and billboard:FindFirstChildOfClass("TextLabel")
	local subLabel = billboard and titleLabel and titleLabel.Parent:FindFirstChildWhichIsA("TextLabel", true)
	if owner then
		for _, label in ipairs(billboard:GetChildren()) do
			if label:IsA("TextLabel") then
				if label == titleLabel then
					label.Text = owner.DisplayName .. "'S BOOTH"
				else
					label.Text = "Open for trading"
				end
			end
		end
	else
		for _, label in ipairs(billboard:GetChildren()) do
			if label:IsA("TextLabel") then
				if label == titleLabel then
					label.Text = "OPEN BOOTH"
				else
					label.Text = "Claim to trade"
				end
			end
		end
	end
end

local function createBooth(parent, index, cframe, accentColor)
	local booth = Instance.new("Model")
	booth.Name = "TradingBooth" .. index
	booth.Parent = parent

	createPart(booth, "BoothBase", Vector3.new(18, 1.2, 12), cframe * CFrame.new(0, 0.6, 0), accentColor:Lerp(Color3.new(1, 1, 1), 0.35))
	createPart(booth, "Counter", Vector3.new(14, 3, 2.4), cframe * CFrame.new(0, 2.2, -3.8), accentColor)
	createPart(booth, "BackPanel", Vector3.new(15, 9, 1.2), cframe * CFrame.new(0, 5, 4.2), COLORS.dark)
	local sign = createPart(booth, "Sign", Vector3.new(13, 3, 0.8), cframe * CFrame.new(0, 8.1, 3.45), accentColor:Lerp(Color3.new(1, 1, 1), 0.2))
	addBillboard(sign, "OPEN BOOTH", "Claim to trade")

	local promptPart = createPart(booth, "ClaimSpot", Vector3.new(15, 4, 7), cframe * CFrame.new(0, 2.5, -1.2), Color3.new(1, 1, 1), Enum.Material.SmoothPlastic)
	promptPart.Transparency = 1
	promptPart.CanCollide = false

	local prompt = Instance.new("ProximityPrompt")
	prompt.Name = "ClaimBoothPrompt"
	prompt.ActionText = "Claim Booth"
	prompt.ObjectText = "Trade Booth"
	prompt.HoldDuration = 0.25
	prompt.MaxActivationDistance = 12
	prompt.RequiresLineOfSight = false
	prompt.Parent = promptPart

	prompt.Triggered:Connect(function(player)
		local currentOwner = booth:GetAttribute("OwnerUserId")
		if currentOwner and currentOwner ~= 0 and currentOwner ~= player.UserId then
			return
		end

		local previousBooth = claimedBooths[player]
		if previousBooth and previousBooth ~= booth and previousBooth.Parent then
			previousBooth:SetAttribute("OwnerUserId", 0)
			updateBoothLabel(previousBooth, nil)
		end

		booth:SetAttribute("OwnerUserId", player.UserId)
		claimedBooths[player] = booth
		updateBoothLabel(booth, player)
		print(player.Name .. " claimed " .. booth.Name .. " in the Trade Market")
	end)

	booth:SetAttribute("OwnerUserId", 0)
	return booth
end

local function ensureMarket()
	if not MARKET_ENABLED then
		local existingMap = workspace:FindFirstChild("ColorSimulatorMap")
		local existing = existingMap and existingMap:FindFirstChild(MARKET_NAME)
		if existing and existing:GetAttribute("RuntimeGenerated") == true then
			existing:Destroy()
		end
		return nil
	end

	local map = getMap()
	local existing = map:FindFirstChild(MARKET_NAME)
	if existing then
		return existing
	end

	local center = getMarketCenter()
	local market = Instance.new("Folder")
	market.Name = MARKET_NAME
	market:SetAttribute("RuntimeGenerated", true)
	market.Parent = map

	local base = createPart(market, "MarketFloor", Vector3.new(180, 2, 120), CFrame.new(center + Vector3.new(0, -1, 0)), COLORS.floor)
	base:SetAttribute("TradeMarket", true)

	createPart(market, "CenterCarpet", Vector3.new(88, 0.25, 34), CFrame.new(center + Vector3.new(0, 0.15, 0)), COLORS.lavender, Enum.Material.Neon)
	local spawn = createPart(market, "MarketSpawn", Vector3.new(12, 1, 12), CFrame.new(center + Vector3.new(0, 0.7, 34)), COLORS.cyan, Enum.Material.Neon)
	spawn.CanCollide = false
	spawn:SetAttribute("MarketSpawn", true)

	local portal = createPart(market, "ReturnPortal", Vector3.new(14, 1, 8), CFrame.new(center + Vector3.new(0, 0.75, 48)), COLORS.green, Enum.Material.Neon)
	portal.CanCollide = false
	local returnPrompt = Instance.new("ProximityPrompt")
	returnPrompt.ActionText = "Return"
	returnPrompt.ObjectText = "Main World"
	returnPrompt.HoldDuration = 0.15
	returnPrompt.MaxActivationDistance = 12
	returnPrompt.RequiresLineOfSight = false
	returnPrompt.Parent = portal
	returnPrompt.Triggered:Connect(function(player)
		local root = getRoot(player)
		if root then
			root.CFrame = findMainWorldCFrame() or CFrame.new(center - Vector3.new(100, -5, 0))
		end
	end)

	local banner = createPart(market, "MarketBanner", Vector3.new(58, 8, 2), CFrame.new(center + Vector3.new(0, 10, -52)), COLORS.dark)
	addBillboard(banner, "TRADE MARKET", "Claim booths and meet players")

	local accents = { COLORS.cyan, COLORS.yellow, COLORS.green, COLORS.pink, COLORS.lavender, Color3.fromRGB(155, 218, 255) }
	local positions = {
		CFrame.new(center + Vector3.new(-52, 0, -30)) * CFrame.Angles(0, math.rad(18), 0),
		CFrame.new(center + Vector3.new(0, 0, -34)),
		CFrame.new(center + Vector3.new(52, 0, -30)) * CFrame.Angles(0, math.rad(-18), 0),
		CFrame.new(center + Vector3.new(-52, 0, 16)) * CFrame.Angles(0, math.rad(162), 0),
		CFrame.new(center + Vector3.new(0, 0, 18)) * CFrame.Angles(0, math.rad(180), 0),
		CFrame.new(center + Vector3.new(52, 0, 16)) * CFrame.Angles(0, math.rad(-162), 0),
	}

	for i, boothCFrame in ipairs(positions) do
		createBooth(market, i, boothCFrame, accents[i])
	end

	print("Trade Market ready with 6 claimable booths.")
	return market
end

local function useCooldown(player)
	local now = os.clock()
	if cooldowns[player] and now - cooldowns[player] < COOLDOWN then
		return false
	end
	cooldowns[player] = now
	return true
end

travelEvent.OnServerEvent:Connect(function(player)
	if not useCooldown(player) then
		return
	end
	if not MARKET_ENABLED then
		travelEvent:FireClient(player, false, "Market is coming soon.")
		return
	end

	local market = ensureMarket()
	local spawn = market:FindFirstChild("MarketSpawn")
	local root = getRoot(player)
	if not spawn or not root then
		travelEvent:FireClient(player, false, "Market is not ready.")
		return
	end

	root.CFrame = CFrame.lookAt(spawn.Position + Vector3.new(0, 5, 0), spawn.Position + Vector3.new(0, 5, -20))
	print(player.Name .. " traveled to the Trade Market")
	travelEvent:FireClient(player, true, "Traveling to Trade Market")
end)

Players.PlayerRemoving:Connect(function(player)
	cooldowns[player] = nil
	local booth = claimedBooths[player]
	if booth and booth.Parent then
		booth:SetAttribute("OwnerUserId", 0)
		updateBoothLabel(booth, nil)
	end
	claimedBooths[player] = nil
end)

task.defer(ensureMarket)
]]></string>
        </Properties>
      </Item>
      <Item class="Script" referent="67">
        <Properties>
          <string name="Name">PaintToolShopHandler</string>
          <token name="RunContext">0</token>
          <string name="Source"><![CDATA[-- Server-owned paintbrush shop and equipment state.
local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")

local ToolData = require(ReplicatedStorage:WaitForChild("ToolData"))
local ColorData = require(ReplicatedStorage:WaitForChild("ColorData"))

local Events = ReplicatedStorage:WaitForChild("Events")
local purchaseEvent = Events:WaitForChild("PurchasePaintTool")
local equipEvent = Events:WaitForChild("EquipPaintTool")
local dirtyEvent = Events:FindFirstChild("PlayerDataDirty")

local cooldowns = {}
local COOLDOWN = 0.35

local function markDirty(player, reason)
	if dirtyEvent then
		dirtyEvent:Fire(player, reason)
	end
end

local function ensureToolsFolder(player)
	local folder = player:FindFirstChild("PaintTools")
	if not folder then
		folder = Instance.new("Folder")
		folder.Name = "PaintTools"
		folder.Parent = player
	end

	local owned = folder:FindFirstChild("Owned")
	if not owned then
		owned = Instance.new("StringValue")
		owned.Name = "Owned"
		owned.Value = "StarterBrush"
		owned.Parent = folder
	end
	if owned.Value == "" then
		owned.Value = "StarterBrush"
	end

	local equipped = folder:FindFirstChild("Equipped")
	if not equipped then
		equipped = Instance.new("StringValue")
		equipped.Name = "Equipped"
		equipped.Value = "StarterBrush"
		equipped.Parent = folder
	end
	if equipped.Value == "" or not ToolData.isValid(equipped.Value) then
		equipped.Value = "StarterBrush"
	end

	return folder, owned, equipped
end

local function csvSet(value)
	local set = {}
	for _, part in ipairs(string.split(value or "", ",")) do
		if part ~= "" then
			set[part] = true
		end
	end
	return set
end

local function setToCsv(set)
	local parts = {}
	for _, toolId in ipairs(ToolData.Order) do
		if set[toolId] then
			table.insert(parts, toolId)
		end
	end
	return table.concat(parts, ",")
end

local function ownsTool(player, toolId)
	local _, owned = ensureToolsFolder(player)
	return csvSet(owned.Value)[toolId] == true
end

local function isToolUnlocked(player, tool)
	local requiredColor = tool and tool.RequiredColor or "Red"
	if requiredColor == "Red" then
		return true
	end

	local storage = player:FindFirstChild("ColorStorage")
	local unlocked = storage and storage:FindFirstChild("UnlockedColors")
	return unlocked and ColorData.isColorUnlocked(unlocked.Value, requiredColor)
end

local function getToolWorldName(tool)
	local world = ColorData.getWorldByColor(tool and tool.RequiredColor or "Red")
	return world and world.name or "Starter Field"
end

local function useCooldown(player)
	local now = os.clock()
	if cooldowns[player] and now - cooldowns[player] < COOLDOWN then
		return false
	end
	cooldowns[player] = now
	return true
end

purchaseEvent.OnServerEvent:Connect(function(player, toolId)
	if not useCooldown(player) then
		return
	end

	local tool = ToolData.Tools[toolId or ""]
	if not tool then
		purchaseEvent:FireClient(player, false, toolId, "Unknown brush.")
		return
	end
	if not isToolUnlocked(player, tool) then
		purchaseEvent:FireClient(player, false, tool.Id, "Unlock " .. getToolWorldName(tool) .. " first.")
		return
	end

	local _, owned, equipped = ensureToolsFolder(player)
	local ownedSet = csvSet(owned.Value)
	if ownedSet[tool.Id] then
		equipped.Value = tool.Id
		markDirty(player, "paint-tool-equipped")
		purchaseEvent:FireClient(player, true, tool.Id, "Equipped " .. tool.DisplayName)
		equipEvent:FireClient(player, true, tool.Id, "Equipped " .. tool.DisplayName)
		return
	end

	local stats = player:FindFirstChild("leaderstats")
	local coins = stats and stats:FindFirstChild("Coins")
	local cost = tonumber(tool.Cost) or 0
	if not coins or coins.Value < cost then
		purchaseEvent:FireClient(player, false, tool.Id, "Need " .. tostring(cost) .. " Coins.")
		return
	end

	coins.Value -= cost
	ownedSet[tool.Id] = true
	owned.Value = setToCsv(ownedSet)
	equipped.Value = tool.Id
	markDirty(player, "paint-tool-purchased")

	print(player.Name .. " bought and equipped " .. tool.DisplayName .. " for " .. tostring(cost) .. " Coins")
	purchaseEvent:FireClient(player, true, tool.Id, "Bought " .. tool.DisplayName)
	equipEvent:FireClient(player, true, tool.Id, "Equipped " .. tool.DisplayName)
end)

equipEvent.OnServerEvent:Connect(function(player, toolId, equippedRequested)
	if not useCooldown(player) then
		return
	end

	local tool = ToolData.Tools[toolId or ""]
	if not tool then
		equipEvent:FireClient(player, false, toolId, "Unknown brush.")
		return
	end
	if not isToolUnlocked(player, tool) then
		equipEvent:FireClient(player, false, tool.Id, "Unlock " .. getToolWorldName(tool) .. " first.")
		return
	end

	local _, _, equipped = ensureToolsFolder(player)
	if not ownsTool(player, tool.Id) then
		equipEvent:FireClient(player, false, tool.Id, "You do not own this brush.")
		return
	end

	if equippedRequested == false and equipped.Value == tool.Id then
		equipped.Value = "StarterBrush"
		equipEvent:FireClient(player, true, "StarterBrush", "Equipped Starter Brush")
	else
		equipped.Value = tool.Id
		equipEvent:FireClient(player, true, tool.Id, "Equipped " .. tool.DisplayName)
	end

	markDirty(player, "paint-tool-equipped")
end)

Players.PlayerAdded:Connect(function(player)
	task.defer(function()
		ensureToolsFolder(player)
	end)
end)

Players.PlayerRemoving:Connect(function(player)
	cooldowns[player] = nil
end)
]]></string>
        </Properties>
      </Item>
      <Item class="Script" referent="68">
        <Properties>
          <string name="Name">PetHandler</string>
          <token name="RunContext">0</token>
          <string name="Source"><![CDATA[-- Script in ServerScriptService named "PetHandler"
local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local RunService = game:GetService("RunService")

local PetData   = require(ReplicatedStorage:WaitForChild("PetData"))
local ColorData = require(ReplicatedStorage:WaitForChild("ColorData"))
local ColorPersonalityData = require(ReplicatedStorage:WaitForChild("ColorPersonalityData"))
local ColorTraitData = require(ReplicatedStorage:WaitForChild("ColorTraitData"))
local ColorMutationData = require(ReplicatedStorage:WaitForChild("ColorMutationData"))
local GameBalance = require(ReplicatedStorage:WaitForChild("GameBalance"))
local GamepassBenefits = require(script.Parent:WaitForChild("GamepassBenefits"))
local ColorEffectHandler = require(script.Parent:WaitForChild("ColorEffectHandler"))

-- Load PetTraits safely
local PetTraits = nil
local Modules = ReplicatedStorage:FindFirstChild("Modules")
if Modules then
	local pt = Modules:FindFirstChild("PetTraits")
	if pt then PetTraits = require(pt) end
end
if not PetTraits then warn("PetHandler: PetTraits module not found!") end

local Events          = ReplicatedStorage:WaitForChild("Events")
local hatchEvent      = Events:WaitForChild("HatchEgg")
local equipEvent      = Events:WaitForChild("EquipPet")
local mergeEvent      = Events:WaitForChild("MergePet")
local petAtkEvent     = Events:WaitForChild("PetAttack")
local petsLoadedEvent = Events:WaitForChild("PetsLoaded")
local dataDirtyEvent = Events:FindFirstChild("PlayerDataDirty")
local grantPetFunction = ReplicatedStorage:FindFirstChild("ServerGrantPet")
if not grantPetFunction then
	grantPetFunction = Instance.new("BindableFunction")
	grantPetFunction.Name = "ServerGrantPet"
	grantPetFunction.Parent = ReplicatedStorage
end

local MAX_EQUIPPED = 3
local DEBUG_LOGS = RunService:IsStudio()

-- inventory: { [player] = { [variantKey] = { petId, stackAmount, traitId, mutationId } } }
-- equipped:  { [player] = { variantKey, ... } }
local playerInventory = {}
local playerEquipped  = {}
local lastMergeAt = {}
local hatchState = {}
local unexpectedClientWarnings = {}
local STUDIO_DEV_PET_ID = "DevRainbowPet"
local STUDIO_DEV_PET_TRAIT = "SuperLucky"
local STUDIO_DEV_PET_STACK = 1

local function warnUnexpectedClientValuesOnce(player, action)
	local key = tostring(player and player.UserId or "server") .. ":" .. tostring(action)
	if unexpectedClientWarnings[key] then
		return
	end
	unexpectedClientWarnings[key] = true
	warn(action .. " ignored unexpected client value fields. Server calculates costs and rewards.")
end

local TRAIT_RANK = {
	Common = 1,
	Uncommon = 2,
	Rare = 3,
	Epic = 4,
	Legendary = 5,
}

local function isEggUnlocked(player, egg)
	local areaColor = egg.areaColor
	if not areaColor or areaColor == "Red" then
		return true
	end

	local storage = player:FindFirstChild("ColorStorage")
	local unlockedColors = storage and storage:FindFirstChild("UnlockedColors")
	if not unlockedColors then
		return false
	end

	return ColorData.isColorUnlocked(unlockedColors.Value, areaColor)
end

local function isBetterTrait(newTrait, oldTrait)
	if not newTrait then
		return false
	end
	if not oldTrait then
		return true
	end

	local newRank = TRAIT_RANK[newTrait.rarity] or 0
	local oldRank = TRAIT_RANK[oldTrait.rarity] or 0
	if newRank ~= oldRank then
		return newRank > oldRank
	end

	return (newTrait.weight or 999) < (oldTrait.weight or 999)
end

local function getVisualColor(colorType)
	if colorType == "Rainbow" then
		return Color3.fromRGB(215, 180, 255)
	end

	local colorInfo = ColorData.Colors[colorType]
	return colorInfo and colorInfo.color or Color3.new(1, 1, 1)
end

local function getBaseBreakableReward(part, data)
	local reward = tonumber(part:GetAttribute("BaseColorReward"))
		or tonumber(data.baseReward)
		or tonumber(data.rewardMin)
		or 1
	return math.max(1, math.floor(reward))
end

local function getStoredColor(part, colorType)
	local stored = part and part:GetAttribute("SpawnColor")
	if typeof(stored) == "Color3" then
		return stored
	end
	return getVisualColor(colorType)
end

local function getMaxSlots(player)
	local pf = player:FindFirstChild("PetData")
	local baseSlots = 3
	if pf then
		local v = pf:FindFirstChild("MaxSlots")
		if v then
			baseSlots = v.Value
		end
	end
	return baseSlots + GamepassBenefits.getExtraEquippedColorSlots(player)
end

local function getDataDirtyEvent()
	if not dataDirtyEvent or not dataDirtyEvent.Parent then
		dataDirtyEvent = Events:FindFirstChild("PlayerDataDirty")
	end
	return dataDirtyEvent
end

local function markDataDirty(player, reason)
	local event = getDataDirtyEvent()
	if event and event:IsA("BindableEvent") then
		event:Fire(player, reason or "colors-changed")
	end
end

local function normalizeInventoryData(variantKey, data)
	if not data or not data.petId then
		return nil
	end

	data.personalityId = PetData.normalizePersonalityId(data.personalityId)
	data.mutationId = PetData.normalizeMutationId(data.mutationId)
	data.traitId = PetData.normalizeTraitId(data.traitId)
	data.stackAmount = math.max(1, tonumber(data.stackAmount) or 1)

	local expectedKey = PetData.makeVariantKey(data.petId, data.personalityId, data.mutationId, data.traitId)
	if not variantKey or variantKey == "" or variantKey ~= expectedKey then
		variantKey = expectedKey
	end

	return variantKey, data
end

local function buildEntry(variantKey, data)
	if not data then
		return nil
	end

	local entry = PetData.buildPetEntry(data.petId, data.stackAmount, data.isShiny, data.personalityId, data.mutationId, data.traitId)
	if entry then
		entry.variantKey = variantKey or entry.variantKey
		local trait = ColorTraitData.get(data.traitId)
		entry.trait = {
			name = trait.DisplayName,
			description = trait.Description,
			color = trait.TextColor,
			icon = trait.Icon or "",
			rarity = trait.Id == "Neutral" and "Common" or "Uncommon",
			visualEffect = "none",
		}
		entry.effectivePower = entry.finalPower
	end
	return entry
end

local function getEquippedPersonalityStats(player)
	local result = {
		colorGainMult = 1,
		sellMult = 1,
		pickupRangeMult = 1,
		walkSpeedBonus = 0,
		luckBonus = 0,
		totalPowerMult = 1,
	}
	-- Legacy personalities are no longer player-facing gameplay effects. Real effects come from
	-- ColorTraitData and ColorMutationData through ColorEffectHandler.
	return result
end

local function getPlayerLuckMultiplier(player)
	local luckMult = 1.0
	local boostFolder = player:FindFirstChild("Boosts")
	if boostFolder then
		local luckVal = boostFolder:FindFirstChild("luck")
		if luckVal and os.time() < luckVal.Value then
			luckMult = 1.5
		end
	end

	luckMult += ColorEffectHandler.GetHatchLuckBonus(player)
	luckMult *= GamepassBenefits.getLuckMultiplier(player)
	return math.clamp(luckMult, 1, 2.5)
end

local function resolveInventoryKey(inventory, key)
	if not inventory or not key then
		return nil
	end

	local normalizedKey = tostring(key)
	if inventory[normalizedKey] then
		return normalizedKey
	end
	local legacyParts = string.split(normalizedKey, "|")

	for variantKey, data in pairs(inventory) do
		if variantKey == normalizedKey or data.petId == normalizedKey then
			return variantKey
		end

		local expectedKey = PetData.makeVariantKey(data.petId, data.personalityId, data.mutationId, data.traitId)
		if expectedKey == normalizedKey then
			return variantKey
		end

		if #legacyParts >= 3 and legacyParts[1] == data.petId then
			local legacyTraitId = PetData.normalizeTraitId(legacyParts[2])
			local legacyMutationId = PetData.normalizeMutationId(legacyParts[3])
			local mutationMatches = legacyMutationId == PetData.normalizeMutationId(data.mutationId)
			local traitMatches = legacyTraitId == PetData.normalizeTraitId(data.traitId)
				or (legacyTraitId == "Neutral" and PetData.normalizeTraitId(data.traitId) == "Neutral")
			if mutationMatches and traitMatches then
				return variantKey
			end
		end
	end

	return nil
end

local function sanitizeEquippedList(player)
	local equipped = playerEquipped[player]
	local inventory = playerInventory[player]
	if not equipped or not inventory then
		return
	end

	local seen = {}
	local writeIndex = 1
	for _, key in ipairs(equipped) do
		local resolvedKey = resolveInventoryKey(inventory, key)
		if resolvedKey and inventory[resolvedKey] and not seen[resolvedKey] then
			equipped[writeIndex] = resolvedKey
			seen[resolvedKey] = true
			writeIndex += 1
		end
	end

	for index = #equipped, writeIndex, -1 do
		table.remove(equipped, index)
	end
end

local function applyWalkSpeedBonus(player)
	local character = player.Character
	local humanoid = character and character:FindFirstChildOfClass("Humanoid")
	if not humanoid then
		return
	end

	ColorEffectHandler.ApplyCharacterEffects(player)
end

-- ========================
--   SYNC TO PETDATA FOLDER
-- ========================
local function syncPetFolder(player, dirtyReason)
	local petFolder = player:FindFirstChild("PetData")
	if not petFolder then return end
	if not playerInventory[player] or not playerEquipped[player] then return end
	sanitizeEquippedList(player)

	local invVal      = petFolder:FindFirstChild("Inventory")
	local equippedVal = petFolder:FindFirstChild("Equipped")

	if invVal then
		local parts = {}
		for variantKey, data in pairs(playerInventory[player]) do
			-- Format: "variantKey:petId:stackAmount:traitId:shiny:personalityId:mutationId"
			local traitStr = PetData.normalizeTraitId(data.traitId)
			local shinyStr = data.isShiny and "shiny" or "normal"
			table.insert(parts, tostring(variantKey) .. ":" .. data.petId .. ":" .. data.stackAmount .. ":" .. traitStr .. ":" .. shinyStr .. ":" .. (data.personalityId or "Neutral") .. ":" .. (data.mutationId or "None"))
		end
		invVal.Value = table.concat(parts, ",")
	end

	if equippedVal then
		equippedVal.Value = table.concat(playerEquipped[player], ",")
	end

	applyWalkSpeedBonus(player)
	markDataDirty(player, dirtyReason)
end

-- ========================
--   SEND STATE TO CLIENT
-- ========================
local function sendState(player)
	if not playerInventory[player] or not playerEquipped[player] then
		return
	end

	local invList = {}
	for variantKey, data in pairs(playerInventory[player]) do
		local entry = buildEntry(variantKey, data)
		if entry then
			table.insert(invList, entry)
		end
	end
	sanitizeEquippedList(player)
	local equippedCopy = table.clone(playerEquipped[player] or {})
	petsLoadedEvent:FireClient(player, invList, equippedCopy)
end

local function grantPetToPlayer(player, petId, amount, traitId, isShiny, autoEquip, personalityId, mutationId)
	local inv = playerInventory[player]
	local equipped = playerEquipped[player]
	if not inv or not equipped or not PetData.Pets[petId] then
		return false, nil
	end

	personalityId = PetData.normalizePersonalityId(personalityId)
	mutationId = PetData.normalizeMutationId(mutationId)
	traitId = PetData.normalizeTraitId(traitId)
	local variantKey = PetData.makeVariantKey(petId, personalityId, mutationId, traitId)

	amount = math.max(1, math.floor(tonumber(amount) or 1))
	if inv[variantKey] then
		inv[variantKey].stackAmount += amount
		if isShiny then
			inv[variantKey].isShiny = true
		end
	else
		inv[variantKey] = {
			petId = petId,
			stackAmount = amount,
			traitId = traitId,
			isShiny = isShiny == true,
			personalityId = personalityId,
			mutationId = mutationId,
		}
		if autoEquip and #equipped < getMaxSlots(player) then
			table.insert(equipped, variantKey)
		end
	end

	local data = inv[variantKey]
	local entry = buildEntry(variantKey, data)

	syncPetFolder(player, "grant-color")
	sendState(player)
	return true, entry
end

local function ensureStudioDevPet(player)
	if not RunService:IsStudio() then
		return
	end

	local inv = playerInventory[player]
	local equipped = playerEquipped[player]
	if not inv or not equipped or not PetData.Pets[STUDIO_DEV_PET_ID] then
		return
	end

	local traitId = PetData.normalizeTraitId(STUDIO_DEV_PET_TRAIT)
	local mutationId = PetData.normalizeMutationId("None")
	local variantKey = PetData.makeVariantKey(STUDIO_DEV_PET_ID, "Neutral", mutationId, traitId)
	local existing = inv[variantKey]
	if existing then
		existing.stackAmount = math.max(tonumber(existing.stackAmount) or 1, STUDIO_DEV_PET_STACK)
		existing.traitId = traitId
		existing.personalityId = "Neutral"
		existing.mutationId = mutationId
		existing.isShiny = false
	else
		inv[variantKey] = {
			petId = STUDIO_DEV_PET_ID,
			stackAmount = STUDIO_DEV_PET_STACK,
			traitId = traitId,
			isShiny = false,
			personalityId = "Neutral",
			mutationId = mutationId,
		}
	end

	for index = #equipped, 1, -1 do
		local key = equipped[index]
		local data = inv[key]
		if data and data.petId == STUDIO_DEV_PET_ID and key ~= variantKey then
			table.remove(equipped, index)
		end
	end

	local alreadyEquipped = false
	for _, key in ipairs(equipped) do
		if key == variantKey then
			alreadyEquipped = true
			break
		end
	end
	if not alreadyEquipped then
		table.insert(equipped, 1, variantKey)
		local maxSlots = getMaxSlots(player)
		while #equipped > maxSlots do
			table.remove(equipped)
		end
	end

	syncPetFolder(player, "studio-dev-rainbow-pet")
	sendState(player)
	print("DevTools: equipped Studio Rainbow Pet for " .. player.Name)
end

-- ========================
--   PARSE SAVED INVENTORY
-- ========================
local function parseInventory(str)
	local inv = {}
	if not str or str == "" then return inv end
	for _, part in ipairs(string.split(str, ",")) do
		local segments = string.split(part, ":")
		local variantKey
		local petId
		local stackIndex
		if tonumber(segments[2]) then
			petId = segments[1]
			stackIndex = 2
		else
			variantKey = segments[1]
			petId = segments[2]
			stackIndex = 3
		end

		local amt      = tonumber(segments[stackIndex]) or 1
		local traitId = PetData.normalizeTraitId(segments[stackIndex + 1])
		local shinyStr = segments[stackIndex + 2] or "normal"
		local personalityId = PetData.normalizePersonalityId(segments[stackIndex + 3] or "Neutral")
		local mutationId = PetData.normalizeMutationId(segments[stackIndex + 4] or "None")
		if not petId or petId == "" then
			continue
		end
		variantKey = variantKey or PetData.makeVariantKey(petId, personalityId, mutationId, traitId)

		local normalizedKey, normalizedData = normalizeInventoryData(variantKey, {
			petId = petId,
			stackAmount = math.max(1, amt),
			traitId = traitId,
			isShiny = shinyStr == "shiny" or shinyStr == "true",
			personalityId = personalityId,
			mutationId = mutationId,
		})
		if normalizedKey and normalizedData then
			inv[normalizedKey] = normalizedData
		end
	end
	return inv
end

-- ========================
--   PLAYER SETUP
-- ========================
Players.PlayerAdded:Connect(function(player)
	playerInventory[player] = {}
	playerEquipped[player]  = {}

	local petFolder = player:WaitForChild("PetData", 10)
	if not petFolder then return end

	local invVal      = petFolder:WaitForChild("Inventory", 5)
	local equippedVal = petFolder:WaitForChild("Equipped",  5)

	if invVal and invVal.Value ~= "" then
		playerInventory[player] = parseInventory(invVal.Value)
	end

	if equippedVal and equippedVal.Value ~= "" then
		local seen = {}
		local maxSlots = getMaxSlots(player)
		for _, savedKey in ipairs(string.split(equippedVal.Value, ",")) do
			local key = resolveInventoryKey(playerInventory[player], savedKey) or savedKey
			if key ~= "" and not playerInventory[player][key] then
				local legacyParts = string.split(savedKey, "|")
				if #legacyParts >= 3 then
					key = PetData.makeVariantKey(legacyParts[1], "Neutral", legacyParts[3], "Neutral")
				else
					key = PetData.makeVariantKey(savedKey, "Neutral", "None", "Neutral")
				end
			end
			if key ~= "" and playerInventory[player][key] and not seen[key] and #playerEquipped[player] < maxSlots then
				seen[key] = true
				table.insert(playerEquipped[player], key)
			end
		end
	end

	player.CharacterAdded:Connect(function()
		task.wait(0.5)
		applyWalkSpeedBonus(player)
	end)
	if player.Character then
		applyWalkSpeedBonus(player)
	end
	local upgrades = player:FindFirstChild("Upgrades")
	local walkSpeedValue = upgrades and upgrades:FindFirstChild("WalkSpeed")
	if walkSpeedValue then
		walkSpeedValue:GetPropertyChangedSignal("Value"):Connect(function()
			applyWalkSpeedBonus(player)
		end)
	end
	ensureStudioDevPet(player)
	task.wait(1)
	ensureStudioDevPet(player)
	sendState(player)
end)

Players.PlayerRemoving:Connect(function(player)
	syncPetFolder(player, "player-removing")
	playerInventory[player] = nil
	playerEquipped[player]  = nil
	lastMergeAt[player] = nil
	hatchState[player] = nil
end)

-- ========================
--   HATCH EGG
-- ========================
local function getHatchCooldown(player)
	local cooldown = tonumber(GameBalance.HatchCooldown) or 2.5
	local upgrades = player:FindFirstChild("Upgrades")
	local hatchSpeed = upgrades and upgrades:FindFirstChild("HatchSpeed")
	if hatchSpeed and typeof(hatchSpeed.Value) == "number" then
		cooldown *= math.clamp(hatchSpeed.Value, 0.1, 1)
	end
	return math.max(tonumber(GameBalance.FastHatchCooldown) or 1.25, cooldown)
end

local function rejectHatch(player, message)
	hatchEvent:FireClient(player, false, nil, message)
end

local function getEggWorldIndex(egg)
	return ColorData.getWorldIndex(egg and egg.areaColor) or 1
end

local function getHighestUnlockedWorldIndex(player)
	local storage = player:FindFirstChild("ColorStorage")
	local unlockedValue = storage and storage:FindFirstChild("UnlockedColors")
	local unlocked = ColorData.getUnlockedColorSet(unlockedValue and unlockedValue.Value or "Red")
	local highest = 1
	for index, world in ipairs(ColorData.Worlds or {}) do
		if unlocked[world.primaryColor] then
			highest = index
		end
	end
	return highest
end

local function isFeatureUnlocked(player, featureName)
	local requiredIndex = GameBalance.getFeatureUnlockWorldIndex
		and GameBalance.getFeatureUnlockWorldIndex(featureName)
		or 1
	return getHighestUnlockedWorldIndex(player) >= requiredIndex
end

local function getFeatureLockedMessage(featureName)
	return GameBalance.getFeatureUnlockText
		and GameBalance.getFeatureUnlockText(featureName)
		or ("Unlock " .. tostring(featureName) .. " later.")
end

local function traitsUnlockedForEgg(egg)
	return getEggWorldIndex(egg) >= (tonumber(GameBalance.TraitsUnlockWorldIndex) or 2)
end

local function mutationsUnlockedForEgg(egg)
	return getEggWorldIndex(egg) >= (tonumber(GameBalance.MutationsUnlockWorldIndex) or 2)
end

hatchEvent.OnServerEvent:Connect(function(player, eggId, ...)
	if select("#", ...) > 0 then
		warnUnexpectedClientValuesOnce(player, "HatchEgg")
	end

	local egg = PetData.Eggs[eggId]
	if not egg then
		rejectHatch(player, "Unknown egg.")
		return
	end

	local now = os.clock()
	local state = hatchState[player]
	if state and (state.active or now < (state.nextAllowedAt or 0)) then
		rejectHatch(player, "Please wait until your egg finishes hatching.")
		return
	end

	if not isEggUnlocked(player, egg) then
		rejectHatch(player, "Unlock " .. tostring(egg.areaColor) .. " first!")
		return
	end

	local stats = player:FindFirstChild("leaderstats")
	if not stats then
		rejectHatch(player, "Player stats are still loading.")
		return
	end
	local coins = stats:FindFirstChild("Coins")
	if not coins or coins.Value < egg.cost then
		rejectHatch(player, "Not enough coins!")
		return
	end

	local inv = playerInventory[player]
	local equipped = playerEquipped[player]
	if not inv or not equipped then
		rejectHatch(player, "Color inventory is still loading.")
		warn("PetHandler: blocked hatch before inventory was ready for " .. player.Name)
		return
	end

	local cooldown = getHatchCooldown(player)
	hatchState[player] = {
		active = true,
		nextAllowedAt = now + cooldown,
	}

	local luckMult = getPlayerLuckMultiplier(player)
	local petId = PetData.rollEgg(eggId, luckMult)
	if not petId or not PetData.Pets[petId] then
		hatchState[player] = nil
		rejectHatch(player, "Egg roll failed. Try again.")
		warn("PetHandler: egg " .. tostring(eggId) .. " rolled missing Color " .. tostring(petId))
		return
	end

	local canRollTraits = traitsUnlockedForEgg(egg)
	local canRollMutations = mutationsUnlockedForEgg(egg)
	local trait = canRollTraits and ColorTraitData.roll() or ColorTraitData.get("Neutral")
	local forcedMutationId = RunService:IsStudio() and player:GetAttribute("ForceNextMutation") or nil
	if forcedMutationId then
		player:SetAttribute("ForceNextMutation", nil)
	end
	local mutation = canRollMutations and ColorMutationData.roll(luckMult) or ColorMutationData.get("None")
	if canRollMutations and forcedMutationId and ColorMutationData.Mutations[forcedMutationId] then
		mutation = ColorMutationData.get(forcedMutationId)
	end
	local traitId = trait and trait.Id or "Neutral"
	local personalityId = "Neutral"
	local mutationId = mutation and mutation.Id or "None"
	local variantKey = PetData.makeVariantKey(petId, personalityId, mutationId, traitId)

	-- Stack or create
	local wasDuplicate = inv[variantKey] ~= nil
	if inv[variantKey] then
		inv[variantKey].stackAmount += 1
		-- (for simplicity: keep existing trait — change if you want override logic)
	else
		inv[variantKey] = {
			petId = petId,
			stackAmount = 1,
			traitId = traitId,
			isShiny = false,
			personalityId = personalityId,
			mutationId = mutationId,
		}
		-- Auto-equip first time
		if #playerEquipped[player] < getMaxSlots(player) then
			table.insert(playerEquipped[player], variantKey)
		end
	end

	coins.Value = coins.Value - egg.cost

	local newStack = inv[variantKey].stackAmount
	local entry = buildEntry(variantKey, inv[variantKey])
	if entry then
		entry.rollIsShiny = false
		entry.wasDuplicate = wasDuplicate
		entry.duplicateCount = newStack
		entry.mergeTier = entry.currentStackTier
		entry.traitsUnlockedForEgg = canRollTraits
		entry.mutationsUnlockedForEgg = canRollMutations
		if DEBUG_LOGS then
			print("Hatched Color " .. tostring(entry.displayName or petId)
				.. " | Trait: " .. tostring(entry.traitName)
				.. " | Mutation: " .. tostring(entry.mutationName)
				.. " | Egg: " .. tostring(eggId))
		end
	end

	syncPetFolder(player, "hatch-color")
	hatchEvent:FireClient(player, true, entry)
	sendState(player)

	task.delay(cooldown, function()
		local current = hatchState[player]
		if current and current.nextAllowedAt <= now + cooldown + 0.01 then
			hatchState[player] = nil
		end
	end)
end)

grantPetFunction.OnInvoke = function(player, petId, amount, traitId, mutationId)
	return grantPetToPlayer(player, petId, amount, traitId, false, true, "Neutral", mutationId)
end

-- ========================
--   EQUIP / UNEQUIP
-- ========================
equipEvent.OnServerEvent:Connect(function(player, action, variantKey)
	local equipped  = playerEquipped[player]
	local inventory = playerInventory[player]
	if not equipped or not inventory then return end
	local resolvedKey = resolveInventoryKey(inventory, variantKey)

	if action == "equip" then
		if not resolvedKey or not inventory[resolvedKey] then return end

		local maxSlots = getMaxSlots(player)
		for _, id in ipairs(equipped) do
			if id == resolvedKey then return end
		end
		if #equipped < maxSlots then
			table.insert(equipped, resolvedKey)
		end
	elseif action == "unequip" then
		if not variantKey then
			return
		end
		for i, id in ipairs(equipped) do
			if id == variantKey or id == resolvedKey then
				table.remove(equipped, i)
				break
			end
		end
	end

	syncPetFolder(player, "equip-color")
	sendState(player)
end)

-- ========================
--   MERGE PET STACK
-- ========================
mergeEvent.OnServerEvent:Connect(function(player, variantKey)
	local inventory = playerInventory[player]
	if not inventory then return end

	if not isFeatureUnlocked(player, "Merge") then
		mergeEvent:FireClient(player, false, variantKey, getFeatureLockedMessage("Merge"))
		return
	end

	local now = os.clock()
	if lastMergeAt[player] and now - lastMergeAt[player] < 0.5 then
		mergeEvent:FireClient(player, false, variantKey, "Slow down.")
		return
	end
	lastMergeAt[player] = now

	local data = inventory[variantKey]
	if not data or not PetData.Pets[data.petId] then
		mergeEvent:FireClient(player, false, variantKey, "You do not own that Color.")
		return
	end

	local mergeInfo = PetData.getMergeInfo(data.stackAmount)
	if not mergeInfo.canMerge then
		local need = math.max(0, mergeInfo.required - mergeInfo.ownedForTier)
		mergeEvent:FireClient(player, false, variantKey, "Need " .. need .. " more.")
		return
	end

	data.stackAmount = mergeInfo.resultStack

	local entry = buildEntry(variantKey, data)

	syncPetFolder(player, "merge-color")
	sendState(player)
	mergeEvent:FireClient(player, true, variantKey, entry)
end)

-- ========================
--   GET PET STATS (with trait multipliers)
-- ========================
local function getPlayerPetStats(player)
	local stats = { breakPower = 1, colorMult = 1.0, coinMult = 1.0, speedMult = 1.0, pickupRangeMult = 1.0, luckBonus = 0 }
	local equipped  = playerEquipped[player]
	local inventory = playerInventory[player]
	if not equipped or not inventory then return stats end
	local personalityStats = getEquippedPersonalityStats(player)

	for _, variantKey in ipairs(equipped) do
		local data  = inventory[variantKey]
		local stack = data and data.stackAmount or 1
		local entry = data and PetData.buildPetEntry(data.petId, stack, data.isShiny, data.personalityId, data.mutationId, data.traitId)
		if entry then
			local effPower = entry.finalPower

			stats.breakPower = stats.breakPower + effPower

			local baseCoinMult = entry.coinMult or 1.0
			stats.coinMult = stats.coinMult * baseCoinMult
			stats.colorMult = stats.colorMult * (entry.colorMult or 1.0)
		end
	end

	stats.breakPower = math.floor(stats.breakPower * personalityStats.totalPowerMult)
	stats.colorMult *= personalityStats.colorGainMult
	stats.coinMult *= personalityStats.sellMult
	stats.pickupRangeMult = personalityStats.pickupRangeMult
	stats.luckBonus = personalityStats.luckBonus

	local upgrades = player:FindFirstChild("Upgrades")
	local colorMultiplier = upgrades and upgrades:FindFirstChild("ColorMultiplier")
	if colorMultiplier then
		stats.colorMult *= colorMultiplier.Value
	end

	return stats
end

-- ========================
--   BREAKABLE TRACKING
-- ========================
local objectHealth    = {}
local objectMaxHealth = {}

local function registerObject(obj)
	if obj:IsA("BasePart") and obj:GetAttribute("BreakableType") then
		local data = ColorData.Breakables[obj:GetAttribute("BreakableType")]
		if data then
			objectHealth[obj]    = data.health
			objectMaxHealth[obj] = data.health
		end
	end
end
for _, obj in ipairs(workspace:GetDescendants()) do registerObject(obj) end
workspace.DescendantAdded:Connect(registerObject)

-- ========================
--   PET AUTO-ATTACK LOOP
-- ========================
local PET_ATTACK_RANGE    = 25
local PET_ATTACK_INTERVAL = 0.5
local lastAttack = {}

RunService.Heartbeat:Connect(function()
	local now = tick()
	for _, player in ipairs(Players:GetPlayers()) do
		local char = player.Character
		if not char then continue end
		local root = char:FindFirstChild("HumanoidRootPart")
		if not root then continue end
		if (now - (lastAttack[player] or 0)) < PET_ATTACK_INTERVAL then continue end

		local petStats = getPlayerPetStats(player)
		if petStats.breakPower <= 1 then continue end

		local storage = player:FindFirstChild("ColorStorage")
		local unlockedColors = storage and storage:FindFirstChild("UnlockedColors")

		local nearest, nearestDist = nil, PET_ATTACK_RANGE
		for obj, health in pairs(objectHealth) do
			if health > 0 and obj and obj.Parent and obj.Transparency < 1 and not obj:GetAttribute("IsCollected") then
				local colorType = obj:GetAttribute("ColorType")
				if unlockedColors and colorType and not ColorData.isColorUnlocked(unlockedColors.Value, colorType) then
					continue
				end

				local dist = (root.Position - obj.Position).Magnitude
				if dist < nearestDist then
					nearest     = obj
					nearestDist = dist
				end
			end
		end

		if nearest then
			lastAttack[player] = now
			local breakableType = nearest:GetAttribute("BreakableType")
			local colorType     = nearest:GetAttribute("ColorType")
			local colorData     = ColorData.Breakables[breakableType]

			objectHealth[nearest] = math.max(0, objectHealth[nearest] - petStats.breakPower)
			local healthPct = objectHealth[nearest] / (objectMaxHealth[nearest] or 1)

			local colorInfo = ColorData.Colors[colorType]
			if colorInfo and nearest and nearest.Parent then
				local baseColor = getStoredColor(nearest, colorType)
				nearest.Color = baseColor:Lerp(Color3.new(1, 1, 1), math.clamp((1 - healthPct) * 0.22, 0, 0.22))
			end

			petAtkEvent:FireClient(player, playerEquipped[player], nearest, colorType)

			if objectHealth[nearest] <= 0 and colorData then
				local baseReward = getBaseBreakableReward(nearest, colorData)
				local areaMult = tonumber(nearest:GetAttribute("RewardMultiplier")) or 1
				local reward     = math.floor(baseReward * areaMult * petStats.colorMult)

				local storage = player:FindFirstChild("ColorStorage")
				if storage then
					local held   = storage:FindFirstChild("ColorHeld")
					local maxCap = storage:FindFirstChild("MaxCapacity")
					if held and maxCap then
						held.Value = math.min(maxCap.Value, held.Value + reward)
					end
				end

				nearest:SetAttribute("IsCollected", true)
				nearest:SetAttribute("Respawning", true)
				nearest.Transparency = 1
				nearest.CanCollide   = false
				objectHealth[nearest] = 0

				task.delay(5, function()
					if nearest and nearest.Parent then
						local data = ColorData.Breakables[nearest:GetAttribute("BreakableType")]
						if data then
							local ci = ColorData.Colors[nearest:GetAttribute("ColorType")]
							local respawnColorType = nearest:GetAttribute("ColorType")
							if ci then nearest.Color = getStoredColor(nearest, respawnColorType) end
							objectHealth[nearest]    = data.health
							objectMaxHealth[nearest] = data.health
							nearest.Transparency     = 0
							nearest.CanCollide       = false
							nearest:SetAttribute("IsCollected", false)
							nearest:SetAttribute("Respawning", false)
						end
					end
				end)
			end
		end
	end
end)

return {
	getPlayerPetStats = getPlayerPetStats,
	AddColorToInventory = grantPetToPlayer,
}
]]></string>
