        <Item class="LocalScript" referent="147">
          <Properties>
            <string name="Name">SocialPanelsUI</string>
            <string name="Source"><![CDATA[-- SocialPanelsUI.client.luau
if true then
	warn("SocialPanelsUI disabled; editable Codes/Settings windows are bound by EditorWindowBinder.")
	return
end

local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local SoundService = game:GetService("SoundService")
local TweenService = game:GetService("TweenService")

local player = Players.LocalPlayer
local UIManager = require(ReplicatedStorage:WaitForChild("UIManager"))
local UITheme = require(ReplicatedStorage:WaitForChild("UITheme"))
local ClientUIRoot = require(ReplicatedStorage:WaitForChild("ClientUIRoot"))
local SettingsData = require(ReplicatedStorage:WaitForChild("SettingsData"))
local Events = ReplicatedStorage:FindFirstChild("Events")
local requestSetSettingEvent = Events and Events:FindFirstChild("RequestSetSetting") or nil
local settingsUpdatedEvent = Events and Events:FindFirstChild("SettingsUpdated") or nil

local DARK = UITheme.Colors.OutlineDark
local CYAN = UITheme.Colors.PrimaryCyan
local PINK = UITheme.Colors.ErrorRed
local LIME = UITheme.Colors.PrimaryGreen
local LAVENDER = UITheme.Colors.PanelLavender

local screenGui = ClientUIRoot.GetLayer(player.PlayerGui, "SocialPanelsUI")

local overlay = UITheme.CreateDimOverlay(screenGui, 50)

local panel = Instance.new("Frame")
panel.Size = UDim2.new(0, 560, 0, 360)
panel.AnchorPoint = Vector2.new(0.5, 0.5)
panel.Position = UDim2.fromScale(0.5, 0.5)
panel.BackgroundColor3 = UITheme.Colors.PanelCream
panel.BorderSizePixel = 0
panel.Visible = false
panel.ZIndex = 60
panel.Parent = screenGui
UITheme.ApplyResponsiveScale(panel, 560, 360, 0.76, 28)

local corner = Instance.new("UICorner")
corner.CornerRadius = UDim.new(0, 22)
corner.Parent = panel

local stroke = Instance.new("UIStroke")
stroke.Color = DARK
stroke.Thickness = 5
stroke.Parent = panel

local title = Instance.new("TextLabel")
title.Size = UDim2.new(1, -86, 0, 72)
title.Position = UDim2.new(0, 24, 0, 8)
title.BackgroundTransparency = 1
title.Font = Enum.Font.LuckiestGuy
title.TextSize = 34
title.TextColor3 = Color3.new(1, 1, 1)
title.TextStrokeTransparency = 0
title.TextStrokeColor3 = DARK
title.TextXAlignment = Enum.TextXAlignment.Left
title.ZIndex = 61
title.Parent = panel

local content = Instance.new("Frame")
content.Size = UDim2.new(1, -54, 1, -110)
content.Position = UDim2.new(0, 27, 0, 90)
content.BackgroundTransparency = 1
content.ZIndex = 61
content.Parent = panel

local contentLayout = Instance.new("UIListLayout")
contentLayout.FillDirection = Enum.FillDirection.Vertical
contentLayout.SortOrder = Enum.SortOrder.LayoutOrder
contentLayout.Padding = UDim.new(0, 8)
contentLayout.Parent = content

local closeBtn = Instance.new("TextButton")
closeBtn.Size = UDim2.new(0, 42, 0, 42)
closeBtn.Position = UDim2.new(1, -64, 0, 16)
closeBtn.BackgroundColor3 = PINK
closeBtn.Active = true
closeBtn.Font = Enum.Font.LuckiestGuy
closeBtn.TextSize = 28
closeBtn.TextColor3 = Color3.new(1, 1, 1)
closeBtn.TextStrokeTransparency = 0
closeBtn.TextStrokeColor3 = DARK
closeBtn.Text = "X"
closeBtn.ZIndex = 70
closeBtn.Parent = panel

local closeCorner = Instance.new("UICorner")
closeCorner.CornerRadius = UDim.new(0, 12)
closeCorner.Parent = closeBtn
local closeStroke = Instance.new("UIStroke")
closeStroke.Color = DARK
closeStroke.Thickness = 4
closeStroke.Parent = closeBtn

local backBtn = Instance.new("TextButton")
backBtn.Size = UDim2.new(0, 42, 0, 42)
backBtn.Position = UDim2.new(0, 18, 0, 16)
backBtn.BackgroundColor3 = UITheme.Colors.PanelCream
backBtn.Font = Enum.Font.LuckiestGuy
backBtn.TextSize = 26
backBtn.TextColor3 = DARK
backBtn.TextStrokeTransparency = 1
backBtn.Text = "<"
backBtn.Visible = false
backBtn.ZIndex = 70
backBtn.Parent = panel
local backCorner = Instance.new("UICorner")
backCorner.CornerRadius = UDim.new(0, 12)
backCorner.Parent = backBtn
local backStroke = Instance.new("UIStroke")
backStroke.Color = DARK
backStroke.Thickness = 4
backStroke.Parent = backBtn

local currentName = nil
local isOpen = false
local openedFromMenu = false
local savedSettings = SettingsData.Normalize(nil)
local settingsLoaded = false
local pendingSettings = {}
local settingButtons = {}
local settingsStatusLabel = nil
local lastCloseRequestAt = 0

local SETTING_LABELS = {
	Music = "MUSIC",
	SFX = "SFX",
	Popups = "POPUPS",
	LowFX = "LOW FX",
}

local SETTING_ORDER = { "Music", "SFX", "Popups", "LowFX" }

local function isMusicSound(sound)
	local name = string.lower(sound.Name or "")
	return string.find(name, "music", 1, true)
		or string.find(name, "bgm", 1, true)
		or string.find(name, "theme", 1, true)
end

local function applyMusicSetting(enabled)
	for _, root in ipairs({ SoundService, workspace }) do
		for _, obj in ipairs(root:GetDescendants()) do
			if obj:IsA("Sound") and isMusicSound(obj) then
				if obj:GetAttribute("SettingsOriginalVolume") == nil then
					obj:SetAttribute("SettingsOriginalVolume", obj.Volume)
				end
				obj.Volume = enabled and (obj:GetAttribute("SettingsOriginalVolume") or 0.5) or 0
			end
		end
	end
end

local function applySettings(settings)
	savedSettings = SettingsData.Normalize(settings)
	settingsLoaded = true
	for key, value in pairs(savedSettings) do
		player:SetAttribute("Setting" .. key, value)
	end
	applyMusicSetting(savedSettings.Music)
	-- SFX/Popups/LowFX are read by the client systems that create those sounds/effects.
end

local function setSettingsStatus(text, color)
	if settingsStatusLabel then
		settingsStatusLabel.Text = text or ""
		settingsStatusLabel.TextColor3 = color or UITheme.Colors.TextMuted
	end
end

local function updateSettingButton(key)
	local button = settingButtons[key]
	if not button then
		return
	end

	local pending = pendingSettings[key] == true
	local value = savedSettings[key] == true
	button.Text = (SETTING_LABELS[key] or string.upper(key)) .. ": " .. (value and "ON" or "OFF")
	button.BackgroundColor3 = pending and LAVENDER or (value and CYAN or PINK)
	button.AutoButtonColor = settingsLoaded and requestSetSettingEvent ~= nil and not pending
end

local function updateAllSettingButtons()
	for _, key in ipairs(SETTING_ORDER) do
		updateSettingButton(key)
	end
end

local function readReplicatedSettings()
	local folder = player:FindFirstChild("Settings")
	if not folder then
		return false
	end

	local values = {}
	for key, defaultValue in pairs(SettingsData.Defaults) do
		local value = folder:FindFirstChild(key)
		values[key] = value and value:IsA("BoolValue") and value.Value or defaultValue
	end
	applySettings(values)
	updateAllSettingButtons()
	return true
end

local function clearContent()
	for _, child in ipairs(content:GetChildren()) do
		if child ~= contentLayout then
			child:Destroy()
		end
	end
end

local function makeLabel(text, size, color)
	local label = Instance.new("TextLabel")
	label.Size = UDim2.new(1, 0, 0, size + 8)
	label.BackgroundTransparency = 1
label.Font = Enum.Font.GothamBold
label.TextSize = size
label.TextColor3 = color or Color3.fromRGB(40, 48, 64)
label.TextStrokeTransparency = 0.7
label.TextStrokeColor3 = Color3.new(1, 1, 1)
	label.TextXAlignment = Enum.TextXAlignment.Left
	label.Text = text
	label.ZIndex = 62
	label.Parent = content
	return label
end

local function makeButton(text, color, onClick)
	local button = Instance.new("TextButton")
	button.Size = UDim2.new(1, 0, 0, 40)
button.BackgroundColor3 = color
	button.AutoButtonColor = true
	button.Font = Enum.Font.LuckiestGuy
button.TextSize = 28
button.TextColor3 = Color3.new(1, 1, 1)
button.TextStrokeTransparency = 0
	button.TextStrokeColor3 = DARK
	button.Text = text
	button.ZIndex = 62
	button.Parent = content
	local corner = Instance.new("UICorner")
corner.CornerRadius = UDim.new(0, 10)
corner.Parent = button
local stroke = Instance.new("UIStroke")
stroke.Color = DARK
stroke.Thickness = 4
stroke.Parent = button
	if onClick then
		button.MouseButton1Click:Connect(onClick)
	end
	return button
end

local function makeRow(left, right)
	local row = Instance.new("TextLabel")
row.Size = UDim2.new(1, 0, 0, 34)
row.BackgroundColor3 = Color3.fromRGB(236, 255, 253)
row.Font = Enum.Font.GothamBold
row.TextSize = 21
row.TextColor3 = Color3.fromRGB(30, 36, 48)
	row.TextXAlignment = Enum.TextXAlignment.Left
	row.Text = "  " .. left .. "    " .. right
	row.ZIndex = 62
	row.Parent = content
	local corner = Instance.new("UICorner")
corner.CornerRadius = UDim.new(0, 8)
corner.Parent = row
local stroke = Instance.new("UIStroke")
stroke.Color = DARK
stroke.Thickness = 3
stroke.Parent = row
	return row
end

local function buildContent(name)
	clearContent()

	if name == "Trading" then
		makeLabel("Trading is coming soon.", 24, CYAN)
		makeLabel("Trade Colors safely in a future update.", 17, UITheme.Colors.TextMuted)
		makeButton("COMING SOON", LAVENDER)
	elseif name == "Market" then
		makeLabel("Market is coming soon.", 24, CYAN)
		makeLabel("List rare Colors in a future update.", 17, UITheme.Colors.TextMuted)
		makeButton("COMING SOON", LAVENDER)
	elseif name == "Settings" then
		makeLabel("Options", 24, CYAN)
		table.clear(settingButtons)
		settingsStatusLabel = makeLabel(settingsLoaded and "Saved per player." or "Loading settings...", 16, UITheme.Colors.TextMuted)
		for _, key in ipairs(SETTING_ORDER) do
			local button = makeButton((SETTING_LABELS[key] or string.upper(key)) .. ": ...", LAVENDER, function()
				if not settingsLoaded or not requestSetSettingEvent then
					setSettingsStatus("Settings are still loading.", PINK)
					return
				end
				if pendingSettings[key] then
					return
				end

				local nextValue = not (savedSettings[key] == true)
				pendingSettings[key] = true
				updateSettingButton(key)
				setSettingsStatus("Saving " .. (SETTING_LABELS[key] or key) .. "...", UITheme.Colors.TextMuted)
				requestSetSettingEvent:FireServer(key, nextValue)

				task.delay(8, function()
					if pendingSettings[key] then
						pendingSettings[key] = nil
						updateSettingButton(key)
						setSettingsStatus("Setting save timed out. Try again.", PINK)
					end
				end)
			end)
			settingButtons[key] = button
			updateSettingButton(key)
		end
	end
end

local function openPanel(name, context)
	currentName = name
	isOpen = true
	openedFromMenu = context and context.from == "Menu" or false
	backBtn.Visible = openedFromMenu
	title.Position = openedFromMenu and UDim2.new(0, 72, 0, 8) or UDim2.new(0, 24, 0, 8)
	title.Size = openedFromMenu and UDim2.new(1, -134, 0, 72) or UDim2.new(1, -86, 0, 72)
	title.Text = string.upper(name)
	buildContent(name)
	overlay.Visible = true
	overlay.BackgroundTransparency = 1
	panel.Visible = true
	panel.Size = UDim2.new(0, 560, 0, 60)
	panel.Position = UDim2.fromScale(0.5, 0.5)
	TweenService:Create(overlay, TweenInfo.new(0.18), {
		BackgroundTransparency = 0.4,
	}):Play()
	TweenService:Create(panel, TweenInfo.new(0.22, Enum.EasingStyle.Back), {
		Size = UDim2.new(0, 560, 0, 360),
		Position = UDim2.fromScale(0.5, 0.5),
	}):Play()
end

local function closePanel(name, context)
	if name and currentName ~= name then
		return
	end
	isOpen = false
	openedFromMenu = false
	backBtn.Visible = false
	if context and context.immediate then
		panel.Visible = false
		overlay.Visible = false
		overlay.BackgroundTransparency = 1
		currentName = nil
		return
	end
	TweenService:Create(overlay, TweenInfo.new(0.14), {
		BackgroundTransparency = 1,
	}):Play()
	TweenService:Create(panel, TweenInfo.new(0.14), {
		Size = UDim2.new(0, 0, 0, 0),
		Position = UDim2.new(0.5, 0, 0.5, 0),
	}):Play()
	task.delay(0.14, function()
		if not isOpen then
			panel.Visible = false
			overlay.Visible = false
			currentName = nil
		end
	end)
end

local function requestClose()
	local now = os.clock()
	if now - lastCloseRequestAt < 0.12 then
		return
	end
	lastCloseRequestAt = now

	local name = currentName
	if name and UIManager.isRegistered(name) then
		UIManager.close(name)
	else
		closePanel()
	end
end

backBtn.MouseButton1Click:Connect(function()
	if openedFromMenu then
		UIManager.open("Menu")
	end
end)

closeBtn.Activated:Connect(requestClose)
closeBtn.MouseButton1Click:Connect(requestClose)

overlay.Activated:Connect(requestClose)
overlay.MouseButton1Click:Connect(requestClose)

if settingsUpdatedEvent then
	settingsUpdatedEvent.OnClientEvent:Connect(function(settings, success, settingKey, message)
		applySettings(settings)
		if settingKey then
			pendingSettings[settingKey] = nil
			updateSettingButton(settingKey)
		else
			updateAllSettingButtons()
		end

		if currentName == "Settings" then
			if success == false then
				setSettingsStatus(message or "Setting was not saved.", PINK)
			else
				setSettingsStatus(message or "Saved.", LIME)
			end
		end
	end)
else
	-- Remotes can arrive shortly after this client script. Settings still registers immediately.
end

task.spawn(function()
	local eventsFolder = Events or ReplicatedStorage:WaitForChild("Events", 10)
	if not eventsFolder then
		return
	end

	if not requestSetSettingEvent then
		requestSetSettingEvent = eventsFolder:WaitForChild("RequestSetSetting", 10)
	end
	if not settingsUpdatedEvent then
		settingsUpdatedEvent = eventsFolder:WaitForChild("SettingsUpdated", 10)
		if settingsUpdatedEvent then
			settingsUpdatedEvent.OnClientEvent:Connect(function(settings, success, settingKey, message)
				applySettings(settings)
				if settingKey then
					pendingSettings[settingKey] = nil
					updateSettingButton(settingKey)
				else
					updateAllSettingButtons()
				end

				if currentName == "Settings" then
					if success == false then
						setSettingsStatus(message or "Setting was not saved.", PINK)
					else
						setSettingsStatus(message or "Saved.", LIME)
					end
				end
			end)
		end
	end
	updateAllSettingButtons()
end)

if not readReplicatedSettings() then
	task.spawn(function()
		local folder = player:WaitForChild("Settings", 10)
		if folder then
			readReplicatedSettings()
			for _, child in ipairs(folder:GetChildren()) do
				if child:IsA("BoolValue") then
					child:GetPropertyChangedSignal("Value"):Connect(readReplicatedSettings)
				end
			end
			folder.ChildAdded:Connect(function(child)
				if child:IsA("BoolValue") then
					child:GetPropertyChangedSignal("Value"):Connect(readReplicatedSettings)
					readReplicatedSettings()
				end
			end)
		end
	end)
end

for _, name in ipairs({ "Trading", "Market", "Settings" }) do
	UIManager.register(name,
		function(context) openPanel(name, context) end,
		function(context) closePanel(name, context) end,
		function() return isOpen and currentName == name end
	)
end
]]></string>
          </Properties>
        </Item>
        <Item class="LocalScript" referent="148">
          <Properties>
            <string name="Name">StudioHUDHookup</string>
            <string name="Source"><![CDATA[-- Hooks the handmade Studio HUD into the existing client UI system.
-- Expected hierarchy in PlayerGui:
-- ColorSimulatorUI/MainHUD/LeftButtons/{InventoryButton,ShopButton,WorldButton,CodesButton}
local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local StarterGui = game:GetService("StarterGui")
local TweenService = game:GetService("TweenService")
local UserInputService = game:GetService("UserInputService")

local player = Players.LocalPlayer
local playerGui = player:WaitForChild("PlayerGui")
local UIManager = require(ReplicatedStorage:WaitForChild("UIManager"))
local ClientUIRoot = require(ReplicatedStorage:WaitForChild("ClientUIRoot"))
local HUDAssetConfig = require(ReplicatedStorage:WaitForChild("HUDAssetConfig"))

local UI_ROOT_NAME = "ColorSimulatorUI"
local WARNED = {}
local BUTTON_TO_WINDOW = {
	InventoryButton = "Inventory",
	ShopButton = "Gamepass",
	WorldButton = "World",
	CodesButton = "Codes",
}
local BUTTON_TO_BINDABLE = {
	InventoryButton = "HudButton_INVENTORY",
	ShopButton = "HudButton_GAMEPASS",
	WorldButton = "HudButton_WORLD",
	CodesButton = "HudButton_CODES",
}
local BUTTON_SOURCE_FILES = {
	InventoryButton = "assets/ui/sliced_clean_hud/icons_may9_transparent_128/inventory_backpack.png",
	ShopButton = "assets/ui/sliced_clean_hud/icons_may9_transparent_128/shop_bag.png",
	WorldButton = "assets/ui/sliced_clean_hud/icons_may9_transparent_128/world_globe.png",
	CodesButton = "assets/ui/sliced_clean_hud/icons_may9_transparent_128/codes_ticket.png",
}
local connectedButtons = setmetatable({}, { __mode = "k" })
local buttonScales = setmetatable({}, { __mode = "k" })
local lastActivatedAt = setmetatable({}, { __mode = "k" })
local openWindow

local function warnOnce(key, message)
	if WARNED[key] then
		return
	end
	WARNED[key] = true
	warn(message)
end

local function getActiveRoot()
	return ClientUIRoot.GetRoot(playerGui) or playerGui:FindFirstChild(UI_ROOT_NAME)
end

local function hasLeftButtons(mainHud)
	local leftButtons = mainHud and mainHud:FindFirstChild("LeftButtons")
	return leftButtons and leftButtons:IsA("GuiObject")
end

local function hasImageAsset(guiObject)
	if guiObject:IsA("ImageButton") or guiObject:IsA("ImageLabel") then
		return type(guiObject.Image) == "string" and guiObject.Image ~= ""
	end
	return false
end

local function countButtonImageAssets(leftButtons)
	local count = 0
	for buttonName in pairs(BUTTON_TO_WINDOW) do
		local button = leftButtons:FindFirstChild(buttonName)
		if button then
			if hasImageAsset(button) then
				count += 1
			end
			for _, descendant in ipairs(button:GetDescendants()) do
				if hasImageAsset(descendant) then
					count += 1
				end
			end
		end
	end
	return count
end

local function getHudSourcePriority(mainHud)
	local screenGui = mainHud and mainHud:FindFirstAncestorOfClass("ScreenGui")
	if not screenGui then
		return 0
	end
	if screenGui.Name == "ScreenGui" then
		return 3
	end
	if screenGui.Name == UI_ROOT_NAME then
		return 2
	end
	return 1
end

local function getCandidateScore(mainHud)
	local leftButtons = mainHud and mainHud:FindFirstChild("LeftButtons")
	if not leftButtons or not leftButtons:IsA("GuiObject") then
		return -1
	end

	local imageScore = countButtonImageAssets(leftButtons) * 100
	local visibleScore = (mainHud.Visible and 10 or 0) + (leftButtons.Visible and 10 or 0)
	return imageScore + visibleScore + getHudSourcePriority(mainHud)
end

local function collectPlayerGuiMainHuds()
	local candidates = {}
	local seen = {}

	local function add(mainHud)
		if mainHud and mainHud:IsA("GuiObject") and hasLeftButtons(mainHud) and not seen[mainHud] then
			seen[mainHud] = true
			table.insert(candidates, mainHud)
		end
	end

	local screen = playerGui:FindFirstChild("ScreenGui")
	add(screen and screen:FindFirstChild("MainHUD"))

	local activeRoot = playerGui:FindFirstChild(UI_ROOT_NAME)
	add(activeRoot and activeRoot:FindFirstChild("MainHUD"))

	for _, descendant in ipairs(playerGui:GetDescendants()) do
		if descendant.Name == "MainHUD" and descendant:IsA("GuiObject") then
			add(descendant)
		end
	end

	return candidates
end

local function getBestPlayerGuiMainHud()
	local best = nil
	local bestScore = -1
	for _, candidate in ipairs(collectPlayerGuiMainHuds()) do
		local score = getCandidateScore(candidate)
		if score > bestScore then
			best = candidate
			bestScore = score
		end
	end
	return best
end

local function hideOnlyGeneratedRootDuplicate(keepMainHud)
	return keepMainHud
end

local function findPlayerGuiScreenMainHud()
	local screen = playerGui:FindFirstChild("ScreenGui")
	local mainHud = screen and screen:FindFirstChild("MainHUD")
	if mainHud and mainHud:IsA("GuiObject") then
		return mainHud, "PlayerGui.ScreenGui"
	end
	return nil, nil
end

local function findFallbackMainHud()
	local fallbackHud = findPlayerGuiScreenMainHud()
	if fallbackHud and fallbackHud:IsA("GuiObject") then
		return fallbackHud, "PlayerGui.ScreenGui"
	end

	for _, descendant in ipairs(playerGui:GetDescendants()) do
		if descendant.Name == "MainHUD" and descendant:IsA("GuiObject") then
			return descendant, "PlayerGui"
		end
	end
	return nil, nil
end

local function ensureMainHudInActiveRoot()
	local root = getActiveRoot()
	if not root then
		return nil
	end

	for _, child in ipairs(root:GetChildren()) do
		if child.Name == "MainHUD" and child:IsA("GuiObject") and hasLeftButtons(child) then
			return child
		end
	end

	local fallbackHud, sourceName = findFallbackMainHud()
	if not fallbackHud or not hasLeftButtons(fallbackHud) then
		return nil
	end

	if sourceName == "PlayerGui.ScreenGui" or fallbackHud:IsDescendantOf(playerGui) then
		return fallbackHud
	end
	return nil
end

local function findMainHud()
	local screenHud = findPlayerGuiScreenMainHud()
	if hasLeftButtons(screenHud) then
		hideOnlyGeneratedRootDuplicate(screenHud)
		return screenHud
	end

	local activeRoot = getActiveRoot()
	if activeRoot then
		for _, child in ipairs(activeRoot:GetChildren()) do
			if child.Name == "MainHUD" and child:IsA("GuiObject") and hasLeftButtons(child) then
				return child
			end
		end
	end

	local adoptedHud = ensureMainHudInActiveRoot()
	if adoptedHud then
		return adoptedHud
	end

	local fallbackHud = findFallbackMainHud()
	return fallbackHud
end

local function findMainHudWithLeftButtons()
	local mainHud = findMainHud()
	if hasLeftButtons(mainHud) then
		return mainHud
	end
	return nil
end

local function getLeftButtons()
	local mainHud = findMainHudWithLeftButtons()
	if not mainHud then
		return nil
	end

	local leftButtons = mainHud:FindFirstChild("LeftButtons")
	if leftButtons and leftButtons:IsA("GuiObject") then
		return leftButtons
	end
	return nil
end

local function collectLeftButtons()
	local leftButtonSets = {}
	local seen = {}

	local function add(leftButtons)
		if leftButtons and leftButtons:IsA("GuiObject") and not seen[leftButtons] then
			seen[leftButtons] = true
			table.insert(leftButtonSets, leftButtons)
		end
	end

	local primary = getLeftButtons()
	add(primary)

	for _, descendant in ipairs(playerGui:GetDescendants()) do
		if descendant.Name == "LeftButtons" and descendant:IsA("GuiObject") then
			local mainHud = descendant.Parent
			if mainHud and mainHud.Name == "MainHUD" and mainHud:IsA("GuiObject") then
				add(descendant)
			end
		end
	end

	return leftButtonSets
end

local function applyVisibilitySafety(leftButtons)
	local mainHud = leftButtons.Parent
	local screenGui = mainHud and mainHud:FindFirstAncestorOfClass("ScreenGui")
	if not mainHud or not screenGui then
		warnOnce("root-missing", "StudioHUDHookup: could not find ScreenGui/MainHUD ancestors for LeftButtons.")
		return
	end

	screenGui.Enabled = true
	screenGui.ResetOnSpawn = false
	screenGui.IgnoreGuiInset = false
	screenGui.DisplayOrder = math.max(screenGui.DisplayOrder, 999)
	screenGui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
	mainHud.Visible = true
	leftButtons.Visible = true
end

local function getOrCreateScale(button)
	local scale = buttonScales[button]
	if scale and scale.Parent == button then
		return scale
	end

	scale = button:FindFirstChild("StudioHUDScale")
	if not scale or not scale:IsA("UIScale") then
		scale = Instance.new("UIScale")
		scale.Name = "StudioHUDScale"
		scale.Parent = button
	end
	scale.Scale = 1
	buttonScales[button] = scale
	return scale
end

local function getPhysicalButtonImage(buttonName)
	local config = HUDAssetConfig.PhysicalButtonImages and HUDAssetConfig.PhysicalButtonImages[buttonName]
	if type(config) == "table" and type(config.Image) == "string" and config.Image ~= "" then
		return config.Image, config.SourceFile
	end
	return nil, type(config) == "table" and config.SourceFile or BUTTON_SOURCE_FILES[buttonName]
end

local function setGuiImageIfBlank(guiObject, imageId)
	if not (guiObject:IsA("ImageButton") or guiObject:IsA("ImageLabel")) then
		return false
	end
	if type(guiObject.Image) == "string" and guiObject.Image ~= "" then
		return true
	end

	guiObject.Image = imageId
	guiObject.ImageTransparency = 0
	guiObject.ScaleType = Enum.ScaleType.Fit
	return true
end

local function applyButtonIcon(button, buttonName)
	local imageId, sourceFile = getPhysicalButtonImage(buttonName)
	button:SetAttribute("ExpectedIconFile", sourceFile or "")

	if not imageId then
		if button:IsA("ImageButton") and (type(button.Image) ~= "string" or button.Image == "") then
			warnOnce(
				"missing-physical-icon-" .. buttonName,
				"StudioHUDHookup: " .. buttonName .. " needs an uploaded Roblox image id for " .. tostring(sourceFile)
			)
		end
		return
	end

	if setGuiImageIfBlank(button, imageId) then
		return
	end

	local icon = button:FindFirstChild("Icon") or button:FindFirstChildWhichIsA("ImageLabel", true)
	if icon and setGuiImageIfBlank(icon, imageId) then
		return
	end

	warnOnce("icon-target-missing-" .. buttonName, "StudioHUDHookup: could not apply icon image to " .. buttonName)
end

local function tweenScale(button, value, duration)
	local scale = getOrCreateScale(button)
	TweenService:Create(scale, TweenInfo.new(duration or 0.1, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
		Scale = value,
	}):Play()
end

local function prepareButton(button)
	button.AutoButtonColor = false
	button.Active = true
	button.Selectable = true
	button.Visible = true

	for _, descendant in ipairs(button:GetDescendants()) do
		if descendant:IsA("GuiObject") and not descendant:IsA("GuiButton") then
			descendant.Active = false
			descendant.Selectable = false
		end
	end

	getOrCreateScale(button)
end

local function activateButton(button, buttonName)
	local now = os.clock()
	if lastActivatedAt[button] and now - lastActivatedAt[button] < 0.2 then
		return
	end
	lastActivatedAt[button] = now
	print("StudioHUDHookup: clicked " .. buttonName)
	openWindow(buttonName)
end

local function fireFallbackBindable(buttonName)
	local bindableName = BUTTON_TO_BINDABLE[buttonName]
	local bindable = bindableName and ReplicatedStorage:FindFirstChild(bindableName)
	if bindable and bindable:IsA("BindableEvent") then
		bindable:Fire({ from = "StudioHUD" })
		return true
	end
	return false
end

function openWindow(buttonName)
	local windowName = BUTTON_TO_WINDOW[buttonName]
	if not windowName then
		return
	end

	if UIManager.isRegistered(windowName) then
		if windowName == "Inventory" then
			local openInventoryBindable = ReplicatedStorage:FindFirstChild("HudOpenInventory")
			if openInventoryBindable and openInventoryBindable:IsA("BindableEvent") then
				openInventoryBindable:Fire({ from = "StudioHUD" })
				return
			end
		end
		local ok, err = pcall(function()
			UIManager.open(windowName, { from = "StudioHUD" })
		end)
		if not ok then
			warnOnce("window-open-" .. windowName, "StudioHUDHookup: failed to open '" .. windowName .. "': " .. tostring(err))
		end
		return
	end

	task.spawn(function()
		local startedAt = os.clock()
		while os.clock() - startedAt < 8 do
			task.wait(0.1)
			if UIManager.isRegistered(windowName) then
				if windowName == "Inventory" then
					local openInventoryBindable = ReplicatedStorage:FindFirstChild("HudOpenInventory")
					if openInventoryBindable and openInventoryBindable:IsA("BindableEvent") then
						openInventoryBindable:Fire({ from = "StudioHUD" })
						return
					end
				end
				local ok, err = pcall(function()
					UIManager.open(windowName, { from = "StudioHUD" })
				end)
				if not ok then
					warnOnce("window-open-" .. windowName, "StudioHUDHookup: failed to open '" .. windowName .. "': " .. tostring(err))
				end
				return
			end
		end

		if fireFallbackBindable(buttonName) then
			return
		end

		if windowName == "Codes" then
			warnOnce("codes-missing", "StudioHUDHookup: Codes UI is not registered yet; CodesButton is connected to this placeholder.")
		else
			warnOnce("window-missing-" .. windowName, "StudioHUDHookup: missing UI window '" .. windowName .. "'.")
		end
	end)
end

local function hookButton(leftButtons, buttonName)
	local button = leftButtons:FindFirstChild(buttonName)
	if not button then
		warnOnce("missing-" .. buttonName, "StudioHUDHookup: missing MainHUD.LeftButtons." .. buttonName)
		return
	end
	if not button:IsA("GuiButton") then
		warnOnce("not-button-" .. buttonName, "StudioHUDHookup: MainHUD.LeftButtons." .. buttonName .. " is not a GuiButton.")
		return
	end
	prepareButton(button)
	applyButtonIcon(button, buttonName)
	if connectedButtons[button] then
		return
	end

	connectedButtons[button] = true
	local isPressed = false
	local isHovering = false

	button.MouseEnter:Connect(function()
		if UserInputService.MouseEnabled then
			isHovering = true
			if not isPressed then
				tweenScale(button, 1.06, 0.1)
			end
		end
	end)

	button.MouseLeave:Connect(function()
		isHovering = false
		if not isPressed then
			tweenScale(button, 1, 0.1)
		end
	end)

	button.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			isPressed = true
			tweenScale(button, 0.92, 0.06)
		end
	end)

	button.InputEnded:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			isPressed = false
			tweenScale(button, isHovering and 1.06 or 1, 0.12)
		end
	end)

	button.Activated:Connect(function()
		tweenScale(button, 0.96, 0.05)
		task.delay(0.06, function()
			if button.Parent then
				tweenScale(button, isHovering and 1.06 or 1, 0.12)
			end
		end)
		activateButton(button, buttonName)
	end)

	button.MouseButton1Click:Connect(function()
		activateButton(button, buttonName)
	end)
end

local function hookHandmadeHud()
	local leftButtonSets = collectLeftButtons()
	if #leftButtonSets <= 0 then
		warnOnce("missing-left-buttons", "StudioHUDHookup: missing handmade HUD path MainHUD.LeftButtons.")
		return false
	end

	for _, leftButtons in ipairs(leftButtonSets) do
		applyVisibilitySafety(leftButtons)

		for buttonName in pairs(BUTTON_TO_WINDOW) do
			hookButton(leftButtons, buttonName)
		end
	end

	playerGui:SetAttribute("StudioMainHUDHooked", true)
	playerGui:SetAttribute("StudioMainHUDVisualDebug", false)
	return true
end

task.defer(function()
	local startedAt = os.clock()
	while os.clock() - startedAt < 10 do
		if hookHandmadeHud() then
			return
		end
		task.wait(0.25)
	end
	warnOnce("not-found", "StudioHUDHookup: handmade MainHUD was not found in PlayerGui.")
end)

playerGui.DescendantAdded:Connect(function(descendant)
	if descendant.Name == "MainHUD" or descendant.Name == "LeftButtons" or BUTTON_TO_WINDOW[descendant.Name] then
		task.defer(hookHandmadeHud)
	end
end)
]]></string>
          </Properties>
        </Item>
        <Item class="LocalScript" referent="149">
          <Properties>
            <string name="Name">TextReadability</string>
            <string name="Source"><![CDATA[-- Light readability pass for player-facing UI text.
-- Keeps the simulator style, but stops small outlined labels from turning into blobs.
local Players = game:GetService("Players")
local TweenService = game:GetService("TweenService")

local player = Players.LocalPlayer
local playerGui = player:WaitForChild("PlayerGui")

local SAFE_GLOW_COLORS = {
	Color3.fromRGB(105, 226, 232), -- soft cyan
	Color3.fromRGB(164, 143, 238), -- soft lavender
	Color3.fromRGB(255, 201, 112), -- warm gold
	Color3.fromRGB(125, 224, 154), -- soft mint
	Color3.fromRGB(244, 147, 184), -- soft rose
}

local SAFE_HOVER_COLORS = {
	Color3.fromRGB(88, 255, 231),
	Color3.fromRGB(255, 218, 92),
	Color3.fromRGB(125, 255, 158),
	Color3.fromRGB(185, 155, 255),
	Color3.fromRGB(255, 136, 198),
}

local hoverOriginals = setmetatable({}, { __mode = "k" })
local DARK_STROKE = Color3.fromRGB(8, 14, 32)

local function luminance(color)
	return color.R * 0.2126 + color.G * 0.7152 + color.B * 0.0722
end

local function colorDistance(a, b)
	local dr = a.R - b.R
	local dg = a.G - b.G
	local db = a.B - b.B
	return math.sqrt(dr * dr + dg * dg + db * db)
end

local function getParentBackground(gui)
	local parent = gui.Parent
	while parent do
		if parent:IsA("GuiObject") and parent.BackgroundTransparency < 0.92 then
			return parent.BackgroundColor3
		end
		parent = parent.Parent
	end
	return Color3.fromRGB(255, 255, 255)
end

local function chooseGlowColor(gui)
	local seedText = tostring(gui.Name) .. "|" .. tostring(gui.Text)
	local seed = 0
	for i = 1, #seedText do
		seed += string.byte(seedText, i) * i
	end

	local textColor = gui.TextColor3
	local bgColor = getParentBackground(gui)
	local bestColor = SAFE_GLOW_COLORS[1]
	local bestScore = -math.huge
	for i, color in ipairs(SAFE_GLOW_COLORS) do
		local candidate = SAFE_GLOW_COLORS[((seed + i - 1) % #SAFE_GLOW_COLORS) + 1]
		local score = colorDistance(candidate, textColor) * 0.55
			+ colorDistance(candidate, bgColor) * 0.45
			- math.abs(luminance(candidate) - 0.72) * 0.28
		if score > bestScore then
			bestScore = score
			bestColor = candidate
		end
	end

	return bestColor
end

local function chooseHoverColor(gui)
	local seedText = tostring(gui.Name) .. "|" .. tostring(gui.Text)
	local seed = 0
	for i = 1, #seedText do
		seed += string.byte(seedText, i) * i
	end

	local bgColor = getParentBackground(gui)
	local bestColor = SAFE_HOVER_COLORS[1]
	local bestScore = -math.huge
	for i = 1, #SAFE_HOVER_COLORS do
		local candidate = SAFE_HOVER_COLORS[((seed + i - 1) % #SAFE_HOVER_COLORS) + 1]
		local lum = luminance(candidate)
		local score = colorDistance(candidate, bgColor)
			- math.abs(lum - 0.78) * 0.35
		if score > bestScore then
			bestScore = score
			bestColor = candidate
		end
	end

	return bestColor
end

local function getTextConstraint(gui)
	for _, child in ipairs(gui:GetChildren()) do
		if child:IsA("UITextSizeConstraint") then
			return child
		end
	end
	return nil
end

local function needsStrongReadableText(gui)
	if gui:GetAttribute("ForceReadableText") then
		return true
	end
	if gui:IsA("TextButton") then
		return gui.Text ~= nil and gui.Text ~= ""
	end

	local text = string.upper(tostring(gui.Text or ""))
	return string.find(text, "RELEASE", 1, true)
		or string.find(text, "CODE:", 1, true)
		or string.find(text, "HIDE", 1, true)
end

local function applyStrongReadableText(gui)
	gui:SetAttribute("NoTextGlow", true)
	gui.Font = Enum.Font.GothamBlack
	gui.TextColor3 = Color3.fromRGB(255, 255, 255)
	gui.TextStrokeColor3 = DARK_STROKE
	gui.TextStrokeTransparency = 0

	if gui:IsA("TextButton") or gui:GetAttribute("ForceReadableText") then
		gui.TextScaled = true
		local constraint = getTextConstraint(gui)
		if not constraint then
			constraint = Instance.new("UITextSizeConstraint")
			constraint.Parent = gui
		end
		constraint.MinTextSize = math.max(constraint.MinTextSize, 10)
		constraint.MaxTextSize = math.max(constraint.MaxTextSize, 18)
	end
end

local function shouldGlowText(gui)
	if gui:GetAttribute("NoTextGlow") or gui:GetAttribute("ReadabilityGlow") then
		return false
	end
	if gui:IsA("TextButton") or gui:IsA("TextBox") then
		return false
	end
	if gui.Text == nil or gui.Text == "" then
		return false
	end
	if gui.TextTransparency > 0.35 then
		return false
	end
	if gui.AbsoluteSize.X < 18 or gui.AbsoluteSize.Y < 10 then
		return false
	end
	local visibleTextSize = gui.TextScaled and gui.AbsoluteSize.Y or gui.TextSize
	if visibleTextSize < 20 then
		return false
	end
	return gui.Font == Enum.Font.LuckiestGuy or gui.TextScaled
end

local function ensureTextGlow(gui)
	if not shouldGlowText(gui) then
		local old = gui:FindFirstChild("SoftReadableGlow")
		if old then
			old:Destroy()
		end
		return
	end

	local glow = gui:FindFirstChild("SoftReadableGlow")
	if not glow then
		glow = Instance.new("TextLabel")
		glow.Name = "SoftReadableGlow"
		glow:SetAttribute("ReadabilityGlow", true)
		glow.BackgroundTransparency = 1
		glow.BorderSizePixel = 0
		glow.Active = false
		glow.Selectable = false
		glow.Parent = gui
	end

	local glowColor = chooseGlowColor(gui)
	glow.AnchorPoint = Vector2.new(0.5, 0.5)
	glow.Position = UDim2.new(0.5, 0, 0.5, 0)
	glow.Size = UDim2.new(1, 0, 1, 0)
	glow.Font = gui.Font
	glow.Text = gui.Text
	glow.TextSize = gui.TextSize
	glow.TextScaled = gui.TextScaled
	glow.TextWrapped = gui.TextWrapped
	glow.TextXAlignment = gui.TextXAlignment
	glow.TextYAlignment = gui.TextYAlignment
	glow.RichText = gui.RichText
	glow.TextColor3 = glowColor
	glow.TextTransparency = 0.78
	glow.TextStrokeColor3 = glowColor:Lerp(Color3.new(1, 1, 1), 0.18)
	glow.TextStrokeTransparency = 0.9
	glow.ZIndex = math.max(1, gui.ZIndex - 1)

	local constraint = getTextConstraint(gui)
	local glowConstraint = getTextConstraint(glow)
	if constraint then
		if not glowConstraint then
			glowConstraint = Instance.new("UITextSizeConstraint")
			glowConstraint.Parent = glow
		end
		glowConstraint.MinTextSize = constraint.MinTextSize
		glowConstraint.MaxTextSize = constraint.MaxTextSize + 2
	elseif glowConstraint then
		glowConstraint:Destroy()
	end
end

local function hasAncestorNamed(instance, name)
	local current = instance.Parent
	while current do
		if current.Name == name then
			return true
		end
		current = current.Parent
	end
	return false
end

local function rememberOriginal(instance, propertyName, value)
	local props = hoverOriginals[instance]
	if not props then
		props = {}
		hoverOriginals[instance] = props
	end
	if props[propertyName] == nil then
		props[propertyName] = value
	end
end

local function tweenColor(instance, propertyName, color)
	TweenService:Create(instance, TweenInfo.new(0.13, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
		[propertyName] = color,
	}):Play()
end

local function shouldTintIconPart(obj)
	if not obj:IsA("GuiObject") then
		return false
	end
	if not hasAncestorNamed(obj, "Icon") then
		return false
	end
	return obj.BackgroundTransparency < 1 and luminance(obj.BackgroundColor3) > 0.48
end

local function applyButtonHover(button, hovering)
	if button:GetAttribute("NoReadableHover") or button:GetAttribute("ForceReadableText") then
		return
	end

	local hoverColor = chooseHoverColor(button)

	local function applyText(obj)
		if obj:GetAttribute("ReadabilityGlow") then
			return
		end
		if obj:IsA("TextLabel") or obj:IsA("TextButton") then
			if obj.Text ~= "" and obj.TextTransparency < 0.6 then
				rememberOriginal(obj, "TextColor3", obj.TextColor3)
				tweenColor(obj, "TextColor3", hovering and hoverColor or hoverOriginals[obj].TextColor3)
			end
		end
	end

	applyText(button)
	for _, obj in ipairs(button:GetDescendants()) do
		applyText(obj)

		if obj:IsA("ImageLabel") or obj:IsA("ImageButton") then
			rememberOriginal(obj, "ImageColor3", obj.ImageColor3)
			tweenColor(obj, "ImageColor3", hovering and hoverColor or hoverOriginals[obj].ImageColor3)
		elseif shouldTintIconPart(obj) then
			rememberOriginal(obj, "BackgroundColor3", obj.BackgroundColor3)
			tweenColor(obj, "BackgroundColor3", hovering and hoverColor or hoverOriginals[obj].BackgroundColor3)
		end
	end
end

local function setupHoverColor(button)
	if not button:IsA("TextButton") or button:GetAttribute("ReadableHoverWatched") then
		return
	end
	if button:GetAttribute("NoReadableHover") or button:GetAttribute("ForceReadableText") then
		return
	end
	button:SetAttribute("ReadableHoverWatched", true)

	button.MouseEnter:Connect(function()
		applyButtonHover(button, true)
	end)

	button.MouseLeave:Connect(function()
		applyButtonHover(button, false)
	end)
end

local function improveText(gui)
	if gui:GetAttribute("ReadabilityGlow") then
		return
	end
	if not (gui:IsA("TextLabel") or gui:IsA("TextButton") or gui:IsA("TextBox")) then
		return
	end

	if gui:IsA("TextButton") then
		setupHoverColor(gui)
	end

	if needsStrongReadableText(gui) then
		applyStrongReadableText(gui)
		return
	end

	local textLum = luminance(gui.TextColor3)
	local strokeLum = luminance(gui.TextStrokeColor3)
	local smallControl = (gui:IsA("TextButton") or gui:IsA("TextBox")) and gui.AbsoluteSize.Y <= 42

	if gui.TextStrokeTransparency < 1 then
		if smallControl and textLum < 0.62 then
			gui.TextStrokeTransparency = 1
		elseif textLum < 0.5 and strokeLum > 0.78 then
			gui.TextStrokeTransparency = 1
		else
			gui.TextStrokeTransparency = math.max(gui.TextStrokeTransparency, 0.35)
		end
	end

	if gui.Font == Enum.Font.LuckiestGuy and gui.TextSize > 0 and gui.TextSize <= 14 then
		gui.Font = Enum.Font.GothamBold
	end

	if gui.TextSize > 0 then
		if gui:IsA("TextButton") or gui:IsA("TextBox") then
			gui.TextSize = math.max(gui.TextSize, 13)
		else
			gui.TextSize = math.max(gui.TextSize, 12)
		end
	end

	if gui.TextScaled then
		local constraint = getTextConstraint(gui)
		if not constraint then
			constraint = Instance.new("UITextSizeConstraint")
			constraint.Parent = gui
		end
		constraint.MinTextSize = math.max(constraint.MinTextSize, 12)
		if constraint.MaxTextSize <= 0 then
			constraint.MaxTextSize = math.max(gui.TextSize, 18)
		end
	end

	ensureTextGlow(gui)

	if not gui:GetAttribute("ReadabilityWatched") then
		gui:SetAttribute("ReadabilityWatched", true)
		gui:GetPropertyChangedSignal("Text"):Connect(function()
			ensureTextGlow(gui)
		end)
		gui:GetPropertyChangedSignal("TextColor3"):Connect(function()
			ensureTextGlow(gui)
		end)
		gui:GetPropertyChangedSignal("TextTransparency"):Connect(function()
			ensureTextGlow(gui)
		end)
		gui:GetPropertyChangedSignal("Visible"):Connect(function()
			ensureTextGlow(gui)
		end)
	end
end

for _, obj in ipairs(playerGui:GetDescendants()) do
	improveText(obj)
end

playerGui.DescendantAdded:Connect(function(obj)
	task.defer(improveText, obj)
end)
]]></string>
          </Properties>
        </Item>
        <Item class="LocalScript" referent="150">
          <Properties>
            <string name="Name">UIController</string>
            <string name="Source"><![CDATA[-- Legacy controller disabled. WindowButtonController.client.luau is the only
-- script that opens/closes MainHUD.ModalWindows.Windows.
if true then
	warn("UIController disabled; WindowButtonController owns editable MainHUD windows.")
	return
end

-- Controls the editor-built UI under PlayerGui.ClientUIRoot.MainHUD.
-- This script intentionally does not create, replace, or style full windows.
local Lighting = game:GetService("Lighting")
local Players = game:GetService("Players")
local UserInputService = game:GetService("UserInputService")

local player = Players.LocalPlayer
local playerGui = player:WaitForChild("PlayerGui")

local WARNED = {}

local WINDOW_NAMES = {
	Inventory = "InventoryWindow",
	Shop = "ShopWindow",
	Worlds = "WorldsWindow",
	DailyQuests = "DailyQuestsWindow",
	Codes = "CodesWindow",
	Upgrades = "UpgradesWindow",
	Settings = "SettingsWindow",
	Trade = "TradeWindow",
}

local WINDOW_BUTTON_NAMES = {
	Settings = "SettingsButton",
	Shop = "ShopButton",
	Upgrades = "UpgradesButton",
	Trade = "TradeButton",
}

local DOCK_TOGGLE_BUTTON_NAME = "InventoryButton"
local DOCK_BUTTON_NAMES = { "ShopButton", "UpgradesButton", "SettingsButton", "TradeButton" }
local LEGACY_GENERATED_LAYER_NAMES = {
	EquipmentShopUI = true,
	GamepassUI = true,
	ShopUI = true,
	WorldUI = true,
	SocialPanelsUI = true,
	CodesUI = true,
	DailyQuestGui = true,
	-- This layer is only meant to appear during the shop fade. If it stays
	-- visible while idle, it sits above the handmade buttons and eats clicks.
	ShopTransitionUI = true,
}
local activeKey = nil
local dockOpen = false
local windows = {}
local buttons = {}
local lastPressAt = {}

local function warnOnce(key, message)
	if WARNED[key] then
		return
	end
	WARNED[key] = true
	warn(message)
end

local function debounce(label)
	local now = os.clock()
	if lastPressAt[label] and now - lastPressAt[label] < 0.12 then
		return false
	end
	lastPressAt[label] = now
	return true
end

local function connectPress(guiObject, callback, label)
	if not guiObject then
		return
	end
	local function run()
		if debounce(label) then
			callback()
		end
	end
	if guiObject:IsA("GuiButton") then
		guiObject.Active = true
		guiObject.Activated:Connect(run)
		guiObject.MouseButton1Click:Connect(run)
	elseif guiObject:IsA("GuiObject") then
		guiObject.Active = true
		guiObject.InputBegan:Connect(function(input)
			if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
				run()
			end
		end)
	else
		warnOnce("not-clickable-" .. tostring(label), "UIController: " .. tostring(label) .. " is not clickable.")
	end
end

local function connectButtonContainer(guiObject, callback, label)
	if not guiObject then
		return
	end

	local connected = false
	if guiObject:IsA("GuiButton") then
		connectPress(guiObject, callback, label)
		connected = true
	end

	for _, descendant in ipairs(guiObject:GetDescendants()) do
		if descendant:IsA("GuiButton") then
			connectPress(descendant, callback, label)
			print("[UIController] wired nested button:", label, descendant:GetFullName())
			connected = true
		end
	end

	if not connected then
		connectPress(guiObject, callback, label)
	end
end

local function getMenuBlur()
	local blur = Lighting:FindFirstChild("MenuBlur")
	if blur and blur:IsA("BlurEffect") then
		return blur
	end
	if blur then
		warnOnce("bad-menublur", "UIController: Lighting.MenuBlur exists but is not a BlurEffect.")
	end
	return nil
end

local dimBackground = nil
local menuBlur = nil
local root = nil
local mainHud = nil

local function findWindowsFolder(mainHudObject)
	local modalWindows = mainHudObject:WaitForChild("ModalWindows", 10)
	if modalWindows then
		local nestedWindows = modalWindows:WaitForChild("Windows", 10)
		if nestedWindows then
			return nestedWindows
		end
		warn("UIController: missing MainHUD.ModalWindows.Windows.")
	end

	local legacyWindows = mainHudObject:FindFirstChild("Windows")
	if legacyWindows then
		warn("UIController: using legacy MainHUD.Windows. Expected MainHUD.ModalWindows.Windows.")
		return legacyWindows
	end

	return nil
end

local function setDockOpen(open)
	dockOpen = open

	if not mainHud then
		warn("[UIController] Missing MainHUD")
		return
	end

	local buttonsRow = mainHud:WaitForChild("ButtonsRow", 10)
	if not buttonsRow then
		warn("[UIController] Missing MainHUD.ButtonsRow")
		return
	end

	for _, buttonName in ipairs(DOCK_BUTTON_NAMES) do
		local button = buttonsRow:FindFirstChild(buttonName)
		if button and button:IsA("GuiObject") then
			button.Visible = open
			button.Active = open
		else
			warn("[UIController] Missing dock button:", buttonName)
		end
	end

	local inventoryButton = buttonsRow:FindFirstChild(DOCK_TOGGLE_BUTTON_NAME)
	if inventoryButton and inventoryButton:IsA("GuiObject") then
		inventoryButton.Visible = true
		inventoryButton.Active = true
	else
		warn("[UIController] Missing " .. DOCK_TOGGLE_BUTTON_NAME)
	end

	print("[UIController] dock visual state:", open)
	for _, child in ipairs(buttonsRow:GetChildren()) do
		if child:IsA("GuiObject") then
			print("[UIController] ButtonsRow child:", child.Name, child.ClassName, "visible=" .. tostring(child.Visible), "position=" .. tostring(child.Position), "size=" .. tostring(child.Size))
		else
			print("[UIController] ButtonsRow child:", child.Name, child.ClassName)
		end
	end
end

local function updateDim()
	local anyOpen = activeKey ~= nil
	if dimBackground and dimBackground:IsA("GuiObject") then
		dimBackground.Visible = anyOpen
	end
	if menuBlur then
		menuBlur.Enabled = anyOpen
	end
end

local function closeAllWindows()
	for _, window in pairs(windows) do
		if window and window:IsA("GuiObject") then
			window.Visible = false
		end
	end
	activeKey = nil
	updateDim()
end

local function hideLegacyGeneratedLayers(root)
	for _, child in ipairs(root:GetChildren()) do
		if LEGACY_GENERATED_LAYER_NAMES[child.Name] and child:IsA("GuiObject") then
			child.Visible = false
		end
	end
end

local function openWindow(key)
	local window = windows[key]
	if not window then
		warnOnce("missing-window-open-" .. key, "UIController: missing window for " .. key .. ". Add it under MainHUD.Windows.")
		return
	end
	closeAllWindows()
	activeKey = key
	window.Visible = true
	updateDim()
	print("[UIController] opened window:", key, window:GetFullName())
end

local function connectCloseButton(key, window)
	local closeButton = window and window:FindFirstChild("CloseButton", true)
	if not closeButton then
		warnOnce("missing-close-" .. key, "UIController: " .. key .. " window is missing CloseButton.")
		return
	end
	connectPress(closeButton, function()
		if activeKey == key then
			closeAllWindows()
		else
			window.Visible = false
		end
		print("[UIController] close clicked:", key)
	end, key .. ".CloseButton")
end

local function wireTabs(window)
	local tabs = window and window:FindFirstChild("Tabs", true)
	if not tabs then
		return
	end

	local contentRoot = window:FindFirstChild("Content", true) or window:FindFirstChild("Pages", true)
	if not contentRoot then
		return
	end

	local pages = {}
	for _, child in ipairs(contentRoot:GetChildren()) do
		if child:IsA("GuiObject") then
			local normalized = child.Name:gsub("Page$", ""):gsub("Frame$", ""):lower()
			pages[normalized] = child
		end
	end

	local function showPage(tabName)
		local normalized = tabName:gsub("Tab$", ""):gsub("Button$", ""):lower()
		for key, page in pairs(pages) do
			page.Visible = key == normalized
		end
		print("[UIController] tab selected:", window.Name, tabName)
	end

	for _, tab in ipairs(tabs:GetDescendants()) do
		if tab:IsA("GuiButton") then
			connectPress(tab, function()
				showPage(tab.Name)
			end, window.Name .. "." .. tab.Name)
		end
	end
end

print("[UIController] loading")

root = playerGui:WaitForChild("ClientUIRoot", 15)
if not root or not root:IsA("ScreenGui") then
	warn("UIController: missing PlayerGui.ClientUIRoot. No windows were controlled.")
	return
end

mainHud = root:WaitForChild("MainHUD", 15)
if not mainHud or not mainHud:IsA("GuiObject") then
	warn("UIController: missing PlayerGui.ClientUIRoot.MainHUD. No windows were controlled.")
	return
end

local windowsFolder = findWindowsFolder(mainHud)
if not windowsFolder then
	warn("UIController: missing PlayerGui.ClientUIRoot.MainHUD.ModalWindows.Windows. Add physical window Frames in Studio.")
	return
end

dimBackground = mainHud:FindFirstChild("DimBackground")
if not dimBackground then
	warnOnce("missing-dim", "UIController: missing MainHUD.DimBackground. Windows will still toggle, but no dim will show.")
elseif not dimBackground:IsA("GuiObject") then
	warnOnce("bad-dim", "UIController: MainHUD.DimBackground is not a GuiObject.")
	dimBackground = nil
end
menuBlur = getMenuBlur()

local mainButtonsRow = mainHud:WaitForChild("ButtonsRow", 10)
if not mainButtonsRow or not mainButtonsRow:IsA("GuiObject") then
	warn("[UIController] Missing MainHUD.ButtonsRow")
	mainButtonsRow = nil
end

for key, windowName in pairs(WINDOW_NAMES) do
	local window = windowsFolder:FindFirstChild(windowName)
	if window and window:IsA("GuiObject") then
		windows[key] = window
		window.Visible = false
		connectCloseButton(key, window)
		wireTabs(window)
	else
		warnOnce("missing-window-" .. key, "UIController: missing MainHUD.Windows." .. windowName)
	end
end

for key, buttonName in pairs(WINDOW_BUTTON_NAMES) do
	local button = mainButtonsRow and mainButtonsRow:FindFirstChild(buttonName)
	if button and button:IsA("GuiObject") then
		buttons[key] = button
		print("[UIController] wired button:", key, button:GetFullName())
	end
end

dockOpen = false
closeAllWindows()
hideLegacyGeneratedLayers(root)
if dimBackground then
	connectPress(dimBackground, function()
		closeAllWindows()
	end, "DimBackground")
end

local inventoryButton = mainButtonsRow and mainButtonsRow:FindFirstChild(DOCK_TOGGLE_BUTTON_NAME)
if inventoryButton and inventoryButton:IsA("GuiObject") then
	connectButtonContainer(inventoryButton, function()
		if activeKey == "Inventory" then
			closeAllWindows()
			setDockOpen(false)
		else
			openWindow("Inventory")
			setDockOpen(true)
		end
	end, DOCK_TOGGLE_BUTTON_NAME)
end

for key, button in pairs(buttons) do
	if button then
		connectButtonContainer(button, function()
			print("[UIController] " .. key .. " clicked")
			openWindow(key)
			setDockOpen(true)
		end, WINDOW_BUTTON_NAMES[key])
	end
end

setDockOpen(false)

root.ChildAdded:Connect(function(child)
	if LEGACY_GENERATED_LAYER_NAMES[child.Name] then
		if child:IsA("GuiObject") then
			child.Visible = false
			warnOnce("hid-generated-" .. child.Name, "UIController: hid legacy generated layer " .. child.Name .. ".")
		end
	end
end)

UserInputService.InputBegan:Connect(function(input)
	if input.UserInputType ~= Enum.UserInputType.MouseButton1 and input.UserInputType ~= Enum.UserInputType.Touch then
		return
	end
	local position = input.UserInputType == Enum.UserInputType.MouseButton1 and UserInputService:GetMouseLocation() or input.Position
	local objects = playerGui:GetGuiObjectsAtPosition(position.X, position.Y)
	print("[UIController] click at", position.X, position.Y, "objects:", #objects)
	for index = 1, math.min(#objects, 8) do
		local object = objects[index]
		print("[UIController] under click", index, object:GetFullName(), object.ClassName, "visible=" .. tostring(object.Visible), "z=" .. tostring(object.ZIndex))
	end
end)

print("[UIController] ready")
]]></string>
          </Properties>
        </Item>
        <Item class="LocalScript" referent="151">
          <Properties>
            <string name="Name">UpgradesUI</string>
            <string name="Source"><![CDATA[-- Upgrades are currently locked while the system is being reworked.
local ReplicatedStorage = game:GetService("ReplicatedStorage")

local UIManager = require(ReplicatedStorage:WaitForChild("UIManager"))

UIManager.register("Upgrades", function() end, function() end, function()
	return false
end)
]]></string>
          </Properties>
        </Item>
        <Item class="LocalScript" referent="152">
          <Properties>
            <string name="Name">WindowButtonController</string>
            <string name="Source"><![CDATA[-- Single controller for the editable Studio UI:
-- PlayerGui.ClientUIRoot.MainHUD.ModalWindows.Windows
local Lighting = game:GetService("Lighting")
local Players = game:GetService("Players")

local player = Players.LocalPlayer
local playerGui = player:WaitForChild("PlayerGui")

local WINDOW_NAMES = {
	Inventory = "InventoryWindow",
	Shop = "ShopWindow",
	Settings = "SettingsWindow",
	Upgrades = "UpgradesWindow",
	Trade = "TradeWindow",
	Worlds = "WorldsWindow",
	DailyQuests = "DailyQuestsWindow",
	Codes = "CodesWindow",
}

local BOTTOM_BUTTONS = {
	Inventory = "InventoryButton",
	Shop = "ShopButton",
	Settings = "SettingsButton",
	Upgrades = "UpgradesButton",
	Trade = "TradeButton",
}

local SIDE_DOCK_BUTTON_NAMES = { "ShopButton", "SettingsButton", "UpgradesButton", "TradeButton" }
local LEFT_BUTTONS = {
	DailyQuests = "DailyQuestsButton",
	Worlds = "WorldsButton",
	Codes = "CodesButton",
}

local LEGACY_GENERATED_LAYER_NAMES = {
	InventoryUI = true,
	EquipmentShopUI = true,
	GamepassUI = true,
	ShopUI = true,
	WorldUI = true,
	SocialPanelsUI = true,
	CodesUI = true,
	DailyQuestGui = true,
}

local root = playerGui:WaitForChild("ClientUIRoot", 15)
if not root then
	warn("WindowButtonController: missing PlayerGui.ClientUIRoot")
	return
end

local mainHud = root:WaitForChild("MainHUD", 15)
if not mainHud then
	warn("WindowButtonController: missing ClientUIRoot.MainHUD")
	return
end

local modalWindows = mainHud:WaitForChild("ModalWindows", 10)
local windowsFolder = modalWindows and modalWindows:WaitForChild("Windows", 10)
if not windowsFolder then
	warn("WindowButtonController: missing MainHUD.ModalWindows.Windows")
	return
end

local bottomHud = mainHud:FindFirstChild("BottomHUD") or mainHud:FindFirstChild("ButtonsRow")
local leftHud = mainHud:FindFirstChild("LeftHUD")
local dimBackground = mainHud:FindFirstChild("DimBackground")
local menuBlur = Lighting:FindFirstChild("MenuBlur")

local DIM_BACKGROUND_ZINDEX = 10
local WINDOW_ZINDEX_FLOOR = 20

local windows = {}
local buttons = {}
local activeKey = nil
local dockOpen = false
local lastPressAt = {}
local warned = {}

local function warnOnce(key, message)
	if warned[key] then
		return
	end
	warned[key] = true
	warn(message)
end

local function debounce(key)
	local now = os.clock()
	if lastPressAt[key] and now - lastPressAt[key] < 0.12 then
		return false
	end
	lastPressAt[key] = now
	return true
end

local function findExactButton(scope, name)
	if not scope then
		return nil
	end
	local direct = scope:FindFirstChild(name)
	if direct and direct:IsA("GuiObject") then
		return direct
	end
	local descendant = scope:FindFirstChild(name, true)
	if descendant and descendant:IsA("GuiObject") then
		return descendant
	end
	return nil
end

local function connectPress(guiObject, callback, key)
	if not guiObject then
		return
	end

	local function run()
		if debounce(key) then
			callback()
		end
	end

	if guiObject:IsA("GuiButton") then
		guiObject.Active = true
		guiObject.Activated:Connect(run)
	else
		guiObject.Active = true
		guiObject.InputBegan:Connect(function(input)
			if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
				run()
			end
		end)
	end
end

local function connectButtonContainer(guiObject, callback, key)
	if not guiObject then
		return
	end

	local connected = false
	if guiObject:IsA("GuiButton") then
		connectPress(guiObject, callback, key)
		connected = true
	end

	for _, descendant in ipairs(guiObject:GetDescendants()) do
		if descendant:IsA("GuiButton") then
			connectPress(descendant, callback, key .. "." .. descendant.Name)
			connected = true
		end
	end

	if not connected then
		connectPress(guiObject, callback, key)
	end
end

local function hideLegacyGeneratedLayers()
	for _, child in ipairs(root:GetChildren()) do
		if LEGACY_GENERATED_LAYER_NAMES[child.Name] and child:IsA("GuiObject") then
			child.Visible = false
		end
	end
end

local function applyGuiZIndexFloor(guiObject, zIndexFloor)
	if guiObject:IsA("GuiObject") and guiObject.ZIndex < zIndexFloor then
		guiObject.ZIndex = zIndexFloor
	end

	for _, descendant in ipairs(guiObject:GetDescendants()) do
		if descendant:IsA("GuiObject") and descendant.ZIndex < zIndexFloor then
			descendant.ZIndex = zIndexFloor
		end
	end
end

local function prepareModalWindow(window)
	window.Active = true
	applyGuiZIndexFloor(window, WINDOW_ZINDEX_FLOOR)
end

local function prepareDimBackground()
	if not (dimBackground and dimBackground:IsA("GuiObject")) then
		return
	end

	dimBackground.ZIndex = DIM_BACKGROUND_ZINDEX
	dimBackground.Active = true
	if dimBackground:IsA("TextButton") or dimBackground:IsA("ImageButton") then
		dimBackground.AutoButtonColor = false
	end
end

local function anyWindowVisible()
	for key, window in pairs(windows) do
		if window.Visible then
			return key
		end
	end
	return nil
end

local function setDockOpen(open)
	dockOpen = open == true

	local inventoryButton = buttons.Inventory
	if inventoryButton then
		inventoryButton.Visible = true
		inventoryButton.Active = true
	end

	for _, buttonName in ipairs(SIDE_DOCK_BUTTON_NAMES) do
		local button = findExactButton(bottomHud, buttonName)
		if button then
			button.Visible = dockOpen
			button.Active = dockOpen
		else
			warnOnce("missing-bottom-" .. buttonName, "WindowButtonController: missing BottomHUD." .. buttonName)
		end
	end
end

local function updateDim()
	local open = activeKey ~= nil
	if dimBackground and dimBackground:IsA("GuiObject") then
		dimBackground.Visible = open
	end
	if menuBlur and menuBlur:IsA("BlurEffect") then
		menuBlur.Enabled = open
	end
end

local function closeAllWindows()
	for _, window in pairs(windows) do
		window.Visible = false
	end
	activeKey = nil
	updateDim()
	setDockOpen(false)
	hideLegacyGeneratedLayers()
end

local function openWindow(key)
	local window = windows[key]
	if not window then
		warnOnce("missing-window-" .. tostring(key), "WindowButtonController: missing window " .. tostring(WINDOW_NAMES[key] or key))
		return
	end

	prepareModalWindow(window)
	for _, other in pairs(windows) do
		other.Visible = false
	end
	window.Visible = true
	activeKey = key
	updateDim()
	hideLegacyGeneratedLayers()

	if BOTTOM_BUTTONS[key] then
		setDockOpen(true)
	end
end

local function openWindowByName(windowName)
	for key, mappedName in pairs(WINDOW_NAMES) do
		if mappedName == windowName or key == windowName then
			openWindow(key)
			return
		end
	end
	warnOnce("unknown-request-" .. tostring(windowName), "WindowButtonController: unknown requested window " .. tostring(windowName))
end

for key, windowName in pairs(WINDOW_NAMES) do
	local window = windowsFolder:FindFirstChild(windowName)
	if window and window:IsA("GuiObject") then
		windows[key] = window
		prepareModalWindow(window)
		window.Visible = false

		local closeButton = window:FindFirstChild("CloseButton", true)
		if closeButton and closeButton:IsA("GuiObject") then
			connectButtonContainer(closeButton, closeAllWindows, key .. ".CloseButton")
		else
			warnOnce("missing-close-" .. key, "WindowButtonController: " .. windowName .. " missing CloseButton")
		end

		window:GetPropertyChangedSignal("Visible"):Connect(function()
			if window.Visible then
				activeKey = key
				updateDim()
				if BOTTOM_BUTTONS[key] then
					setDockOpen(true)
				end
			elseif activeKey == key then
				activeKey = anyWindowVisible()
				updateDim()
				if not activeKey then
					setDockOpen(false)
				end
			end
		end)
	else
		warnOnce("missing-window-" .. key, "WindowButtonController: missing MainHUD.ModalWindows.Windows." .. windowName)
	end
end

for key, buttonName in pairs(BOTTOM_BUTTONS) do
	local button = findExactButton(bottomHud, buttonName)
	if button then
		buttons[key] = button
		connectButtonContainer(button, function()
			openWindow(key)
		end, buttonName)
	else
		warnOnce("missing-bottom-" .. buttonName, "WindowButtonController: missing BottomHUD." .. buttonName)
	end
end

for key, buttonName in pairs(LEFT_BUTTONS) do
	local button = findExactButton(leftHud or mainHud, buttonName)
	if button then
		button.Visible = true
		button.Active = true
		connectButtonContainer(button, function()
			openWindow(key)
		end, buttonName)
	else
		warnOnce("missing-left-" .. buttonName, "WindowButtonController: missing LeftHUD." .. buttonName)
	end
end

prepareDimBackground()
if dimBackground and dimBackground:IsA("GuiObject") then
	connectPress(dimBackground, closeAllWindows, "DimBackground")
end

root:GetAttributeChangedSignal("RequestedWindow"):Connect(function()
	local requested = root:GetAttribute("RequestedWindow")
	if requested and requested ~= "" then
		openWindowByName(requested)
	end
end)

root:GetAttributeChangedSignal("RequestedWindowNonce"):Connect(function()
	local requested = root:GetAttribute("RequestedWindow")
	if requested and requested ~= "" then
		openWindowByName(requested)
	end
end)

root.ChildAdded:Connect(function(child)
	if LEGACY_GENERATED_LAYER_NAMES[child.Name] and child:IsA("GuiObject") then
		child.Visible = false
	end
end)

closeAllWindows()
setDockOpen(false)

print("[WindowButtonController] editable MainHUD windows ready.")
]]></string>
          </Properties>
        </Item>
        <Item class="LocalScript" referent="153">
          <Properties>
            <string name="Name">WorldUI</string>
            <string name="Source"><![CDATA[-- SectorUI.client.luau. Internal registration names stay "World" for compatibility.
if true then
	warn("WorldUI disabled; editable MainHUD.ModalWindows.Windows.WorldsWindow is bound by EditorWindowBinder.")
	return
end

local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local TweenService = game:GetService("TweenService")

local player = Players.LocalPlayer
local ColorData = require(ReplicatedStorage:WaitForChild("ColorData"))
local GameBalance = require(ReplicatedStorage:WaitForChild("GameBalance"))
local UIManager = require(ReplicatedStorage:WaitForChild("UIManager"))
local UITheme = require(ReplicatedStorage:WaitForChild("UITheme"))
local ClientUIRoot = require(ReplicatedStorage:WaitForChild("ClientUIRoot"))

local Events = ReplicatedStorage:WaitForChild("Events")
local unlockEvent = Events:WaitForChild("UnlockArea")
local tutorialActionEvent = Events:WaitForChild("TutorialAction", 10)

local UI_DARK = Color3.fromRGB(35, 38, 45)
local UI_WHITE = Color3.fromRGB(255, 255, 255)
local UI_CYAN = Color3.fromRGB(118, 238, 244)
local UI_GREEN = Color3.fromRGB(116, 245, 42)
local UI_RED = Color3.fromRGB(255, 24, 96)
local UI_YELLOW = Color3.fromRGB(255, 235, 105)
local PANEL_WIDTH = 620
local PANEL_HEIGHT = 470

local unlockedCsv = "Red"
local unlockedSet = { Red = true }
local currentWorldColor = "Red"
local currentCoins = 0
local redTutorialCompleted = false
local rows = {}
local soonRow
local tutorialCompletionConnection
local tutorialStageConnection

local screenGui = ClientUIRoot.GetLayer(player.PlayerGui, "WorldUI")

local overlay = UITheme.CreateDimOverlay(screenGui, 50)

local panel = Instance.new("Frame")
panel.Name = "WorldPanel"
panel.AnchorPoint = Vector2.new(0.5, 0.5)
panel.Size = UDim2.new(0, PANEL_WIDTH, 0, PANEL_HEIGHT)
panel.Position = UDim2.fromScale(0.5, 0.5)
panel.BackgroundColor3 = UI_WHITE
panel.BorderSizePixel = 0
panel.Visible = false
panel.ZIndex = 60
panel.Parent = screenGui
UITheme.ApplyResponsiveScale(panel, PANEL_WIDTH, PANEL_HEIGHT, 0.74, 28)
local corner = Instance.new("UICorner")
corner.CornerRadius = UDim.new(0, 24)
corner.Parent = panel
local stroke = Instance.new("UIStroke")
stroke.Color = UI_DARK
stroke.Thickness = 5
stroke.Parent = panel

local header = Instance.new("Frame")
header.Size = UDim2.new(1, 0, 0, 60)
header.BackgroundColor3 = UI_CYAN
header.BorderSizePixel = 0
header.Parent = panel
local headerCorner = Instance.new("UICorner")
headerCorner.CornerRadius = UDim.new(0, 24)
headerCorner.Parent = header

local title = Instance.new("TextLabel")
title.Size = UDim2.new(1, -70, 1, 0)
title.Position = UDim2.new(0, 20, 0, 0)
title.BackgroundTransparency = 1
title.Font = Enum.Font.LuckiestGuy
title.TextSize = 28
title.TextColor3 = UI_WHITE
title.TextStrokeTransparency = 0
title.TextStrokeColor3 = UI_DARK
title.TextXAlignment = Enum.TextXAlignment.Left
title.Text = "SECTORS"
title.Parent = header

local closeBtn = Instance.new("TextButton")
closeBtn.Size = UDim2.new(0, 42, 0, 42)
closeBtn.Position = UDim2.new(1, -52, 0.5, -21)
closeBtn.BackgroundColor3 = UI_RED
closeBtn.AutoButtonColor = false
closeBtn.Font = Enum.Font.LuckiestGuy
closeBtn.TextSize = 22
closeBtn.TextColor3 = UI_WHITE
closeBtn.TextStrokeTransparency = 0
closeBtn.TextStrokeColor3 = UI_DARK
closeBtn.Text = "X"
closeBtn.Parent = header
local closeCorner = Instance.new("UICorner")
closeCorner.CornerRadius = UDim.new(0, 14)
closeCorner.Parent = closeBtn
local closeStroke = Instance.new("UIStroke")
closeStroke.Color = UI_DARK
closeStroke.Thickness = 4
closeStroke.Parent = closeBtn

local statusLabel = Instance.new("TextLabel")
statusLabel.Size = UDim2.new(1, -30, 0, 42)
statusLabel.Position = UDim2.new(0, 15, 0, 68)
statusLabel.BackgroundTransparency = 1
statusLabel.Font = Enum.Font.GothamBold
statusLabel.TextSize = 13
statusLabel.TextColor3 = Color3.fromRGB(80, 84, 104)
statusLabel.TextXAlignment = Enum.TextXAlignment.Left
statusLabel.TextWrapped = true
statusLabel.Text = "Preview locked Sectors and return to unlocked Sectors."
statusLabel.Parent = panel

local list = Instance.new("ScrollingFrame")
list.Size = UDim2.new(1, -30, 1, -128)
list.Position = UDim2.new(0, 15, 0, 116)
list.BackgroundTransparency = 1
list.BorderSizePixel = 0
list.ScrollBarThickness = 6
list.ScrollBarImageColor3 = UI_DARK
list.CanvasSize = UDim2.new(0, 0, 0, 0)
list.Parent = panel
local layout = Instance.new("UIListLayout")
layout.Padding = UDim.new(0, 10)
layout.SortOrder = Enum.SortOrder.LayoutOrder
layout.Parent = list

local function formatNum(value)
	value = tonumber(value) or 0
	return GameBalance and GameBalance.formatNumber and GameBalance.formatNumber(value) or tostring(value)
end

local function setStatus(text, color)
	statusLabel.Text = text
	statusLabel.TextColor3 = color or Color3.fromRGB(80, 84, 104)
end

local isSectorPlayable

local function getSectorSummary(world)
	local eggName = world.EggIds and world.EggIds[1] and tostring(world.EggIds[1]:gsub("Egg", " Egg")) or "new Egg"
	local brushText = world.BrushIds and #world.BrushIds > 0 and "new brushes" or "new gear"
	if world.primaryColor == "Orange" then
		return "Orange Sector: stronger orange spills, better Coin rewards, " .. eggName .. ", " .. brushText .. ", and the Mutation Core."
	end
	return tostring(world.name or "Sector") .. ": new color spills, better rewards, " .. eggName .. ", and " .. brushText .. "."
end

local function previewSector(world)
	local playable = isSectorPlayable(world.primaryColor)
	local color = playable and Color3.fromRGB(80, 84, 104) or UI_RED
	setStatus(getSectorSummary(world), color)
end

local function applyModalLayer()
	panel.ZIndex = 60
	for _, obj in ipairs(panel:GetDescendants()) do
		if obj:IsA("GuiObject") and obj.ZIndex < 61 then
			obj.ZIndex = 61
		end
	end
	closeBtn.ZIndex = 70
end

local function isUnlocked(colorType)
	local progression = GameBalance.Progression or {}
	local maxPlayableIndex = tonumber(progression.MaxPlayableSectorIndex) or math.huge
	local index = ColorData.getWorldIndex(colorType) or math.huge
	return unlockedSet[colorType] == true and index <= maxPlayableIndex
end

function isSectorPlayable(colorType)
	local progression = GameBalance.Progression or {}
	local maxPlayableIndex = tonumber(progression.MaxPlayableSectorIndex) or math.huge
	local index = ColorData.getWorldIndex(colorType) or math.huge
	return index <= maxPlayableIndex
end

local function isTutorialPreviewStep()
	local folder = player:FindFirstChild("TutorialObjectives")
	local completed = folder and folder:FindFirstChild("TutorialCompleted")
	if completed and completed.Value == true then
		return false
	end
	local stage = folder and folder:FindFirstChild("Stage")
	return stage and stage.Value == "PreviewNextWorld"
end

local function isTutorialLockedGate(colorType)
	return colorType == "Orange" and not redTutorialCompleted
end

local function canTryUnlock(world)
	if world.primaryColor == "Orange" and isTutorialPreviewStep() then
		return true
	end
	local previous = ColorData.getPreviousWorld(world.primaryColor)
	return isSectorPlayable(world.primaryColor)
		and (not previous or isUnlocked(previous.primaryColor))
		and currentCoins >= (tonumber(world.unlockCost) or 0)
end

local function canPreviewLockedWorld(world, visible)
	if not world or isUnlocked(world.primaryColor) or not isSectorPlayable(world.primaryColor) then
		return false
	end
	return visible == true
end

local function getVisibleWorldSet()
	local visible = {}
	local highestUnlockedIndex = 1
	local allPlayableUnlocked = true
	local progression = GameBalance.Progression or {}
	local maxPlayableIndex = tonumber(progression.MaxPlayableSectorIndex) or #ColorData.Worlds

	for index, world in ipairs(ColorData.Worlds) do
		if index > maxPlayableIndex then
			break
		end
		if isUnlocked(world.primaryColor) then
			highestUnlockedIndex = index
		else
			allPlayableUnlocked = false
			break
		end
	end

	local nextIndex = math.min(highestUnlockedIndex + 1, maxPlayableIndex, #ColorData.Worlds)
	for index, world in ipairs(ColorData.Worlds) do
		if index > maxPlayableIndex then
			break
		end
		if index <= highestUnlockedIndex or index == nextIndex then
			visible[world.primaryColor] = true
		end
	end

	return visible, allPlayableUnlocked
end

local function getWorldColor(world)
	local colorInfo = ColorData.Colors[world.primaryColor]
	return colorInfo and colorInfo.color or UI_CYAN
end

local function updateGateSign(sign, world, open)
	for _, surface in ipairs(sign:GetChildren()) do
		if surface:IsA("SurfaceGui") then
			local title = surface:FindFirstChild("Title", true)
			local status = surface:FindFirstChild("Status", true)
			local backing = surface:FindFirstChild("Backing")
			if title and title:IsA("TextLabel") then
				title.Text = world.name
				title.TextColor3 = Color3.fromRGB(242, 248, 255)
			end
			if status and status:IsA("TextLabel") then
				status.Text = open and "Unlocked - Go" or (formatNum(world.unlockCost) .. " Coins")
				status.TextColor3 = open and Color3.fromRGB(145, 245, 170) or Color3.fromRGB(255, 216, 122)
			end
			if backing and backing:IsA("Frame") then
				backing.BackgroundTransparency = open and 0.24 or 0.12
			end
		end
	end
end

local function applyGateVisualState(gate, world, open)
	local worldColor = getWorldColor(world)
	local lockedPanel = worldColor:Lerp(Color3.fromRGB(35, 38, 45), 0.62)
	local openPanel = worldColor:Lerp(Color3.fromRGB(190, 245, 245), 0.2)
	gate.Color = open and openPanel or lockedPanel
	gate.Material = open and Enum.Material.Glass or Enum.Material.SmoothPlastic
	gate.LocalTransparencyModifier = open and 0.58 or 0

	for _, child in ipairs(gate:GetChildren()) do
		if child:IsA("BasePart") and child:GetAttribute("GateDecor") then
			local role = child:GetAttribute("GateVisualRole") or child.Name
			if role == "GateVisualSign" then
				child.Color = Color3.fromRGB(24, 27, 34)
				child.LocalTransparencyModifier = open and 0.12 or 0
				updateGateSign(child, world, open)
			elseif string.find(role, "Glow") then
				child.Color = open and worldColor:Lerp(Color3.fromRGB(255, 255, 255), 0.2) or Color3.fromRGB(255, 96, 116)
				child.LocalTransparencyModifier = open and 0.12 or 0.2
			elseif role == "GateVisualStatusLight" then
				child.Color = open and Color3.fromRGB(125, 255, 150) or Color3.fromRGB(255, 104, 118)
				child.LocalTransparencyModifier = 0
			else
				child.Color = open and Color3.fromRGB(42, 50, 58) or Color3.fromRGB(24, 27, 34)
				child.LocalTransparencyModifier = open and 0.18 or 0
			end
		end
	end
end

local function refreshGates()
	for _, obj in ipairs(workspace:GetDescendants()) do
		if obj:IsA("BasePart") then
			local gateColor = obj:GetAttribute("GateColor") or obj:GetAttribute("UnlockColor")
			if obj:GetAttribute("AreaGate") then
				gateColor = gateColor or obj:GetAttribute("ColorType")
			end

			if gateColor and ColorData.getWorldByColor(gateColor) then
				local world = ColorData.getWorldByColor(gateColor)
				local open = isUnlocked(gateColor)
				local playable = isSectorPlayable(gateColor)
				local tutorialLocked = isTutorialLockedGate(gateColor)
				if obj:GetAttribute("GateInteraction") then
					obj.LocalTransparencyModifier = 1
					obj.CanCollide = false
					local prompt = obj:FindFirstChild("GatePrompt")
					if prompt and prompt:IsA("ProximityPrompt") then
						prompt.Enabled = playable and not tutorialLocked
						prompt.ActionText = open and ("Go to " .. world.name) or ("Unlock " .. world.name)
						prompt.ObjectText = playable and (open and "Unlocked" or (formatNum(world.unlockCost) .. " Coins")) or "Locked for now"
						prompt.MaxActivationDistance = 30
						prompt.HoldDuration = 0.1
						prompt.RequiresLineOfSight = false
					end
				elseif obj:GetAttribute("AreaGate") then
					applyGateVisualState(obj, world, open)
					obj.CanCollide = tutorialLocked or not open or not playable
					local prompt = obj:FindFirstChild("GatePrompt")
					if prompt and prompt:IsA("ProximityPrompt") then
						prompt.Enabled = playable and not tutorialLocked
						prompt.ActionText = open and ("Go to " .. world.name) or ("Unlock " .. world.name)
						prompt.ObjectText = playable and (open and "Unlocked" or (formatNum(world.unlockCost) .. " Coins")) or "Locked for now"
					end

					local billboard = obj:FindFirstChild("GateBillboard")
					if billboard and billboard:IsA("BillboardGui") then
						billboard.Enabled = false
					end
				elseif obj:GetAttribute("GateDecor") then
					obj.LocalTransparencyModifier = open and 0.2 or 0
					obj.CanCollide = false
				else
					obj.LocalTransparencyModifier = open and 0.75 or 0
					obj.CanCollide = not open
				end
			end
		end
	end
end

local function refreshRows()
	unlockedSet = ColorData.getUnlockedColorSet(unlockedCsv)
	local visibleSet, allUnlocked = getVisibleWorldSet()

	for _, row in pairs(rows) do
		local world = row.world
		local visible = visibleSet[world.primaryColor] == true
		row.frame.Visible = visible
		if not visible then
			continue
		end

		local unlocked = isUnlocked(world.primaryColor)
		local tutorialPreview = world.primaryColor == "Orange" and isTutorialPreviewStep()
		local canUnlock = canTryUnlock(world)
		local canPreview = tutorialPreview or (not canUnlock and canPreviewLockedWorld(world, visible))
		local current = unlocked and currentWorldColor == world.primaryColor
		local previous = ColorData.getPreviousWorld(world.primaryColor)
		local playable = isSectorPlayable(world.primaryColor)

		row.frame.BackgroundColor3 = current and Color3.fromRGB(236, 255, 252) or (unlocked and Color3.fromRGB(250, 255, 255) or Color3.fromRGB(244, 246, 252))
		if row.stroke then
			row.stroke.Color = tutorialPreview and UI_YELLOW or (current and UI_GREEN or UI_DARK)
			row.stroke.Thickness = (current or tutorialPreview) and 4 or 3
		end
		if current then
			row.status.Text = "CURRENT SECTOR"
		elseif unlocked then
			row.status.Text = "UNLOCKED"
		elseif tutorialPreview then
			row.status.Text = "Preview next Sector"
		elseif canPreview then
			row.status.Text = "Preview available - requires " .. formatNum(world.unlockCost) .. " Coins"
		elseif not playable then
			row.status.Text = "LOCKED FOR NOW"
		elseif previous and not isUnlocked(previous.primaryColor) then
			row.status.Text = "Requires " .. previous.name
		else
			row.status.Text = "Requires " .. formatNum(world.unlockCost) .. " Coins"
		end
		row.status.TextColor3 = unlocked and Color3.fromRGB(35, 130, 55) or Color3.fromRGB(120, 90, 30)
		row.button.Visible = not unlocked
		row.button.Active = true
		row.button.BackgroundColor3 = tutorialPreview and UI_YELLOW or (canPreview and UI_CYAN or (canUnlock and UI_GREEN or Color3.fromRGB(210, 214, 225)))
		row.button.Text = (tutorialPreview or canPreview) and "PREVIEW" or (canUnlock and "UNLOCK" or "LOCKED")
		row.teleport.Visible = unlocked
		row.teleport.Active = tutorialPreview or unlocked
		row.teleport.BackgroundColor3 = tutorialPreview and UI_YELLOW or (current and UI_GREEN or UI_CYAN)
		row.teleport.Text = tutorialPreview and "PREVIEW" or (current and "HERE" or "GO")
		row.teleport.TextSize = current and 17 or 13
	end

	if soonRow then
		soonRow.Visible = allUnlocked
	end

	list.CanvasSize = UDim2.new(0, 0, 0, layout.AbsoluteContentSize.Y + 12)
	refreshGates()
end

local function buildRows()
	for _, child in ipairs(list:GetChildren()) do
		if not child:IsA("UIListLayout") then
			child:Destroy()
		end
	end
	rows = {}

	for order, world in ipairs(ColorData.Worlds) do
		local row = Instance.new("Frame")
		row.Name = "WorldRow_" .. world.primaryColor
		row.Size = UDim2.new(1, -6, 0, 76)
		row.LayoutOrder = order
		row.BackgroundColor3 = Color3.fromRGB(250, 255, 255)
		row.BorderSizePixel = 0
		row.Active = true
		row.Parent = list
		local rowCorner = Instance.new("UICorner")
		rowCorner.CornerRadius = UDim.new(0, 14)
		rowCorner.Parent = row
		local rowStroke = Instance.new("UIStroke")
		rowStroke.Color = UI_DARK
		rowStroke.Thickness = 3
		rowStroke.Parent = row

		local swatch = Instance.new("Frame")
		swatch.Size = UDim2.new(0, 44, 0, 44)
		swatch.Position = UDim2.new(0, 14, 0.5, -22)
		swatch.BackgroundColor3 = ColorData.Colors[world.primaryColor] and ColorData.Colors[world.primaryColor].color or UI_CYAN
		swatch.BorderSizePixel = 0
		swatch.Parent = row
		local swatchCorner = Instance.new("UICorner")
		swatchCorner.CornerRadius = UDim.new(1, 0)
		swatchCorner.Parent = swatch
		local swatchStroke = Instance.new("UIStroke")
		swatchStroke.Color = UI_DARK
		swatchStroke.Thickness = 3
		swatchStroke.Parent = swatch

		local name = Instance.new("TextLabel")
		name.Size = UDim2.new(1, -230, 0, 30)
		name.Position = UDim2.new(0, 72, 0, 10)
		name.BackgroundTransparency = 1
		name.Font = Enum.Font.LuckiestGuy
		name.TextSize = 19
		name.TextColor3 = UI_DARK
		name.TextXAlignment = Enum.TextXAlignment.Left
		name.Text = world.name
		name.Parent = row

		local status = Instance.new("TextLabel")
		status.Size = UDim2.new(1, -230, 0, 24)
		status.Position = UDim2.new(0, 72, 0, 40)
		status.BackgroundTransparency = 1
		status.Font = Enum.Font.GothamBold
		status.TextSize = 13
		status.TextXAlignment = Enum.TextXAlignment.Left
		status.Text = ""
		status.Parent = row

		local button = Instance.new("TextButton")
		button.Name = "WorldUnlockButton_" .. world.primaryColor
		button.Size = UDim2.new(0, 118, 0, 42)
		button.Position = UDim2.new(1, -132, 0.5, -21)
		button.AutoButtonColor = false
		button.Font = Enum.Font.LuckiestGuy
		button.TextSize = 15
		button.TextColor3 = UI_WHITE
		button.TextStrokeTransparency = 0
		button.TextStrokeColor3 = UI_DARK
		button.Text = "UNLOCK"
		button.Parent = row
		local buttonCorner = Instance.new("UICorner")
		buttonCorner.CornerRadius = UDim.new(0, 12)
		buttonCorner.Parent = button
		local buttonStroke = Instance.new("UIStroke")
		buttonStroke.Color = UI_DARK
		buttonStroke.Thickness = 3
		buttonStroke.Parent = button

		local teleportButton = Instance.new("TextButton")
		teleportButton.Name = "WorldTeleportButton_" .. world.primaryColor
		teleportButton.Size = UDim2.new(0, 118, 0, 42)
		teleportButton.Position = UDim2.new(1, -132, 0.5, -21)
		teleportButton.BackgroundColor3 = UI_CYAN
		teleportButton.AutoButtonColor = false
		teleportButton.Font = Enum.Font.LuckiestGuy
		teleportButton.TextSize = 17
		teleportButton.TextColor3 = UI_WHITE
		teleportButton.TextStrokeTransparency = 0
		teleportButton.TextStrokeColor3 = UI_DARK
		teleportButton.Text = "GO"
		teleportButton.Visible = false
		teleportButton.Parent = row
		local teleportCorner = Instance.new("UICorner")
		teleportCorner.CornerRadius = UDim.new(0, 12)
		teleportCorner.Parent = teleportButton
		local teleportStroke = Instance.new("UIStroke")
		teleportStroke.Color = UI_DARK
		teleportStroke.Thickness = 3
		teleportStroke.Parent = teleportButton

		button.MouseButton1Click:Connect(function()
			previewSector(world)
			if world.primaryColor == "Orange" and isTutorialPreviewStep() then
				setStatus(world.name .. " previewed. Visit the shop next.", Color3.fromRGB(35, 130, 55))
				if tutorialActionEvent and tutorialActionEvent:IsA("RemoteEvent") then
					tutorialActionEvent:FireServer("NextWorldPreviewed")
				end
				return
			end
			if button.Active then
				if not canTryUnlock(world) then
					return
				end
				unlockEvent:FireServer(world.primaryColor)
			end
		end)

		teleportButton.MouseButton1Click:Connect(function()
			previewSector(world)
			if world.primaryColor == "Orange" and isTutorialPreviewStep() then
				setStatus(world.name .. " previewed. Visit the shop next.", Color3.fromRGB(35, 130, 55))
				if tutorialActionEvent and tutorialActionEvent:IsA("RemoteEvent") then
					tutorialActionEvent:FireServer("NextWorldPreviewed")
				end
				return
			end
			if teleportButton.Active and isUnlocked(world.primaryColor) then
				if currentWorldColor == world.primaryColor then
					return
				end
				unlockEvent:FireServer("teleport", world.primaryColor)
			end
		end)

		row.InputBegan:Connect(function(input)
			if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
				previewSector(world)
			end
		end)

		rows[world.primaryColor] = { world = world, frame = row, stroke = rowStroke, status = status, button = button, teleport = teleportButton }
	end

	soonRow = Instance.new("Frame")
	soonRow.Size = UDim2.new(1, -6, 0, 76)
	soonRow.LayoutOrder = #ColorData.Worlds + 1
	soonRow.BackgroundColor3 = Color3.fromRGB(246, 242, 255)
	soonRow.BorderSizePixel = 0
	soonRow.Parent = list
	local soonCorner = Instance.new("UICorner")
	soonCorner.CornerRadius = UDim.new(0, 14)
	soonCorner.Parent = soonRow
	local soonStroke = Instance.new("UIStroke")
	soonStroke.Color = UI_DARK
	soonStroke.Thickness = 3
	soonStroke.Parent = soonRow

	local soonSwatch = Instance.new("Frame")
	soonSwatch.Size = UDim2.new(0, 44, 0, 44)
	soonSwatch.Position = UDim2.new(0, 14, 0.5, -22)
	soonSwatch.BackgroundColor3 = Color3.fromRGB(202, 176, 255)
	soonSwatch.BorderSizePixel = 0
	soonSwatch.Parent = soonRow
	local soonSwatchCorner = Instance.new("UICorner")
	soonSwatchCorner.CornerRadius = UDim.new(1, 0)
	soonSwatchCorner.Parent = soonSwatch
	local soonSwatchStroke = Instance.new("UIStroke")
	soonSwatchStroke.Color = UI_DARK
	soonSwatchStroke.Thickness = 3
	soonSwatchStroke.Parent = soonSwatch

	local soonName = Instance.new("TextLabel")
	soonName.Size = UDim2.new(1, -230, 0, 30)
	soonName.Position = UDim2.new(0, 72, 0, 10)
	soonName.BackgroundTransparency = 1
	soonName.Font = Enum.Font.LuckiestGuy
	soonName.TextSize = 19
	soonName.TextColor3 = UI_DARK
	soonName.TextXAlignment = Enum.TextXAlignment.Left
	soonName.Text = "BETA PATH COMPLETE"
	soonName.Parent = soonRow

	local soonStatus = Instance.new("TextLabel")
	soonStatus.Size = UDim2.new(1, -230, 0, 24)
	soonStatus.Position = UDim2.new(0, 72, 0, 40)
	soonStatus.BackgroundTransparency = 1
	soonStatus.Font = Enum.Font.GothamBold
	soonStatus.TextSize = 13
	soonStatus.TextXAlignment = Enum.TextXAlignment.Left
	soonStatus.TextColor3 = Color3.fromRGB(92, 78, 130)
	soonStatus.Text = "Red and Orange are the current playable Sectors."
	soonStatus.Parent = soonRow

	local soonBadge = Instance.new("TextLabel")
	soonBadge.Size = UDim2.new(0, 118, 0, 42)
	soonBadge.Position = UDim2.new(1, -132, 0.5, -21)
	soonBadge.BackgroundColor3 = Color3.fromRGB(202, 176, 255)
	soonBadge.Font = Enum.Font.LuckiestGuy
	soonBadge.TextSize = 17
	soonBadge.TextColor3 = UI_WHITE
	soonBadge.TextStrokeTransparency = 0
	soonBadge.TextStrokeColor3 = UI_DARK
	soonBadge.Text = "LIVE"
	soonBadge.Parent = soonRow
	local soonBadgeCorner = Instance.new("UICorner")
	soonBadgeCorner.CornerRadius = UDim.new(0, 12)
	soonBadgeCorner.Parent = soonBadge
	local soonBadgeStroke = Instance.new("UIStroke")
	soonBadgeStroke.Color = UI_DARK
	soonBadgeStroke.Thickness = 3
	soonBadgeStroke.Parent = soonBadge

	refreshRows()
end

local isOpen = false
local function toggleWorld(open)
	isOpen = open
	if open then
		if tutorialActionEvent and tutorialActionEvent:IsA("RemoteEvent") then
			tutorialActionEvent:FireServer("WorldMenuOpened")
		end
		overlay.Visible = true
		overlay.BackgroundTransparency = 1
		panel.Visible = true
		panel.Size = UDim2.new(0, 80, 0, 80)
		panel.Position = UDim2.fromScale(0.5, 0.5)
		applyModalLayer()
		TweenService:Create(overlay, TweenInfo.new(0.18), {
			BackgroundTransparency = 0.4,
		}):Play()
		TweenService:Create(panel, TweenInfo.new(0.3, Enum.EasingStyle.Back), {
			Size = UDim2.new(0, PANEL_WIDTH, 0, PANEL_HEIGHT),
			Position = UDim2.fromScale(0.5, 0.5),
		}):Play()
		refreshRows()
	else
		TweenService:Create(overlay, TweenInfo.new(0.18), {
			BackgroundTransparency = 1,
		}):Play()
		TweenService:Create(panel, TweenInfo.new(0.2), {
			Size = UDim2.new(0, 60, 0, 60),
			Position = UDim2.fromScale(0.5, 0.5),
		}):Play()
		task.wait(0.2)
		panel.Visible = false
		overlay.Visible = false
	end
end

unlockEvent.OnClientEvent:Connect(function(kind, arg1, arg2, arg3)
	if kind == "state" then
		unlockedCsv = arg1 or "Red"
		currentWorldColor = arg3 or currentWorldColor
		refreshRows()
	elseif kind == "unlocked" then
		local world = arg2
		if world then
			currentWorldColor = arg1 or currentWorldColor
			setStatus(world.name .. " unlocked!", Color3.fromRGB(35, 130, 55))
		end
		refreshRows()
	elseif kind == "teleported" then
		local world = arg2
		if world then
			currentWorldColor = arg1 or currentWorldColor
			setStatus("Moved to " .. world.name .. ".", Color3.fromRGB(35, 130, 55))
		end
		refreshRows()
	elseif kind == "error" then
		setStatus(tostring(arg2 or "Could not unlock area."), UI_RED)
	end
end)

local storage = player:WaitForChild("ColorStorage", 10)
local unlockedValue = storage and storage:WaitForChild("UnlockedColors", 10)
local currentWorldValue = storage and storage:WaitForChild("CurrentWorld", 10)
local leaderstats = player:WaitForChild("leaderstats", 10)
local coinsValue = leaderstats and leaderstats:WaitForChild("Coins", 10)
if unlockedValue then
	unlockedCsv = unlockedValue.Value
	unlockedValue:GetPropertyChangedSignal("Value"):Connect(function()
		unlockedCsv = unlockedValue.Value
		refreshRows()
	end)
end
if currentWorldValue then
	currentWorldColor = currentWorldValue.Value ~= "" and currentWorldValue.Value or currentWorldColor
	currentWorldValue:GetPropertyChangedSignal("Value"):Connect(function()
		currentWorldColor = currentWorldValue.Value ~= "" and currentWorldValue.Value or "Red"
		refreshRows()
	end)
end
if coinsValue then
	currentCoins = coinsValue.Value
	coinsValue:GetPropertyChangedSignal("Value"):Connect(function()
		currentCoins = coinsValue.Value
		refreshRows()
	end)
end

local function bindTutorialCompletion()
	if tutorialCompletionConnection then
		tutorialCompletionConnection:Disconnect()
		tutorialCompletionConnection = nil
	end
	if tutorialStageConnection then
		tutorialStageConnection:Disconnect()
		tutorialStageConnection = nil
	end

	local folder = player:FindFirstChild("TutorialObjectives")
	local completed = folder and folder:FindFirstChild("TutorialCompleted")
	local stage = folder and folder:FindFirstChild("Stage")
	redTutorialCompleted = completed and completed.Value == true
	if completed then
		tutorialCompletionConnection = completed:GetPropertyChangedSignal("Value"):Connect(function()
			redTutorialCompleted = completed.Value == true
			refreshGates()
			refreshRows()
		end)
	end
	if stage then
		tutorialStageConnection = stage:GetPropertyChangedSignal("Value"):Connect(function()
			refreshGates()
			refreshRows()
		end)
	end

	refreshGates()
	refreshRows()
end

bindTutorialCompletion()
player.ChildAdded:Connect(function(child)
	if child.Name == "TutorialObjectives" then
		task.defer(bindTutorialCompletion)
	end
end)

closeBtn.MouseButton1Click:Connect(function()
	toggleWorld(false)
end)

overlay.MouseButton1Click:Connect(function()
	toggleWorld(false)
end)

workspace.DescendantAdded:Connect(function(obj)
	if obj:IsA("BasePart") then
		task.defer(refreshGates)
	end
end)

buildRows()
refreshRows()

UIManager.register("World", function() toggleWorld(true) end, function() toggleWorld(false) end, function() return isOpen end)

local worldBtn = ReplicatedStorage:WaitForChild("HudButton_WORLD", 10)
if worldBtn then
	worldBtn.Event:Connect(function() UIManager.toggle("World") end)
end
]]></string>
          </Properties>
        </Item>
        <Item class="LocalScript" referent="154">
          <Properties>
            <string name="Name">WorldsWindowBinder</string>
            <string name="Source"><![CDATA[-- Single controller for the editable Sectors/Worlds window.
-- Builds the live Worlds/Zones tab inside the Studio-made WorldsWindow.
local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local TweenService = game:GetService("TweenService")

local player = Players.LocalPlayer
local playerGui = player:WaitForChild("PlayerGui")
local ColorData = require(ReplicatedStorage:WaitForChild("ColorData"))
local GameBalance = require(ReplicatedStorage:WaitForChild("GameBalance"))

local Events = ReplicatedStorage:WaitForChild("Events")
local requestTravel = Events:WaitForChild("RequestTravelToLocation")
local unlockEvent = Events:WaitForChild("UnlockArea")
local travelResult = Events:FindFirstChild("TravelToLocationResult")

local COLORS = {
	Accent = Color3.fromRGB(88, 224, 235),
	Off = Color3.fromRGB(230, 235, 243),
	Text = Color3.fromRGB(31, 34, 45),
	White = Color3.fromRGB(255, 255, 255),
	Green = Color3.fromRGB(72, 210, 102),
	Red = Color3.fromRGB(245, 76, 76),
	Orange = Color3.fromRGB(245, 151, 35),
	Gold = Color3.fromRGB(255, 198, 64),
	Pipes = Color3.fromRGB(34, 140, 160),
	Card = Color3.fromRGB(247, 249, 252),
	Muted = Color3.fromRGB(112, 118, 132),
	Outline = Color3.fromRGB(30, 34, 44),
}

local SECTORS = {
	{
		id = "OriginSector",
		colorType = "Red",
		title = "Origin Sector",
		description = "Free starting sector. Your game spawn is the Origin Spawn.",
		thumbnailText = "ORIGIN",
		color = COLORS.Red,
	},
	{
		id = "OrangeSector",
		colorType = "Orange",
		title = "Orange Sector",
		description = "Unlocks orange spills and the Pipes zone.",
		thumbnailText = "ORANGE",
		color = COLORS.Orange,
		cost = 15000,
	},
}

local ZONES = {
	OriginSector = {
		{
			id = "RedWastelands",
			title = "Red Wastelands",
			description = "Clean spills and earn Coins.",
			color = COLORS.Red,
			alwaysUnlocked = true,
		},
		{
			id = "ZorkShop",
			title = "Zork Shop",
			description = "Visit Zork for shop rewards and upgrades.",
			color = COLORS.Gold,
			alwaysUnlocked = true,
		},
	},
	OrangeSector = {
		{
			id = "InsidePipes",
			title = "The Pipes",
			description = "Reach this zone in Orange Sector first to unlock its teleport.",
			color = COLORS.Pipes,
			requiredColor = "Orange",
		},
	},
}

local root = playerGui:WaitForChild("ClientUIRoot", 20)
local mainHUD = root and root:WaitForChild("MainHUD", 20)
local modal = mainHUD and mainHUD:WaitForChild("ModalWindows", 20)
local windows = modal and modal:WaitForChild("Windows", 20)
local worldsWindow = windows and windows:WaitForChild("WorldsWindow", 20)
if not worldsWindow then
	warn("WorldsWindowBinder: WorldsWindow missing")
	return
end

local currentPage = "Worlds"
local previewIndex = 1
local unlockedCsv = "Red"
local currentWorldColor = "Red"
local unlockedTeleportsCsv = "OriginSector"

local function formatCoins(value)
	return GameBalance.formatNumber(tonumber(value) or 0)
end

local function worldUnlocked(colorType)
	return ColorData.isColorUnlocked(unlockedCsv, colorType)
end

local function teleportUnlocked(locationId)
	if locationId == "OriginSector" then
		return true
	end
	for _, id in ipairs(string.split(unlockedTeleportsCsv or "", ",")) do
		if id == locationId then
			return true
		end
	end
	return false
end

local function find(name)
	return worldsWindow:FindFirstChild(name, true)
end

local function setText(object, text)
	if object and (object:IsA("TextLabel") or object:IsA("TextButton")) then
		object.Text = tostring(text or "")
	end
end

local function applyCorner(object, radius)
	local corner = object:FindFirstChildOfClass("UICorner") or Instance.new("UICorner")
	corner.CornerRadius = UDim.new(0, radius or 12)
	corner.Parent = object
end

local function applyStroke(object, thickness, color)
	local stroke = object:FindFirstChildOfClass("UIStroke") or Instance.new("UIStroke")
	stroke.Thickness = thickness or 2
	stroke.Color = color or COLORS.Outline
	stroke.Parent = object
end

local function make(className, props)
	local object = Instance.new(className)
	for key, value in pairs(props or {}) do
		object[key] = value
	end
	return object
end

local body = worldsWindow:FindFirstChild("Content") or worldsWindow:FindFirstChild("Body")
if not body or not body:IsA("GuiObject") then
	body = make("Frame", {
		Name = "Content",
		BackgroundTransparency = 1,
		Position = UDim2.fromOffset(22, 82),
		Size = UDim2.new(1, -44, 1, -108),
		Parent = worldsWindow,
	})
end

for _, child in ipairs(body:GetChildren()) do
	if child:IsA("GuiObject") then
		child.Visible = false
	end
end

local surface = body:FindFirstChild("WorldsBinderSurface")
if not surface then
	surface = make("Frame", {
		Name = "WorldsBinderSurface",
		BackgroundTransparency = 1,
		Size = UDim2.fromScale(1, 1),
		Parent = body,
	})
else
	surface.Visible = true
end
surface:ClearAllChildren()

local toastLayer = root:FindFirstChild("WorldsToastLayer")
if not toastLayer then
	toastLayer = make("Frame", {
		Name = "WorldsToastLayer",
		BackgroundTransparency = 1,
		Size = UDim2.fromScale(1, 1),
		ZIndex = 250,
		Parent = root,
	})
end

local function showToast(text, color)
	local toast = make("TextLabel", {
		Name = "TeleportToast",
		AnchorPoint = Vector2.new(0.5, 0),
		Position = UDim2.new(0.5, 0, 0, 78),
		Size = UDim2.fromOffset(420, 44),
		BackgroundColor3 = color or COLORS.Green,
		BorderSizePixel = 0,
		Font = Enum.Font.GothamBlack,
		Text = text,
		TextColor3 = COLORS.White,
		TextScaled = true,
		TextStrokeColor3 = COLORS.Outline,
		TextStrokeTransparency = 0,
		ZIndex = 260,
		Parent = toastLayer,
	})
	applyCorner(toast, 12)
	applyStroke(toast, 3, COLORS.Outline)
	toast.BackgroundTransparency = 1
	toast.TextTransparency = 1
	toast.TextStrokeTransparency = 1
	TweenService:Create(toast, TweenInfo.new(0.16), {
		BackgroundTransparency = 0,
		TextTransparency = 0,
		TextStrokeTransparency = 0,
		Position = UDim2.new(0.5, 0, 0, 58),
	}):Play()
	task.delay(2.1, function()
		if toast.Parent then
			TweenService:Create(toast, TweenInfo.new(0.2), {
				BackgroundTransparency = 1,
				TextTransparency = 1,
				TextStrokeTransparency = 1,
				Position = UDim2.new(0.5, 0, 0, 42),
			}):Play()
			task.delay(0.25, function()
				if toast.Parent then
					toast:Destroy()
				end
			end)
		end
	end)
end

local function makeLabel(parent, name, text, pos, size, textSize, color)
	return make("TextLabel", {
		Name = name,
		BackgroundTransparency = 1,
		Position = pos,
		Size = size,
		Font = Enum.Font.GothamBlack,
		Text = text,
		TextColor3 = color or COLORS.Text,
		TextSize = textSize or 18,
		TextWrapped = true,
		TextXAlignment = Enum.TextXAlignment.Left,
		TextYAlignment = Enum.TextYAlignment.Center,
		ZIndex = 80,
		Parent = parent,
	})
end

local pages = make("Frame", {
	Name = "Pages",
	BackgroundTransparency = 1,
	Position = UDim2.fromScale(0, 0.12),
	Size = UDim2.fromScale(1, 0.88),
	Parent = surface,
})

local worldsPage = make("Frame", {
	Name = "WorldsPage",
	BackgroundTransparency = 1,
	Size = UDim2.fromScale(1, 1),
	Parent = pages,
})

local zonesPage = make("Frame", {
	Name = "ZonesPage",
	BackgroundTransparency = 1,
	Size = UDim2.fromScale(1, 1),
	Visible = false,
	Parent = pages,
})

local function getPreviewSector()
	return SECTORS[previewIndex] or SECTORS[1]
end

local function requestSector(sector)
	if sector.id == "OrangeSector" and not worldUnlocked("Orange") then
		unlockEvent:FireServer("unlock", "Orange")
		return
	end
	requestTravel:FireServer(sector.id)
end

local function requestZone(zone)
	if zone.requiredColor and not worldUnlocked(zone.requiredColor) then
		showToast("Unlock " .. tostring(zone.requiredColor) .. " Sector first.", COLORS.Red)
		return
	end
	if not zone.alwaysUnlocked and not teleportUnlocked(zone.id) then
		showToast("Visit " .. zone.title .. " first to unlock its teleport.", COLORS.Orange)
		return
	end
	requestTravel:FireServer(zone.id)
end

local function renderTabs()
	local worldsTab = find("WorldsTab")
	local zonesTab = find("ZonesTab")
	if worldsTab and worldsTab:IsA("GuiObject") then
		worldsTab.BackgroundColor3 = currentPage == "Worlds" and COLORS.Accent or COLORS.Off
	end
	if zonesTab and zonesTab:IsA("GuiObject") then
		zonesTab.BackgroundColor3 = currentPage == "Zones" and COLORS.Accent or COLORS.Off
	end
end

local render

local function drawWorlds()
	worldsPage:ClearAllChildren()
	local sector = getPreviewSector()
	local unlocked = sector.colorType == "Red" or worldUnlocked(sector.colorType)
	local current = currentWorldColor == sector.colorType

	local card = make("Frame", {
		Name = "SectorPreview",
		Position = UDim2.fromScale(0.08, 0.10),
		Size = UDim2.fromScale(0.84, 0.72),
		BackgroundColor3 = sector.color,
		BorderSizePixel = 0,
		Parent = worldsPage,
	})
	applyCorner(card, 8)

	local thumb = make("Frame", {
		Name = "Thumbnail",
		Position = UDim2.fromScale(0.04, 0.16),
		Size = UDim2.fromScale(0.28, 0.56),
		BackgroundColor3 = sector.color:Lerp(Color3.fromRGB(20, 24, 30), 0.12),
		BorderSizePixel = 0,
		Parent = card,
	})
	applyCorner(thumb, 8)
	applyStroke(thumb, 4, sector.colorType == "Orange" and Color3.fromRGB(255, 88, 20) or COLORS.Outline)
	local thumbText = makeLabel(thumb, "ThumbnailText", sector.thumbnailText, UDim2.fromScale(0.08, 0.28), UDim2.fromScale(0.84, 0.26), 22, COLORS.White)
	thumbText.TextXAlignment = Enum.TextXAlignment.Center
	thumbText.TextStrokeColor3 = COLORS.Outline
	thumbText.TextStrokeTransparency = 0

	local titlePrefix = current and "Current Sector" or (unlocked and "Unlocked Sector" or "Next Sector")
	makeLabel(card, "TitlePrefix", titlePrefix, UDim2.fromScale(0.38, 0.15), UDim2.fromScale(0.50, 0.10), 18, COLORS.White)
	local title = makeLabel(card, "Title", sector.title, UDim2.fromScale(0.38, 0.26), UDim2.fromScale(0.52, 0.12), 28, COLORS.White)
	title.TextStrokeColor3 = COLORS.Outline
	title.TextStrokeTransparency = 0
	makeLabel(card, "Description", sector.description, UDim2.fromScale(0.38, 0.40), UDim2.fromScale(0.50, 0.18), 15, COLORS.White)

	local buttonText
	local buttonColor
	if sector.id == "OrangeSector" and not unlocked then
		buttonText = "UNLOCK " .. formatCoins(sector.cost) .. " COINS"
		buttonColor = COLORS.Green
	elseif current then
		buttonText = "HERE"
		buttonColor = COLORS.Green
	else
		buttonText = "GO"
		buttonColor = COLORS.Accent
	end

	local action = make("TextButton", {
		Name = "SectorAction",
		Position = UDim2.fromScale(0.38, 0.64),
		Size = UDim2.fromScale(0.36, 0.13),
		BackgroundColor3 = buttonColor,
		BorderSizePixel = 0,
		AutoButtonColor = true,
		Font = Enum.Font.GothamBlack,
		Text = buttonText,
		TextColor3 = COLORS.White,
		TextScaled = true,
		TextStrokeColor3 = COLORS.Outline,
		TextStrokeTransparency = 0,
		Parent = card,
	})
	applyCorner(action, 12)
	action.MouseButton1Click:Connect(function()
		requestSector(sector)
	end)

	local left = make("TextButton", {
		Name = "PreviousSectorButton",
		Position = UDim2.fromScale(0.01, 0.42),
		Size = UDim2.fromScale(0.055, 0.18),
		BackgroundColor3 = COLORS.Off,
		BorderSizePixel = 0,
		Font = Enum.Font.GothamBlack,
		Text = "<",
		TextColor3 = COLORS.Text,
		TextScaled = true,
		Parent = worldsPage,
	})
	applyCorner(left, 10)
	left.MouseButton1Click:Connect(function()
		previewIndex = previewIndex == 1 and #SECTORS or previewIndex - 1
		render()
	end)

	local right = make("TextButton", {
		Name = "NextSectorButton",
		Position = UDim2.fromScale(0.935, 0.42),
		Size = UDim2.fromScale(0.055, 0.18),
		BackgroundColor3 = COLORS.Accent,
		BorderSizePixel = 0,
		Font = Enum.Font.GothamBlack,
		Text = ">",
		TextColor3 = COLORS.White,
		TextScaled = true,
		Parent = worldsPage,
	})
	applyCorner(right, 10)
	right.MouseButton1Click:Connect(function()
		previewIndex = previewIndex == #SECTORS and 1 or previewIndex + 1
		render()
	end)
end

local function drawZoneCard(parent, zone, index)
	local unlocked = zone.alwaysUnlocked or teleportUnlocked(zone.id)
	local sectorUnlocked = not zone.requiredColor or worldUnlocked(zone.requiredColor)
	local card = make("TextButton", {
		Name = zone.id .. "ZoneCard",
		Position = UDim2.fromScale(0.06 + ((index - 1) % 2) * 0.48, 0.24 + math.floor((index - 1) / 2) * 0.38),
		Size = UDim2.fromScale(0.42, 0.30),
		BackgroundColor3 = sectorUnlocked and COLORS.Card or Color3.fromRGB(225, 229, 238),
		BorderSizePixel = 0,
		Text = "",
		AutoButtonColor = sectorUnlocked,
		Active = sectorUnlocked,
		Parent = parent,
	})
	applyCorner(card, 8)
	applyStroke(card, 2, unlocked and zone.color or Color3.fromRGB(190, 196, 210))

	local swatch = make("Frame", {
		Name = "Swatch",
		Position = UDim2.fromScale(0.05, 0.18),
		Size = UDim2.fromScale(0.22, 0.50),
		BackgroundColor3 = zone.color,
		BorderSizePixel = 0,
		Parent = card,
	})
	applyCorner(swatch, 8)

	makeLabel(card, "Title", zone.title, UDim2.fromScale(0.33, 0.12), UDim2.fromScale(0.58, 0.18), 19, COLORS.Text)
	makeLabel(card, "Description", zone.description, UDim2.fromScale(0.33, 0.33), UDim2.fromScale(0.58, 0.24), 13, COLORS.Muted)

	local statusText = "TELEPORT"
	local statusColor = COLORS.Green
	if not sectorUnlocked then
		statusText = "LOCKED"
		statusColor = COLORS.Red
	elseif not unlocked then
		statusText = "VISIT FIRST"
		statusColor = COLORS.Orange
	end
	local status = make("TextLabel", {
		Name = "StatusPill",
		Position = UDim2.fromScale(0.33, 0.68),
		Size = UDim2.fromScale(0.36, 0.16),
		BackgroundColor3 = statusColor,
		BorderSizePixel = 0,
		Font = Enum.Font.GothamBlack,
		Text = statusText,
		TextColor3 = COLORS.White,
		TextScaled = true,
		TextStrokeColor3 = COLORS.Outline,
		TextStrokeTransparency = 0,
		Parent = card,
	})
	applyCorner(status, 999)

	card.MouseButton1Click:Connect(function()
		requestZone(zone)
	end)
end

local function drawZones()
	zonesPage:ClearAllChildren()
	local sector = getPreviewSector()
	local zones = ZONES[sector.id] or {}
	makeLabel(zonesPage, "ZonesHeader", "Zones in " .. sector.title, UDim2.fromScale(0.05, 0.04), UDim2.fromScale(0.74, 0.10), 24, COLORS.Text)
	local subtitle = sector.id == "OrangeSector" and "The Pipes teleport unlocks after you visit it in the Orange Sector." or "Origin Sector teleports are available from the start."
	makeLabel(zonesPage, "ZonesSubtitle", subtitle, UDim2.fromScale(0.05, 0.13), UDim2.fromScale(0.82, 0.07), 14, COLORS.Muted)
	for index, zone in ipairs(zones) do
		drawZoneCard(zonesPage, zone, index)
	end
end

function render()
	renderTabs()
	worldsPage.Visible = currentPage == "Worlds"
	zonesPage.Visible = currentPage == "Zones"
	if currentPage == "Worlds" then
		drawWorlds()
	else
		drawZones()
	end
end

local worldsTab = find("WorldsTab")
if worldsTab and worldsTab:IsA("GuiButton") then
	worldsTab.MouseButton1Click:Connect(function()
		currentPage = "Worlds"
		render()
	end)
end

local zonesTab = find("ZonesTab")
if zonesTab and zonesTab:IsA("GuiButton") then
	zonesTab.MouseButton1Click:Connect(function()
		currentPage = "Zones"
		render()
	end)
end

local storage = player:WaitForChild("ColorStorage", 10)
local unlockedValue = storage and storage:WaitForChild("UnlockedColors", 10)
local currentWorldValue = storage and storage:WaitForChild("CurrentWorld", 10)
local unlockedTeleportsValue = storage and storage:WaitForChild("UnlockedTeleports", 10)

if unlockedValue then
	unlockedCsv = unlockedValue.Value
	unlockedValue:GetPropertyChangedSignal("Value"):Connect(function()
		unlockedCsv = unlockedValue.Value
		render()
	end)
end
if currentWorldValue then
	currentWorldColor = currentWorldValue.Value ~= "" and currentWorldValue.Value or currentWorldColor
	currentWorldValue:GetPropertyChangedSignal("Value"):Connect(function()
		currentWorldColor = currentWorldValue.Value ~= "" and currentWorldValue.Value or "Red"
		if currentWorldColor == "Orange" then
			previewIndex = 2
		end
		render()
	end)
end
if unlockedTeleportsValue then
	unlockedTeleportsCsv = unlockedTeleportsValue.Value ~= "" and unlockedTeleportsValue.Value or "OriginSector"
	unlockedTeleportsValue:GetPropertyChangedSignal("Value"):Connect(function()
		unlockedTeleportsCsv = unlockedTeleportsValue.Value ~= "" and unlockedTeleportsValue.Value or "OriginSector"
		render()
	end)
end

unlockEvent.OnClientEvent:Connect(function(kind, colorType)
	if colorType == "Orange" and (kind == "unlocked" or kind == "teleported" or kind == "state") then
		previewIndex = 2
	end
	render()
end)

if travelResult then
	travelResult.OnClientEvent:Connect(function(result)
		if type(result) ~= "table" then
			return
		end
		if result.UnlockedTeleports then
			unlockedTeleportsCsv = result.UnlockedTeleports
		end
		if result.UnlockedTeleport then
			showToast("New teleport unlocked: " .. tostring(result.DisplayName or result.LocationId), COLORS.Green)
		elseif result.Success == false and result.Message then
			showToast(tostring(result.Message), COLORS.Red)
		end
		render()
	end)
end

worldsWindow:GetPropertyChangedSignal("Visible"):Connect(function()
	if worldsWindow.Visible then
		render()
	end
end)

if currentWorldColor == "Orange" then
	previewIndex = 2
end
render()
print("WorldsWindowBinder: Worlds/Zones progression UI active")
]]></string>
          </Properties>
        </Item>
      </Item>
    </Item>
  </Item>
</roblox>