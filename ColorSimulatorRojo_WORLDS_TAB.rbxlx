        <Item class="LocalScript" referent="114">
          <Properties>
            <string name="Name">AdminFly</string>
            <string name="Source"><![CDATA[local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")

local player = Players.LocalPlayer
local enabled = false
local speed = 72

local function getCharacterParts()
	local character = player.Character
	if not character then
		return nil, nil
	end

	local humanoid = character:FindFirstChildOfClass("Humanoid")
	local root = character:FindFirstChild("HumanoidRootPart")
	return humanoid, root
end

local function getMoveVector()
	local camera = workspace.CurrentCamera
	if not camera then
		return Vector3.zero
	end

	local move = Vector3.zero
	if UserInputService:IsKeyDown(Enum.KeyCode.W) then
		move += camera.CFrame.LookVector
	end
	if UserInputService:IsKeyDown(Enum.KeyCode.S) then
		move -= camera.CFrame.LookVector
	end
	if UserInputService:IsKeyDown(Enum.KeyCode.D) then
		move += camera.CFrame.RightVector
	end
	if UserInputService:IsKeyDown(Enum.KeyCode.A) then
		move -= camera.CFrame.RightVector
	end
	if UserInputService:IsKeyDown(Enum.KeyCode.Space) then
		move += Vector3.yAxis
	end
	if UserInputService:IsKeyDown(Enum.KeyCode.LeftControl) or UserInputService:IsKeyDown(Enum.KeyCode.LeftShift) then
		move -= Vector3.yAxis
	end

	if move.Magnitude > 0 then
		return move.Unit
	end
	return Vector3.zero
end

local function setEnabled(value)
	enabled = value == true
	local humanoid, root = getCharacterParts()
	if humanoid then
		humanoid.PlatformStand = enabled
	end
	if root and not enabled then
		root.AssemblyLinearVelocity = Vector3.zero
		root.AssemblyAngularVelocity = Vector3.zero
	end
end

player:GetAttributeChangedSignal("AdminFlyEnabled"):Connect(function()
	setEnabled(player:GetAttribute("AdminFlyEnabled") == true)
end)

player.CharacterAdded:Connect(function()
	task.wait(0.25)
	setEnabled(player:GetAttribute("AdminFlyEnabled") == true)
end)

RunService.RenderStepped:Connect(function()
	if not enabled then
		return
	end

	local humanoid, root = getCharacterParts()
	if not humanoid or not root then
		return
	end

	humanoid.PlatformStand = true
	local move = getMoveVector()
	root.AssemblyLinearVelocity = move * speed
	root.AssemblyAngularVelocity = Vector3.zero

	local camera = workspace.CurrentCamera
	if camera then
		local look = camera.CFrame.LookVector
		local flatLook = Vector3.new(look.X, 0, look.Z)
		if flatLook.Magnitude > 0.01 then
			root.CFrame = CFrame.lookAt(root.Position, root.Position + flatLook.Unit)
		end
	end
end)

setEnabled(player:GetAttribute("AdminFlyEnabled") == true)
]]></string>
          </Properties>
        </Item>
        <Item class="LocalScript" referent="115">
          <Properties>
            <string name="Name">BuffToastUI</string>
            <string name="Source"><![CDATA[local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local TweenService = game:GetService("TweenService")
local Debris = game:GetService("Debris")

local player = Players.LocalPlayer
local ClientUIRoot = require(ReplicatedStorage:WaitForChild("ClientUIRoot"))

local events = ReplicatedStorage:WaitForChild("Events")
local noticeEvent = events:WaitForChild("WildBuffNotice")

local layer = ClientUIRoot.GetLayer(player.PlayerGui, "WildBuffToastUI")

local function showToast(message, color)
	message = tostring(message or "")
	color = color or Color3.fromRGB(118, 238, 244)

	local toast = Instance.new("TextLabel")
	toast.Name = "WildBuffToast"
	toast.AnchorPoint = Vector2.new(0.5, 1)
	toast.Size = UDim2.new(0, 360, 0, 50)
	toast.Position = UDim2.new(0.5, 0, 1, -210)
	toast.BackgroundColor3 = Color3.fromRGB(28, 32, 42)
	toast.BackgroundTransparency = 0
	toast.BorderSizePixel = 0
	toast.Font = Enum.Font.LuckiestGuy
	toast.TextSize = 18
	toast.TextScaled = true
	toast.TextWrapped = true
	toast.TextColor3 = Color3.fromRGB(255, 255, 255)
	toast.TextStrokeTransparency = 0.08
	toast.TextStrokeColor3 = Color3.fromRGB(20, 22, 28)
	toast.Text = message
	toast.ZIndex = 120
	toast.Parent = layer
	local textSizeLimit = Instance.new("UITextSizeConstraint")
	textSizeLimit.MinTextSize = 12
	textSizeLimit.MaxTextSize = 18
	textSizeLimit.Parent = toast

	local corner = Instance.new("UICorner")
	corner.CornerRadius = UDim.new(0, 14)
	corner.Parent = toast
	local stroke = Instance.new("UIStroke")
	stroke.Color = color
	stroke.Thickness = 3
	stroke.Transparency = 0.05
	stroke.Parent = toast

	TweenService:Create(toast, TweenInfo.new(0.18, Enum.EasingStyle.Back), {
		Position = UDim2.new(0.5, 0, 1, -232),
	}):Play()
	task.delay(2.1, function()
		if toast.Parent then
			TweenService:Create(toast, TweenInfo.new(0.22), {
				BackgroundTransparency = 1,
				TextTransparency = 1,
				TextStrokeTransparency = 1,
			}):Play()
		end
	end)
	Debris:AddItem(toast, 2.45)
end

noticeEvent.OnClientEvent:Connect(function(payload)
	if type(payload) ~= "table" then
		return
	end

	if payload.type == "buff" then
		showToast(tostring(payload.name or "Wild Color") .. "! " .. tostring(math.floor(payload.duration or 0)) .. "s", payload.color)
	elseif payload.type == "gems" then
		showToast("+" .. tostring(payload.amount or 0) .. " Gems", Color3.fromRGB(90, 255, 120))
	elseif payload.type == "message" then
		showToast(tostring(payload.message or ""), payload.color)
	end
end)
]]></string>
          </Properties>
        </Item>
        <Item class="LocalScript" referent="116">
          <Properties>
            <string name="Name">CodesUI</string>
            <string name="Source"><![CDATA[-- CodesUI.client.luau
if true then
	warn("CodesUI disabled; editable MainHUD.ModalWindows.Windows.CodesWindow is bound by EditorWindowBinder.")
	return
end

local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local TweenService = game:GetService("TweenService")

local player = Players.LocalPlayer
local UIManager = require(ReplicatedStorage:WaitForChild("UIManager"))
local UITheme = require(ReplicatedStorage:WaitForChild("UITheme"))
local ClientUIRoot = require(ReplicatedStorage:WaitForChild("ClientUIRoot"))

local Events = ReplicatedStorage:WaitForChild("Events")
local redeemEvent = Events:WaitForChild("RedeemCode", 10)

local DARK = Color3.fromRGB(35, 38, 45)
local WHITE = Color3.fromRGB(255, 255, 255)
local BLUE = Color3.fromRGB(118, 205, 255)
local GREEN = Color3.fromRGB(116, 220, 125)
local RED = Color3.fromRGB(255, 105, 125)
local PANEL = Color3.fromRGB(255, 248, 252)
local PANEL_WIDTH = 540
local PANEL_HEIGHT = 320

local screenGui = ClientUIRoot.GetLayer(player.PlayerGui, "CodesUI")

local overlay = UITheme.CreateDimOverlay(screenGui, 50)

local panel = Instance.new("Frame")
panel.Name = "CodesPanel"
panel.AnchorPoint = Vector2.new(0.5, 0.5)
panel.Size = UDim2.new(0, PANEL_WIDTH, 0, PANEL_HEIGHT)
panel.Position = UDim2.fromScale(0.5, 0.5)
panel.BackgroundColor3 = PANEL
panel.BorderSizePixel = 0
panel.Visible = false
panel.ZIndex = 60
panel.Parent = screenGui
UITheme.ApplyResponsiveScale(panel, PANEL_WIDTH, PANEL_HEIGHT, 0.74, 28)
local corner = Instance.new("UICorner")
corner.CornerRadius = UDim.new(0, 22)
corner.Parent = panel
local stroke = Instance.new("UIStroke")
stroke.Color = DARK
stroke.Thickness = 5
stroke.Parent = panel

local header = Instance.new("Frame")
header.Size = UDim2.new(1, 0, 0, 62)
header.BackgroundColor3 = BLUE
header.BorderSizePixel = 0
header.Parent = panel
local headerCorner = Instance.new("UICorner")
headerCorner.CornerRadius = UDim.new(0, 22)
headerCorner.Parent = header

local title = Instance.new("TextLabel")
title.Size = UDim2.new(1, -76, 1, 0)
title.Position = UDim2.new(0, 20, 0, 0)
title.BackgroundTransparency = 1
title.Font = Enum.Font.LuckiestGuy
title.TextSize = 30
title.TextColor3 = WHITE
title.TextStrokeTransparency = 0
title.TextStrokeColor3 = DARK
title.TextXAlignment = Enum.TextXAlignment.Left
title.Text = "CODES"
title.Parent = header

local closeBtn = Instance.new("TextButton")
closeBtn.Size = UDim2.new(0, 42, 0, 42)
closeBtn.Position = UDim2.new(1, -54, 0.5, -21)
closeBtn.BackgroundColor3 = RED
closeBtn.Font = Enum.Font.LuckiestGuy
closeBtn.TextSize = 22
closeBtn.TextColor3 = WHITE
closeBtn.TextStrokeTransparency = 0
closeBtn.TextStrokeColor3 = DARK
closeBtn.Text = "X"
closeBtn.Parent = header
local closeCorner = Instance.new("UICorner")
closeCorner.CornerRadius = UDim.new(0, 12)
closeCorner.Parent = closeBtn

local prompt = Instance.new("TextLabel")
prompt.Size = UDim2.new(1, -40, 0, 48)
prompt.Position = UDim2.new(0, 20, 0, 88)
prompt.BackgroundTransparency = 1
prompt.Font = Enum.Font.GothamBold
prompt.TextSize = 16
prompt.TextColor3 = Color3.fromRGB(80, 84, 104)
prompt.TextWrapped = true
prompt.TextXAlignment = Enum.TextXAlignment.Left
prompt.Text = "Redeem update codes for Coins, Color, and starter rewards."
prompt.Parent = panel

local input = Instance.new("TextBox")
input.Size = UDim2.new(1, -180, 0, 54)
input.Position = UDim2.new(0, 20, 0, 150)
input.BackgroundColor3 = WHITE
input.Font = Enum.Font.LuckiestGuy
input.TextSize = 22
input.TextColor3 = DARK
input.PlaceholderText = "ENTER CODE"
input.PlaceholderColor3 = Color3.fromRGB(150, 155, 175)
input.Text = ""
input.ClearTextOnFocus = false
input.Parent = panel
local inputCorner = Instance.new("UICorner")
inputCorner.CornerRadius = UDim.new(0, 14)
inputCorner.Parent = input
local inputStroke = Instance.new("UIStroke")
inputStroke.Color = DARK
inputStroke.Thickness = 3
inputStroke.Parent = input

local redeemBtn = Instance.new("TextButton")
redeemBtn.Size = UDim2.new(0, 130, 0, 54)
redeemBtn.Position = UDim2.new(1, -150, 0, 150)
redeemBtn.BackgroundColor3 = GREEN
redeemBtn.Font = Enum.Font.LuckiestGuy
redeemBtn.TextSize = 20
redeemBtn.TextColor3 = WHITE
redeemBtn.TextStrokeTransparency = 0
redeemBtn.TextStrokeColor3 = DARK
redeemBtn.Text = "REDEEM"
redeemBtn.Parent = panel
local redeemCorner = Instance.new("UICorner")
redeemCorner.CornerRadius = UDim.new(0, 14)
redeemCorner.Parent = redeemBtn
local redeemStroke = Instance.new("UIStroke")
redeemStroke.Color = DARK
redeemStroke.Thickness = 3
redeemStroke.Parent = redeemBtn

local statusLabel = Instance.new("TextLabel")
statusLabel.Size = UDim2.new(1, -40, 0, 46)
statusLabel.Position = UDim2.new(0, 20, 0, 222)
statusLabel.BackgroundTransparency = 1
statusLabel.Font = Enum.Font.GothamBold
statusLabel.TextSize = 15
statusLabel.TextColor3 = Color3.fromRGB(80, 84, 104)
statusLabel.TextWrapped = true
statusLabel.TextXAlignment = Enum.TextXAlignment.Left
statusLabel.Text = "Try RELEASE or COLOR."
statusLabel.Parent = panel

local isOpen = false
local pending = false

local function applyModalLayer()
	panel.ZIndex = 60
	for _, obj in ipairs(panel:GetDescendants()) do
		if obj:IsA("GuiObject") and obj.ZIndex < 61 then
			obj.ZIndex = 61
		end
	end
	closeBtn.ZIndex = 70
end

local function setStatus(text, color)
	statusLabel.Text = text or ""
	statusLabel.TextColor3 = color or Color3.fromRGB(80, 84, 104)
end

local function submitCode()
	if pending then
		return
	end

	local code = input.Text
	if code == "" then
		setStatus("Enter a code first.", RED)
		return
	end

	pending = true
	redeemBtn.Text = "..."
	setStatus("Checking code...")
	if not redeemEvent then
		pending = false
		redeemBtn.Text = "REDEEM"
		setStatus("Codes are still loading. Restart Play after Rojo syncs.", RED)
		return
	end
	redeemEvent:FireServer(code)
end

local function toggleCodes(open)
	isOpen = open
	if open then
		overlay.Visible = true
		overlay.BackgroundTransparency = 1
		panel.Visible = true
		panel.Size = UDim2.new(0, 80, 0, 80)
		panel.Position = UDim2.fromScale(0.5, 0.5)
		applyModalLayer()
		TweenService:Create(overlay, TweenInfo.new(0.18), {
			BackgroundTransparency = 0.4,
		}):Play()
		TweenService:Create(panel, TweenInfo.new(0.25, Enum.EasingStyle.Back), {
			Size = UDim2.new(0, PANEL_WIDTH, 0, PANEL_HEIGHT),
			Position = UDim2.fromScale(0.5, 0.5),
		}):Play()
	else
		TweenService:Create(overlay, TweenInfo.new(0.16), {
			BackgroundTransparency = 1,
		}):Play()
		TweenService:Create(panel, TweenInfo.new(0.16), {
			Size = UDim2.new(0, 0, 0, 0),
			Position = UDim2.fromScale(0.5, 0.5),
		}):Play()
		task.delay(0.16, function()
			if not isOpen then
				panel.Visible = false
				overlay.Visible = false
			end
		end)
	end
end

redeemBtn.MouseButton1Click:Connect(submitCode)
input.FocusLost:Connect(function(enterPressed)
	if enterPressed then
		submitCode()
	end
end)

closeBtn.MouseButton1Click:Connect(function()
	toggleCodes(false)
end)

overlay.MouseButton1Click:Connect(function()
	toggleCodes(false)
end)

if redeemEvent then
	redeemEvent.OnClientEvent:Connect(function(success, message)
		pending = false
		redeemBtn.Text = "REDEEM"
		if success then
			input.Text = ""
			setStatus(tostring(message or "Code redeemed!"), Color3.fromRGB(45, 150, 80))
		else
			setStatus(tostring(message or "Could not redeem code."), RED)
		end
	end)
end

UIManager.register("Codes", function() toggleCodes(true) end, function() toggleCodes(false) end, function() return isOpen end)

local codesBtn = ReplicatedStorage:WaitForChild("HudButton_CODES", 10)
if codesBtn then
	codesBtn.Event:Connect(function()
		UIManager.toggle("Codes")
	end)
end
]]></string>
          </Properties>
        </Item>
        <Item class="LocalScript" referent="117">
          <Properties>
            <string name="Name">ColorEffectClient</string>
            <string name="Source"><![CDATA[local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local TweenService = game:GetService("TweenService")
local Debris = game:GetService("Debris")

local player = Players.LocalPlayer
local Events = ReplicatedStorage:WaitForChild("Events")
local colorEffectVfxEvent = Events:WaitForChild("ColorEffectVFX")

local function getClientSetting(key, defaultValue)
	local value = player:GetAttribute("Setting" .. key)
	return type(value) == "boolean" and value or defaultValue
end

local EFFECT_COLORS = {
	Lightning = Color3.fromRGB(92, 220, 255),
	Magnet = Color3.fromRGB(105, 230, 255),
	Storm = Color3.fromRGB(95, 175, 255),
	Glitched = Color3.fromRGB(180, 90, 255),
	Rainbow = Color3.fromRGB(255, 120, 220),
}

local function getFxColor(payload)
	local mutationId = payload and payload.MutationId
	return EFFECT_COLORS[mutationId] or EFFECT_COLORS[payload and payload.Effect] or EFFECT_COLORS.Lightning
end

local function makeBeamPart(fromPosition, toPosition, color)
	local direction = toPosition - fromPosition
	local distance = direction.Magnitude
	if distance <= 0.1 then
		return
	end

	local part = Instance.new("Part")
	part.Name = "ColorEffectBeam"
	part.Anchored = true
	part.CanCollide = false
	part.CanTouch = false
	part.CanQuery = false
	part.CastShadow = false
	part.Material = Enum.Material.Neon
	part.Color = color
	part.Size = Vector3.new(0.18, 0.18, distance)
	part.CFrame = CFrame.lookAt(fromPosition:Lerp(toPosition, 0.5), toPosition)
	part.Transparency = 0.12
	part.Parent = workspace

	TweenService:Create(part, TweenInfo.new(0.18), {
		Transparency = 1,
		Size = Vector3.new(0.04, 0.04, distance),
	}):Play()
	Debris:AddItem(part, 0.22)
end

local function makeFlash(position, color)
	local flash = Instance.new("Part")
	flash.Name = "ColorEffectFlash"
	flash.Shape = Enum.PartType.Ball
	flash.Anchored = true
	flash.CanCollide = false
	flash.CanTouch = false
	flash.CanQuery = false
	flash.CastShadow = false
	flash.Material = Enum.Material.Neon
	flash.Color = color
	flash.Size = Vector3.new(1.2, 1.2, 1.2)
	flash.CFrame = CFrame.new(position)
	flash.Transparency = 0.2
	flash.Parent = workspace

	TweenService:Create(flash, TweenInfo.new(0.22, Enum.EasingStyle.Quad), {
		Transparency = 1,
		Size = Vector3.new(3.5, 3.5, 3.5),
	}):Play()
	Debris:AddItem(flash, 0.28)
end

local function playLightning(payload)
	local fromPosition = payload.From
	local targets = payload.Targets
	if typeof(fromPosition) ~= "Vector3" or type(targets) ~= "table" then
		return
	end

	local color = getFxColor(payload)
	for _, targetPosition in ipairs(targets) do
		if typeof(targetPosition) == "Vector3" then
			makeBeamPart(fromPosition, targetPosition, color)
			makeFlash(targetPosition, color)
		end
	end
end

local function playMagnet(payload)
	local fromPosition = payload.From
	local targets = payload.Targets
	if typeof(fromPosition) ~= "Vector3" or type(targets) ~= "table" then
		return
	end

	local color = getFxColor(payload)
	for _, targetPosition in ipairs(targets) do
		if typeof(targetPosition) == "Vector3" then
			local orb = Instance.new("Part")
			orb.Name = "ColorMagnetOrb"
			orb.Shape = Enum.PartType.Ball
			orb.Anchored = true
			orb.CanCollide = false
			orb.CanTouch = false
			orb.CanQuery = false
			orb.CastShadow = false
			orb.Material = Enum.Material.Neon
			orb.Color = color
			orb.Size = Vector3.new(0.7, 0.7, 0.7)
			orb.CFrame = CFrame.new(targetPosition)
			orb.Parent = workspace
			TweenService:Create(orb, TweenInfo.new(0.24, Enum.EasingStyle.Quad), {
				CFrame = CFrame.new(fromPosition),
				Transparency = 1,
			}):Play()
			Debris:AddItem(orb, 0.3)
		end
	end
end

colorEffectVfxEvent.OnClientEvent:Connect(function(payload)
	if type(payload) ~= "table" then
		return
	end
	if getClientSetting("LowFX", false) then
		return
	end

	if payload.Effect == "Magnet" then
		playMagnet(payload)
	else
		playLightning(payload)
	end
end)
]]></string>
          </Properties>
        </Item>
        <Item class="LocalScript" referent="118">
          <Properties>
            <string name="Name">CoreGuiPolish</string>
            <string name="Source"><![CDATA[-- Hide old Roblox CoreGui panels that clash with the custom simulator HUD.
local StarterGui = game:GetService("StarterGui")

local function setCoreGuiEnabled(coreGuiType, enabled)
	for _ = 1, 20 do
		local ok = pcall(function()
			StarterGui:SetCoreGuiEnabled(coreGuiType, enabled)
		end)
		if ok then
			return
		end
		task.wait(0.25)
	end
end

task.spawn(function()
	setCoreGuiEnabled(Enum.CoreGuiType.Backpack, false)
	setCoreGuiEnabled(Enum.CoreGuiType.PlayerList, false)
end)
]]></string>
          </Properties>
        </Item>
        <Item class="LocalScript" referent="119">
          <Properties>
            <string name="Name">CoreJuice</string>
            <string name="Source"><![CDATA[-- Client-only feedback layer for the core loop: break Color, hatch, merge, unlock.
local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local SoundService = game:GetService("SoundService")
local TweenService = game:GetService("TweenService")
local UserInputService = game:GetService("UserInputService")
local Debris = game:GetService("Debris")

local player = Players.LocalPlayer
local playerGui = player:WaitForChild("PlayerGui")
local ClientUIRoot = require(ReplicatedStorage:WaitForChild("ClientUIRoot"))

local Events = ReplicatedStorage:WaitForChild("Events")
local collectEvent = Events:WaitForChild("CollectColor")
local petBreakRewardEvent = Events:WaitForChild("PetBreakReward")
local hatchEvent = Events:WaitForChild("HatchEgg")
local mergeEvent = Events:WaitForChild("MergePet")
local unlockEvent = Events:WaitForChild("UnlockArea")
local hatchFocusActive = ReplicatedStorage:FindFirstChild("HatchFocusActive")
if not hatchFocusActive then
	hatchFocusActive = Instance.new("BoolValue")
	hatchFocusActive.Name = "HatchFocusActive"
	hatchFocusActive.Parent = ReplicatedStorage
end

local stats = player:WaitForChild("leaderstats")
local coins = stats:WaitForChild("Coins")

local UI_DARK = Color3.fromRGB(35, 38, 45)
local CYAN = Color3.fromRGB(118, 238, 244)
local YELLOW = Color3.fromRGB(255, 235, 105)
local GREEN = Color3.fromRGB(116, 245, 42)
local PINK = Color3.fromRGB(255, 24, 96)
local PURPLE = Color3.fromRGB(200, 120, 255)
local WHITE = Color3.fromRGB(255, 255, 255)
local ORANGE = Color3.fromRGB(255, 170, 70)

local SOUND_IDS = {
	collect = "rbxasset://sounds/button.wav",
	coins = "rbxasset://sounds/electronicpingshort.wav",
	hatch = "rbxasset://sounds/electronicpingshort.wav",
	merge = "rbxasset://sounds/button.wav",
	unlock = "rbxasset://sounds/electronicpingshort.wav",
}

local juiceGui = ClientUIRoot.GetLayer(playerGui, "CoreJuiceUI")

local function playSound(kind, volume, speed)
	local soundId = SOUND_IDS[kind]
	if not soundId then
		return
	end

	local sound = Instance.new("Sound")
	sound.SoundId = soundId
	sound.Volume = volume or 0.25
	sound.PlaybackSpeed = speed or 1
	sound.Parent = SoundService
	sound:Play()
	Debris:AddItem(sound, 3)
end

local function getHudObject(name)
	local currentRoot = playerGui:FindFirstChild("ColorSimulatorUI")
	if currentRoot then
		local hud = currentRoot:FindFirstChild("HUD")
		if hud then
			local object = hud:FindFirstChild(name, true)
			if object then
				return object
			end
		end

		local legacyLayer = currentRoot:FindFirstChild("HudUI")
		if legacyLayer then
			return legacyLayer:FindFirstChild(name, true)
		end
	end

	local legacyRoot = playerGui:FindFirstChild("HudUI")
	return legacyRoot and legacyRoot:FindFirstChild(name, true) or nil
end

local function pulse(guiObject, peak)
	if not guiObject then
		return
	end

	local scale = guiObject:FindFirstChild("JuiceScale")
	if not scale then
		scale = Instance.new("UIScale")
		scale.Name = "JuiceScale"
		scale.Scale = 1
		scale.Parent = guiObject
	end

	TweenService:Create(scale, TweenInfo.new(0.08, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
		Scale = peak or 1.08,
	}):Play()

	task.delay(0.08, function()
		if scale and scale.Parent then
			TweenService:Create(scale, TweenInfo.new(0.18, Enum.EasingStyle.Back), {
				Scale = 1,
			}):Play()
		end
	end)
end

local function makeFlash(color, transparency)
	local flash = Instance.new("Frame")
	flash.Size = UDim2.new(1, 0, 1, 0)
	flash.BackgroundColor3 = color
	flash.BackgroundTransparency = transparency or 0.55
	flash.BorderSizePixel = 0
	flash.ZIndex = 300
	flash.Parent = juiceGui

	TweenService:Create(flash, TweenInfo.new(0.35, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
		BackgroundTransparency = 1,
	}):Play()

	Debris:AddItem(flash, 0.4)
end

local function burstAt(screenPos, color, count, spread)
	count = count or 12
	spread = spread or 60

	for i = 1, count do
		local dot = Instance.new("Frame")
		local size = math.random(7, 13)
		dot.Size = UDim2.new(0, size, 0, size)
		dot.AnchorPoint = Vector2.new(0.5, 0.5)
		dot.Position = UDim2.new(0, screenPos.X, 0, screenPos.Y)
		dot.BackgroundColor3 = color
		dot.BorderSizePixel = 0
		dot.ZIndex = 250
		dot.Parent = juiceGui
		local corner = Instance.new("UICorner")
		corner.CornerRadius = UDim.new(1, 0)
		corner.Parent = dot
		local stroke = Instance.new("UIStroke")
		stroke.Color = UI_DARK
		stroke.Thickness = 1
		stroke.Transparency = 0.25
		stroke.Parent = dot

		local angle = math.rad((360 / count) * i + math.random(-18, 18))
		local distance = math.random(math.floor(spread * 0.45), spread)
		local target = screenPos + Vector2.new(math.cos(angle) * distance, math.sin(angle) * distance)

		TweenService:Create(dot, TweenInfo.new(0.45, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
			Position = UDim2.new(0, target.X, 0, target.Y),
			BackgroundTransparency = 1,
			Size = UDim2.new(0, 2, 0, 2),
		}):Play()

		task.delay(0.3, function()
			if stroke and stroke.Parent then
				TweenService:Create(stroke, TweenInfo.new(0.15), { Transparency = 1 }):Play()
			end
		end)
		Debris:AddItem(dot, 0.55)
	end
end

local function toast(text, color)
	local label = Instance.new("TextLabel")
	label.AnchorPoint = Vector2.new(0.5, 0.5)
	label.Size = UDim2.new(0, 320, 0, 42)
	label.Position = UDim2.new(0.5, 0, 0.22, 0)
	label.BackgroundTransparency = 1
	label.Font = Enum.Font.LuckiestGuy
	label.TextSize = 24
	label.TextColor3 = color or WHITE
	label.TextStrokeTransparency = 0
	label.TextStrokeColor3 = UI_DARK
	label.Text = text
	label.ZIndex = 260
	label.Parent = juiceGui

	label.TextTransparency = 1
	label.TextStrokeTransparency = 1
	TweenService:Create(label, TweenInfo.new(0.16, Enum.EasingStyle.Back), {
		TextTransparency = 0,
		TextStrokeTransparency = 0,
		Position = UDim2.new(0.5, 0, 0.18, 0),
	}):Play()

	task.delay(1.1, function()
		if label and label.Parent then
			TweenService:Create(label, TweenInfo.new(0.2), {
				TextTransparency = 1,
				TextStrokeTransparency = 1,
				Position = UDim2.new(0.5, 0, 0.14, 0),
			}):Play()
		end
	end)

	Debris:AddItem(label, 1.45)
end

local function ripple(button, color)
	if not button or not button:IsA("GuiButton") then
		return
	end

	local pos = UserInputService:GetMouseLocation()
	local absPos = button.AbsolutePosition
	local localX = pos.X - absPos.X
	local localY = pos.Y - absPos.Y
	local maxSize = math.max(button.AbsoluteSize.X, button.AbsoluteSize.Y) * 1.6

	local circle = Instance.new("Frame")
	circle.AnchorPoint = Vector2.new(0.5, 0.5)
	circle.Size = UDim2.new(0, 0, 0, 0)
	circle.Position = UDim2.new(0, localX, 0, localY)
	circle.BackgroundColor3 = color or WHITE
	circle.BackgroundTransparency = 0.55
	circle.BorderSizePixel = 0
	circle.ZIndex = button.ZIndex + 4
	circle.Active = false
	circle.Parent = button
	local corner = Instance.new("UICorner")
	corner.CornerRadius = UDim.new(1, 0)
	corner.Parent = circle

	TweenService:Create(circle, TweenInfo.new(0.32, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
		Size = UDim2.new(0, maxSize, 0, maxSize),
		BackgroundTransparency = 1,
	}):Play()

	Debris:AddItem(circle, 0.36)
end

local function buttonColor(button)
	if button:IsA("TextButton") or button:IsA("ImageButton") then
		return button.BackgroundColor3
	end
	return CYAN
end

local function enhanceButton(button)
	if not button:IsA("GuiButton") or button:GetAttribute("CoreJuiced") then
		return
	end
	button:SetAttribute("CoreJuiced", true)

	local scale = button:FindFirstChild("ButtonJuiceScale")
	if not scale then
		scale = Instance.new("UIScale")
		scale.Name = "ButtonJuiceScale"
		scale.Scale = 1
		scale.Parent = button
	end

	local function tweenScale(value, duration)
		if scale and scale.Parent then
			TweenService:Create(scale, TweenInfo.new(duration or 0.12, Enum.EasingStyle.Back), { Scale = value }):Play()
		end
	end

	button.MouseEnter:Connect(function()
		tweenScale(1.045, 0.12)
	end)

	button.MouseLeave:Connect(function()
		tweenScale(1, 0.12)
	end)

	button.MouseButton1Down:Connect(function()
		tweenScale(0.94, 0.06)
	end)

	button.MouseButton1Up:Connect(function()
		tweenScale(1.045, 0.1)
		task.delay(0.09, function()
			tweenScale(1, 0.12)
		end)
	end)

	button.Activated:Connect(function()
		local color = buttonColor(button)
		playSound("collect", 0.08, math.random(112, 124) / 100)
		ripple(button, color:Lerp(WHITE, 0.45))
		burstAt(UserInputService:GetMouseLocation(), color:Lerp(WHITE, 0.25), 5, 22)
	end)
end

local function enhancePanel(panel)
	if not panel:IsA("Frame") or panel:GetAttribute("CoreShine") then
		return
	end
	if panel:IsDescendantOf(juiceGui) then
		return
	end
	if not panel:FindFirstChildOfClass("UIStroke") then
		return
	end

	local name = string.lower(panel.Name)
	if not (string.find(name, "panel") or string.find(name, "popup") or string.find(name, "card")) then
		return
	end

	panel:SetAttribute("CoreShine", true)

	local shine = Instance.new("Frame")
	shine.Name = "CoreShineSweep"
	shine.Size = UDim2.new(0, 70, 1, 40)
	shine.Position = UDim2.new(0, -90, 0, -20)
	shine.BackgroundColor3 = WHITE
	shine.BackgroundTransparency = 0.7
	shine.BorderSizePixel = 0
	shine.Rotation = 14
	shine.ZIndex = panel.ZIndex + 2
	shine.Active = false
	shine.Parent = panel
	local gradient = Instance.new("UIGradient")
	gradient.Transparency = NumberSequence.new({
		NumberSequenceKeypoint.new(0, 1),
		NumberSequenceKeypoint.new(0.5, 0.15),
		NumberSequenceKeypoint.new(1, 1),
	})
	gradient.Parent = shine

	task.spawn(function()
		while shine.Parent do
			task.wait(math.random(18, 32) / 10)
			if panel.Visible then
				shine.Position = UDim2.new(0, -90, 0, -20)
				TweenService:Create(shine, TweenInfo.new(0.7, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
					Position = UDim2.new(1, 30, 0, -20),
				}):Play()
			end
		end
	end)
end

local function enhanceExistingGui(root)
	for _, obj in ipairs(root:GetDescendants()) do
		if obj:IsA("GuiButton") then
			enhanceButton(obj)
		elseif obj:IsA("Frame") then
			enhancePanel(obj)
		end
	end
end

task.defer(function()
	enhanceExistingGui(playerGui)
end)

playerGui.DescendantAdded:Connect(function(obj)
	task.defer(function()
		if obj:IsA("GuiButton") then
			enhanceButton(obj)
		elseif obj:IsA("Frame") then
			enhancePanel(obj)
		end
	end)
end)

collectEvent.OnClientEvent:Connect(function(success, amount)
	if not success or not amount or amount <= 0 then
		return
	end

	playSound("collect", 0.18, math.random(96, 110) / 100)
	pulse(getHudObject("CoinsRow") or getHudObject("CoinPill"), 1.04)
	burstAt(UserInputService:GetMouseLocation(), CYAN, 8, 42)
end)

local lastCoins = coins.Value
local lastCoinJuiceAt = 0
local petRewardCoinsToSuppress = 0
local lastPetRewardAt = 0

local function playCoinJuice()
	local now = os.clock()
	if now - lastCoinJuiceAt < 0.45 then
		return
	end
	lastCoinJuiceAt = now

	pulse(getHudObject("CoinsRow") or getHudObject("CoinPill"), 1.08)
end

coins:GetPropertyChangedSignal("Value"):Connect(function()
	local oldCoins = lastCoins
	local gained = coins.Value - oldCoins
	if gained > 0 then
		pulse(getHudObject("CoinsRow") or getHudObject("CoinPill"), 1.05)
		local suppressForPet = false
		if petRewardCoinsToSuppress > 0 and os.clock() - lastPetRewardAt < 2 then
			local consumed = math.min(petRewardCoinsToSuppress, gained)
			petRewardCoinsToSuppress -= consumed
			suppressForPet = consumed > 0
		end
		if not suppressForPet then
			playCoinJuice()
		end
	end
	lastCoins = coins.Value
end)

petBreakRewardEvent.OnClientEvent:Connect(function(payload)
	local amount = 0
	if type(payload) == "table" then
		amount = tonumber(payload.Amount or payload.amount) or 0
	else
		amount = tonumber(payload) or 0
	end
	amount = math.floor(amount)
	if amount <= 0 then
		return
	end

	petRewardCoinsToSuppress += amount
	lastPetRewardAt = os.clock()
	pulse(getHudObject("CoinsRow") or getHudObject("CoinPill"), 1.05)
end)

local hatchToastToken = 0
hatchEvent.OnClientEvent:Connect(function(success, entry)
	if not success or not entry then
		return
	end

	hatchToastToken += 1
	local token = hatchToastToken
	task.delay(2.65, function()
		if token ~= hatchToastToken then
			return
		end

		playSound("hatch", 0.32, entry.rarity == "Legendary" and 0.9 or 1.12)
		local color = entry.rarity == "Legendary" and YELLOW
			or entry.rarity == "Epic" and PURPLE
			or entry.rarity == "Rare" and CYAN
			or WHITE
		makeFlash(color, entry.rarity == "Legendary" and 0.45 or 0.75)
		if hatchFocusActive.Value == true then
			return
		end
		local label = string.upper(entry.displayName or entry.baseName or "COLOR")
		if entry.traitName then
			label ..= " [" .. string.upper(entry.traitName) .. "]"
		elseif entry.trait then
			label ..= " [" .. string.upper(entry.trait.name) .. "]"
		end
		toast("HATCHED " .. label, color)
	end)
end)

mergeEvent.OnClientEvent:Connect(function(success, petId, result)
	if not success then
		return
	end

	playSound("merge", 0.3, 0.82)
	makeFlash(PURPLE, 0.65)
	toast("MERGE UPGRADE", PURPLE)
	burstAt(Vector2.new(workspace.CurrentCamera.ViewportSize.X / 2, workspace.CurrentCamera.ViewportSize.Y * 0.35), PURPLE, 18, 96)
end)

unlockEvent.OnClientEvent:Connect(function(kind, colorType, world)
	if kind ~= "unlocked" then
		return
	end

	playSound("unlock", 0.38, 0.82)
	makeFlash(GREEN, 0.55)
	toast((world and string.upper(world.name) or "SECTOR") .. " UNLOCKED", GREEN)
	burstAt(Vector2.new(workspace.CurrentCamera.ViewportSize.X / 2, workspace.CurrentCamera.ViewportSize.Y * 0.28), GREEN, 24, 130)
end)
]]></string>
          </Properties>
        </Item>
        <Item class="LocalScript" referent="120">
          <Properties>
            <string name="Name">CurrencyHUD</string>
            <string name="Source"><![CDATA[-- Hooks the handmade PlayerGui.ClientUIRoot.MainHUD currency UI.
-- This script does NOT create a duplicate HUD/window. It only binds existing Studio UI
-- and creates tiny temporary gain popups/animations when values increase.
local Players = game:GetService("Players")
local TweenService = game:GetService("TweenService")

local player = Players.LocalPlayer
local playerGui = player:WaitForChild("PlayerGui")

local WARNED = {}

local function warnOnce(key, message)
	if WARNED[key] then
		return
	end
	WARNED[key] = true
	warn(message)
end

local function formatNumber(value)
	value = math.floor(tonumber(value) or 0)
	local sign = value < 0 and "-" or ""
	value = math.abs(value)

	if value < 1000 then
		return sign .. tostring(value)
	end
	if value < 1000000 then
		local text = string.format("%.1f", value / 1000):gsub("%.0$", "")
		return sign .. text .. "K"
	end
	if value < 1000000000 then
		local text = string.format("%.1f", value / 1000000):gsub("%.0$", "")
		return sign .. text .. "M"
	end

	local text = string.format("%.1f", value / 1000000000):gsub("%.0$", "")
	return sign .. text .. "B"
end

local function printChildren(parent, indent)
	indent = indent or ""
	if not parent then
		return
	end

	for _, child in ipairs(parent:GetChildren()) do
		print(indent .. child.Name .. " [" .. child.ClassName .. "]")
	end
end

local function waitForMainHUD()
	local root = playerGui:WaitForChild("ClientUIRoot", 15)
	if not root then
		warnOnce("missing-root", "CurrencyHUD: missing PlayerGui.ClientUIRoot; handmade currency not hooked.")
		return nil
	end

	local mainHud = root:WaitForChild("MainHUD", 15)
	if not mainHud then
		warnOnce("missing-mainhud", "CurrencyHUD: missing PlayerGui.ClientUIRoot.MainHUD; handmade currency not hooked.")
		printChildren(root, "[CurrencyHUD] ClientUIRoot child: ")
		return nil
	end

	return mainHud
end

local function findCurrencyBar(mainHud)
	local leftHud = mainHud:FindFirstChild("LeftHUD")
	local bar = leftHud and leftHud:FindFirstChild("CurrencyBar")
		or mainHud:FindFirstChild("CurrencyBar")
		or mainHud:FindFirstChild("CurrencyBar", true)

	if not bar then
		warnOnce("missing-currencybar", "CurrencyHUD: missing handmade CurrencyBar.")
		printChildren(mainHud, "[CurrencyHUD] MainHUD child: ")
		return nil
	end

	return bar
end

local function setZRecursive(obj, z)
	if obj:IsA("GuiObject") then
		obj.ZIndex = z
	end
	for _, child in ipairs(obj:GetChildren()) do
		setZRecursive(child, z)
	end
end

local function polishCurrencyBar(bar)
	if not bar or not bar:IsA("GuiObject") then
		return
	end

	bar.BackgroundTransparency = 1
	bar.BorderSizePixel = 0
	bar.ClipsDescendants = false
	bar.Visible = true
	bar.ZIndex = math.max(bar.ZIndex, 10)

	-- If the bar is inside LeftHUD, let LeftHUD handle positioning. If it is still
	-- directly under MainHUD, place it cleanly in the lower-left safe zone.
	if bar.Parent and bar.Parent.Name == "LeftHUD" then
		bar.AnchorPoint = Vector2.new(0, 1)
		bar.Position = UDim2.fromScale(0, 1)
		bar.Size = UDim2.fromScale(1, 0.30)
	else
		bar.AnchorPoint = Vector2.new(0, 1)
		bar.Position = UDim2.new(0.035, 0, 0.96, 0)
		bar.Size = UDim2.new(0.16, 0, 0.20, 0)
	end

	local layout = bar:FindFirstChildOfClass("UIListLayout")
	if not layout then
		layout = Instance.new("UIListLayout")
		layout.Parent = bar
	end
	layout.FillDirection = Enum.FillDirection.Vertical
	layout.HorizontalAlignment = Enum.HorizontalAlignment.Left
	layout.VerticalAlignment = Enum.VerticalAlignment.Bottom
	layout.SortOrder = Enum.SortOrder.LayoutOrder
	layout.Padding = UDim.new(0, 10)

	for _, frame in ipairs(bar:GetChildren()) do
		if frame:IsA("GuiObject") and not frame:IsA("UIListLayout") then
			frame.BackgroundTransparency = 1
			frame.BorderSizePixel = 0
			frame.ClipsDescendants = false
			frame.Size = UDim2.new(0, 150, 0, 48)
			frame.ZIndex = bar.ZIndex + 1
			if frame.Name:lower():find("gem") or frame.Name:lower():find("diamond") then
				frame.LayoutOrder = 1
			elseif frame.Name:lower():find("coin") then
				frame.LayoutOrder = 2
			else
				frame.LayoutOrder = 3
			end
		end
	end

	setZRecursive(bar, bar.ZIndex)
end

local function findCurrencyFrame(root, names)
	for _, name in ipairs(names) do
		local frame = root:FindFirstChild(name)
		if frame and frame:IsA("GuiObject") then
			return frame
		end
	end

	for _, descendant in ipairs(root:GetDescendants()) do
		if descendant:IsA("GuiObject") then
			local lowered = descendant.Name:lower()
			for _, name in ipairs(names) do
				if lowered == name:lower() or lowered:find(name:lower(), 1, true) then
					return descendant
				end
			end
		end
	end

	return nil
end

local function findTextLabel(root, frameNames)
	local frame = findCurrencyFrame(root, frameNames)
	if frame then
		local amount = frame:FindFirstChild("Amount", true)
		if amount and amount:IsA("TextLabel") then
			return amount, frame
		end

		for _, descendant in ipairs(frame:GetDescendants()) do
			if descendant:IsA("TextLabel") then
				return descendant, frame
			end
		end
	end

	return nil, frame
end

local function styleAmountLabel(label)
	if not label then
		return
	end

	label.BackgroundTransparency = 1
	label.BorderSizePixel = 0
	label.Font = Enum.Font.GothamBlack
	label.TextColor3 = Color3.fromRGB(255, 255, 255)
	label.TextStrokeColor3 = Color3.fromRGB(0, 0, 0)
	label.TextStrokeTransparency = 0
	label.TextScaled = true
	label.TextXAlignment = Enum.TextXAlignment.Left
	label.TextYAlignment = Enum.TextYAlignment.Center
	label.ZIndex = math.max(label.ZIndex, 12)

	local constraint = label:FindFirstChildOfClass("UITextSizeConstraint") or Instance.new("UITextSizeConstraint")
	constraint.MinTextSize = 12
	constraint.MaxTextSize = 28
	constraint.Parent = label
end

local function styleIcon(frame)
	if not frame then
		return
	end
	local icon = frame:FindFirstChild("Icon", true)
	if icon and icon:IsA("GuiObject") then
		icon.ZIndex = math.max(icon.ZIndex, 12)
		if icon:IsA("ImageLabel") or icon:IsA("ImageButton") then
			icon.BackgroundTransparency = 1
			icon.ScaleType = Enum.ScaleType.Fit
		end
	end
end

local function playGainEffect(label, frame, delta, prefix)
	if not label or not label.Parent or not frame then
		return
	end

	prefix = prefix or "+"
	local originalTextSize = label.TextSize
	local originalRotation = label.Rotation
	local originalColor = label.TextColor3

	local scale = frame:FindFirstChild("CurrencyPopScale")
	if not scale then
		scale = Instance.new("UIScale")
		scale.Name = "CurrencyPopScale"
		scale.Scale = 1
		scale.Parent = frame
	end

	TweenService:Create(scale, TweenInfo.new(0.10, Enum.EasingStyle.Back, Enum.EasingDirection.Out), { Scale = 1.16 }):Play()
	task.delay(0.10, function()
		if scale.Parent then
			TweenService:Create(scale, TweenInfo.new(0.18, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), { Scale = 1 }):Play()
		end
	end)

	label.TextColor3 = Color3.fromRGB(255, 245, 160)
	task.delay(0.18, function()
		if label.Parent then
			label.TextColor3 = originalColor
			label.TextSize = originalTextSize
			label.Rotation = originalRotation
		end
	end)

	local popup = Instance.new("TextLabel")
	popup.Name = "CurrencyGainPopup"
	popup.BackgroundTransparency = 1
	popup.AnchorPoint = Vector2.new(0, 0.5)
	popup.Position = UDim2.new(1, 6, 0.5, 0)
	popup.Size = UDim2.fromOffset(120, 34)
	popup.Font = Enum.Font.GothamBlack
	popup.Text = prefix .. formatNumber(delta)
	popup.TextColor3 = Color3.fromRGB(255, 255, 255)
	popup.TextStrokeColor3 = Color3.fromRGB(0, 0, 0)
	popup.TextStrokeTransparency = 0
	popup.TextScaled = true
	popup.TextXAlignment = Enum.TextXAlignment.Left
	popup.ZIndex = (frame.ZIndex or 10) + 12
	popup.Parent = frame

	local popupConstraint = Instance.new("UITextSizeConstraint")
	popupConstraint.MinTextSize = 12
	popupConstraint.MaxTextSize = 24
	popupConstraint.Parent = popup

	TweenService:Create(popup, TweenInfo.new(0.55, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
		Position = UDim2.new(1, 18, 0.5, -30),
		TextTransparency = 1,
		TextStrokeTransparency = 1,
	}):Play()

	task.delay(0.65, function()
		if popup.Parent then
			popup:Destroy()
		end
	end)
end

local function connectValue(valueObject, label, frame, missingText, prefix)
	if not label then
		return
	end
	if not valueObject then
		label.Text = missingText or "0"
		return
	end

	local lastValue = tonumber(valueObject.Value) or 0
	local initialized = false

	local function update()
		local newValue = tonumber(valueObject.Value) or 0
		label.Text = formatNumber(newValue)
		if initialized and newValue > lastValue then
			playGainEffect(label, frame, newValue - lastValue, prefix)
		end
		lastValue = newValue
		initialized = true
	end

	update()
	valueObject:GetPropertyChangedSignal("Value"):Connect(update)
end

local mainHud = waitForMainHUD()
if not mainHud then
	return
end

local currencyBar = findCurrencyBar(mainHud)
if not currencyBar then
	return
end

polishCurrencyBar(currencyBar)

local coinsAmount, coinsFrame = findTextLabel(currencyBar, { "CoinsFrame", "CoinFrame", "Coins", "Coin" })
local gemsAmount, gemsFrame = findTextLabel(currencyBar, { "GemsFrame", "GemFrame", "DiamondsFrame", "DiamondFrame", "Gems", "Diamonds" })
local colorAmount, colorFrame = findTextLabel(currencyBar, { "ColorFrame", "ColorsFrame", "PaintFrame", "Color" })

styleAmountLabel(coinsAmount)
styleAmountLabel(gemsAmount)
styleAmountLabel(colorAmount)
styleIcon(coinsFrame)
styleIcon(gemsFrame)
styleIcon(colorFrame)

if not coinsAmount then
	warnOnce("missing-coins-label", "CurrencyHUD: could not find CoinsFrame.Amount TextLabel.")
end
if not gemsAmount then
	warnOnce("missing-gems-label", "CurrencyHUD: could not find Gems/Diamonds Amount TextLabel.")
end

local leaderstats = player:WaitForChild("leaderstats", 20)
if not leaderstats then
	warnOnce("missing-leaderstats", "CurrencyHUD: leaderstats did not load.")
	return
end

local coins = leaderstats:FindFirstChild("Coins") or leaderstats:WaitForChild("Coins", 10)
local gems = leaderstats:FindFirstChild("Gems") or leaderstats:FindFirstChild("Diamonds")
if not gems then
	gems = leaderstats:WaitForChild("Gems", 10) or leaderstats:WaitForChild("Diamonds", 2)
end

local colorValue = leaderstats:FindFirstChild("Color") or leaderstats:FindFirstChild("Colors") or leaderstats:FindFirstChild("Paint")

connectValue(coins, coinsAmount, coinsFrame, "0", "+")
connectValue(gems, gemsAmount, gemsFrame, "0", "+")
connectValue(colorValue, colorAmount, colorFrame, "0", "+")

if not coins then
	warnOnce("missing-coins", "CurrencyHUD: leaderstats.Coins is missing.")
end
if not gems then
	warnOnce("missing-gems", "CurrencyHUD: leaderstats.Gems/Diamonds is missing.")
end

print("CurrencyHUD: hooked and polished handmade currency UI with gain effects.")
]]></string>
          </Properties>
        </Item>
        <Item class="LocalScript" referent="121">
          <Properties>
            <string name="Name">DailyQuestClient</string>
            <string name="Source"><![CDATA[-- StarterPlayerScripts/Client/DailyQuestClient
local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")

local player = Players.LocalPlayer
local remote = ReplicatedStorage:WaitForChild("DailyQuestRemote")
local UIManager = require(ReplicatedStorage:WaitForChild("UIManager"))

local COLORS = {
	Outline = Color3.fromRGB(35, 38, 45),
	Text = Color3.fromRGB(31, 34, 45),
	Muted = Color3.fromRGB(112, 118, 132),
	Green = Color3.fromRGB(84, 225, 112),
	Cyan = Color3.fromRGB(88, 224, 235),
	Disabled = Color3.fromRGB(174, 181, 198),
}

local questData = nil
local questRows = {}

local FALLBACK_QUESTS = {
	{
		id = "CleanColorSpills",
		title = "CLEAN COLOR SPILLS",
		description = "Clean 40 color spills.",
		iconText = "BRUSH",
		progress = 0,
		target = 40,
		rewardCurrency = "Gems",
		rewardAmount = 20,
		reward = 20,
		claimed = false,
	},
	{
		id = "EarnCoins",
		title = "EARN COINS",
		description = "Earn 1,000 coins.",
		iconText = "COINS",
		progress = 0,
		target = 1000,
		rewardCurrency = "Gems",
		rewardAmount = 25,
		reward = 25,
		claimed = false,
	},
	{
		id = "HatchColors",
		title = "HATCH COLORS",
		description = "Hatch 3 colors from eggs.",
		iconText = "EGG",
		progress = 0,
		target = 3,
		rewardCurrency = "Gems",
		rewardAmount = 30,
		reward = 30,
		claimed = false,
	},
}

local function getMainHUD()
	local root = player:WaitForChild("PlayerGui"):WaitForChild("ClientUIRoot", 30)
	if not root then
		return nil
	end
	return root:WaitForChild("MainHUD", 30)
end

local function getWindows(mainHUD)
	local modalWindows = mainHUD and mainHUD:FindFirstChild("ModalWindows")
	if modalWindows and modalWindows:FindFirstChild("Windows") then
		return modalWindows.Windows
	end
	return mainHUD and mainHUD:FindFirstChild("Windows")
end

local function findDeep(parent, name)
	return parent and parent:FindFirstChild(name, true)
end

local function setText(obj, value)
	if obj and (obj:IsA("TextLabel") or obj:IsA("TextButton") or obj:IsA("TextBox")) then
		obj.Text = tostring(value or "")
	end
end

local function formatTime(seconds)
	seconds = math.max(0, tonumber(seconds) or 0)
	local hours = math.floor(seconds / 3600)
	local minutes = math.floor((seconds % 3600) / 60)
	return string.format("%02dh %02dm", hours, minutes)
end

local function copyQuest(quest)
	local copy = {}
	for key, value in pairs(quest) do
		copy[key] = value
	end
	return copy
end

local function getQuestList(data)
	local source = type(data) == "table" and (data.Quests or data.quests) or nil
	local quests = {}
	if type(source) == "table" then
		for index = 1, 3 do
			if type(source[index]) == "table" then
				quests[index] = source[index]
			end
		end
	end
	for index = 1, 3 do
		if type(quests[index]) ~= "table" then
			quests[index] = copyQuest(FALLBACK_QUESTS[index])
		end
	end
	return quests
end

local function corner(obj, radius)
	local c = obj:FindFirstChildOfClass("UICorner") or Instance.new("UICorner")
	c.CornerRadius = UDim.new(0, radius or 16)
	c.Parent = obj
	return c
end

local function stroke(obj, thickness, color)
	local s = obj:FindFirstChildOfClass("UIStroke") or Instance.new("UIStroke")
	s.Thickness = thickness or 2
	s.Color = color or COLORS.Outline
	s.Parent = obj
	return s
end

local function makeQuestRow(parent, index)
	local row = Instance.new("Frame")
	row.Name = "QuestRow" .. index
	row.Size = UDim2.new(1, -24, 0, 94)
	row.Position = UDim2.new(0, 12, 0, 12 + ((index - 1) * 106))
	row.BackgroundColor3 = Color3.fromRGB(247, 250, 254)
	row.BorderSizePixel = 0
	row.Parent = parent
	corner(row, 18)
	stroke(row, 2)

	local icon = Instance.new("TextLabel")
	icon.Name = "IconText"
	icon.Position = UDim2.fromScale(0.02, 0.14)
	icon.Size = UDim2.fromScale(0.14, 0.72)
	icon.BackgroundColor3 = Color3.fromRGB(236, 240, 246)
	icon.BorderSizePixel = 0
	icon.Font = Enum.Font.GothamBlack
	icon.TextSize = 15
	icon.TextWrapped = true
	icon.TextColor3 = COLORS.Text
	icon.Parent = row
	corner(icon, 16)

	local title = Instance.new("TextLabel")
	title.Name = "QuestTitle"
	title.Position = UDim2.fromScale(0.19, 0.08)
	title.Size = UDim2.fromScale(0.42, 0.23)
	title.BackgroundTransparency = 1
	title.Font = Enum.Font.GothamBlack
	title.TextSize = 18
	title.TextColor3 = COLORS.Text
	title.TextXAlignment = Enum.TextXAlignment.Left
	title.TextWrapped = true
	title.Parent = row

	local desc = Instance.new("TextLabel")
	desc.Name = "QuestDesc"
	desc.Position = UDim2.fromScale(0.19, 0.31)
	desc.Size = UDim2.fromScale(0.43, 0.18)
	desc.BackgroundTransparency = 1
	desc.Font = Enum.Font.GothamMedium
	desc.TextSize = 13
	desc.TextColor3 = COLORS.Muted
	desc.TextXAlignment = Enum.TextXAlignment.Left
	desc.TextWrapped = true
	desc.Parent = row

	local bar = Instance.new("Frame")
	bar.Name = "ProgressBarBg"
	bar.Position = UDim2.fromScale(0.19, 0.61)
	bar.Size = UDim2.fromScale(0.42, 0.18)
	bar.BackgroundColor3 = Color3.fromRGB(231, 235, 241)
	bar.BorderSizePixel = 0
	bar.Parent = row
	corner(bar, 14)
	stroke(bar, 2, Color3.fromRGB(190, 196, 208))

	local fill = Instance.new("Frame")
	fill.Name = "ProgressFill"
	fill.Size = UDim2.fromScale(0, 1)
	fill.BackgroundColor3 = COLORS.Cyan
	fill.BorderSizePixel = 0
	fill.Parent = bar
	corner(fill, 14)

	local progressText = Instance.new("TextLabel")
	progressText.Name = "ProgressText"
	progressText.Size = UDim2.fromScale(1, 1)
	progressText.BackgroundTransparency = 1
	progressText.Font = Enum.Font.GothamBlack
	progressText.TextSize = 13
	progressText.TextColor3 = COLORS.Text
	progressText.Parent = bar

	local reward = Instance.new("TextLabel")
	reward.Name = "RewardText"
	reward.Position = UDim2.fromScale(0.64, 0.20)
	reward.Size = UDim2.fromScale(0.13, 0.58)
	reward.BackgroundColor3 = Color3.fromRGB(236, 240, 246)
	reward.BorderSizePixel = 0
	reward.Font = Enum.Font.GothamBlack
	reward.TextSize = 12
	reward.TextWrapped = true
	reward.TextColor3 = COLORS.Text
	reward.Parent = row
	corner(reward, 16)

	local claim = Instance.new("TextButton")
	claim.Name = "ClaimButton"
	claim.Position = UDim2.fromScale(0.80, 0.28)
	claim.Size = UDim2.fromScale(0.17, 0.38)
	claim.BackgroundColor3 = COLORS.Disabled
	claim.BorderSizePixel = 0
	claim.Font = Enum.Font.GothamBlack
	claim.TextSize = 14
	claim.TextColor3 = Color3.fromRGB(255, 255, 255)
	claim.TextStrokeTransparency = 0
	claim.TextStrokeColor3 = COLORS.Outline
	claim.Parent = row
	corner(claim, 16)
	stroke(claim, 2)

	return row
end

local function getQuestContent(window)
	return findDeep(window, "QuestList") or findDeep(window, "Body") or findDeep(window, "Content") or window
end

local function ensureRows(window)
	local content = getQuestContent(window)
	if not content then return end
	for _, child in ipairs(content:GetChildren()) do
		if child:GetAttribute("EditableQuestGenerated") == true then
			child:Destroy()
		end
	end
	questRows = {}
	for i = 1, 3 do
		local row = findDeep(content, "QuestRow" .. i) or makeQuestRow(content, i)
		row:SetAttribute("EditableQuestGenerated", true)
		questRows[i] = row
	end
end

local function updateRow(row, quest, index)
	local progress = tonumber(quest.progress) or 0
	local target = math.max(1, tonumber(quest.target) or 1)
	local complete = progress >= target
	local claimed = quest.claimed == true
	local rewardAmount = tonumber(quest.rewardAmount or quest.reward) or 0
	local rewardCurrency = tostring(quest.rewardCurrency or "Gems")

	setText(findDeep(row, "IconText"), tostring(quest.iconText or (index == 1 and "BRUSH" or index == 2 and "COINS" or "EGG")))
	setText(findDeep(row, "QuestTitle"), tostring(quest.title or "Daily Quest"))
	setText(findDeep(row, "QuestDesc"), tostring(quest.description or ""))
	setText(findDeep(row, "ProgressText"), tostring(progress) .. " / " .. tostring(target))
	setText(findDeep(row, "RewardText"), "REWARD\n+" .. tostring(rewardAmount) .. " " .. rewardCurrency)

	local fill = findDeep(row, "ProgressFill")
	if fill and fill:IsA("GuiObject") then
		fill.Size = UDim2.fromScale(math.clamp(progress / target, 0, 1), 1)
	end

	local claim = findDeep(row, "ClaimButton")
	if not claim or not claim:IsA("TextButton") then
		return
	end

	claim:SetAttribute("QuestIndex", index)
	claim:SetAttribute("Claimable", false)
	claim:SetAttribute("Claiming", false)

	if claimed then
		claim.Text = "CLAIMED"
		claim.BackgroundColor3 = COLORS.Disabled
		claim.Active = false
		claim.AutoButtonColor = false

	elseif complete then
		claim.Text = "CLAIM"
		claim.BackgroundColor3 = COLORS.Cyan
		claim.Active = true
		claim.AutoButtonColor = true
		claim:SetAttribute("Claimable", true)

	else
		claim.Text = "IN PROGRESS"
		claim.BackgroundColor3 = COLORS.Disabled
		claim.Active = false
		claim.AutoButtonColor = false
	end

	if not claim:GetAttribute("ClaimHooked") then
		claim:SetAttribute("ClaimHooked", true)

		claim.MouseButton1Click:Connect(function()
			if not claim:GetAttribute("Claimable") then
				return
			end

			if claim:GetAttribute("Claiming") then
				return
			end

			local questIndex = claim:GetAttribute("QuestIndex")
			if not questIndex then
				return
			end

			claim:SetAttribute("Claiming", true)
			claim.Active = false
			claim.AutoButtonColor = false
			claim.Text = "..."

			remote:FireServer("Claim", questIndex)
		end)
	end
end

local function render(window, data)
	if not window then return end
	data = type(data) == "table" and data or {}
	questData = data

	local content = getQuestContent(window)
	local binderList = content and content:FindFirstChild("BinderList")
	if binderList and binderList:IsA("GuiObject") then
		binderList.Visible = false
	end

	ensureRows(window)

	setText(findDeep(window, "TimerText"), "NEW QUESTS IN " .. formatTime(data.resetIn))
	setText(findDeep(window, "ResetText"), "Resets in: " .. formatTime(data.resetIn))

	local quests = getQuestList(data)
	for index = 1, 3 do
		local quest = quests[index]
		local row = questRows[index]
		if row then
			row.Visible = true
			updateRow(row, quest, index)
		end
	end
end

local mainHUD = getMainHUD()
local windows = mainHUD and getWindows(mainHUD)
local dailyWindow = windows and windows:WaitForChild("DailyQuestsWindow", 30)

local function openGui()
	if dailyWindow then
		dailyWindow.Visible = true
		render(dailyWindow, questData or {})
	end
	remote:FireServer("Get")
end

local function closeGui()
	if dailyWindow then
		dailyWindow.Visible = false
	end
end

remote.OnClientEvent:Connect(function(action, data)
	if action == "Open" or action == "Update" or action == "Locked" then
		if dailyWindow then
			render(dailyWindow, data)
		end
	end
end)

UIManager.register("DailyQuests", openGui, closeGui, function()
	return dailyWindow and dailyWindow.Visible == true
end)

local dailyQuestButton = ReplicatedStorage:WaitForChild("HudButton_DAILYQUESTS", 10)
if dailyQuestButton then
	dailyQuestButton.Event:Connect(function()
		if dailyWindow and dailyWindow.Visible then
			remote:FireServer("Get")
		end
	end)
end

if dailyWindow then
	render(dailyWindow, {})
	dailyWindow:GetPropertyChangedSignal("Visible"):Connect(function()
		if dailyWindow.Visible then
			render(dailyWindow, questData or {})
			remote:FireServer("Get")
		end
	end)
	remote:FireServer("Get")
else
	warn("DailyQuestClient: editable DailyQuestsWindow missing; old runtime UI creation is disabled.")
end
]]></string>
          </Properties>
        </Item>
        <Item class="LocalScript" referent="122">
          <Properties>
            <string name="Name">EditableInventoryBinder</string>
            <string name="Source"><![CDATA[-- Binds the editable Studio InventoryWindow to server-owned inventory data.
-- This script only populates existing UI and sends requests. It never grants,
-- equips, deletes, or consumes anything locally.
local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")

local player = Players.LocalPlayer
local playerGui = player:WaitForChild("PlayerGui")

local remotes = ReplicatedStorage:WaitForChild("Remotes")
local inventoryRequest = remotes:WaitForChild("InventoryRequest")
local inventoryAction = remotes:WaitForChild("InventoryAction")

local Events = ReplicatedStorage:WaitForChild("Events")
local hatchEvent = Events:WaitForChild("HatchEgg")
local petsLoadedEvent = Events:WaitForChild("PetsLoaded")
local useItemEvent = Events:WaitForChild("UseItem")
local equipPaintToolEvent = Events:WaitForChild("EquipPaintTool")

local PetModelUtil = require(ReplicatedStorage:WaitForChild("Modules"):WaitForChild("PetModelUtil"))

local TAB_NAMES = { "Colors", "Brushes", "Potions", "Items" }
local currentTab = "Colors"
local inventoryData = { Colors = {}, Brushes = {}, Potions = {}, Items = {}, Count = 0, Capacity = 75 }
local selectedItem = nil
local loading = false

local function waitForInventoryWindow()
	local root = playerGui:WaitForChild("ClientUIRoot", 30)
	local mainHud = root and root:WaitForChild("MainHUD", 30)
	local modalWindows = mainHud and mainHud:WaitForChild("ModalWindows", 30)
	local windows = modalWindows and modalWindows:WaitForChild("Windows", 30)
	return windows and windows:WaitForChild("InventoryWindow", 30)
end

local inventoryWindow = waitForInventoryWindow()
if not inventoryWindow or not inventoryWindow:IsA("GuiObject") then
	warn("EditableInventoryBinder: InventoryWindow missing. No runtime inventory window was created.")
	return
end

local ui = {}
local cardConnections = {}
local renderDetails

local function disconnectCards()
	for _, connection in ipairs(cardConnections) do
		if connection and connection.Connected then
			connection:Disconnect()
		end
	end
	table.clear(cardConnections)
end

local function ensureFrame(parent, name, className)
	local frame = parent:FindFirstChild(name)
	if frame and frame:IsA("GuiObject") then
		return frame
	end
	frame = Instance.new(className or "Frame")
	frame.Name = name
	frame.BackgroundTransparency = className == "ScrollingFrame" and 1 or 0
	frame.BackgroundColor3 = Color3.fromRGB(244, 248, 252)
	frame.BorderSizePixel = 0
	frame.Parent = parent
	return frame
end

local function ensureLabel(parent, name, text)
	local label = parent:FindFirstChild(name)
	if label and label:IsA("TextLabel") then
		return label
	end
	label = Instance.new("TextLabel")
	label.Name = name
	label.BackgroundTransparency = 1
	label.Font = Enum.Font.GothamBold
	label.TextColor3 = Color3.fromRGB(38, 36, 52)
	label.TextWrapped = true
	label.TextXAlignment = Enum.TextXAlignment.Left
	label.TextYAlignment = Enum.TextYAlignment.Top
	label.TextSize = 14
	label.Text = text or ""
	label.Parent = parent
	return label
end

local function ensureButton(parent, name, text)
	local button = parent:FindFirstChild(name)
	if button and button:IsA("TextButton") then
		return button
	end
	button = Instance.new("TextButton")
	button.Name = name
	button.AutoButtonColor = true
	button.BackgroundColor3 = Color3.fromRGB(84, 225, 112)
	button.BorderSizePixel = 0
	button.Font = Enum.Font.GothamBlack
	button.TextColor3 = Color3.fromRGB(255, 255, 255)
	button.TextStrokeColor3 = Color3.fromRGB(35, 38, 45)
	button.TextStrokeTransparency = 0
	button.TextSize = 15
	button.Text = text or "OK"
	button.Parent = parent
	Instance.new("UICorner", button).CornerRadius = UDim.new(0, 10)
	return button
end

local function setText(object, value)
	if object and (object:IsA("TextLabel") or object:IsA("TextButton") or object:IsA("TextBox")) then
		object.Text = tostring(value or "")
	end
end

local function setButtonEnabled(button, enabled)
	button.Visible = true
	button.Active = enabled == true
	button.AutoButtonColor = enabled == true
	button.BackgroundTransparency = enabled and 0 or 0.35
end

local function getSlotIndex(slot)
	return tonumber(string.match(slot.Name, "^Slot(%d+)$")) or math.huge
end

local function collectEditableSlots(parent)
	local slots = {}
	for _, child in ipairs(parent:GetChildren()) do
		if child:IsA("GuiObject") and string.match(child.Name, "^Slot%d+$") then
			table.insert(slots, child)
		end
	end
	table.sort(slots, function(a, b)
		return getSlotIndex(a) < getSlotIndex(b)
	end)
	return slots
end

local function prepareStructure()
	ui.tabs = inventoryWindow:FindFirstChild("Tabs") or ensureFrame(inventoryWindow, "Tabs")
	ui.body = inventoryWindow:FindFirstChild("Content") or inventoryWindow:FindFirstChild("Body") or ensureFrame(inventoryWindow, "Content")
	ui.body.Position = ui.body.Position == UDim2.new() and UDim2.fromOffset(22, 122) or ui.body.Position
	ui.body.Size = ui.body.Size == UDim2.new() and UDim2.new(1, -44, 1, -148) or ui.body.Size

	ui.gridPanel = ui.body:FindFirstChild("ItemGrid") or ui.body:FindFirstChild("GridPanel") or ensureFrame(ui.body, "ItemGrid")
	ui.gridPanel.Position = UDim2.fromOffset(12, 12)
	ui.gridPanel.Size = UDim2.new(0.62, -20, 1, -24)
	ui.gridPanel.BackgroundColor3 = Color3.fromRGB(246, 249, 255)
	ui.slots = collectEditableSlots(ui.gridPanel)
	ui.usesEditableSlots = #ui.slots > 0

	if ui.usesEditableSlots then
		ui.grid = ui.gridPanel
	else
		ui.grid = ui.gridPanel:FindFirstChild("Grid") or ensureFrame(ui.gridPanel, "Grid", "ScrollingFrame")
		ui.grid.Position = UDim2.fromOffset(8, 8)
		ui.grid.Size = UDim2.new(1, -16, 1, -48)
		ui.grid.ScrollBarThickness = 6
		ui.grid.CanvasSize = UDim2.fromOffset(0, 0)

		local layout = ui.grid:FindFirstChildOfClass("UIGridLayout") or Instance.new("UIGridLayout")
		layout.CellPadding = UDim2.fromOffset(10, 10)
		layout.CellSize = UDim2.fromOffset(146, 140)
		layout.SortOrder = Enum.SortOrder.LayoutOrder
		layout.Parent = ui.grid
		if not ui.grid:GetAttribute("InventoryLayoutBound") then
			ui.grid:SetAttribute("InventoryLayoutBound", true)
			layout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
				ui.grid.CanvasSize = UDim2.fromOffset(0, layout.AbsoluteContentSize.Y + 20)
			end)
		end
	end

	ui.emptyText = ensureLabel(ui.gridPanel, "EmptyText", "")
	ui.emptyText.Position = UDim2.fromOffset(12, 52)
	ui.emptyText.Size = UDim2.new(1, -24, 0, 70)
	ui.emptyText.Font = Enum.Font.GothamBlack
	ui.emptyText.TextSize = 20
	ui.emptyText.TextXAlignment = Enum.TextXAlignment.Center
	ui.emptyText.TextYAlignment = Enum.TextYAlignment.Center
	ui.emptyText.Visible = false

	ui.footer = ui.gridPanel:FindFirstChild("Footer") or ensureFrame(ui.gridPanel, "Footer")
	ui.footer.Position = UDim2.new(0, 8, 1, -38)
	ui.footer.Size = UDim2.new(1, -16, 0, 30)
	ui.footer.BackgroundTransparency = 1
	ui.capacityText = ensureLabel(ui.footer, "CapacityText", "")
	ui.capacityText.Size = UDim2.fromScale(1, 1)
	ui.capacityText.TextXAlignment = Enum.TextXAlignment.Right

	ui.detailPanel = ui.body:FindFirstChild("DetailsPanel") or ui.body:FindFirstChild("DetailPanel") or ensureFrame(ui.body, "DetailsPanel")
	ui.detailPanel.Position = UDim2.new(0.64, 0, 0, 12)
	ui.detailPanel.Size = UDim2.new(0.36, -12, 1, -24)
	ui.detailPanel.BackgroundColor3 = Color3.fromRGB(239, 246, 255)

	ui.bigPreview = ui.detailPanel:FindFirstChild("BigPreview") or ensureFrame(ui.detailPanel, "BigPreview")
	ui.bigPreview.Position = UDim2.fromOffset(16, 16)
	ui.bigPreview.Size = UDim2.new(1, -32, 0, 112)
	ui.bigPreview.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
	ui.selectedName = ui.detailPanel:FindFirstChild("SelectedName") or ui.detailPanel:FindFirstChild("SelectLabel") or ensureLabel(ui.detailPanel, "SelectedName", "Select an Item")
	ui.selectedName.Position = UDim2.fromOffset(16, 138)
	ui.selectedName.Size = UDim2.new(1, -32, 0, 32)
	ui.selectedName.Font = Enum.Font.GothamBlack
	ui.selectedName.TextSize = 20
	ui.selectedRarity = ensureLabel(ui.detailPanel, "SelectedRarity", "")
	ui.selectedRarity.Position = UDim2.fromOffset(16, 172)
	ui.selectedRarity.Size = UDim2.new(1, -32, 0, 26)
	ui.selectedDescription = ensureLabel(ui.detailPanel, "SelectedDescription", "Choose a card to see details.")
	ui.selectedDescription.Position = UDim2.fromOffset(16, 202)
	ui.selectedDescription.Size = UDim2.new(1, -32, 0, 58)
	ui.statsBox = ui.detailPanel:FindFirstChild("StatsBox") or ensureFrame(ui.detailPanel, "StatsBox")
	ui.statsBox.Position = UDim2.fromOffset(16, 268)
	ui.statsBox.Size = UDim2.new(1, -32, 0, 78)
	ui.statsBox.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
	ui.statsText = ensureLabel(ui.statsBox, "StatsText", "")
	ui.statsText.Position = UDim2.fromOffset(10, 8)
	ui.statsText.Size = UDim2.new(1, -20, 1, -16)

	ui.equipButton = ensureButton(ui.detailPanel, "EquipButton", "EQUIP")
	ui.equipButton.Position = UDim2.new(0, 16, 1, -130)
	ui.equipButton.Size = UDim2.new(1, -32, 0, 34)
	ui.lockButton = ensureButton(ui.detailPanel, "LockButton", "LOCK")
	ui.lockButton.Position = UDim2.new(0, 16, 1, -88)
	ui.lockButton.Size = UDim2.new(1, -32, 0, 34)
	ui.deleteButton = ensureButton(ui.detailPanel, "DeleteButton", "DELETE")
	ui.deleteButton.Position = UDim2.new(0, 16, 1, -46)
	ui.deleteButton.Size = UDim2.new(1, -32, 0, 34)

	ui.cardTemplate = ui.grid:FindFirstChild("ItemCardTemplate")
	if not ui.cardTemplate and not ui.usesEditableSlots then
		ui.cardTemplate = Instance.new("TextButton")
		ui.cardTemplate.Name = "ItemCardTemplate"
		ui.cardTemplate.Visible = false
		ui.cardTemplate.Text = ""
		ui.cardTemplate.AutoButtonColor = true
		ui.cardTemplate.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
		ui.cardTemplate.BorderSizePixel = 0
		ui.cardTemplate.Size = UDim2.fromOffset(146, 140)
		ui.cardTemplate.Parent = ui.grid
		Instance.new("UICorner", ui.cardTemplate).CornerRadius = UDim.new(0, 12)
		local stroke = Instance.new("UIStroke")
		stroke.Color = Color3.fromRGB(35, 38, 45)
		stroke.Thickness = 2
		stroke.Parent = ui.cardTemplate
	end
end

local function clearPreview(preview)
	for _, child in ipairs(preview:GetChildren()) do
		if child.Name == "PreviewViewport" or child.Name == "PreviewImage" or child.Name == "PreviewText" then
			child:Destroy()
		end
	end
end

local function paintPreview(preview, item)
	clearPreview(preview)
	if item.IconImage and item.IconImage ~= "" then
		local image = Instance.new("ImageLabel")
		image.Name = "PreviewImage"
		image.BackgroundTransparency = 1
		image.Image = item.IconImage
		image.Size = UDim2.fromScale(1, 1)
		image.Parent = preview
		return
	end

	if item.Kind == "Color" and item.PetId then
		local viewport = Instance.new("ViewportFrame")
		viewport.Name = "PreviewViewport"
		viewport.BackgroundTransparency = 1
		viewport.Size = UDim2.fromScale(1, 1)
		viewport.Parent = preview
		local ok = pcall(function()
			PetModelUtil.MountViewport(viewport, item.PetId, { spin = false })
		end)
		if ok then
			return
		end
		viewport:Destroy()
	end

	local label = Instance.new("TextLabel")
	label.Name = "PreviewText"
	label.BackgroundColor3 = item.IconColor or Color3.fromRGB(225, 235, 248)
	label.BorderSizePixel = 0
	label.Size = UDim2.fromScale(1, 1)
	label.Font = Enum.Font.GothamBlack
	label.TextScaled = true
	label.TextColor3 = Color3.fromRGB(255, 255, 255)
	label.TextStrokeColor3 = Color3.fromRGB(35, 38, 45)
	label.TextStrokeTransparency = 0
	label.Text = item.IconText or string.upper(string.sub(item.Name or item.Id or "IT", 1, 2))
	label.Parent = preview
	Instance.new("UICorner", label).CornerRadius = UDim.new(0, 10)
end

local function makeCard(item, index)
	if not ui.cardTemplate then
		return
	end
	local card = ui.cardTemplate:Clone()
	card.Name = "ItemCard_" .. tostring(index)
	card:SetAttribute("EditableInventoryGeneratedCard", true)
	card.Visible = true
	card.LayoutOrder = index
	card.Parent = ui.grid

	for _, child in ipairs(card:GetChildren()) do
		if child:IsA("GuiObject") and child.Name ~= "UICorner" then
			child:Destroy()
		end
	end

	local preview = ensureFrame(card, "Preview")
	preview.Position = UDim2.fromOffset(10, 8)
	preview.Size = UDim2.new(1, -20, 0, 76)
	preview.BackgroundColor3 = Color3.fromRGB(242, 247, 255)
	paintPreview(preview, item)

	local name = ensureLabel(card, "Name", item.Name)
	name.Position = UDim2.fromOffset(8, 88)
	name.Size = UDim2.new(1, -16, 0, 28)
	name.Font = Enum.Font.GothamBlack
	name.TextSize = 13
	name.TextXAlignment = Enum.TextXAlignment.Center
	local meta = ensureLabel(card, "Meta", "")
	meta.Position = UDim2.fromOffset(8, 116)
	meta.Size = UDim2.new(1, -16, 0, 20)
	meta.TextSize = 11
	meta.TextXAlignment = Enum.TextXAlignment.Center
	meta.Text = item.Equipped and "EQUIPPED" or (item.Amount and ("x" .. tostring(item.Amount)) or tostring(item.Rarity or ""))

	local stroke = card:FindFirstChildOfClass("UIStroke")
	if stroke then
		stroke.Color = item.Equipped and Color3.fromRGB(84, 225, 112) or (item.Locked and Color3.fromRGB(88, 174, 255) or Color3.fromRGB(35, 38, 45))
		stroke.Thickness = item.Equipped and 4 or 2
	end

	local connection = card.Activated:Connect(function()
		selectedItem = item
		renderDetails()
	end)
	table.insert(cardConnections, connection)
end

local function clearEditableSlot(slot)
	slot:SetAttribute("InventoryItemKind", nil)
	slot:SetAttribute("InventoryItemId", nil)
	slot.Active = false
	if slot:IsA("GuiButton") then
		slot.AutoButtonColor = false
	end

	for _, child in ipairs(slot:GetChildren()) do
		if child:GetAttribute("EditableInventoryGenerated") == true then
			child:Destroy()
		end
	end

	local icon = slot:FindFirstChild("Icon", true)
	if icon and icon:IsA("TextLabel") then
		icon.Text = ""
		icon.BackgroundTransparency = 1
	elseif icon and icon:IsA("ImageLabel") then
		icon.Image = ""
		icon.BackgroundTransparency = 1
	end

	local stroke = slot:FindFirstChildOfClass("UIStroke")
	if stroke then
		stroke.Color = Color3.fromRGB(35, 38, 45)
		stroke.Thickness = 2
	end
end

local function bindSlotClick(slot, item)
	local function selectItem()
		selectedItem = item
		renderDetails()
	end

	if slot:IsA("GuiButton") then
		slot.Active = true
		slot.AutoButtonColor = true
		table.insert(cardConnections, slot.Activated:Connect(selectItem))
	else
		slot.Active = true
		table.insert(cardConnections, slot.InputBegan:Connect(function(input)
			if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
				selectItem()
			end
		end))
	end
end

local function fillEditableSlot(slot, item)
	clearEditableSlot(slot)
	slot.Visible = true
	slot:SetAttribute("InventoryItemKind", item.Kind)
	slot:SetAttribute("InventoryItemId", item.Id)

	local icon = slot:FindFirstChild("Icon", true)
	local previewParent = icon and icon:IsA("GuiObject") and icon or slot
	if icon and (icon:IsA("TextLabel") or icon:IsA("TextButton")) then
		icon.Text = ""
		icon.BackgroundTransparency = 1
	end
	paintPreview(previewParent, item)

	local name = ensureLabel(slot, "ItemName", tostring(item.Name or item.Id or "Color"))
	name:SetAttribute("EditableInventoryGenerated", true)
	name.Position = UDim2.new(0, 4, 1, -32)
	name.Size = UDim2.new(1, -8, 0, 16)
	name.Font = Enum.Font.GothamBlack
	name.TextScaled = true
	name.TextXAlignment = Enum.TextXAlignment.Center
	name.TextYAlignment = Enum.TextYAlignment.Center
	name.TextColor3 = Color3.fromRGB(35, 38, 45)
	setText(name, item.Name or item.Id or "Color")

	local meta = ensureLabel(slot, "ItemMeta", "")
	meta:SetAttribute("EditableInventoryGenerated", true)
	meta.Position = UDim2.new(0, 4, 1, -16)
	meta.Size = UDim2.new(1, -8, 0, 14)
	meta.Font = Enum.Font.GothamBold
	meta.TextScaled = true
	meta.TextXAlignment = Enum.TextXAlignment.Center
	meta.TextYAlignment = Enum.TextYAlignment.Center
	meta.TextColor3 = Color3.fromRGB(78, 85, 104)
	setText(meta, item.Equipped and "EQUIPPED" or (item.Amount and ("x" .. tostring(item.Amount)) or tostring(item.Rarity or "")))

	local stroke = slot:FindFirstChildOfClass("UIStroke")
	if stroke then
		stroke.Color = item.Equipped and Color3.fromRGB(84, 225, 112) or (item.Locked and Color3.fromRGB(88, 174, 255) or Color3.fromRGB(35, 38, 45))
		stroke.Thickness = item.Equipped and 4 or 2
	end

	bindSlotClick(slot, item)
end

renderDetails = function()
	local item = selectedItem
	if not item then
		clearPreview(ui.bigPreview)
		setText(ui.selectedName, "Select an Item")
		setText(ui.selectedRarity, "")
		setText(ui.selectedDescription, "Choose a card to see details.")
		setText(ui.statsText, "")
		setText(ui.equipButton, "SELECT")
		setButtonEnabled(ui.equipButton, false)
		setText(ui.lockButton, "LOCK")
		setButtonEnabled(ui.lockButton, false)
		setText(ui.deleteButton, "DELETE")
		setButtonEnabled(ui.deleteButton, false)
		return
	end

	paintPreview(ui.bigPreview, item)
	setText(ui.selectedName, item.Name)
	setText(ui.selectedRarity, item.Rarity or item.Mutation or item.Kind)
	setText(ui.selectedDescription, item.Description or item.Bonus or "")
	setText(ui.statsText, table.concat(item.Stats or {}, "\n"))

	if item.Kind == "Color" then
		setText(ui.equipButton, item.Equipped and "UNEQUIP" or "EQUIP")
		setButtonEnabled(ui.equipButton, true)
		setText(ui.lockButton, item.Locked and "UNLOCK" or "LOCK")
		setButtonEnabled(ui.lockButton, true)
		setText(ui.deleteButton, "DELETE")
		setButtonEnabled(ui.deleteButton, not item.Locked and not item.Equipped)
	elseif item.Kind == "Brush" then
		setText(ui.equipButton, item.Equipped and "EQUIPPED" or "EQUIP")
		setButtonEnabled(ui.equipButton, not item.Equipped)
		setText(ui.lockButton, "LOCK")
		setButtonEnabled(ui.lockButton, false)
		setText(ui.deleteButton, "DELETE")
		setButtonEnabled(ui.deleteButton, false)
	else
		setText(ui.equipButton, item.Usable and "USE" or "INFO")
		setButtonEnabled(ui.equipButton, item.Usable == true)
		setText(ui.lockButton, "LOCK")
		setButtonEnabled(ui.lockButton, false)
		setText(ui.deleteButton, "DELETE")
		setButtonEnabled(ui.deleteButton, false)
	end
end

local function getTabItems()
	return inventoryData[currentTab] or {}
end

local function renderInventory()
	disconnectCards()
	if ui.usesEditableSlots then
		ui.slots = collectEditableSlots(ui.gridPanel)
		for _, slot in ipairs(ui.slots) do
			clearEditableSlot(slot)
			slot.Visible = false
		end
	else
		for _, child in ipairs(ui.grid:GetChildren()) do
			if child:GetAttribute("EditableInventoryGeneratedCard") == true then
				child:Destroy()
			elseif child:IsA("GuiObject") and child.Name ~= "ItemCardTemplate" then
				child.Visible = false
			end
		end
	end

	for _, tabName in ipairs(TAB_NAMES) do
		local tab = ui.tabs:FindFirstChild(tabName .. "Tab", true)
		if tab and tab:IsA("TextButton") then
			local active = tabName == currentTab
			tab.BackgroundColor3 = active and Color3.fromRGB(82, 219, 225) or Color3.fromRGB(232, 238, 248)
			tab.TextColor3 = active and Color3.fromRGB(255, 255, 255) or Color3.fromRGB(38, 36, 52)
		end
	end

	local items = getTabItems()
	ui.emptyText.Visible = #items == 0
	if not ui.usesEditableSlots then
		ui.grid.Visible = #items > 0
	end
	ui.emptyText.Text = "No " .. string.lower(currentTab) .. " yet."
	ui.capacityText.Text = "Colors: " .. tostring(inventoryData.Count or 0) .. " / " .. tostring(inventoryData.Capacity or 75)

	for index, item in ipairs(items) do
		if ui.usesEditableSlots then
			local slot = ui.slots[index]
			if slot then
				fillEditableSlot(slot, item)
			end
		else
			makeCard(item, index)
		end
	end

	if selectedItem then
		local stillExists = false
		for _, item in ipairs(items) do
			if item.Id == selectedItem.Id and item.Kind == selectedItem.Kind then
				selectedItem = item
				stillExists = true
				break
			end
		end
		if not stillExists then
			selectedItem = nil
		end
	end
	renderDetails()
end

local function requestInventory()
	if loading then
		return
	end
	loading = true
	local ok, data = pcall(function()
		return inventoryRequest:InvokeServer("GetInventory")
	end)
	loading = false
	if ok and type(data) == "table" then
		inventoryData = data
		renderInventory()
	else
		warn("EditableInventoryBinder: inventory request failed: " .. tostring(data))
	end
end

local function sendAction(action, item)
	if not item then
		return
	end
	inventoryAction:FireServer(action, {
		Kind = item.Kind,
		Id = item.Id,
		Locked = not item.Locked,
	})
end

local function wireControls()
	for _, tabName in ipairs(TAB_NAMES) do
		local tab = ui.tabs:FindFirstChild(tabName .. "Tab", true)
		if tab and tab:IsA("GuiButton") and tab:GetAttribute("EditableInventoryBound") ~= true then
			tab:SetAttribute("EditableInventoryBound", true)
			tab.Activated:Connect(function()
				currentTab = tabName
				selectedItem = nil
				renderInventory()
			end)
		end
	end

	ui.equipButton.Activated:Connect(function()
		if not selectedItem then
			return
		end
		if selectedItem.Kind == "Color" then
			sendAction(selectedItem.Equipped and "Unequip" or "Equip", selectedItem)
		elseif selectedItem.Kind == "Brush" then
			sendAction("Equip", selectedItem)
		elseif selectedItem.Kind == "Potion" or selectedItem.Kind == "Item" then
			sendAction("Use", selectedItem)
		end
	end)
	ui.lockButton.Activated:Connect(function()
		if selectedItem and selectedItem.Kind == "Color" then
			sendAction("Lock", selectedItem)
		end
	end)
	ui.deleteButton.Activated:Connect(function()
		if selectedItem and selectedItem.Kind == "Color" and not selectedItem.Locked and not selectedItem.Equipped then
			sendAction("Delete", selectedItem)
		end
	end)
end

prepareStructure()
wireControls()
renderDetails()

inventoryWindow:GetPropertyChangedSignal("Visible"):Connect(function()
	if inventoryWindow.Visible then
		requestInventory()
	end
end)

inventoryAction.OnClientEvent:Connect(function(result)
	if type(result) == "table" and type(result.Inventory) == "table" then
		inventoryData = result.Inventory
		renderInventory()
	else
		requestInventory()
	end
end)

hatchEvent.OnClientEvent:Connect(function(success)
	if success and inventoryWindow.Visible then
		task.defer(requestInventory)
	end
end)
petsLoadedEvent.OnClientEvent:Connect(function()
	if inventoryWindow.Visible then
		task.defer(requestInventory)
	end
end)
useItemEvent.OnClientEvent:Connect(function()
	if inventoryWindow.Visible then
		task.defer(requestInventory)
	end
end)
equipPaintToolEvent.OnClientEvent:Connect(function()
	if inventoryWindow.Visible then
		task.defer(requestInventory)
	end
end)

if inventoryWindow.Visible then
	requestInventory()
end

print("[EditableInventoryBinder] InventoryWindow bound through server bridge.")
]]></string>
          </Properties>
        </Item>
        <Item class="LocalScript" referent="123">
          <Properties>
            <string name="Name">EditableShopBinder</string>
            <string name="Source"><![CDATA[-- Populates the editable Studio ShopWindow with real gamepasses/dev products.
-- This does not create a duplicate shop window. It only fills the existing editable window.
local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local MarketplaceService = game:GetService("MarketplaceService")

local player = Players.LocalPlayer
local playerGui = player:WaitForChild("PlayerGui")

local RobuxShopConfig = require(ReplicatedStorage:WaitForChild("RobuxShopConfig"))

local COLORS = {
	Outline = Color3.fromRGB(35, 38, 45),
	Card = Color3.fromRGB(255, 255, 255),
	Panel = Color3.fromRGB(244, 248, 252),
	Text = Color3.fromRGB(38, 36, 52),
	Muted = Color3.fromRGB(92, 98, 116),
	Accent = Color3.fromRGB(82, 219, 225),
	Green = Color3.fromRGB(84, 225, 112),
	Disabled = Color3.fromRGB(170, 178, 194),
}

local function findMainHUD()
	local root = playerGui:WaitForChild("ClientUIRoot", 30)
	return root and root:WaitForChild("MainHUD", 30)
end

local function findWindows(mainHUD)
	local modalWindows = mainHUD and mainHUD:FindFirstChild("ModalWindows")
	if modalWindows and modalWindows:FindFirstChild("Windows") then
		return modalWindows.Windows
	end
	return mainHUD and mainHUD:FindFirstChild("Windows")
end

local function corner(obj, radius)
	local c = obj:FindFirstChildOfClass("UICorner") or Instance.new("UICorner")
	c.CornerRadius = UDim.new(0, radius or 16)
	c.Parent = obj
	return c
end

local function stroke(obj, thickness, color)
	local s = obj:FindFirstChildOfClass("UIStroke") or Instance.new("UIStroke")
	s.Thickness = thickness or 2
	s.Color = color or COLORS.Outline
	s.Parent = obj
	return s
end

local function clearGenerated(container)
	for _, child in ipairs(container:GetChildren()) do
		if child:GetAttribute("EditableShopGenerated") == true then
			child:Destroy()
		end
	end
end

local function label(parent, name, text, pos, size, textSize, color)
	local l = Instance.new("TextLabel")
	l.Name = name
	l.BackgroundTransparency = 1
	l.Text = text or ""
	l.Position = pos
	l.Size = size
	l.Font = Enum.Font.GothamBold
	l.TextSize = textSize or 14
	l.TextColor3 = color or COLORS.Text
	l.TextXAlignment = Enum.TextXAlignment.Left
	l.TextYAlignment = Enum.TextYAlignment.Center
	l.TextWrapped = true
	l.Parent = parent
	return l
end

local function makeButton(parent, name, text, pos, size, bg)
	local b = Instance.new("TextButton")
	b.Name = name
	b.Text = text
	b.Position = pos
	b.Size = size
	b.BackgroundColor3 = bg or COLORS.Green
	b.BorderSizePixel = 0
	b.Font = Enum.Font.GothamBlack
	b.TextColor3 = Color3.fromRGB(255, 255, 255)
	b.TextStrokeTransparency = 0
	b.TextStrokeColor3 = COLORS.Outline
	b.TextScaled = true
	b.Parent = parent
	corner(b, 12)
	stroke(b, 2)
	return b
end

local function getContent(shopWindow)
	return shopWindow:FindFirstChild("Content", true) or shopWindow:FindFirstChild("Body", true) or shopWindow
end

local function getTabs(shopWindow)
	return shopWindow:FindFirstChild("Tabs", true)
end

local function setTabVisual(tabs, activeName)
	if not tabs then return end
	for _, tab in ipairs(tabs:GetDescendants()) do
		if tab:IsA("TextButton") then
			local isActive = string.lower(tab.Name):find(string.lower(activeName)) or string.lower(tab.Text):find(string.lower(activeName))
			tab.BackgroundColor3 = isActive and COLORS.Accent or Color3.fromRGB(232, 238, 248)
			tab.TextColor3 = isActive and Color3.fromRGB(255,255,255) or COLORS.Text
		end
	end
end

local function ownsPass(gamepassId)
	if not gamepassId or tonumber(gamepassId) == 0 then
		return false
	end
	local ok, result = pcall(function()
		return MarketplaceService:UserOwnsGamePassAsync(player.UserId, tonumber(gamepassId))
	end)
	return ok and result == true
end

local function makeShopCard(parent, item, index, kind)
	local width = 220
	local height = 126
	local col = (index - 1) % 3
	local row = math.floor((index - 1) / 3)

	local card = Instance.new("Frame")
	card.Name = tostring(item.id or item.displayName or kind) .. "Card"
	card:SetAttribute("EditableShopGenerated", true)
	card.Position = UDim2.fromOffset(14 + col * 238, 14 + row * 140)
	card.Size = UDim2.fromOffset(width, height)
	card.BackgroundColor3 = COLORS.Card
	card.BorderSizePixel = 0
	card.Parent = parent
	corner(card, 18)
	stroke(card, 3)

	local icon = Instance.new("ImageLabel")
	icon.Name = "Icon"
	icon.Position = UDim2.fromOffset(10, 12)
	icon.Size = UDim2.fromOffset(58, 58)
	icon.BackgroundColor3 = item.color or Color3.fromRGB(225, 244, 255)
	icon.BorderSizePixel = 0
	icon.Image = tostring(item.iconImage or "")
	icon.ScaleType = Enum.ScaleType.Fit
	icon.Parent = card
	corner(icon, 14)
	stroke(icon, 2)

	if icon.Image == "" then
		local iconText = label(icon, "IconText", tostring(item.icon or "?"), UDim2.fromScale(0, 0), UDim2.fromScale(1, 1), 15, COLORS.Text)
		iconText.TextXAlignment = Enum.TextXAlignment.Center
		iconText.Font = Enum.Font.GothamBlack
	end

	label(card, "Name", tostring(item.displayName or item.id or "Item"), UDim2.fromOffset(78, 8), UDim2.new(1, -88, 0, 28), 16, COLORS.Text).Font = Enum.Font.GothamBlack
	label(card, "Description", tostring(item.description or ""), UDim2.fromOffset(78, 38), UDim2.new(1, -88, 0, 34), 11, COLORS.Muted)

	local owned = kind == "Gamepass" and ownsPass(item.gamepassId)
	local hasRealId = kind == "Gamepass" and tonumber(item.gamepassId) and tonumber(item.gamepassId) > 0
		or kind == "Product" and tonumber(item.productId) and tonumber(item.productId) > 0
	local buttonText = owned and "OWNED" or (hasRealId and ("BUY " .. tostring(item.price or "")) or "SET ID")
	local buy = makeButton(card, "BuyButton", buttonText, UDim2.new(1, -112, 1, -42), UDim2.fromOffset(98, 32), owned and COLORS.Disabled or (hasRealId and COLORS.Green or COLORS.Disabled))
	buy.AutoButtonColor = hasRealId and not owned

	buy.MouseButton1Click:Connect(function()
		if owned then return end
		if kind == "Gamepass" then
			if hasRealId then
				MarketplaceService:PromptGamePassPurchase(player, tonumber(item.gamepassId))
			else
				warn("Missing gamepassId for", item.id)
			end
		elseif kind == "Product" then
			if hasRealId then
				MarketplaceService:PromptProductPurchase(player, tonumber(item.productId))
			else
				warn("Missing productId for", item.id)
			end
		end
	end)
end

local function renderGamepasses(content)
	clearGenerated(content)
	local passes = RobuxShopConfig.getSortedGamepasses()
	if #passes == 0 then
		label(content, "NoGamepassesLabel", "No gamepasses configured yet.", UDim2.fromScale(0.05, 0.40), UDim2.fromScale(0.90, 0.12), 22, COLORS.Muted).TextXAlignment = Enum.TextXAlignment.Center
		return
	end
	for i, pass in ipairs(passes) do
		makeShopCard(content, pass, i, "Gamepass")
	end
end

local function renderProducts(content, tabName)
	clearGenerated(content)
	local products = RobuxShopConfig.getSortedDevProducts()
	if #products == 0 then
		label(content, "ComingSoonLabel", tabName .. " coming soon. Product IDs are not set yet.", UDim2.fromScale(0.05, 0.40), UDim2.fromScale(0.90, 0.12), 22, COLORS.Muted).TextXAlignment = Enum.TextXAlignment.Center
		return
	end
	for i, product in ipairs(products) do
		makeShopCard(content, product, i, "Product")
	end
end

local function hookTabs(shopWindow, content)
	local tabs = getTabs(shopWindow)
	local function show(tabName)
		setTabVisual(tabs, tabName)
		if tabName == "Gamepasses" then
			renderGamepasses(content)
		else
			renderProducts(content, tabName)
		end
	end

	if tabs then
		for _, tab in ipairs(tabs:GetDescendants()) do
			if tab:IsA("TextButton") then
				local lowered = string.lower(tab.Text .. " " .. tab.Name)
				tab.MouseButton1Click:Connect(function()
					if lowered:find("gamepass") then
						show("Gamepasses")
					elseif lowered:find("potion") then
						show("Potions")
					elseif lowered:find("currency") then
						show("Currency")
					elseif lowered:find("bundle") then
						show("Bundles")
					else
						show("Gamepasses")
					end
				end)
			end
		end
	end

	show("Gamepasses")
end

local mainHUD = findMainHUD()
local windows = mainHUD and findWindows(mainHUD)
local shopWindow = windows and windows:WaitForChild("ShopWindow", 30)
if shopWindow then
	hookTabs(shopWindow, getContent(shopWindow))
else
	warn("EditableShopBinder: ShopWindow missing; no runtime shop window will be created.")
end
]]></string>
          </Properties>
        </Item>
        <Item class="LocalScript" referent="124">
          <Properties>
            <string name="Name">EditorWindowBinder</string>
            <string name="Source"><![CDATA[-- Binds editor-built MainHUD.Windows to live player data.
-- This script does not create ScreenGuis or rebuild top-level window frames.
local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local MarketplaceService = game:GetService("MarketplaceService")

local player = Players.LocalPlayer
local playerGui = player:WaitForChild("PlayerGui")

local PetData = require(ReplicatedStorage:WaitForChild("PetData"))
local ToolData = require(ReplicatedStorage:WaitForChild("ToolData"))
local ItemsData = require(ReplicatedStorage:WaitForChild("ItemsData"))
local UpgradeData = require(ReplicatedStorage:WaitForChild("UpgradeData"))
local ColorData = require(ReplicatedStorage:WaitForChild("ColorData"))
local SettingsData = require(ReplicatedStorage:WaitForChild("SettingsData"))
local RobuxShopConfig = require(ReplicatedStorage:WaitForChild("RobuxShopConfig"))
local Modules = ReplicatedStorage:WaitForChild("Modules")
local PetDefinitions = require(Modules:WaitForChild("PetDefinitions"))
local PetModelUtil = require(Modules:WaitForChild("PetModelUtil"))

local Events = ReplicatedStorage:WaitForChild("Events")
local equipPetEvent = Events:WaitForChild("EquipPet")
local lockPetEvent = Events:WaitForChild("LockPet")
local deletePetEvent = Events:WaitForChild("DeletePet")
local petsLoadedEvent = Events:WaitForChild("PetsLoaded")
local equipPaintToolEvent = Events:WaitForChild("EquipPaintTool")
local useItemEvent = Events:WaitForChild("UseItem")
local purchaseUpgradeEvent = Events:WaitForChild("PurchaseUpgrade")
local unlockAreaEvent = Events:WaitForChild("UnlockArea")
local requestTravelToSectorEvent = Events:WaitForChild("RequestTravelToSector")
local requestSetSettingEvent = Events:WaitForChild("RequestSetSetting")
local settingsUpdatedEvent = Events:WaitForChild("SettingsUpdated")
local redeemCodeEvent = Events:WaitForChild("RedeemCode")
local dailyQuestRemote = ReplicatedStorage:WaitForChild("DailyQuestRemote", 10)

local LEGACY_ROOT_LAYERS = {
	InventoryUI = true,
	ShopUI = true,
	WorldUI = true,
	GamepassUI = true,
	DailyQuestGui = true,
	CodesUI = true,
}

local TAB_NAMES = { "Colors", "Brushes", "Potions", "Items" }
local RARITY_ORDER = { Legendary = 1, Epic = 2, Rare = 3, Uncommon = 4, Common = 5 }
local BIND_INVENTORY_WINDOW = false
local BIND_WORLDS_WINDOW = false
local BIND_DAILY_QUESTS_WINDOW = false
local FALLBACK_DAILY_QUESTS = {
	{
		id = "CleanColorSpills",
		title = "CLEAN COLOR SPILLS",
		description = "Clean 40 color spills.",
		iconText = "BRUSH",
		progress = 0,
		target = 40,
		rewardCurrency = "Gems",
		rewardAmount = 20,
		reward = 20,
		claimed = false,
	},
	{
		id = "EarnCoins",
		title = "EARN COINS",
		description = "Earn 1,000 coins.",
		iconText = "COINS",
		progress = 0,
		target = 1000,
		rewardCurrency = "Gems",
		rewardAmount = 25,
		reward = 25,
		claimed = false,
	},
	{
		id = "HatchColors",
		title = "HATCH COLORS",
		description = "Hatch 3 colors from eggs.",
		iconText = "EGG",
		progress = 0,
		target = 3,
		rewardCurrency = "Gems",
		rewardAmount = 30,
		reward = 30,
		claimed = false,
	},
}

local root = playerGui:WaitForChild("ClientUIRoot", 15)
if not root then
	warn("EditorWindowBinder: missing PlayerGui.ClientUIRoot")
	return
end

local mainHud = root:WaitForChild("MainHUD", 15)
if not mainHud then
	warn("EditorWindowBinder: missing ClientUIRoot.MainHUD")
	return
end

local modalWindows = mainHud:WaitForChild("ModalWindows", 10)
local windows = modalWindows and modalWindows:WaitForChild("Windows", 10) or mainHud:FindFirstChild("Windows")
if not windows then
	warn("EditorWindowBinder: missing MainHUD.ModalWindows.Windows")
	return
end
if not modalWindows then
	warn("EditorWindowBinder: using legacy MainHUD.Windows. Expected MainHUD.ModalWindows.Windows.")
end

local inventoryWindow = windows:WaitForChild("InventoryWindow", 10)
if not inventoryWindow or not inventoryWindow:IsA("GuiObject") then
	warn("EditorWindowBinder: missing MainHUD.ModalWindows.Windows.InventoryWindow")
	return
end

local petFolder = player:WaitForChild("PetData", 10)
local petInventoryValue = petFolder and petFolder:WaitForChild("Inventory", 10)
local petEquippedValue = petFolder and petFolder:WaitForChild("Equipped", 10)

local paintToolsFolder = player:WaitForChild("PaintTools", 10)
local ownedPaintToolsValue = paintToolsFolder and paintToolsFolder:WaitForChild("Owned", 10)
local equippedPaintToolValue = paintToolsFolder and paintToolsFolder:WaitForChild("Equipped", 10)

local currentTab = "Colors"
local currentShopTab = "Gamepasses"
local SHOP_GAMEPASS_IDS = {
	VIP = true,
	DoubleCoins = true,
	LuckyHatch = true,
}
local colorEntries = {}
local equippedColors = {}
local lockedColors = {}
local playerItems = {}
local selectedEntry = nil

local ui = {}
local connections = {}

local function disconnectAll(list)
	for _, connection in ipairs(list) do
		if connection and connection.Connected then
			connection:Disconnect()
		end
	end
	table.clear(list)
end

local function hideLegacyRootLayers()
	for _, child in ipairs(root:GetChildren()) do
		if LEGACY_ROOT_LAYERS[child.Name] and child:IsA("GuiObject") then
			child.Visible = false
		end
	end
end

local function requestEditorWindow(windowName)
	root:SetAttribute("RequestedWindow", windowName)
	root:SetAttribute("RequestedWindowNonce", os.clock())
	hideLegacyRootLayers()
end

local function ensureFrame(parent, name, position, size, color)
	local frame = parent:FindFirstChild(name)
	if frame and frame:IsA("GuiObject") then
		return frame
	end

	frame = Instance.new("Frame")
	frame.Name = name
	frame.BackgroundColor3 = color or Color3.fromRGB(246, 249, 255)
	frame.BorderSizePixel = 0
	frame.Position = position or UDim2.fromScale(0, 0)
	frame.Size = size or UDim2.fromScale(1, 1)
	frame.Parent = parent
	return frame
end

local function ensureLabel(parent, name, text, position, size, textSize)
	local label = parent:FindFirstChild(name)
	if label and label:IsA("TextLabel") then
		return label
	end

	label = Instance.new("TextLabel")
	label.Name = name
	label.BackgroundTransparency = 1
	label.Font = Enum.Font.GothamBold
	label.TextColor3 = Color3.fromRGB(38, 36, 52)
	label.TextWrapped = true
	label.TextXAlignment = Enum.TextXAlignment.Left
	label.TextYAlignment = Enum.TextYAlignment.Top
	label.TextSize = textSize or 16
	label.Text = text or ""
	label.Position = position or UDim2.fromScale(0, 0)
	label.Size = size or UDim2.fromScale(1, 0)
	label.Parent = parent
	return label
end

local function ensureButton(parent, name, text, position, size)
	local button = parent:FindFirstChild(name)
	if button and button:IsA("TextButton") then
		return button
	end

	button = Instance.new("TextButton")
	button.Name = name
	button.AutoButtonColor = true
	button.BackgroundColor3 = Color3.fromRGB(84, 225, 112)
	button.BorderSizePixel = 0
	button.Font = Enum.Font.GothamBlack
	button.TextColor3 = Color3.fromRGB(255, 255, 255)
	button.TextStrokeColor3 = Color3.fromRGB(35, 38, 45)
	button.TextStrokeTransparency = 0
	button.TextSize = 16
	button.Text = text or "OK"
	button.Position = position or UDim2.fromScale(0, 0)
	button.Size = size or UDim2.fromOffset(120, 34)
	button.Parent = parent

	local corner = Instance.new("UICorner")
	corner.CornerRadius = UDim.new(0, 10)
	corner.Parent = button

	return button
end

local function findGuiObject(parent, name)
	local object = parent and parent:FindFirstChild(name)
	if object and object:IsA("GuiObject") then
		return object
	end
	return nil
end

local function setButtonEnabled(button, enabled)
	if not button then
		return
	end
	button.Visible = true
	button.Active = enabled
	button.AutoButtonColor = enabled
	button.BackgroundTransparency = enabled and 0 or 0.35
end

local function connectPress(guiObject, callback)
	if not guiObject then
		return
	end
	if guiObject:IsA("GuiButton") then
		guiObject.Active = true
		guiObject.Activated:Connect(callback)
	else
		guiObject.Active = true
		guiObject.InputBegan:Connect(function(input)
			if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
				callback()
			end
		end)
	end
end

local function getEntryKey(entry)
	if typeof(entry) == "table" then
		return entry.variantKey or entry.petId
	end
	return tostring(entry or "")
end

local function parsePetInventoryValue(value)
	local entries = {}
	if not value or value == "" then
		return entries
	end

	for _, encoded in ipairs(string.split(value, ",")) do
		if encoded == "" then
			continue
		end

		local segments = string.split(encoded, ":")
		local variantKey
		local petId
		local stackIndex
		if tonumber(segments[2]) then
			petId = segments[1]
			stackIndex = 2
		else
			variantKey = segments[1]
			petId = segments[2]
			stackIndex = 3
		end

		if petId and petId ~= "" then
			local stackAmount = tonumber(segments[stackIndex]) or 1
			local traitId = PetData.normalizeTraitId(segments[stackIndex + 1])
			local shinyStr = segments[stackIndex + 2] or "normal"
			local personalityId = PetData.normalizePersonalityId(segments[stackIndex + 3] or "Neutral")
			local mutationId = PetData.normalizeMutationId(segments[stackIndex + 4] or "None")
			variantKey = variantKey or PetData.makeVariantKey(petId, personalityId, mutationId, traitId)

			local entry = PetData.buildPetEntry(
				petId,
				math.max(1, stackAmount),
				shinyStr == "shiny" or shinyStr == "true",
				personalityId,
				mutationId,
				traitId
			)
			if entry then
				entry.variantKey = variantKey
				entry.effectivePower = entry.finalPower
				table.insert(entries, entry)
			end
		end
	end

	return entries
end

local function parseEquippedValue(value)
	local equipped = {}
	for _, variantKey in ipairs(string.split(value or "", ",")) do
		if variantKey ~= "" then
			table.insert(equipped, variantKey)
		end
	end
	return equipped
end

local function parseLockedValue(value)
	local locked = {}
	for _, variantKey in ipairs(string.split(value or "", ",")) do
		if variantKey ~= "" then
			locked[variantKey] = true
		end
	end
	return locked
end

local function isColorEquipped(entry)
	local key = getEntryKey(entry)
	for _, equippedKey in ipairs(equippedColors) do
		if equippedKey == key then
			return true
		end
	end
	return false
end

local function isColorLocked(entry)
	return lockedColors[getEntryKey(entry)] == true or entry.isLocked == true
end

local function getOwnedPaintToolSet()
	local set = { StarterBrush = true }
	local csv = ownedPaintToolsValue and ownedPaintToolsValue.Value or "StarterBrush"
	for _, toolId in ipairs(string.split(csv, ",")) do
		if toolId ~= "" then
			set[toolId] = true
		end
	end
	return set
end

local function getEquippedPaintToolId()
	if equippedPaintToolValue and equippedPaintToolValue.Value ~= "" then
		return equippedPaintToolValue.Value
	end
	return "StarterBrush"
end

local function isPotion(item)
	return item and (item.boostType ~= nil or item.category == "Boosts")
end

local function setItemQuantity(itemId, quantity)
	quantity = tonumber(quantity) or 0
	if quantity > 0 then
		playerItems[itemId] = quantity
	else
		playerItems[itemId] = nil
	end
end

local function clearList()
	if not ui.list then
		return
	end
	disconnectAll(connections)
	for _, child in ipairs(ui.list:GetChildren()) do
		if not child:IsA("UIGridLayout") and not child:IsA("UIPadding") then
			child:Destroy()
		end
	end
end

local function ensureInventoryStructure()
	ui.tabs = findGuiObject(inventoryWindow, "Tabs") or ensureFrame(inventoryWindow, "Tabs", UDim2.fromOffset(22, 68), UDim2.new(1, -44, 0, 40))
	ui.content = findGuiObject(inventoryWindow, "Content") or ensureFrame(inventoryWindow, "Content", UDim2.fromOffset(22, 122), UDim2.new(1, -44, 1, -148))
	ui.gridRoot = findGuiObject(ui.content, "ItemGrid") or ensureFrame(ui.content, "ItemGrid", UDim2.fromOffset(12, 12), UDim2.new(0.62, -20, 1, -24))
	ui.details = findGuiObject(inventoryWindow, "DetailsPanel")
		or findGuiObject(ui.content, "DetailsPanel")
		or ensureFrame(inventoryWindow, "DetailsPanel", UDim2.new(0.64, 0, 0, 122), UDim2.new(0.36, -34, 1, -148))

	for _, child in ipairs(ui.gridRoot:GetChildren()) do
		if child:IsA("GuiObject") and child.Name ~= "BinderList" then
			child.Visible = false
		end
	end

	ui.list = ui.gridRoot:FindFirstChild("BinderList")
	if not ui.list or not ui.list:IsA("ScrollingFrame") then
		ui.list = Instance.new("ScrollingFrame")
		ui.list.Name = "BinderList"
		ui.list.BackgroundTransparency = 1
		ui.list.BorderSizePixel = 0
		ui.list.Position = UDim2.fromScale(0, 0)
		ui.list.Size = UDim2.fromScale(1, 1)
		ui.list.CanvasSize = UDim2.fromOffset(0, 0)
		ui.list.ScrollBarThickness = 6
		ui.list.Parent = ui.gridRoot
	end

	local layout = ui.list:FindFirstChildOfClass("UIGridLayout") or Instance.new("UIGridLayout")
	layout.CellPadding = UDim2.fromOffset(10, 10)
	layout.CellSize = UDim2.fromOffset(130, 112)
	layout.SortOrder = Enum.SortOrder.LayoutOrder
	layout.Parent = ui.list
	if not ui.list:GetAttribute("BinderLayoutConnected") then
		ui.list:SetAttribute("BinderLayoutConnected", true)
		layout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
			ui.list.CanvasSize = UDim2.fromOffset(0, layout.AbsoluteContentSize.Y + 18)
		end)
	end

	local padding = ui.list:FindFirstChildOfClass("UIPadding") or Instance.new("UIPadding")
	padding.PaddingTop = UDim.new(0, 8)
	padding.PaddingLeft = UDim.new(0, 8)
	padding.PaddingRight = UDim.new(0, 8)
	padding.PaddingBottom = UDim.new(0, 8)
	padding.Parent = ui.list

	ui.templates = inventoryWindow:FindFirstChild("Templates") or Instance.new("Folder")
	ui.templates.Name = "Templates"
	ui.templates.Parent = inventoryWindow

	ui.cardTemplate = ui.templates:FindFirstChild("ItemCardTemplate")
	if not ui.cardTemplate or not ui.cardTemplate:IsA("GuiObject") then
		local template = Instance.new("Frame")
		template.Name = "ItemCardTemplate"
		template.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
		template.BorderSizePixel = 0
		template.Size = UDim2.fromOffset(130, 112)
		template.Visible = false
		template.Parent = ui.templates

		local corner = Instance.new("UICorner")
		corner.CornerRadius = UDim.new(0, 12)
		corner.Parent = template

		local stroke = Instance.new("UIStroke")
		stroke.Color = Color3.fromRGB(35, 38, 45)
		stroke.Thickness = 2
		stroke.Parent = template

		ensureLabel(template, "IconText", "IT", UDim2.fromOffset(8, 8), UDim2.fromOffset(40, 28), 18).TextXAlignment = Enum.TextXAlignment.Center
		ensureLabel(template, "Name", "Item", UDim2.fromOffset(8, 38), UDim2.new(1, -16, 0, 32), 13)
		ensureLabel(template, "Meta", "Meta", UDim2.fromOffset(8, 72), UDim2.new(1, -16, 0, 28), 11)
		ui.cardTemplate = template
	else
		ui.cardTemplate.Visible = false
	end

	ui.detailTitle = ensureLabel(ui.details, "SelectLabel", "Select an Item", UDim2.fromOffset(14, 12), UDim2.new(1, -28, 0, 36), 22)
	ui.detailTitle.TextXAlignment = Enum.TextXAlignment.Center
	ui.detailName = ensureLabel(ui.details, "NameLabel", "", UDim2.fromOffset(14, 54), UDim2.new(1, -28, 0, 36), 20)
	ui.detailMeta = ensureLabel(ui.details, "MetaLabel", "", UDim2.fromOffset(14, 92), UDim2.new(1, -28, 0, 38), 14)
	ui.detailDescription = ensureLabel(ui.details, "DescriptionLabel", "Choose a card to see details.", UDim2.fromOffset(14, 136), UDim2.new(1, -28, 0, 96), 14)
	ui.detailStats = ensureLabel(ui.details, "StatsLabel", "", UDim2.fromOffset(14, 238), UDim2.new(1, -28, 0, 90), 13)
	ui.actionButton = ensureButton(ui.details, "EquipButton", "EQUIP", UDim2.new(0, 14, 1, -132), UDim2.new(1, -28, 0, 34))
	ui.lockButton = ensureButton(ui.details, "LockButton", "COMING SOON", UDim2.new(0, 14, 1, -90), UDim2.new(1, -28, 0, 34))
	ui.deleteButton = ensureButton(ui.details, "DeleteButton", "COMING SOON", UDim2.new(0, 14, 1, -48), UDim2.new(1, -28, 0, 34))

	connectPress(ui.actionButton, function()
		if not selectedEntry then
			return
		end

		if selectedEntry.kind == "Color" then
			if isColorEquipped(selectedEntry.entry) then
				equipPetEvent:FireServer("unequip", getEntryKey(selectedEntry.entry))
			else
				equipPetEvent:FireServer("equip", getEntryKey(selectedEntry.entry))
			end
		elseif selectedEntry.kind == "Brush" then
			equipPaintToolEvent:FireServer(selectedEntry.tool.Id, true)
		elseif selectedEntry.kind == "Item" and selectedEntry.item.usable then
			useItemEvent:FireServer(selectedEntry.itemId, 1)
		end
	end)

	connectPress(ui.lockButton, function()
		if selectedEntry and selectedEntry.kind == "Color" then
			local entry = selectedEntry.entry
			lockPetEvent:FireServer(getEntryKey(entry), not isColorLocked(entry))
		end
	end)
	connectPress(ui.deleteButton, function()
		if selectedEntry and selectedEntry.kind == "Color" then
			deletePetEvent:FireServer(getEntryKey(selectedEntry.entry))
		end
	end)
end

local function setTabVisuals()
	for _, tabName in ipairs(TAB_NAMES) do
		local tab = ui.tabs and ui.tabs:FindFirstChild(tabName .. "Tab")
		if tab and tab:IsA("TextButton") then
			local active = tabName == currentTab
			tab.BackgroundColor3 = active and Color3.fromRGB(82, 219, 225) or Color3.fromRGB(232, 238, 248)
			tab.TextColor3 = active and Color3.fromRGB(255, 255, 255) or Color3.fromRGB(38, 36, 52)
		end
	end
end

local function setDetailsEmpty(message)
	selectedEntry = nil
	ui.detailTitle.Text = "Select an Item"
	ui.detailName.Text = ""
	ui.detailMeta.Text = ""
	ui.detailDescription.Text = message or "Choose a card to see details."
	ui.detailStats.Text = ""
	ui.actionButton.Text = "SELECT"
	setButtonEnabled(ui.actionButton, false)
	ui.lockButton.Text = "COMING SOON"
	ui.deleteButton.Text = "COMING SOON"
	setButtonEnabled(ui.lockButton, false)
	setButtonEnabled(ui.deleteButton, false)
end

local function setDetailsForColor(entry)
	selectedEntry = { kind = "Color", entry = entry }
	local pet = PetData.Pets[entry.petId] or {}
	local definition = PetDefinitions.Get(entry.petId)
	local equipped = isColorEquipped(entry)
	local locked = isColorLocked(entry)

	ui.detailTitle.Text = "Color Details"
	ui.detailName.Text = entry.displayName or pet.displayName or entry.petId
	ui.detailMeta.Text = tostring(entry.rarity or pet.rarity or "Unknown") .. " | x" .. PetData.formatStack(entry.stackAmount or 1)
	ui.detailDescription.Text = tostring(entry.traitName or "Neutral") .. ": " .. tostring(entry.traitDescription or "No special trait.")
	ui.detailStats.Text = table.concat({
		"Power: " .. tostring(entry.effectivePower or entry.finalPower or 0),
		"Color Gain: x" .. string.format("%.2f", tonumber(entry.colorMult) or 1),
		"Sell Value: x" .. string.format("%.2f", tonumber(entry.coinMult) or 1),
		"Model: " .. tostring((definition and definition.ModelName) or pet.modelName or entry.petId),
	}, "\n")
	ui.actionButton.Text = equipped and "UNEQUIP" or "EQUIP"
	setButtonEnabled(ui.actionButton, true)
	ui.lockButton.Text = locked and "UNLOCK" or "LOCK"
	ui.deleteButton.Text = "DELETE"
	setButtonEnabled(ui.lockButton, true)
	setButtonEnabled(ui.deleteButton, not locked and not equipped)
end

local function setDetailsForBrush(tool)
	selectedEntry = { kind = "Brush", tool = tool }
	local equipped = getEquippedPaintToolId() == tool.Id

	ui.detailTitle.Text = "Brush Details"
	ui.detailName.Text = tool.DisplayName or tool.Id
	ui.detailMeta.Text = tostring(tool.Rarity or "Common") .. " | " .. tostring(tool.World or "World")
	ui.detailDescription.Text = tostring(tool.Description or tool.PassiveDescription or "Paint tool.")
	ui.detailStats.Text = table.concat({
		"Power: x" .. string.format("%.2f", tonumber(tool.PowerMultiplier) or 1),
		"Range: " .. tostring(tool.Range or "-"),
		"Width: " .. tostring(tool.Width or "-"),
		"Cooldown: " .. tostring(tool.Cooldown or "-"),
	}, "\n")
	ui.actionButton.Text = equipped and "EQUIPPED" or "EQUIP"
	setButtonEnabled(ui.actionButton, not equipped)
	ui.lockButton.Text = "LOCK COMING SOON"
	ui.deleteButton.Text = "DELETE COMING SOON"
	setButtonEnabled(ui.lockButton, false)
	setButtonEnabled(ui.deleteButton, false)
end

local function setDetailsForItem(itemId, item, quantity)
	selectedEntry = { kind = "Item", itemId = itemId, item = item }
	local usable = item.usable == true

	ui.detailTitle.Text = isPotion(item) and "Potion Details" or "Item Details"
	ui.detailName.Text = item.displayName or itemId
	ui.detailMeta.Text = tostring(item.rarity or "Common") .. " | x" .. ItemsData.formatNum(quantity or 0)
	ui.detailDescription.Text = tostring(item.description or "Inventory item.")
	ui.detailStats.Text = item.boostType and ("Boost: " .. tostring(item.boostType) .. "\nDuration: " .. tostring(item.boostDuration or 0) .. "s") or ""
	ui.actionButton.Text = usable and "USE" or "INFO"
	setButtonEnabled(ui.actionButton, usable)
	ui.lockButton.Text = "LOCKED"
	ui.deleteButton.Text = "DELETE COMING SOON"
	setButtonEnabled(ui.lockButton, false)
	setButtonEnabled(ui.deleteButton, false)
end

local function makeCard(layoutOrder, icon, title, meta, color, callback)
	local card = ui.cardTemplate:Clone()
	card.Name = "InventoryCard_" .. tostring(layoutOrder)
	card.Visible = true
	card.LayoutOrder = layoutOrder
	card.Parent = ui.list
	card.Active = true

	local stroke = card:FindFirstChildOfClass("UIStroke")
	if stroke then
		stroke.Color = color or Color3.fromRGB(35, 38, 45)
	end

	local iconLabel = card:FindFirstChild("IconText", true)
	if iconLabel and iconLabel:IsA("TextLabel") then
		iconLabel.Text = icon
		iconLabel.TextColor3 = color or Color3.fromRGB(38, 36, 52)
	end

	local nameLabel = card:FindFirstChild("Name", true)
	if nameLabel and nameLabel:IsA("TextLabel") then
		nameLabel.Text = title
	end

	local metaLabel = card:FindFirstChild("Meta", true)
	if metaLabel and metaLabel:IsA("TextLabel") then
		metaLabel.Text = meta
	end

	local viewport = card:FindFirstChildWhichIsA("ViewportFrame", true)
	if viewport and callback and string.sub(icon, 1, 1) ~= "" then
		-- PetModelUtil is intentionally used only when the editable template has a viewport slot.
		-- Text/color cards remain the fallback for simple Studio templates.
	end

	local connection
	connection = card.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			callback()
		end
	end)
	table.insert(connections, connection)

	return card
end

local function makeEmptyInventoryCard(message)
	makeCard(1, "--", message or "No items yet", "Come back after you earn one.", Color3.fromRGB(170, 180, 205), function() end)
end

local function refreshColors()
	table.sort(colorEntries, function(a, b)
		local rarityCompare = (RARITY_ORDER[a.rarity] or 99) < (RARITY_ORDER[b.rarity] or 99)
		if (RARITY_ORDER[a.rarity] or 99) ~= (RARITY_ORDER[b.rarity] or 99) then
			return rarityCompare
		end
		return (a.effectivePower or a.finalPower or 0) > (b.effectivePower or b.finalPower or 0)
	end)

	local count = 0
	for _, entry in ipairs(colorEntries) do
		count += 1
		local pet = PetData.Pets[entry.petId] or {}
		local definition = PetDefinitions.Get(entry.petId)
		local displayName = entry.displayName or pet.displayName or entry.petId
		local color = (definition and definition.IconColor) or entry.baseColor or pet.color or Color3.fromRGB(170, 180, 205)
		local icon = string.upper(string.sub(displayName, 1, 2))
		local equippedText = isColorEquipped(entry) and " | EQUIPPED" or ""
		local lockedText = isColorLocked(entry) and " | LOCKED" or ""
		local meta = tostring(entry.rarity or pet.rarity or "Color") .. " x" .. PetData.formatStack(entry.stackAmount or 1) .. equippedText .. lockedText
		local card = makeCard(count, icon, displayName, meta, color, function()
			setDetailsForColor(entry)
		end)
		local viewport = card:FindFirstChildWhichIsA("ViewportFrame", true)
		if viewport then
			pcall(function()
				PetModelUtil.MountViewport(viewport, entry.petId, { spin = false })
			end)
		end
	end

	return count
end

local function refreshBrushes()
	local owned = getOwnedPaintToolSet()
	local count = 0
	for _, toolId in ipairs(ToolData.Order or {}) do
		local tool = ToolData.Tools[toolId]
		if tool and owned[toolId] then
			count += 1
			local color = ToolData.RarityColors and ToolData.RarityColors[tool.Rarity or "Common"] or tool.PaintColor or Color3.fromRGB(82, 219, 225)
			local equippedText = getEquippedPaintToolId() == tool.Id and " | EQUIPPED" or ""
			makeCard(count, tool.ShortName or "BR", tool.DisplayName or tool.Id, tostring(tool.Rarity or "Brush") .. equippedText, color, function()
				setDetailsForBrush(tool)
			end)
		end
	end
	return count
end

local function getSortedOwnedItems(wantPotions)
	local list = {}
	for itemId, quantity in pairs(playerItems) do
		local item = ItemsData.Items[itemId]
		if item and quantity > 0 and isPotion(item) == wantPotions then
			table.insert(list, { id = itemId, item = item, quantity = quantity })
		end
	end
	table.sort(list, function(a, b)
		local rarityA = ItemsData.Rarities[a.item.rarity or "Common"]
		local rarityB = ItemsData.Rarities[b.item.rarity or "Common"]
		local orderA = rarityA and rarityA.order or 99
		local orderB = rarityB and rarityB.order or 99
		if orderA ~= orderB then
			return orderA > orderB
		end
		return (a.item.displayName or a.id) < (b.item.displayName or b.id)
	end)
	return list
end

local function refreshItems(wantPotions)
	local list = getSortedOwnedItems(wantPotions)
	for index, entry in ipairs(list) do
		local rarity = ItemsData.Rarities[entry.item.rarity or "Common"]
		makeCard(index, entry.item.icon or "IT", entry.item.displayName or entry.id, "x" .. ItemsData.formatNum(entry.quantity), rarity and rarity.color or Color3.fromRGB(170, 180, 205), function()
			setDetailsForItem(entry.id, entry.item, entry.quantity)
		end)
	end
	return #list
end

local function refreshInventory()
	if not ui.list then
		return
	end

	clearList()
	setTabVisuals()

	local count = 0
	if currentTab == "Colors" then
		count = refreshColors()
	elseif currentTab == "Brushes" then
		count = refreshBrushes()
	elseif currentTab == "Potions" then
		count = refreshItems(true)
	elseif currentTab == "Items" then
		count = refreshItems(false)
	end

	if count == 0 then
		makeEmptyInventoryCard("No items yet")
		setDetailsEmpty("No items yet.")
	elseif not selectedEntry then
		setDetailsEmpty("Choose a card to see details.")
	end
end

local function setTab(tabName)
	currentTab = tabName
	selectedEntry = nil
	refreshInventory()
end

local function wireTabs()
	for _, tabName in ipairs(TAB_NAMES) do
		local tab = ui.tabs:FindFirstChild(tabName .. "Tab")
		if not tab or not tab:IsA("TextButton") then
			tab = ensureButton(ui.tabs, tabName .. "Tab", tabName, UDim2.fromOffset(0, 0), UDim2.fromOffset(118, 34))
		end
		connectPress(tab, function()
			setTab(tabName)
		end)
	end
end

local function refreshPetsFromValues()
	if petInventoryValue then
		colorEntries = parsePetInventoryValue(petInventoryValue.Value)
	end
	if petEquippedValue then
		equippedColors = parseEquippedValue(petEquippedValue.Value)
	end
	local lockedValue = petFolder and petFolder:FindFirstChild("Locked")
	if lockedValue and lockedValue:IsA("StringValue") then
		lockedColors = parseLockedValue(lockedValue.Value)
	end
	if inventoryWindow.Visible then
		refreshInventory()
	end
end

local function applyPetState(inventory, equipped)
	colorEntries = inventory or {}
	equippedColors = equipped or {}
	table.clear(lockedColors)
	for _, entry in ipairs(colorEntries) do
		if entry.isLocked == true then
			lockedColors[getEntryKey(entry)] = true
		end
	end
	if inventoryWindow.Visible then
		refreshInventory()
	end
end

local function setupDataListeners()
	if petInventoryValue then
		petInventoryValue:GetPropertyChangedSignal("Value"):Connect(refreshPetsFromValues)
	end
	if petEquippedValue then
		petEquippedValue:GetPropertyChangedSignal("Value"):Connect(refreshPetsFromValues)
	end
	local lockedValue = petFolder and petFolder:FindFirstChild("Locked")
	if lockedValue and lockedValue:IsA("StringValue") then
		lockedValue:GetPropertyChangedSignal("Value"):Connect(refreshPetsFromValues)
	end
	if petFolder then
		petFolder.ChildAdded:Connect(function(child)
			if child.Name == "Locked" and child:IsA("StringValue") then
				child:GetPropertyChangedSignal("Value"):Connect(refreshPetsFromValues)
				refreshPetsFromValues()
			end
		end)
	end
	if ownedPaintToolsValue then
		ownedPaintToolsValue:GetPropertyChangedSignal("Value"):Connect(function()
			if currentTab == "Brushes" and inventoryWindow.Visible then
				refreshInventory()
			end
		end)
	end
	if equippedPaintToolValue then
		equippedPaintToolValue:GetPropertyChangedSignal("Value"):Connect(function()
			if currentTab == "Brushes" and inventoryWindow.Visible then
				refreshInventory()
			end
		end)
	end

	petsLoadedEvent.OnClientEvent:Connect(applyPetState)
	useItemEvent.OnClientEvent:Connect(function(resultType, arg1, arg2)
		if resultType == "sync" and type(arg1) == "table" then
			table.clear(playerItems)
			for itemId, quantity in pairs(arg1) do
				setItemQuantity(itemId, quantity)
			end
		elseif resultType == "update" or resultType == "used" or resultType == "boosted" then
			setItemQuantity(arg1, arg2)
		end

		if (currentTab == "Potions" or currentTab == "Items") and inventoryWindow.Visible then
			refreshInventory()
		end
	end)
end

local function getWindowContent(windowName)
	local window = windows:FindFirstChild(windowName)
	if not window or not window:IsA("GuiObject") then
		warn("EditorWindowBinder: missing MainHUD.ModalWindows.Windows." .. windowName)
		return nil, nil
	end

	local content = findGuiObject(window, "Content") or ensureFrame(window, "Content", UDim2.fromOffset(22, 82), UDim2.new(1, -44, 1, -108))
	return window, content
end

local function ensureBinderList(content)
	local list = content:FindFirstChild("BinderList")
	if not list or not list:IsA("ScrollingFrame") then
		list = Instance.new("ScrollingFrame")
		list.Name = "BinderList"
		list.BackgroundTransparency = 1
		list.BorderSizePixel = 0
		list.Position = UDim2.fromScale(0, 0)
		list.Size = UDim2.fromScale(1, 1)
		list.CanvasSize = UDim2.fromOffset(0, 0)
		list.ScrollBarThickness = 6
		list.Parent = content
	end

	for _, child in ipairs(content:GetChildren()) do
		if child ~= list and child:IsA("GuiObject") then
			child.Visible = false
		end
	end

	local layout = list:FindFirstChildOfClass("UIListLayout") or Instance.new("UIListLayout")
	layout.SortOrder = Enum.SortOrder.LayoutOrder
	layout.Padding = UDim.new(0, 10)
	layout.Parent = list
	if not list:GetAttribute("BinderLayoutConnected") then
		list:SetAttribute("BinderLayoutConnected", true)
		layout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
			list.CanvasSize = UDim2.fromOffset(0, layout.AbsoluteContentSize.Y + 20)
		end)
	end

	local padding = list:FindFirstChildOfClass("UIPadding") or Instance.new("UIPadding")
	padding.PaddingTop = UDim.new(0, 12)
	padding.PaddingLeft = UDim.new(0, 12)
	padding.PaddingRight = UDim.new(0, 12)
	padding.PaddingBottom = UDim.new(0, 12)
	padding.Parent = list

	for _, child in ipairs(list:GetChildren()) do
		if not child:IsA("UIListLayout") and not child:IsA("UIPadding") then
			child:Destroy()
		end
	end

	return list
end

local function makeWindowCard(list, order, title, body, buttonText, callback, color)
	local card = Instance.new("Frame")
	card.Name = "BinderCard_" .. tostring(order)
	card.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
	card.BorderSizePixel = 0
	card.LayoutOrder = order
	card.Size = UDim2.new(1, -6, 0, 98)
	card.Parent = list

	local corner = Instance.new("UICorner")
	corner.CornerRadius = UDim.new(0, 12)
	corner.Parent = card

	local stroke = Instance.new("UIStroke")
	stroke.Color = color or Color3.fromRGB(35, 38, 45)
	stroke.Thickness = 2
	stroke.Parent = card

	ensureLabel(card, "Title", title, UDim2.fromOffset(14, 10), UDim2.new(1, -150, 0, 26), 18)
	ensureLabel(card, "Body", body, UDim2.fromOffset(14, 40), UDim2.new(1, -150, 0, 48), 13)

	if buttonText then
		local button = ensureButton(card, "ActionButton", buttonText, UDim2.new(1, -128, 0.5, -17), UDim2.fromOffset(112, 34))
		if callback then
			connectPress(button, callback)
		else
			setButtonEnabled(button, false)
		end
	end

	return card
end

local function getOwnedColorSet()
	local storage = player:FindFirstChild("ColorStorage")
	local unlockedValue = storage and storage:FindFirstChild("UnlockedColors")
	return ColorData.getUnlockedColorSet(unlockedValue and unlockedValue.Value or "Red")
end

local function getCurrentWorld()
	local storage = player:FindFirstChild("ColorStorage")
	local currentValue = storage and storage:FindFirstChild("CurrentWorld")
	return currentValue and currentValue.Value or player:GetAttribute("ActiveWorldColor") or "Red"
end

local function getCurrentCoins()
	local stats = player:FindFirstChild("leaderstats")
	local coins = stats and stats:FindFirstChild("Coins")
	return coins and tonumber(coins.Value) or 0
end

local function getUpgradeLevel(upgradeId)
	local folder = player:FindFirstChild("Upgrades")
	if not folder then
		return 0
	end

	local levelValue = folder:FindFirstChild(upgradeId .. "_Level")
	if levelValue and (levelValue:IsA("IntValue") or levelValue:IsA("NumberValue")) then
		return levelValue.Value
	end
	return 0
end

local renderShop

local function getOrCreateTemplatesFolder(window)
	local templates = window:FindFirstChild("Templates")
	if not templates then
		templates = Instance.new("Folder")
		templates.Name = "Templates"
		templates.Parent = window
	end
	return templates
end

local function ensureShopCardTemplate(shopWindow)
	local templates = getOrCreateTemplatesFolder(shopWindow)
	local template = templates:FindFirstChild("ShopCardTemplate")
	if template and template:IsA("GuiObject") then
		template.Visible = false
		return template
	end

	template = Instance.new("Frame")
	template.Name = "ShopCardTemplate"
	template.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
	template.BorderSizePixel = 0
	template.Size = UDim2.new(1, -6, 0, 116)
	template.Visible = false
	template.Parent = templates

	local corner = Instance.new("UICorner")
	corner.CornerRadius = UDim.new(0, 12)
	corner.Parent = template

	local stroke = Instance.new("UIStroke")
	stroke.Color = Color3.fromRGB(35, 38, 45)
	stroke.Thickness = 2
	stroke.Parent = template

	local iconFrame = ensureFrame(template, "Icon", UDim2.fromOffset(12, 14), UDim2.fromOffset(72, 72), Color3.fromRGB(244, 248, 252))
	ensureLabel(iconFrame, "IconText", "VIP", UDim2.fromScale(0, 0), UDim2.fromScale(1, 1), 20).TextXAlignment = Enum.TextXAlignment.Center
	local image = Instance.new("ImageLabel")
	image.Name = "IconImage"
	image.BackgroundTransparency = 1
	image.Size = UDim2.fromScale(1, 1)
	image.Visible = false
	image.Parent = iconFrame

	ensureLabel(template, "Name", "Product", UDim2.fromOffset(96, 10), UDim2.new(1, -238, 0, 26), 18)
	ensureLabel(template, "Description", "Description", UDim2.fromOffset(96, 38), UDim2.new(1, -238, 0, 40), 13)
	ensureLabel(template, "Badge", "", UDim2.fromOffset(96, 80), UDim2.new(1, -238, 0, 22), 12)
	ensureLabel(template, "Price", "R$ 0", UDim2.new(1, -130, 0, 14), UDim2.fromOffset(112, 24), 14).TextXAlignment = Enum.TextXAlignment.Center
	ensureButton(template, "BuyButton", "BUY", UDim2.new(1, -130, 1, -48), UDim2.fromOffset(112, 34))

	return template
end

local function ensureShopTabs(shopWindow)
	local tabs = findGuiObject(shopWindow, "Tabs") or ensureFrame(shopWindow, "Tabs", UDim2.fromOffset(22, 68), UDim2.new(1, -44, 0, 40))
	local desiredTabs = { "Bundles", "Gamepasses", "Potions", "Currency" }
	local desiredSet = {}
	for index, tabName in ipairs(desiredTabs) do
		desiredSet[tabName .. "Tab"] = true
		local tab = tabs:FindFirstChild(tabName .. "Tab")
		if not tab or not tab:IsA("TextButton") then
			tab = ensureButton(tabs, tabName .. "Tab", tabName, UDim2.fromOffset(0, 0), UDim2.fromOffset(118, 34))
		end
		tab.Text = tabName
		tab.LayoutOrder = index
		tab.Visible = true
		if not tab:GetAttribute("ShopTabConnected") then
			tab:SetAttribute("ShopTabConnected", true)
			connectPress(tab, function()
				currentShopTab = tabName
				renderShop()
			end)
		end
	end

	for _, child in ipairs(tabs:GetChildren()) do
		if child:IsA("GuiObject") and string.sub(child.Name, -3) == "Tab" and not desiredSet[child.Name] then
			child.Visible = false
		end
	end

	return tabs
end

local function setShopTabVisuals(tabs)
	for _, tabName in ipairs({ "Bundles", "Gamepasses", "Potions", "Currency" }) do
		local tab = tabs and tabs:FindFirstChild(tabName .. "Tab")
		if tab and tab:IsA("TextButton") then
			local active = tabName == currentShopTab
			tab.BackgroundColor3 = active and Color3.fromRGB(82, 219, 225) or Color3.fromRGB(232, 238, 248)
			tab.TextColor3 = active and Color3.fromRGB(255, 255, 255) or Color3.fromRGB(38, 36, 52)
		end
	end
end

local function setShopTitle(shopWindow)
	local title = shopWindow:FindFirstChild("Title")
	if title and title:IsA("TextLabel") then
		title.Text = "ROBUX SHOP"
	end
end

local function ownsGamepass(pass)
	local gamepassId = tonumber(pass and pass.gamepassId)
	if not gamepassId or gamepassId <= 0 then
		return false
	end

	if player:GetAttribute("Pass_" .. tostring(pass.id)) == true then
		return true
	end

	local grants = player:FindFirstChild("GamepassGrants")
	local grant = grants and (grants:FindFirstChild(tostring(pass.id)) or grants:FindFirstChild(tostring(gamepassId)))
	return grant and grant:IsA("BoolValue") and grant.Value == true
end

local function makeShopCard(list, template, order, data)
	local card = template:Clone()
	card.Name = "ShopCard_" .. tostring(order)
	card.LayoutOrder = order
	card.Visible = true
	card.Parent = list

	local iconImage = card:FindFirstChild("IconImage", true)
	if iconImage and iconImage:IsA("ImageLabel") then
		iconImage.Image = tostring(data.image or "")
		iconImage.Visible = data.image ~= nil and data.image ~= ""
	end

	local iconText = card:FindFirstChild("IconText", true)
	if iconText and iconText:IsA("TextLabel") then
		iconText.Text = tostring(data.icon or "")
		iconText.Visible = not (data.image ~= nil and data.image ~= "")
	end

	local name = card:FindFirstChild("Name", true)
	if name and name:IsA("TextLabel") then
		name.Text = tostring(data.title or "")
	end

	local description = card:FindFirstChild("Description", true)
	if description and description:IsA("TextLabel") then
		description.Text = tostring(data.description or "")
	end

	local badge = card:FindFirstChild("Badge", true)
	if badge and badge:IsA("TextLabel") then
		badge.Text = tostring(data.badge or "")
		badge.Visible = data.badge ~= nil and data.badge ~= ""
	end

	local price = card:FindFirstChild("Price", true)
	if price and price:IsA("TextLabel") then
		price.Text = tostring(data.priceText or "")
	end

	local button = card:FindFirstChild("BuyButton", true)
	if button and button:IsA("TextButton") then
		button.Text = tostring(data.buttonText or "BUY")
		if data.callback then
			setButtonEnabled(button, true)
			connectPress(button, data.callback)
		else
			setButtonEnabled(button, false)
		end
	end

	local stroke = card:FindFirstChildOfClass("UIStroke")
	if stroke then
		stroke.Color = data.color or Color3.fromRGB(35, 38, 45)
	end

	return card
end

function renderShop()
	local shopWindow, content = getWindowContent("ShopWindow")
	if not content then
		return
	end

	setShopTitle(shopWindow)
	local tabs = ensureShopTabs(shopWindow)
	setShopTabVisuals(tabs)
	local template = ensureShopCardTemplate(shopWindow)
	local list = ensureBinderList(content)
	local order = 0

	if currentShopTab == "Gamepasses" then
		for _, pass in ipairs(RobuxShopConfig.getSortedGamepasses()) do
			if not SHOP_GAMEPASS_IDS[pass.id] then
				continue
			end
			order += 1
			local gamepassId = tonumber(pass.gamepassId)
			local owned = ownsGamepass(pass)
			local canPrompt = gamepassId and gamepassId > 0 and not owned
			makeShopCard(
				list,
				template,
				order,
				{
					icon = pass.icon,
					image = pass.iconImage,
					title = pass.displayName or pass.id,
					description = pass.description or "Gamepass",
					badge = pass.badge,
					priceText = pass.price and ("R$ " .. tostring(pass.price)) or "R$ ?",
					buttonText = owned and "OWNED" or (canPrompt and "BUY" or "SET ID"),
					callback = canPrompt and function()
						MarketplaceService:PromptGamePassPurchase(player, gamepassId)
					end or nil,
					color = pass.color,
				}
			)
		end
		if order == 0 then
			makeShopCard(list, template, 1, {
				icon = "GP",
				title = "Gamepasses",
				description = "Gamepass config is not ready.",
				priceText = "",
				buttonText = "COMING SOON",
				color = Color3.fromRGB(170, 180, 205),
			})
		end

	elseif currentShopTab == "Potions" then
		local hasPotionProducts = false
		for _, product in ipairs(RobuxShopConfig.getSortedDevProducts()) do
			if product.category == "Potions" or product.category == "Boosts" or product.boostType then
				hasPotionProducts = true
				order += 1
				local productId = tonumber(product.productId)
				makeShopCard(list, template, order, {
					icon = product.icon,
					image = product.iconImage,
					title = product.displayName or product.id,
					description = product.description or "Boost",
					badge = product.badge,
					priceText = product.price and ("R$ " .. tostring(product.price)) or "R$ ?",
					buttonText = productId and productId > 0 and "BUY" or "SET ID",
					callback = productId and productId > 0 and function()
						MarketplaceService:PromptProductPurchase(player, productId)
					end or nil,
					color = product.color,
				})
			end
		end
		if not hasPotionProducts then
			makeShopCard(list, template, 1, {
				icon = "POT",
				title = "Potions",
				description = "Potion products coming soon.",
				priceText = "",
				buttonText = "COMING SOON",
				color = Color3.fromRGB(170, 180, 205),
			})
		end

	elseif currentShopTab == "Currency" then
		local products = RobuxShopConfig.getSortedDevProducts()
		if #products == 0 then
			makeShopCard(list, template, 1, {
				icon = "$",
				title = "Currency",
				description = "Currency packs coming soon.",
				priceText = "",
				buttonText = "COMING SOON",
				color = Color3.fromRGB(170, 180, 205),
			})
		else
			for _, product in ipairs(products) do
				order += 1
				local productId = tonumber(product.productId)
				makeShopCard(list, template, order, {
					icon = product.icon,
					image = product.iconImage,
					title = product.displayName or product.id,
					description = product.description or "Currency pack",
					badge = product.badge,
					priceText = product.price and ("R$ " .. tostring(product.price)) or "R$ ?",
					buttonText = productId and productId > 0 and "BUY" or "SET ID",
					callback = productId and productId > 0 and function()
						MarketplaceService:PromptProductPurchase(player, productId)
					end or nil,
					color = product.color,
				})
			end
		end

	elseif currentShopTab == "Bundles" then
		makeShopCard(list, template, 1, {
			icon = "FP",
			title = "FOREVER PAINTER",
			description = "Permanent supporter bundle coming soon.",
			priceText = "",
			buttonText = "COMING SOON",
			color = Color3.fromRGB(177, 141, 255),
		})
	end
end

local function renderUpgrades()
	local _, content = getWindowContent("UpgradesWindow")
	if not content then
		return
	end

	local list = ensureBinderList(content)
	for index, upgrade in ipairs(UpgradeData.Upgrades or {}) do
		if not upgrade.id then
			warn("EditorWindowBinder: UpgradeData entry missing id at index " .. tostring(index))
			continue
		end

		local level = getUpgradeLevel(upgrade.id)
		local maxLevel = #(upgrade.levels or {})
		local nextLevel = math.min(level + 1, maxLevel)
		local nextData = upgrade.levels and upgrade.levels[nextLevel]
		local maxed = level >= maxLevel
		local body = "Level " .. tostring(level) .. "/" .. tostring(maxLevel)
			.. "\nCurrent: " .. UpgradeData.getValueDisplay(upgrade.id, level)
			.. "\n" .. tostring(upgrade.description or "")
		if nextData then
			body ..= "\nNext: " .. UpgradeData.getValueDisplay(upgrade.id, nextLevel) .. " | " .. UpgradeData.formatNumber(nextData.cost) .. " Coins"
		end

		makeWindowCard(list, index, upgrade.displayName or upgrade.id, body, maxed and "MAXED" or "UPGRADE", maxed and nil or function()
			purchaseUpgradeEvent:FireServer(upgrade.id)
		end, Color3.fromRGB(116, 232, 158))
	end
end

local function getSettingValue(settingKey, defaultValue)
	local folder = player:FindFirstChild("Settings")
	local value = folder and folder:FindFirstChild(settingKey)
	if value and value:IsA("BoolValue") then
		return value.Value
	end
	return defaultValue
end

local function renderSettings()
	local _, content = getWindowContent("SettingsWindow")
	if not content then
		return
	end

	local list = ensureBinderList(content)
	local settings = {
		{ title = "Music", key = "Music", default = true },
		{ title = "SFX", key = "SFX", default = true },
		{ title = "Low Detail", key = "LowFX", default = false },
	}

	for index, setting in ipairs(settings) do
		local enabled = getSettingValue(setting.key, setting.default)
		makeWindowCard(list, index, setting.title, "Current: " .. (enabled and "ON" or "OFF"), enabled and "TURN OFF" or "TURN ON", function()
			requestSetSettingEvent:FireServer(setting.key, not enabled)
		end, Color3.fromRGB(82, 219, 225))
	end

	makeWindowCard(list, 4, "Hide Pets", "This setting is not in the current settings schema yet.", "COMING SOON", nil, Color3.fromRGB(170, 180, 205))
	makeWindowCard(list, 5, "Auto Delete", "Auto delete configuration is coming soon.", "COMING SOON", nil, Color3.fromRGB(170, 180, 205))
end

local codeStatusLabel = nil

local function trim(text)
	return string.gsub(tostring(text or ""), "^%s*(.-)%s*$", "%1")
end

local function renderCodes()
	local codeWindow, content = getWindowContent("CodesWindow")
	if not content then
		return
	end

	local codeBox = codeWindow:FindFirstChild("CodeBox", true)
		or codeWindow:FindFirstChild("CodeInput", true)
	local redeemButton = codeWindow:FindFirstChild("RedeemButton", true)
	local infoText = codeWindow:FindFirstChild("InfoText", true)
		or codeWindow:FindFirstChild("StatusText", true)
		or codeWindow:FindFirstChild("StatusLabel", true)
	local recentRewards = codeWindow:FindFirstChild("RecentRewards", true)

	if not (codeBox and codeBox:IsA("TextBox") and redeemButton and redeemButton:IsA("GuiButton")) then
		local list = ensureBinderList(content)
		local card = makeWindowCard(list, 1, "Codes", "Enter a code and redeem it.", nil, nil, Color3.fromRGB(255, 224, 104))
		codeBox = Instance.new("TextBox")
		codeBox.Name = "CodeBox"
		codeBox.PlaceholderText = "CODE"
		codeBox.Text = ""
		codeBox.ClearTextOnFocus = false
		codeBox.Font = Enum.Font.GothamBold
		codeBox.TextSize = 16
		codeBox.TextColor3 = Color3.fromRGB(38, 36, 52)
		codeBox.BackgroundColor3 = Color3.fromRGB(244, 248, 252)
		codeBox.BorderSizePixel = 0
		codeBox.Position = UDim2.new(1, -260, 0.5, -17)
		codeBox.Size = UDim2.fromOffset(132, 34)
		codeBox.Parent = card
		redeemButton = ensureButton(card, "RedeemButton", "REDEEM", UDim2.new(1, -118, 0.5, -17), UDim2.fromOffset(102, 34))
		infoText = card:FindFirstChild("Body")
	end

	if infoText and infoText:IsA("TextLabel") then
		codeStatusLabel = infoText
		if codeStatusLabel.Text == "" then
			codeStatusLabel.Text = "Enter a code."
		end
	end

	if recentRewards and recentRewards:IsA("TextLabel") and recentRewards.Text == "" then
		recentRewards.Text = "Recent rewards will appear here."
	end

	if redeemButton and redeemButton:IsA("GuiButton") and not redeemButton:GetAttribute("EditorCodesBound") then
		redeemButton:SetAttribute("EditorCodesBound", true)
		connectPress(redeemButton, function()
			local box = codeWindow:FindFirstChild("CodeBox", true) or codeWindow:FindFirstChild("CodeInput", true)
			local code = box and box:IsA("TextBox") and trim(box.Text) or ""
			if code == "" then
				if codeStatusLabel then
					codeStatusLabel.Text = "Enter a code first."
				end
				return
			end
			if codeStatusLabel then
				codeStatusLabel.Text = "Checking code..."
			end
			redeemCodeEvent:FireServer(code)
		end)
	end
end

local function renderTrade()
	local _, content = getWindowContent("TradeWindow")
	if not content then
		return
	end
	local list = ensureBinderList(content)
	makeWindowCard(list, 1, "Trading", "Trading is coming soon.", nil, nil, Color3.fromRGB(192, 154, 255))
end

local WORLD_CARD_NAMES = {
	Red = { "RedAreaCard", "RedWorldCard", "RedSectorCard", "RedCard" },
	Orange = { "OrangeAreaCard", "OrangeWorldCard", "OrangeSectorCard", "OrangeCard" },
	Blue = { "BlueAreaCard", "BlueWorldCard", "BlueSectorCard", "BlueCard" },
	Yellow = { "YellowAreaCard", "YellowWorldCard", "YellowSectorCard", "YellowCard" },
	Green = { "GreenAreaCard", "GreenWorldCard", "GreenSectorCard", "GreenCard" },
	Purple = { "PurpleAreaCard", "PurpleWorldCard", "PurpleSectorCard", "PurpleCard" },
	Neon = { "NeonAreaCard", "NeonWorldCard", "NeonSectorCard", "NeonCard" },
	Rainbow = { "RainbowAreaCard", "RainbowWorldCard", "RainbowSectorCard", "RainbowCard" },
}

local function findWorldCard(content, colorType)
	for _, name in ipairs(WORLD_CARD_NAMES[colorType] or {}) do
		local card = content:FindFirstChild(name, true)
		if card and card:IsA("GuiObject") then
			return card
		end
	end
	return nil
end

local function findTeleportButton(card, colorType)
	if not card then
		return nil
	end

	local button = card:FindFirstChild("TeleportButton", true)
		or card:FindFirstChild("WorldTeleportButton_" .. tostring(colorType), true)
	if button and button:IsA("TextButton") then
		return button
	end
	return nil
end

local function setWorldButtonFeedback(button, text, restoreText)
	if not button then
		return
	end
	button.Text = text
	task.delay(1.2, function()
		if button and button.Parent and button.Text == text then
			button.Text = restoreText
		end
	end)
end

local function teleportToWorld(world, button)
	local colorType = world and (world.primaryColor or world.id)
	if not colorType then
		return
	end

	local unlocked = getOwnedColorSet()
	if unlocked[colorType] ~= true then
		setWorldButtonFeedback(button, "LOCKED", "LOCKED")
		warn("EditorWindowBinder: blocked locked Sector teleport to " .. tostring(colorType))
		return
	end

	if getCurrentWorld() == colorType then
		setWorldButtonFeedback(button, "CURRENT", "CURRENT")
		return
	end

	requestTravelToSectorEvent:FireServer(colorType)
	setWorldButtonFeedback(button, "GOING", "GO")
end

local function unlockWorld(world, button)
	local colorType = world and (world.primaryColor or world.id)
	if not colorType then
		return
	end

	local previous = ColorData.getPreviousWorld(colorType)
	local unlocked = getOwnedColorSet()
	if previous and unlocked[previous.primaryColor] ~= true then
		setWorldButtonFeedback(button, "LOCKED", "UNLOCK")
		return
	end

	local cost = tonumber(world.UnlockCost or world.unlockCost) or 0
	if getCurrentCoins() < cost then
		setWorldButtonFeedback(button, "NEED COINS", "UNLOCK")
		return
	end

	unlockAreaEvent:FireServer("unlock", colorType)
	setWorldButtonFeedback(button, "BUYING", "UNLOCK")
end

local function bindWorldCard(content, world, isUnlocked, isCurrent)
	local colorType = world.primaryColor or world.id
	local card = findWorldCard(content, colorType)
	local button = findTeleportButton(card, colorType)
	if not button then
		return false
	end

	button.Visible = true
	local previous = ColorData.getPreviousWorld(colorType)
	local canUnlock = not isUnlocked
		and (not previous or getOwnedColorSet()[previous.primaryColor] == true)
		and getCurrentCoins() >= (tonumber(world.UnlockCost or world.unlockCost) or 0)
	button.Active = isUnlocked or canUnlock
	button.AutoButtonColor = isUnlocked or canUnlock
	button.Text = isCurrent and "CURRENT" or (isUnlocked and "GO" or (canUnlock and "UNLOCK" or "LOCKED"))
	button.BackgroundTransparency = (isUnlocked or canUnlock) and 0 or 0.25

	if not button:GetAttribute("EditorWorldTeleportBound") then
		button:SetAttribute("EditorWorldTeleportBound", true)
		connectPress(button, function()
			local boundColor = button:GetAttribute("WorldColor")
			local boundWorld = boundColor and ColorData.getWorldByColor(boundColor) or world
			local boundUnlocked = getOwnedColorSet()
			local boundPrimaryColor = boundWorld and (boundWorld.primaryColor or boundWorld.id)
			if boundPrimaryColor and boundUnlocked[boundPrimaryColor] ~= true then
				unlockWorld(boundWorld, button)
			else
				teleportToWorld(boundWorld, button)
			end
		end)
	end
	button:SetAttribute("WorldColor", colorType)

	local status = card and (card:FindFirstChild("Status", true) or card:FindFirstChild("StatusLabel", true) or card:FindFirstChild("Requirement", true))
	if status and status:IsA("TextLabel") then
		status.Text = isUnlocked and (isCurrent and "Current Sector" or "Unlocked")
			or ("Unlock for " .. UpgradeData.formatNumber(world.UnlockCost or world.unlockCost or 0) .. " Coins")
	end

	return true
end

local function renderWorlds()
	local _, content = getWindowContent("WorldsWindow")
	if not content then
		return
	end

	local unlocked = getOwnedColorSet()
	local current = getCurrentWorld()
	local boundExistingCards = 0
	for _, world in ipairs(ColorData.Worlds or {}) do
		local colorType = world.primaryColor or world.id
		local isUnlocked = unlocked[colorType] == true
		local isCurrent = current == colorType
		if bindWorldCard(content, world, isUnlocked, isCurrent) then
			boundExistingCards += 1
		end
	end

	if boundExistingCards > 0 then
		local list = content:FindFirstChild("BinderList")
		if list and list:IsA("GuiObject") then
			list.Visible = false
		end
		return
	end

	local list = ensureBinderList(content)
	for index, world in ipairs(ColorData.Worlds or {}) do
		local colorType = world.primaryColor or world.id
		local isUnlocked = unlocked[colorType] == true
		local isCurrent = current == colorType
		local requirement = isUnlocked and "Unlocked" or ("Requires " .. tostring(world.RequiredZoneId or "previous Sector") .. " | " .. UpgradeData.formatNumber(world.UnlockCost or world.unlockCost or 0) .. " Coins")
		local previous = ColorData.getPreviousWorld(colorType)
		local canUnlock = not isUnlocked
			and (not previous or unlocked[previous.primaryColor] == true)
			and getCurrentCoins() >= (tonumber(world.UnlockCost or world.unlockCost) or 0)
		local buttonText = isCurrent and "CURRENT" or (isUnlocked and "GO" or (canUnlock and "UNLOCK" or "LOCKED"))
		local colorConfig = colorType and ColorData.Colors[colorType]
		local card
		card = makeWindowCard(list, index, world.DisplayName or world.name or colorType, requirement, buttonText, (isUnlocked or canUnlock) and function()
			local button = card and card:FindFirstChild("ActionButton", true)
			if isUnlocked then
				teleportToWorld(world, button)
			else
				unlockWorld(world, button)
			end
		end or nil, colorConfig and colorConfig.color)
	end
end

local dailyQuestData = nil

local function formatDuration(seconds)
	seconds = math.max(0, math.floor(tonumber(seconds) or 0))
	local hours = math.floor(seconds / 3600)
	local minutes = math.floor((seconds % 3600) / 60)
	return string.format("%02dh %02dm", hours, minutes)
end

local function copyDailyQuestFallback(index)
	local source = FALLBACK_DAILY_QUESTS[index] or FALLBACK_DAILY_QUESTS[1]
	local copy = {}
	for key, value in pairs(source) do
		copy[key] = value
	end
	return copy
end

local function getDailyQuestRows(data)
	local source = type(data) == "table" and (data.Quests or data.quests) or nil
	local rows = {}
	if type(source) == "table" then
		for index = 1, 3 do
			if type(source[index]) == "table" then
				rows[index] = source[index]
			end
		end
	end
	for index = 1, 3 do
		if type(rows[index]) ~= "table" then
			rows[index] = copyDailyQuestFallback(index)
		end
	end
	return rows
end

local function renderDailyQuests()
	local _, content = getWindowContent("DailyQuestsWindow")
	if not content then
		return
	end

	local list = ensureBinderList(content)
	if not dailyQuestRemote then
		makeWindowCard(list, 1, "Daily Quests", "DailyQuestRemote is missing. Showing progress is unavailable.", nil, nil, Color3.fromRGB(170, 180, 205))
		warn("EditorWindowBinder: DailyQuestRemote missing.")
		return
	end

	if not dailyQuestData then
		makeWindowCard(list, 1, "Daily Quests", "Requesting quests...", nil, nil, Color3.fromRGB(170, 180, 205))
		dailyQuestRemote:FireServer("Get")
		return
	end

	local resetLabel = Instance.new("TextLabel")
	resetLabel.Name = "ResetTimer"
	resetLabel.BackgroundTransparency = 1
	resetLabel.LayoutOrder = 0
	resetLabel.Size = UDim2.new(1, -6, 0, 26)
	resetLabel.Font = Enum.Font.GothamBlack
	resetLabel.TextColor3 = Color3.fromRGB(38, 36, 52)
	resetLabel.TextStrokeColor3 = Color3.fromRGB(255, 255, 255)
	resetLabel.TextStrokeTransparency = 0.2
	resetLabel.TextSize = 16
	resetLabel.TextXAlignment = Enum.TextXAlignment.Left
	resetLabel.Text = "Resets in: " .. formatDuration(dailyQuestData.resetIn)
	resetLabel.Parent = list

	local quests = getDailyQuestRows(dailyQuestData)
	for index = 1, 3 do
		local quest = quests[index]
		local progress = tonumber(quest.progress or quest.amount) or 0
		local required = tonumber(quest.target or quest.requiredAmount or quest.required or quest.goal) or 1
		local complete = progress >= required
		local claimed = quest.claimed == true
		local rewardAmount = tonumber(quest.rewardAmount or quest.reward) or 0
		local rewardCurrency = tostring(quest.rewardCurrency or "Gems")
		local iconText = quest.iconText and (tostring(quest.iconText) .. "  ") or ""
		local body = tostring(quest.description or "")
			.. "\n" .. tostring(progress) .. "/" .. tostring(required)
			.. " | Reward: " .. tostring(rewardAmount) .. " " .. rewardCurrency
		makeWindowCard(list, index, iconText .. tostring(quest.title or ("Quest " .. tostring(index))), body, claimed and "CLAIMED" or (complete and "CLAIM" or "IN PROGRESS"), (complete and not claimed) and function()
			dailyQuestRemote:FireServer("Claim", index)
		end or nil, complete and Color3.fromRGB(116, 232, 158) or Color3.fromRGB(82, 219, 225))
	end
end

local function refreshAuxiliaryWindows()
	renderShop()
	renderUpgrades()
	renderSettings()
	renderCodes()
	renderTrade()
	if BIND_WORLDS_WINDOW then
		renderWorlds()
	end
	if BIND_DAILY_QUESTS_WINDOW then
		renderDailyQuests()
	end
end

local function setupAuxiliaryListeners()
	purchaseUpgradeEvent.OnClientEvent:Connect(function()
		renderUpgrades()
	end)
	settingsUpdatedEvent.OnClientEvent:Connect(function()
		renderSettings()
	end)
	redeemCodeEvent.OnClientEvent:Connect(function(success, message)
		renderCodes()
		if codeStatusLabel then
			codeStatusLabel.Text = tostring(message or (success and "Code redeemed!" or "Could not redeem code."))
			codeStatusLabel.TextColor3 = success and Color3.fromRGB(35, 130, 55) or Color3.fromRGB(220, 80, 90)
		end
	end)

	if dailyQuestRemote then
		dailyQuestRemote.OnClientEvent:Connect(function(action, data)
			if BIND_DAILY_QUESTS_WINDOW and (action == "Open" or action == "Update" or action == "Locked") then
				dailyQuestData = data
				renderDailyQuests()
			end
		end)
	end

	local settingsFolder = player:FindFirstChild("Settings")
	if settingsFolder then
		for _, child in ipairs(settingsFolder:GetChildren()) do
			if child:IsA("BoolValue") then
				child:GetPropertyChangedSignal("Value"):Connect(renderSettings)
			end
		end
		settingsFolder.ChildAdded:Connect(function(child)
			if child:IsA("BoolValue") then
				child:GetPropertyChangedSignal("Value"):Connect(renderSettings)
				renderSettings()
			end
		end)
	end

	local upgradesFolder = player:FindFirstChild("Upgrades")
	if upgradesFolder then
		for _, child in ipairs(upgradesFolder:GetChildren()) do
			if child:IsA("ValueBase") then
				child:GetPropertyChangedSignal("Value"):Connect(renderUpgrades)
			end
		end
		upgradesFolder.ChildAdded:Connect(function(child)
			if child:IsA("ValueBase") then
				child:GetPropertyChangedSignal("Value"):Connect(renderUpgrades)
				renderUpgrades()
			end
		end)
	end

	if BIND_WORLDS_WINDOW then
		local colorStorage = player:FindFirstChild("ColorStorage")
		if colorStorage then
			for _, valueName in ipairs({ "UnlockedColors", "CurrentWorld" }) do
				local value = colorStorage:FindFirstChild(valueName)
				if value and value:IsA("ValueBase") then
					value:GetPropertyChangedSignal("Value"):Connect(renderWorlds)
				end
			end
		end
		local leaderstats = player:FindFirstChild("leaderstats")
		local coins = leaderstats and leaderstats:FindFirstChild("Coins")
		if coins and coins:IsA("ValueBase") then
			coins:GetPropertyChangedSignal("Value"):Connect(renderWorlds)
		end
	end

	for _, windowName in ipairs({ "ShopWindow", "UpgradesWindow", "SettingsWindow", "CodesWindow", "TradeWindow", "WorldsWindow", "DailyQuestsWindow" }) do
		local window = windows:FindFirstChild(windowName)
		if window and window:IsA("GuiObject") then
			window:GetPropertyChangedSignal("Visible"):Connect(function()
				if window.Visible then
					if windowName == "ShopWindow" then
						renderShop()
					elseif windowName == "UpgradesWindow" then
						renderUpgrades()
					elseif windowName == "SettingsWindow" then
						renderSettings()
					elseif windowName == "CodesWindow" then
						renderCodes()
					elseif windowName == "TradeWindow" then
						renderTrade()
					elseif BIND_WORLDS_WINDOW and windowName == "WorldsWindow" then
						renderWorlds()
					elseif BIND_DAILY_QUESTS_WINDOW and windowName == "DailyQuestsWindow" then
						renderDailyQuests()
					end
				end
			end)
		end
	end
end

hideLegacyRootLayers()
root.ChildAdded:Connect(function(child)
	if LEGACY_ROOT_LAYERS[child.Name] and child:IsA("GuiObject") then
		child.Visible = false
	end
end)

setupAuxiliaryListeners()
if BIND_INVENTORY_WINDOW then
	ensureInventoryStructure()
	wireTabs()
	setupDataListeners()
	refreshPetsFromValues()
	setDetailsEmpty("Choose a card to see details.")
	refreshInventory()
end
refreshAuxiliaryWindows()

inventoryWindow:GetPropertyChangedSignal("Visible"):Connect(function()
	hideLegacyRootLayers()
	if BIND_INVENTORY_WINDOW and inventoryWindow.Visible then
		refreshPetsFromValues()
		refreshInventory()
	end
end)

print("[EditorWindowBinder] auxiliary editable windows bound; EditableInventoryBinder owns InventoryWindow.")
]]></string>
          </Properties>
        </Item>
        <Item class="LocalScript" referent="125">
          <Properties>
            <string name="Name">EggShopUI</string>
            <string name="Source"><![CDATA[-- Focused Sector egg shop: one usable egg per Sector.
local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local TweenService = game:GetService("TweenService")
local Debris = game:GetService("Debris")
local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")

local player = Players.LocalPlayer
local PetData = require(ReplicatedStorage:WaitForChild("PetData"))
local ColorData = require(ReplicatedStorage:WaitForChild("ColorData"))
local UIManager = require(ReplicatedStorage:WaitForChild("UIManager"))
local GameBalance = require(ReplicatedStorage:WaitForChild("GameBalance"))
local UITheme = require(ReplicatedStorage:WaitForChild("UITheme"))
local ClientUIRoot = require(ReplicatedStorage:WaitForChild("ClientUIRoot"))
local Modules = ReplicatedStorage:WaitForChild("Modules")
local PetModelUtil = require(Modules:WaitForChild("PetModelUtil"))

local Events = ReplicatedStorage:WaitForChild("Events")
local hatchEvent = Events:WaitForChild("HatchEgg")
local hatchFocusActive = ReplicatedStorage:FindFirstChild("HatchFocusActive")
if not hatchFocusActive then
	hatchFocusActive = Instance.new("BoolValue")
	hatchFocusActive.Name = "HatchFocusActive"
	hatchFocusActive.Parent = ReplicatedStorage
end
local autoHatchActive = ReplicatedStorage:FindFirstChild("AutoHatchActive")
if not autoHatchActive then
	autoHatchActive = Instance.new("BoolValue")
	autoHatchActive.Name = "AutoHatchActive"
	autoHatchActive.Parent = ReplicatedStorage
end
local openEggShopEvent = ReplicatedStorage:FindFirstChild("OpenEggShop")
if not openEggShopEvent then
	openEggShopEvent = Instance.new("BindableEvent")
	openEggShopEvent.Name = "OpenEggShop"
	openEggShopEvent.Parent = ReplicatedStorage
end

local colorStorage = player:WaitForChild("ColorStorage")
local unlockedColors = colorStorage:WaitForChild("UnlockedColors")
local leaderstats = player:WaitForChild("leaderstats", 10)
local coinsValue = leaderstats and leaderstats:WaitForChild("Coins", 10)
local playerGui = player:WaitForChild("PlayerGui")

local DARK = Color3.fromRGB(35, 38, 45)
local WHITE = Color3.fromRGB(255, 255, 255)
local PANEL_BG = Color3.fromRGB(255, 248, 252)
local PANEL_STROKE = Color3.fromRGB(255, 180, 220)
local TITLE_BG = Color3.fromRGB(180, 220, 255)
local TITLE_TEXT = Color3.fromRGB(80, 60, 130)
local SUB_BG = Color3.fromRGB(245, 235, 252)
local GREEN = Color3.fromRGB(116, 220, 125)
local LOCKED = Color3.fromRGB(205, 210, 225)
local PANEL_WIDTH = 650
local PANEL_HEIGHT = 430
local CLIENT_HATCH_REQUEST_COOLDOWN = math.max(0.85, tonumber(GameBalance.FastHatchCooldown) or 1.25)

local RARITY_COLOR = {
	Common = Color3.fromRGB(150, 150, 160),
	Uncommon = Color3.fromRGB(70, 190, 95),
	Rare = Color3.fromRGB(80, 130, 255),
	Epic = Color3.fromRGB(180, 80, 255),
	Legendary = Color3.fromRGB(255, 190, 50),
	Secret = Color3.fromRGB(255, 80, 140),
}

local EGG_BY_WORLD = {}
for _, eggId in ipairs(PetData.EggOrder or {}) do
	local egg = PetData.Eggs[eggId]
	if egg and egg.areaColor then
		EGG_BY_WORLD[egg.areaColor] = eggId
	end
end

local selectedEggId = (PetData.EggOrder and PetData.EggOrder[1]) or next(PetData.Eggs)
local isOpen = false
local isHatching = false
local hatchPending = false
local hatchStartedAt = 0
local hatchToken = 0
local lastHatchRequestAt = 0
local lastHatchRequestEggId = nil
local hatchInputLockedUntil = 0
local worldRows = {}
local hiddenWorldGuis = {}
local eggOptionGuis = {}
local eggPrompts = {}
local eggParts = {}
local currentNearbyEgg = nil
local autoHatchEnabled = false
local autoHatchRunning = false
local autoHatchThread = nil
local lastAutoHatchAt = 0
local hatchOverlay = nil
local stopAutoButton = nil
local setExternalHatchUiHidden = function() end

local function updateHatchFocusState()
	local overlayVisible = hatchOverlay and hatchOverlay.Visible == true
	hatchFocusActive.Value = overlayVisible or isHatching or hatchPending or autoHatchEnabled
	autoHatchActive.Value = autoHatchEnabled == true
	setExternalHatchUiHidden(hatchFocusActive.Value == true)
	if stopAutoButton then
		stopAutoButton.Visible = autoHatchEnabled == true
	end
end

local function formatNum(value)
	value = tonumber(value) or 0
	if value >= 1000000 then
		return string.format("%.1fM", value / 1000000)
	elseif value >= 1000 then
		return string.format("%.1fK", value / 1000)
	end
	return tostring(value)
end

local function getWorldForEgg(egg)
	return egg and egg.areaColor and ColorData.getWorldByColor(egg.areaColor) or nil
end

local function isWorldPlayable(colorType)
	local worldIndex = ColorData.getWorldIndex(colorType)
	if not worldIndex then
		return false
	end
	local progression = GameBalance.Progression or {}
	local maxPlayableIndex = tonumber(progression.MaxPlayableSectorIndex) or math.huge
	return worldIndex <= maxPlayableIndex
end

local function isEggUnlocked(egg)
	return not egg.areaColor
		or (isWorldPlayable(egg.areaColor) and (egg.areaColor == "Red" or ColorData.isColorUnlocked(unlockedColors.Value, egg.areaColor)))
end

local function canAffordEgg(egg)
	if not egg then
		return false
	end
	local cost = math.max(0, math.floor(tonumber(egg.cost) or 0))
	if cost <= 0 then
		return true
	end
	return coinsValue and coinsValue.Value >= cost
end

local function chooseBestUnlockedEgg()
	local best = selectedEggId
	for _, eggId in ipairs(PetData.EggOrder or {}) do
		local egg = PetData.Eggs[eggId]
		if egg and isEggUnlocked(egg) and (not egg.areaColor or isWorldPlayable(egg.areaColor)) then
			best = eggId
		end
	end
	return best
end

local function getEggIdFromPart(part)
	local current = part
	while current and current ~= workspace do
		if current.Name == "PetAppearanceStudio" then
			return nil
		end
		local eggId = current:GetAttribute("EggId")
		if eggId then
			return eggId
		end
		current = current.Parent
	end
	return nil
end

local function getEggCostText(eggId)
	local egg = eggId and PetData.Eggs[eggId]
	if not egg then
		return ""
	end
	return formatNum(egg.cost or 0) .. " Coins"
end

local function configureEggPrompt(prompt)
	if not prompt or not prompt:IsA("ProximityPrompt") then
		return
	end

	prompt.ActionText = "Hatch"
	prompt.ObjectText = "Egg"
	prompt.KeyboardKeyCode = Enum.KeyCode.E
	prompt.GamepadKeyCode = Enum.KeyCode.ButtonX
	prompt.HoldDuration = 0
	prompt.MaxActivationDistance = math.max(prompt.MaxActivationDistance, 18)
	prompt.RequiresLineOfSight = false
	prompt.Style = Enum.ProximityPromptStyle.Custom
	prompt:SetAttribute("EggShopPrompt", true)
end

local function createEggOptionsGui(eggPart)
	eggParts[eggPart] = true
	if eggOptionGuis[eggPart] then
		return eggOptionGuis[eggPart]
	end

	local eggId = getEggIdFromPart(eggPart)
	local egg = eggId and PetData.Eggs[eggId]
	local title = egg and egg.displayName or "Egg"

	local gui = Instance.new("BillboardGui")
	gui.Name = "EggOptions"
	gui.AlwaysOnTop = true
	gui.Enabled = false
	gui.LightInfluence = 0
	gui.MaxDistance = 60
	gui.Size = UDim2.fromOffset(320, 170)
	gui.StudsOffsetWorldSpace = Vector3.new(0, math.max(11.5, eggPart.Size.Y * 0.5 + 8), 0)
	gui:SetAttribute("EggOptionGui", true)
	gui.Parent = eggPart

	local panel = Instance.new("Frame")
	panel.Name = "Panel"
	panel.Size = UDim2.fromScale(1, 1)
	panel.BackgroundColor3 = Color3.fromRGB(255, 248, 236)
	panel.BackgroundTransparency = 0.05
	panel.BorderSizePixel = 0
	panel.ClipsDescendants = true
	panel.Parent = gui

	local corner = Instance.new("UICorner")
	corner.CornerRadius = UDim.new(0, 18)
	corner.Parent = panel

	local stroke = Instance.new("UIStroke")
	stroke.Color = Color3.fromRGB(44, 47, 58)
	stroke.Thickness = 4
	stroke.Parent = panel

	local titleLabel = Instance.new("TextLabel")
	titleLabel.Name = "Title"
	titleLabel.Size = UDim2.new(1, -24, 0, 30)
	titleLabel.Position = UDim2.new(0, 12, 0, 10)
	titleLabel.BackgroundTransparency = 1
	titleLabel.Font = Enum.Font.LuckiestGuy
	titleLabel.Text = string.upper(title)
	titleLabel.TextScaled = true
	titleLabel.TextColor3 = Color3.fromRGB(78, 58, 130)
	titleLabel.TextStrokeTransparency = 0.55
	titleLabel.TextStrokeColor3 = WHITE
	titleLabel.TextXAlignment = Enum.TextXAlignment.Center
	titleLabel.Parent = panel
	local titleSize = Instance.new("UITextSizeConstraint")
	titleSize.MinTextSize = 14
	titleSize.MaxTextSize = 22
	titleSize.Parent = titleLabel

	local mainLabel = Instance.new("TextLabel")
	mainLabel.Name = "MainTitle"
	mainLabel.Size = UDim2.new(1, -24, 0, 42)
	mainLabel.Position = UDim2.new(0, 12, 0, 42)
	mainLabel.BackgroundTransparency = 1
	mainLabel.Font = Enum.Font.LuckiestGuy
	mainLabel.Text = "EGG"
	mainLabel.TextScaled = true
	mainLabel.TextColor3 = Color3.fromRGB(255, 218, 74)
	mainLabel.TextStrokeTransparency = 0
	mainLabel.TextStrokeColor3 = Color3.fromRGB(44, 47, 58)
	mainLabel.TextXAlignment = Enum.TextXAlignment.Center
	mainLabel.Parent = panel
	local mainSize = Instance.new("UITextSizeConstraint")
	mainSize.MinTextSize = 22
	mainSize.MaxTextSize = 42
	mainSize.Parent = mainLabel

	local costLabel = Instance.new("TextLabel")
	costLabel.Name = "Cost"
	costLabel.Size = UDim2.new(1, -24, 0, 20)
	costLabel.Position = UDim2.new(0, 12, 0, 84)
	costLabel.BackgroundTransparency = 1
	costLabel.Font = Enum.Font.GothamBold
	costLabel.Text = getEggCostText(eggId)
	costLabel.TextSize = 14
	costLabel.TextColor3 = Color3.fromRGB(88, 92, 112)
	costLabel.TextXAlignment = Enum.TextXAlignment.Center
	costLabel.Parent = panel

	local function makeOption(name, x, width, keyText, actionText, color)
		local option = Instance.new("Frame")
		option.Name = name
		option.Size = UDim2.new(0, width, 0, 42)
		option.Position = UDim2.new(0, x, 0, 113)
		option.BackgroundColor3 = color
		option.BorderSizePixel = 0
		option.Parent = panel

		local optionCorner = Instance.new("UICorner")
		optionCorner.CornerRadius = UDim.new(0, 12)
		optionCorner.Parent = option

		local optionStroke = Instance.new("UIStroke")
		optionStroke.Color = Color3.fromRGB(44, 47, 58)
		optionStroke.Thickness = 2
		optionStroke.Parent = option

		local key = Instance.new("TextLabel")
		key.Name = "Key"
		key.Size = UDim2.new(0, 30, 0, 30)
		key.Position = UDim2.new(0, 7, 0.5, -15)
		key.BackgroundColor3 = WHITE
		key.BackgroundTransparency = 0.1
		key.Font = Enum.Font.LuckiestGuy
		key.Text = keyText
		key.TextSize = 18
		key.TextColor3 = Color3.fromRGB(36, 39, 50)
		key.Parent = option

		local keyCorner = Instance.new("UICorner")
		keyCorner.CornerRadius = UDim.new(1, 0)
		keyCorner.Parent = key

		local label = Instance.new("TextLabel")
		label.Name = "Label"
		label.Size = UDim2.new(1, -43, 1, 0)
		label.Position = UDim2.new(0, 39, 0, 0)
		label.BackgroundTransparency = 1
		label.Font = Enum.Font.LuckiestGuy
		label.Text = actionText
		label.TextScaled = true
		label.TextColor3 = WHITE
		label.TextStrokeTransparency = 0.35
		label.TextStrokeColor3 = Color3.fromRGB(36, 39, 50)
		label.TextXAlignment = Enum.TextXAlignment.Left
		label.Parent = option
		local labelSize = Instance.new("UITextSizeConstraint")
		labelSize.MinTextSize = 12
		labelSize.MaxTextSize = 18
		labelSize.Parent = label

		return label
	end

	makeOption("OpenOption", 21, 136, "E", "HATCH", Color3.fromRGB(116, 218, 230))
	local autoLabel = makeOption("AutoOption", 169, 120, "R", "AUTO", Color3.fromRGB(176, 134, 244))
	gui:SetAttribute("AutoLabelPath", autoLabel:GetFullName())

	eggOptionGuis[eggPart] = gui
	return gui
end

local function findNearestEggPart()
	local character = player.Character
	local root = character and character:FindFirstChild("HumanoidRootPart")
	if not root then
		return nil
	end

	local bestPart = nil
	local bestDistance = math.huge
	for eggPart in pairs(eggParts) do
		if not eggPart.Parent then
			eggParts[eggPart] = nil
			eggOptionGuis[eggPart] = nil
		else
			local distance = (root.Position - eggPart.Position).Magnitude
			if distance < bestDistance and distance <= 22 then
				bestDistance = distance
				bestPart = eggPart
			end
		end
	end

	return bestPart
end

local function setEggOptionsVisible(eggPart)
	local overlayVisible = hatchOverlay and hatchOverlay.Visible or false
	local shouldShowPrompt = not isOpen and not isHatching and not overlayVisible
	for part, gui in pairs(eggOptionGuis) do
		if not part.Parent then
			eggOptionGuis[part] = nil
		elseif gui and gui.Parent then
			gui.Enabled = part == eggPart and shouldShowPrompt
			local autoOption = gui:FindFirstChild("Panel") and gui.Panel:FindFirstChild("AutoOption")
			local label = autoOption and autoOption:FindFirstChild("Label")
			if label then
				label.Text = autoHatchEnabled and "STOP" or "AUTO"
			end
		end
	end

	if eggPart then
		createEggOptionsGui(eggPart).Enabled = shouldShowPrompt
	end
end

local function setEggPromptsEnabled(enabled)
	for prompt in pairs(eggPrompts) do
		if not prompt.Parent then
			eggPrompts[prompt] = nil
		elseif prompt:IsA("ProximityPrompt") then
			prompt.Enabled = enabled == true
		end
	end
end

local screenGui = ClientUIRoot.GetLayer(playerGui, "EggShopUI")
local rootScreenGui = screenGui and screenGui:FindFirstAncestorOfClass("ScreenGui")
local externalGuiEnabledState = {}
local defaultPlayerGuiNames = {
	Chat = true,
	BubbleChat = true,
	TouchGui = true,
	Freecam = true,
	PlayerList = true,
}

setExternalHatchUiHidden = function(hidden)
	for _, child in ipairs(playerGui:GetChildren()) do
		if child:IsA("ScreenGui") and child ~= rootScreenGui and not defaultPlayerGuiNames[child.Name] then
			if hidden then
				if externalGuiEnabledState[child] == nil then
					externalGuiEnabledState[child] = child.Enabled
				end
				child.Enabled = false
			elseif externalGuiEnabledState[child] ~= nil then
				child.Enabled = externalGuiEnabledState[child]
				externalGuiEnabledState[child] = nil
			end
		end
	end
end

playerGui.ChildAdded:Connect(function(child)
	if hatchFocusActive.Value == true and child:IsA("ScreenGui") then
		task.defer(function()
			setExternalHatchUiHidden(true)
		end)
	end
end)

