	{ "Light", "Legendary", "Ethereal", "Ethereal", "Transparent flowing energy", "Auto Collect Nearby Gems", "light_ethereal", "auto_collect_gems", 3 },
	{ "Light", "Legendary", "Heavenstorm", "Heavenstorm", "Holy lightning clouds", "Random Gem Storms", "light_storm", "gem_storms", 3 },
	{ "Light", "Legendary", "Godlight", "Godlight", "Blinding divine glow", "Huge Luck Boost", "light_godlight", "huge_luck", 3 },
	{ "Light", "Legendary", "Seraphic", "Seraphic", "Giant angelic energy wings", "Massive Support Buffs", "light_wings", "massive_support", 3 },

	-- Corrupted
	{ "Corrupted", "Common", "Glitched", "Glitched", "RGB flickers, screen tearing", "Hits 2 Spills", "corrupted_glitch", "multi_hit_2", 45 },
	{ "Corrupted", "Common", "Fractured", "Fractured", "Cracked geometry, floating shards", "Loot Explosions", "corrupted_shards", "loot_explosions", 45 },
	{ "Corrupted", "Common", "Chaotic", "Chaotic", "Random flashing colors", "Random Buff Cycles", "corrupted_chaos", "random_buffs", 45 },
	{ "Corrupted", "Common", "Static", "Static", "TV static effects", "Chain Damage", "corrupted_static", "chain_damage", 45 },
	{ "Corrupted", "Common", "Mutagenic", "Mutagenic", "Bubbling mutation blobs", "Duplicate Drops Chance", "corrupted_bubbles", "duplicate_drops", 45 },
	{ "Corrupted", "Common", "Scrambled", "Scrambled", "Distorted textures", "Random Stat Swaps", "corrupted_scramble", "stat_swaps", 45 },
	{ "Corrupted", "Common", "Bugged", "Bugged", "Broken particles, stuttering motion", "Speed Bursts", "corrupted_bugged", "speed_bursts", 45 },
	{ "Corrupted", "Common", "Corruptcode", "Corruptcode", "Matrix-style symbols", "Random Coin Spikes", "corrupted_code", "coin_spikes", 45 },
	{ "Corrupted", "Rare", "Overloaded", "Overloaded", "Massive unstable energy", "Hits 3 Spills", "corrupted_overload", "multi_hit_3", 8 },
	{ "Corrupted", "Rare", "Virus", "Virus", "Digital corruption spread", "Spreads Damage", "corrupted_virus", "spreading_damage", 8 },
	{ "Corrupted", "Rare", "BrokenReality", "Broken Reality", "Space distortion", "Duplicate Coins & Gems", "corrupted_reality", "duplicate_rewards", 8 },
	{ "Corrupted", "Rare", "Riftborn", "Riftborn", "Dimensional tears", "Teleports Between Spills", "corrupted_rift", "spill_teleport", 8 },
	{ "Corrupted", "Rare", "Hyperglitch", "Hyperglitch", "Violent RGB snapping", "Huge Attack Speed", "corrupted_hyper", "huge_attack_speed", 8 },
	{ "Corrupted", "Rare", "Malformed", "Malformed", "Twisted geometry", "Massive Random Multipliers", "corrupted_malformed", "random_multipliers", 8 },
	{ "Corrupted", "Rare", "Errorbound", "Errorbound", "Missing textures flicker", "Bonus Loot Bursts", "corrupted_error", "loot_bursts", 8 },
	{ "Corrupted", "Rare", "SystemFailure", "System Failure", "UI glitch aura", "Random Mega Crits", "corrupted_system", "mega_crits", 8 },
	{ "Corrupted", "Legendary", "Anomaly", "Anomaly", "Impossible geometry", "Hits All Nearby Spills", "corrupted_anomaly", "hit_all_nearby", 1 },
	{ "Corrupted", "Legendary", "Singularity", "Singularity", "Glitch black hole fusion", "Vacuums Rewards", "corrupted_singularity", "reward_vacuum", 1 },
	{ "Corrupted", "Legendary", "Error404", "Error 404", "Missing texture chaos", "Huge Random Multipliers", "corrupted_404", "huge_random_multipliers", 1 },
	{ "Corrupted", "Legendary", "OmegaCorruption", "Omega Corruption", "Giant corruption storm", "Attacks Entire Groups", "corrupted_omega", "group_attack", 1 },
	{ "Corrupted", "Legendary", "RealityCollapse", "Reality Collapse", "Space collapsing inward", "Massive AOE Destruction", "corrupted_collapse", "massive_aoe", 1 },
}

local function makeStats(mutationType, rarity, specialEffect)
	local stats = {}
	local common = rarity == "Common"
	local rare = rarity == "Rare"
	local legendary = rarity == "Legendary"

	if mutationType == "Dark" then
		if specialEffect == "coins_boost" then
			stats.SellCoinsMultiplier = common and 1.15 or rare and 1.4 or 2.2
		elseif specialEffect == "spill_coins" then
			stats.SellCoinsMultiplier = common and 1.2 or 1.45
			stats.ColorGainMultiplier = common and 1.08 or 1.16
		elseif specialEffect == "item_drops" or specialEffect == "bonus_loot" or specialEffect == "drop_chance" then
			stats.ItemDropMultiplier = common and 1.10 or 1.35
		elseif specialEffect == "massive_drops" then
			stats.ItemDropMultiplier = 2.25
		elseif specialEffect == "damage" then
			stats.PowerMultiplier = common and 1.12 or 1.35
		elseif specialEffect == "pickup_radius" then
			stats.BrushRangeMultiplier = common and 1.15 or 1.35
		elseif specialEffect == "coins_drops" then
			stats.SellCoinsMultiplier = 1.10
			stats.ItemDropMultiplier = 1.10
		elseif specialEffect == "crit_chance" then
			stats.CritChanceBonus = 0.05
		elseif specialEffect == "break_speed" then
			stats.BrushCooldownMultiplier = 0.90
			stats.PowerMultiplier = 1.08
		elseif specialEffect == "instant_weak_spill" then
			stats.InstantWeakSpillChance = 0.08
			stats.PowerMultiplier = 1.28
		elseif specialEffect == "combo_coins" then
			stats.SellCoinsMultiplier = 1.3
			stats.ComboCoinMultiplier = 1.25
		elseif specialEffect == "reward_pull" or specialEffect == "reward_vacuum" then
			stats.MagnetProcChance = legendary and 0.25 or 0.12
			stats.MagnetTargets = legendary and 5 or 3
			stats.MagnetRange = legendary and 55 or 38
		elseif specialEffect == "coin_bursts" then
			stats.SellCoinsMultiplier = 1.22
			stats.CoinBurstChance = 0.08
		elseif specialEffect == "double_loot_explosions" or specialEffect == "chain_explosions" then
			stats.ItemDropMultiplier = 1.8
			stats.LightningProcChance = 0.2
			stats.LightningTargets = 3
			stats.LightningRange = 46
			stats.LightningCooldown = 2.5
		elseif specialEffect == "huge_coins" then
			stats.SellCoinsMultiplier = 2.5
		end
	elseif mutationType == "Light" then
		if specialEffect == "gems_boost" then
			stats.GemRewardMultiplier = common and 1.15 or rare and 1.5 or 2.35
		elseif specialEffect == "crystal_gems" then
			stats.GemRewardMultiplier = 1.2
		elseif specialEffect == "speed" then
			stats.WalkSpeedMultiplier = 1.10
			stats.BrushCooldownMultiplier = 0.95
		elseif specialEffect == "luck" then
			stats.HatchLuckBonus = rare and 0.12 or 0.08
		elseif specialEffect == "huge_luck" then
			stats.HatchLuckBonus = 0.28
			stats.HatchLuckMultiplier = 1.12
		elseif specialEffect == "gem_spawn" then
			stats.GemSpawnChanceMultiplier = 1.15
		elseif specialEffect == "everything" then
			stats.SellCoinsMultiplier = 1.05
			stats.GemRewardMultiplier = 1.05
			stats.PowerMultiplier = 1.05
			stats.HatchLuckBonus = 0.02
		elseif specialEffect == "pickup_speed" then
			stats.BrushRangeMultiplier = 1.10
			stats.BrushCooldownMultiplier = 0.94
		elseif specialEffect == "double_gems" then
			stats.GemRewardMultiplier = 1.3
			stats.DoubleGemChance = 0.08
		elseif specialEffect == "mutation_luck" then
			stats.MutationLuckMultiplier = 1.2
		elseif specialEffect == "egg_rewards" then
			stats.HatchLuckBonus = 0.08
			stats.SellCoinsMultiplier = 1.1
		elseif specialEffect == "auto_collect_gems" then
			stats.GemRewardMultiplier = 1.8
			stats.MagnetProcChance = 0.16
			stats.MagnetTargets = 4
			stats.MagnetRange = 46
		elseif specialEffect == "gem_storms" then
			stats.GemRewardMultiplier = 1.75
			stats.LightningProcChance = 0.18
			stats.LightningTargets = 3
			stats.LightningRange = 45
			stats.LightningCooldown = 2.8
		elseif specialEffect == "support_buff" or specialEffect == "massive_support" then
			stats.WalkSpeedMultiplier = legendary and 1.18 or 1.08
			stats.GemRewardMultiplier = legendary and 1.55 or 1.2
		else
			stats.GemRewardMultiplier = legendary and 2 or rare and 1.35 or 1.1
		end
	elseif mutationType == "Corrupted" then
		stats.PowerMultiplier = common and 1.25 or rare and 1.7 or 2.65
		stats.WalkSpeedMultiplier = common and 0.96 or rare and 0.94 or 0.92
		if specialEffect == "multi_hit_2" then
			stats.LightningProcChance = 0.18
			stats.LightningTargets = 2
		elseif specialEffect == "multi_hit_3" then
			stats.LightningProcChance = 0.24
			stats.LightningTargets = 3
		elseif specialEffect == "hit_all_nearby" or specialEffect == "group_attack" or specialEffect == "massive_aoe" then
			stats.LightningProcChance = 0.34
			stats.LightningTargets = 4
			stats.LightningRange = 55
		elseif specialEffect == "chain_damage" or specialEffect == "spreading_damage" then
			stats.LightningProcChance = 0.22
			stats.LightningTargets = 3
		elseif specialEffect == "huge_attack_speed" or specialEffect == "speed_bursts" then
			stats.BrushCooldownMultiplier = rare and 0.78 or 0.88
		elseif specialEffect == "duplicate_rewards" then
			stats.SellCoinsMultiplier = 1.35
			stats.GemRewardMultiplier = 1.35
		elseif specialEffect == "reward_vacuum" then
			stats.MagnetProcChance = 0.28
			stats.MagnetTargets = 5
			stats.MagnetRange = 55
		elseif specialEffect == "random_multipliers" or specialEffect == "huge_random_multipliers" then
			stats.RandomMultiplierCeiling = legendary and 3.5 or 2.2
			stats.SellCoinsMultiplier = legendary and 1.5 or 1.2
		elseif specialEffect == "loot_explosions" or specialEffect == "loot_bursts" or specialEffect == "duplicate_drops" then
			stats.ItemDropMultiplier = rare and 1.55 or 1.25
		elseif specialEffect == "coin_spikes" then
			stats.SellCoinsMultiplier = 1.25
			stats.CoinBurstChance = 0.12
		end
		stats.LightningRange = stats.LightningRange or (rare and 42 or common and 34 or 55)
		stats.LightningCooldown = stats.LightningCooldown or (legendary and 2.2 or rare and 2.6 or 3)
	end

	if stats.PowerMultiplier == nil then
		stats.PowerMultiplier = RARITY_POWER[rarity] or 1
	end
	stats.GemDamageMultiplier = stats.GemDamageMultiplier or stats.PowerMultiplier

	return stats
end

local function makeMutation(row, sortOrder)
	local mutationType, rarity, id, displayName, visualTheme, effectText, visualEffect, specialEffect, weight = table.unpack(row)
	local stats = makeStats(mutationType, rarity, specialEffect)
	local aura = TYPE_AURAS[mutationType] or TYPE_AURAS.None

	return {
		Id = id,
		DisplayName = displayName,
		Type = mutationType,
		Rarity = rarity,
		Description = effectText .. ".",
		VisualTheme = visualTheme,
		StatModifiers = stats,
		Effects = stats,
		SpecialEffect = specialEffect,
		VisualEffect = visualEffect,
		VisualTag = visualEffect,
		Weight = weight,
		ChanceWeight = weight,
		IsMutation = true,
		PowerMultiplier = stats.PowerMultiplier or 1,
		AuraColor = aura,
		TypeColor = TYPE_COLORS[mutationType] or TYPE_COLORS.None,
		RarityText = rarity .. " " .. mutationType .. " Mutation",
		SortOrder = (RARITY_SORT[rarity] or 0) * 1000 + sortOrder,
	}
end

ColorMutationData.TypeColors = TYPE_COLORS
ColorMutationData.TypeAuras = TYPE_AURAS

ColorMutationData.Mutations = {
	None = {
		Id = "None",
		DisplayName = "Normal",
		Type = "None",
		Rarity = "None",
		Description = "No mutation.",
		VisualTheme = "Standard Color appearance",
		StatModifiers = {},
		Effects = {},
		SpecialEffect = "none",
		VisualEffect = "none",
		VisualTag = "none",
		Weight = NO_MUTATION_WEIGHT,
		IsMutation = false,
		PowerMultiplier = 1,
		AuraColor = TYPE_AURAS.None,
		TypeColor = TYPE_COLORS.None,
		RarityText = "Normal",
		SortOrder = 999999,
	},
}

ColorMutationData.RollOrder = {}

for index, row in ipairs(rows) do
	local mutation = makeMutation(row, index)
	ColorMutationData.Mutations[mutation.Id] = mutation
	table.insert(ColorMutationData.RollOrder, mutation.Id)
end

ColorMutationData.LegacyAliases = {
	Sparked = "Shadowed",
	Chromatic = "Prism",
	Shiny = "Glimmer",
	Golden = "CursedGold",
	Featherlight = "Angelic",
	Hyper = "Hyperglitch",
	Magnetic = "Darkmatter",
	Rainbow = "Prism",
	Storm = "Heavenstorm",
}

for id in pairs(ColorMutationData.Mutations) do
	ColorMutationData.LegacyAliases[string.lower(id)] = id
end

local function normalizeRaw(mutationId)
	if type(mutationId) ~= "string" then
		return ColorMutationData.NoneId
	end

	local trimmed = string.gsub(mutationId, "^%s*(.-)%s*$", "%1")
	if trimmed == "" then
		return ColorMutationData.NoneId
	end

	return ColorMutationData.LegacyAliases[trimmed]
		or ColorMutationData.LegacyAliases[string.lower(trimmed)]
		or trimmed
end

function ColorMutationData.get(mutationId)
	mutationId = normalizeRaw(mutationId)
	return ColorMutationData.Mutations[mutationId]
		or ColorMutationData.Mutations[ColorMutationData.NoneId]
end

function ColorMutationData.isMutated(mutationId)
	mutationId = normalizeRaw(mutationId)
	return mutationId ~= ColorMutationData.NoneId and ColorMutationData.Mutations[mutationId] ~= nil
end

function ColorMutationData.normalize(mutationId)
	mutationId = normalizeRaw(mutationId)
	if ColorMutationData.Mutations[mutationId] then
		return mutationId
	end
	return ColorMutationData.NoneId
end

function ColorMutationData.getTypeColor(mutationType)
	return TYPE_COLORS[mutationType] or TYPE_COLORS.None
end

function ColorMutationData.getTypeAura(mutationType)
	return TYPE_AURAS[mutationType] or TYPE_AURAS.None
end

function ColorMutationData.roll(luckMultiplier)
	luckMultiplier = math.clamp(tonumber(luckMultiplier) or 1, 1, 3.5)

	local noMutationWeight = NO_MUTATION_WEIGHT
	local totalWeight = noMutationWeight
	local weighted = {}

	for _, mutationId in ipairs(ColorMutationData.RollOrder) do
		local mutation = ColorMutationData.Mutations[mutationId]
		if mutation and mutation.Weight and mutation.Weight > 0 then
			local rarityBoost = mutation.Rarity == "Legendary" and 0.85
				or mutation.Rarity == "Rare" and 0.55
				or 0.2
			local typePenalty = mutation.Type == "Corrupted" and 0.75 or 1
			local weight = mutation.Weight * typePenalty * (1 + ((luckMultiplier - 1) * rarityBoost))
			totalWeight += weight
			table.insert(weighted, { mutation = mutation, weight = weight })
		end
	end

	local roll = math.random() * totalWeight
	if roll <= noMutationWeight then
		return ColorMutationData.Mutations.None
	end
	roll -= noMutationWeight

	for _, data in ipairs(weighted) do
		roll -= data.weight
		if roll <= 0 then
			return data.mutation
		end
	end

	return ColorMutationData.Mutations.None
end

return ColorMutationData
]]></string>
      </Properties>
    </Item>
    <Item class="ModuleScript" referent="7">
      <Properties>
        <string name="Name">ColorPersonalityData</string>
        <string name="Source"><![CDATA[local ColorPersonalityData = {}

-- Internal systems may use Pet naming, but player-facing companions are called Colors.
ColorPersonalityData.DefaultId = "Neutral"

ColorPersonalityData.Personalities = {
	Neutral = {
		Id = "Neutral",
		DisplayName = "Neutral",
		Description = "A steady Color with no special bonus.",
		Weight = 25,
		EffectType = "None",
		EffectValue = 0,
		Color = Color3.fromRGB(185, 190, 205),
		Icon = "-",
	},
	Cheerful = {
		Id = "Cheerful",
		DisplayName = "Cheerful",
		Description = "Boosts Color gained slightly.",
		Weight = 20,
		EffectType = "ColorGainMultiplier",
		EffectValue = 0.05,
		Color = Color3.fromRGB(116, 245, 42),
		Icon = "+",
	},
	Greedy = {
		Id = "Greedy",
		DisplayName = "Greedy",
		Description = "Boosts Coins from Color breaks.",
		Weight = 20,
		EffectType = "SellMultiplier",
		EffectValue = 0.05,
		Color = Color3.fromRGB(255, 226, 92),
		Icon = "$",
	},
	Speedy = {
		Id = "Speedy",
		DisplayName = "Speedy",
		Description = "Slightly increases walk speed while equipped.",
		Weight = 15,
		EffectType = "WalkSpeedBonus",
		EffectValue = 1,
		Color = Color3.fromRGB(118, 238, 244),
		Icon = ">",
	},
	Curious = {
		Id = "Curious",
		DisplayName = "Curious",
		Description = "Slightly increases pickup range.",
		Weight = 10,
		EffectType = "PickupRangeMultiplier",
		EffectValue = 0.05,
		Color = Color3.fromRGB(170, 150, 255),
		Icon = "?",
	},
	Lucky = {
		Id = "Lucky",
		DisplayName = "Lucky",
		Description = "Slightly improves hatch luck while equipped.",
		Weight = 7,
		EffectType = "LuckBonus",
		EffectValue = 0.02,
		Color = Color3.fromRGB(140, 255, 145),
		Icon = "*",
	},
	Loyal = {
		Id = "Loyal",
		DisplayName = "Loyal",
		Description = "Slightly boosts all equipped Colors.",
		Weight = 3,
		EffectType = "TotalPowerMultiplier",
		EffectValue = 0.03,
		Color = Color3.fromRGB(255, 160, 190),
		Icon = "L",
	},
	Sleepy = {
		Id = "Sleepy",
		DisplayName = "Sleepy",
		Description = "A mellow Color. Future updates may give it merge bonuses.",
		Weight = 5,
		EffectType = "None",
		EffectValue = 0,
		Color = Color3.fromRGB(185, 175, 235),
		Icon = "Z",
	},
}

ColorPersonalityData.Order = {
	"Neutral",
	"Cheerful",
	"Greedy",
	"Speedy",
	"Curious",
	"Lucky",
	"Loyal",
	"Sleepy",
}

function ColorPersonalityData.get(personalityId)
	return ColorPersonalityData.Personalities[personalityId or ColorPersonalityData.DefaultId]
		or ColorPersonalityData.Personalities[ColorPersonalityData.DefaultId]
end

function ColorPersonalityData.roll()
	local totalWeight = 0
	for _, personalityId in ipairs(ColorPersonalityData.Order) do
		local personality = ColorPersonalityData.Personalities[personalityId]
		totalWeight += personality and personality.Weight or 0
	end

	local roll = math.random() * totalWeight
	for _, personalityId in ipairs(ColorPersonalityData.Order) do
		local personality = ColorPersonalityData.Personalities[personalityId]
		roll -= personality and personality.Weight or 0
		if roll <= 0 then
			return personality
		end
	end

	return ColorPersonalityData.Personalities.Neutral
end

return ColorPersonalityData
]]></string>
      </Properties>
    </Item>
    <Item class="ModuleScript" referent="8">
      <Properties>
        <string name="Name">ColorTraitData</string>
        <string name="Source"><![CDATA[local ColorTraitData = {}

ColorTraitData.DefaultId = "Neutral"

ColorTraitData.Traits = {
	Neutral = {
		Id = "Neutral",
		DisplayName = "Neutral",
		Description = "No special bonus.",
		Weight = 25,
		Effects = {},
		SortOrder = 1,
		TextColor = Color3.fromRGB(185, 190, 205),
		Icon = "-",
	},
	Swift = {
		Id = "Swift",
		DisplayName = "Swift",
		Description = "Slightly increases movement speed.",
		Weight = 16,
		Effects = { WalkSpeedBonus = 1.5 },
		SortOrder = 2,
		TextColor = Color3.fromRGB(118, 238, 244),
		Icon = ">",
	},
	Bouncy = {
		Id = "Bouncy",
		DisplayName = "Bouncy",
		Description = "Slightly increases jump power.",
		Weight = 12,
		Effects = { JumpPowerBonus = 6 },
		SortOrder = 3,
		TextColor = Color3.fromRGB(170, 150, 255),
		Icon = "^",
	},
	Quick = {
		Id = "Quick",
		DisplayName = "Quick",
		Description = "Brushes slightly faster.",
		Weight = 14,
		Effects = { BrushCooldownMultiplier = 0.95 },
		SortOrder = 4,
		TextColor = Color3.fromRGB(255, 170, 72),
		Icon = "Q",
	},
	Wide = {
		Id = "Wide",
		DisplayName = "Wide",
		Description = "Increases brush range.",
		Weight = 12,
		Effects = { BrushRangeMultiplier = 1.08 },
		SortOrder = 5,
		TextColor = Color3.fromRGB(91, 230, 235),
		Icon = "+",
	},
	Bright = {
		Id = "Bright",
		DisplayName = "Bright",
		Description = "Collects slightly more Color.",
		Weight = 12,
		Effects = { ColorGainMultiplier = 1.06 },
		SortOrder = 6,
		TextColor = Color3.fromRGB(255, 75, 200),
		Icon = "*",
	},
	Greedy = {
		Id = "Greedy",
		DisplayName = "Greedy",
		Description = "Sells Color for slightly more Coins.",
		Weight = 10,
		Effects = { SellCoinsMultiplier = 1.06 },
		SortOrder = 7,
		TextColor = Color3.fromRGB(255, 210, 64),
		Icon = "$",
	},
	Lucky = {
		Id = "Lucky",
		DisplayName = "Lucky",
		Description = "Slightly improves hatch luck.",
		Weight = 6,
		Effects = { HatchLuckBonus = 0.03 },
		SortOrder = 8,
		TextColor = Color3.fromRGB(91, 228, 126),
		Icon = "%",
	},
	SuperLucky = {
		Id = "SuperLucky",
		DisplayName = "Super Lucky",
		Description = "Massively improves hatch luck.",
		Weight = 0,
		Effects = { HatchLuckBonus = 1.5 },
		SortOrder = 9,
		TextColor = Color3.fromRGB(255, 235, 90),
		Icon = "%",
	},
	Charged = {
		Id = "Charged",
		DisplayName = "Charged",
		Description = "Sometimes zaps nearby Color blobs while brushing.",
		Weight = 3,
		Effects = {
			LightningProcChance = 0.08,
			LightningTargets = 1,
			LightningRange = 28,
			LightningCooldown = 4,
		},
		SortOrder = 9,
		TextColor = Color3.fromRGB(107, 218, 255),
		Icon = "Z",
	},
}

ColorTraitData.Order = {
	"Neutral",
	"Swift",
	"Bouncy",
	"Quick",
	"Wide",
	"Bright",
	"Greedy",
	"Lucky",
	"SuperLucky",
	"Charged",
}

function ColorTraitData.normalize(traitId)
	if ColorTraitData.Traits[traitId or ""] then
		return traitId
	end
	return ColorTraitData.DefaultId
end

function ColorTraitData.get(traitId)
	return ColorTraitData.Traits[ColorTraitData.normalize(traitId)]
end

function ColorTraitData.roll()
	local totalWeight = 0
	for _, traitId in ipairs(ColorTraitData.Order) do
		local trait = ColorTraitData.Traits[traitId]
		totalWeight += trait and trait.Weight or 0
	end

	local roll = math.random() * totalWeight
	for _, traitId in ipairs(ColorTraitData.Order) do
		local trait = ColorTraitData.Traits[traitId]
		roll -= trait and trait.Weight or 0
		if roll <= 0 then
			return trait
		end
	end

	return ColorTraitData.Traits.Neutral
end

return ColorTraitData
]]></string>
      </Properties>
    </Item>
    <Item class="Folder" referent="9">
      <Properties>
