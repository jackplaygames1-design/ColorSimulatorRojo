        <Item class="LocalScript" referent="141">
          <Properties>
            <string name="Name">ProximityWorldLabels</string>
            <string name="Source"><![CDATA[local Players = game:GetService("Players")
local RunService = game:GetService("RunService")

local player = Players.LocalPlayer
local labels = {}

local function getRoot()
	local character = player.Character
	return character and character:FindFirstChild("HumanoidRootPart")
end

local function getLabelPosition(label)
	local adornee = label.Adornee
	if adornee and adornee:IsA("BasePart") then
		return adornee.Position
	end

	local parent = label.Parent
	if parent and parent:IsA("BasePart") then
		return parent.Position
	end

	return nil
end

local function trackLabel(obj)
	if not obj:IsA("BillboardGui") or not obj:GetAttribute("ProximityWorldLabel") then
		return
	end

	labels[obj] = true
	obj.Enabled = false
end

for _, obj in ipairs(workspace:GetDescendants()) do
	trackLabel(obj)
end

workspace.DescendantAdded:Connect(function(obj)
	task.defer(trackLabel, obj)
end)

RunService.RenderStepped:Connect(function()
	local root = getRoot()
	if not root then
		return
	end

	for label in pairs(labels) do
		if not label.Parent then
			labels[label] = nil
		else
			local position = getLabelPosition(label)
			if position then
				local parent = label.Parent
				if parent and parent:IsA("BasePart") and parent:GetAttribute("EggId") and parent:FindFirstChild("EggOptions") then
					label.Enabled = false
					continue
				end

				local showDistance = tonumber(label:GetAttribute("ShowDistance")) or 58
				local hideDistance = tonumber(label:GetAttribute("HideDistance")) or (showDistance + 10)
				local distance = (root.Position - position).Magnitude

				if label.Enabled then
					label.Enabled = distance <= hideDistance
				else
					label.Enabled = distance <= showDistance
				end
			end
		end
	end
end)
]]></string>
          </Properties>
        </Item>
        <Item class="LocalScript" referent="142">
          <Properties>
            <string name="Name">ReadableTextPolish</string>
            <string name="Source"><![CDATA[-- Global readability polish for Color Simulator UI.
-- Fixes unreadable dark/blobbed button text by forcing bold white text with a dark outline.
-- Also makes hovered/pressed buttons turn cyan/blue for consistent feedback.
local Players = game:GetService("Players")
local TweenService = game:GetService("TweenService")
local UserInputService = game:GetService("UserInputService")

local player = Players.LocalPlayer
local playerGui = player:WaitForChild("PlayerGui")

local TEXT_WHITE = Color3.fromRGB(255, 255, 255)
local OUTLINE = Color3.fromRGB(20, 24, 34)
local HOVER_BLUE = Color3.fromRGB(88, 224, 235)
local DISABLED_GREY = Color3.fromRGB(175, 181, 195)

local processedText = setmetatable({}, { __mode = "k" })
local processedButtons = setmetatable({}, { __mode = "k" })

local BUTTON_WORDS = {
	BUY = true,
	CLAIM = true,
	CLAIMED = true,
	EQUIP = true,
	SELECT = true,
	DELETE = true,
	LOCK = true,
	LOCKED = true,
	HIDE = true,
	SHOW = true,
	RELEASE = true,
	CONTINUE = true,
	CLOSE = true,
	OPEN = true,
	READY = true,
	AVAILABLE = true,
	CURRENT = true,
	SHOP = true,
	QUESTS = true,
	NEXT = true,
	DONE = true,
	REDEEM = true,
	TELEPORT = true,
	"IN PROGRESS" = true,
	"COMING SOON" = true,
	"DELETE OFF" = true,
	"SET ID" = true,
	OWNED = true,
}

local function normalizeText(text)
	return string.upper(tostring(text or "")):gsub("^%s+", ""):gsub("%s+$", "")
end

local function shouldStyleText(obj)
	if not (obj:IsA("TextLabel") or obj:IsA("TextButton") or obj:IsA("TextBox")) then
		return false
	end
	if obj:GetAttribute("NoGlobalTextPolish") == true then
		return false
	end
	local text = normalizeText(obj.Text)
	if text == "" then
		return false
	end
	if BUTTON_WORDS[text] then
		return true
	end
	if obj:IsA("TextButton") then
		return true
	end
	if #text <= 18 and (obj.Name:lower():find("button") or obj.Name:lower():find("status") or obj.Name:lower():find("pill")) then
		return true
	end
	return false
end

local function applyReadableText(obj)
	if processedText[obj] then
		return
	end
	processedText[obj] = true

	obj.Font = Enum.Font.GothamBlack
	obj.TextColor3 = TEXT_WHITE
	obj.TextStrokeColor3 = OUTLINE
	obj.TextStrokeTransparency = 0
	obj.TextTransparency = 0
	obj.TextWrapped = true

	if obj:IsA("TextButton") or obj:IsA("TextLabel") then
		obj.TextScaled = true
		local constraint = obj:FindFirstChild("ReadableTextSizeConstraint") or Instance.new("UITextSizeConstraint")
		constraint.Name = "ReadableTextSizeConstraint"
		constraint.MinTextSize = 10
		constraint.MaxTextSize = math.max(16, math.min(34, obj.TextSize > 0 and obj.TextSize or 22))
		constraint.Parent = obj
	end
end

local function isDisabledButton(button)
	local text = normalizeText(button.Text)
	return text == "LOCKED" or text == "CLAIMED" or text == "COMING SOON" or text == "SET ID" or text == "DELETE OFF" or button.Active == false
end

local function applyHover(button)
	if processedButtons[button] then
		return
	end
	processedButtons[button] = true

	button.AutoButtonColor = false
	local originalColor = button.BackgroundColor3
	local hoverColor = HOVER_BLUE
	local pressedColor = Color3.fromRGB(56, 190, 220)

	local function tweenColor(color)
		if not button.Parent then return end
		TweenService:Create(button, TweenInfo.new(0.10, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
			BackgroundColor3 = color,
		}):Play()
	end

	button.MouseEnter:Connect(function()
		if isDisabledButton(button) then return end
		tweenColor(hoverColor)
	end)

	button.MouseLeave:Connect(function()
		if not button.Parent then return end
		if isDisabledButton(button) then
			button.BackgroundColor3 = DISABLED_GREY
		else
			tweenColor(originalColor)
		end
	end)

	button.MouseButton1Down:Connect(function()
		if isDisabledButton(button) then return end
		tweenColor(pressedColor)
	end)

	button.MouseButton1Up:Connect(function()
		if isDisabledButton(button) then return end
		local mouseLocation = UserInputService:GetMouseLocation()
		local pos = button.AbsolutePosition
		local size = button.AbsoluteSize
		local inside = mouseLocation.X >= pos.X and mouseLocation.X <= pos.X + size.X and mouseLocation.Y >= pos.Y and mouseLocation.Y <= pos.Y + size.Y
		tweenColor(inside and hoverColor or originalColor)
	end)

	button:GetPropertyChangedSignal("BackgroundColor3"):Connect(function()
		if not isDisabledButton(button) and button.BackgroundColor3 ~= hoverColor and button.BackgroundColor3 ~= pressedColor then
			originalColor = button.BackgroundColor3
		end
	end)

	button:GetPropertyChangedSignal("Text"):Connect(function()
		applyReadableText(button)
		if isDisabledButton(button) then
			button.BackgroundColor3 = DISABLED_GREY
		end
	end)
end

local function polish(obj)
	if shouldStyleText(obj) then
		applyReadableText(obj)
	end
	if obj:IsA("TextButton") then
		applyHover(obj)
	end
end

local function scan(root)
	for _, obj in ipairs(root:GetDescendants()) do
		polish(obj)
	end
end

scan(playerGui)

playerGui.DescendantAdded:Connect(function(obj)
	task.defer(function()
		if obj.Parent then
			polish(obj)
			for _, child in ipairs(obj:GetDescendants()) do
				polish(child)
			end
		end
	end)
end)

-- Re-polish periodically for UI created/changed by existing scripts.
task.spawn(function()
	while player.Parent do
		scan(playerGui)
		task.wait(2)
	end
end)
]]></string>
          </Properties>
        </Item>
        <Item class="LocalScript" referent="143">
          <Properties>
            <string name="Name">RunController</string>
            <string name="Source"><![CDATA[-- Local sprint controller. It boosts the current server-provided WalkSpeed so upgrades
-- and equipped Color personality bonuses still remain the source of truth.
local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local ContextActionService = game:GetService("ContextActionService")
local TweenService = game:GetService("TweenService")
local Workspace = game:GetService("Workspace")

local player = Players.LocalPlayer
local GameBalance = require(ReplicatedStorage:WaitForChild("GameBalance"))

local RUN_ACTION = "ColorSimulatorRun"
local runningConfig = GameBalance.Running or {}
local enabled = runningConfig.Enabled ~= false
local speedMultiplier = tonumber(runningConfig.SpeedMultiplier) or 1.45
local minRunSpeed = tonumber(runningConfig.MinRunSpeed) or 62
local maxRunSpeed = tonumber(runningConfig.MaxRunSpeed) or 104

local humanoid
local baseWalkSpeed = 44
local isRunning = false
local applyingSpeed = false
local defaultFov = Workspace.CurrentCamera and Workspace.CurrentCamera.FieldOfView or 70

local function getRunSpeed()
	return math.clamp(baseWalkSpeed * speedMultiplier, minRunSpeed, maxRunSpeed)
end

local function tweenFov(target)
	local camera = Workspace.CurrentCamera
	if not camera then
		return
	end

	TweenService:Create(camera, TweenInfo.new(0.16, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
		FieldOfView = target,
	}):Play()
end

local function applySpeed()
	if not humanoid or not enabled then
		return
	end

	applyingSpeed = true
	humanoid.WalkSpeed = isRunning and getRunSpeed() or baseWalkSpeed
	applyingSpeed = false
	tweenFov(isRunning and (defaultFov + 4) or defaultFov)
end

local function setRunning(active)
	if not enabled or isRunning == active then
		return
	end

	isRunning = active
	applySpeed()
end

local function bindHumanoid(character)
	humanoid = character and character:FindFirstChildOfClass("Humanoid")
	if not humanoid then
		humanoid = character and character:WaitForChild("Humanoid", 10)
	end
	if not humanoid then
		return
	end

	baseWalkSpeed = humanoid.WalkSpeed
	humanoid:GetPropertyChangedSignal("WalkSpeed"):Connect(function()
		if applyingSpeed then
			return
		end

		if isRunning then
			local current = humanoid.WalkSpeed
			local expected = getRunSpeed()
			if math.abs(current - expected) > 0.05 then
				baseWalkSpeed = current
				applySpeed()
			end
		else
			baseWalkSpeed = humanoid.WalkSpeed
		end
	end)

	humanoid.Died:Connect(function()
		isRunning = false
	end)
end

local function onRunAction(_, inputState)
	if inputState == Enum.UserInputState.Begin then
		setRunning(true)
	elseif inputState == Enum.UserInputState.End or inputState == Enum.UserInputState.Cancel then
		setRunning(false)
	end

	return Enum.ContextActionResult.Sink
end

if enabled then
	ContextActionService:BindAction(RUN_ACTION, onRunAction, true, Enum.KeyCode.LeftShift, Enum.KeyCode.RightShift, Enum.KeyCode.ButtonL3)
	ContextActionService:SetTitle(RUN_ACTION, "RUN")
	ContextActionService:SetPosition(RUN_ACTION, UDim2.new(1, -92, 1, -168))
end

if player.Character then
	bindHumanoid(player.Character)
end

player.CharacterAdded:Connect(function(character)
	isRunning = false
	task.defer(bindHumanoid, character)
end)
]]></string>
          </Properties>
        </Item>
