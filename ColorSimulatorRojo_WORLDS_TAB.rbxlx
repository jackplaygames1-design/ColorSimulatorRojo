    <Item class="ModuleScript" referent="39">
      <Properties>
        <string name="Name">ItemsData</string>
        <string name="Source"><![CDATA[-- ModuleScript in ReplicatedStorage named "ItemsData"
local ItemsData = {}

ItemsData.Rarities = {
