        <Item class="LocalScript" referent="131">
          <Properties>
            <string name="Name">LegacyRuntimeUICleaner</string>
            <string name="Source"><![CDATA[-- Kills old duplicate runtime UI roots so only the editable Studio UI stays on screen.
-- Tutorial UI is intentionally allowed until the handmade tutorial replacement exists.
local Players = game:GetService("Players")

local player = Players.LocalPlayer
local playerGui = player:WaitForChild("PlayerGui")

local CURRENT_ROOT = "ClientUIRoot"

local LEGACY_SCREEN_GUI_NAMES = {
	ColorSimulatorUI = true,
	InventoryUI = true,
	InventoryGui = true,
	OldInventoryUI = true,
	MainInventoryUI = true,
	DailyQuestGui = true,
	DailyQuestUI = true,
	ZorkDailyQuestGui = true,
	EquipmentShopUI = true,
	ShopUI = true,
	WorldUI = true,
	WorldsUI = true,
	CodesUI = true,
	SettingsUI = true,
	UpgradesUI = true,
	TradeUI = true,
	GamepassGui = true,
	PetInventoryUI = true,
	SocialPanelUI = true,
	SocialPanelsUI = true,
}

local ALLOWED_RUNTIME_SCREEN_GUI_NAMES = {
	TutorialUI = true,
	TutorialGui = true,
	TouchGui = true,
	Chat = true,
	BubbleChat = true,
	Freecam = true,
}

local warned = {}
local function warnOnce(name)
	if warned[name] then return end
	warned[name] = true
	warn("LegacyRuntimeUICleaner: removed duplicate runtime UI -> " .. name)
end

local function shouldRemove(gui)
	if not gui:IsA("ScreenGui") then
		return false
	end
	if gui.Name == CURRENT_ROOT then
		return false
	end
	if ALLOWED_RUNTIME_SCREEN_GUI_NAMES[gui.Name] then
		return false
	end
	if gui:GetAttribute("AllowRuntimeUI") == true then
		return false
	end
	if gui:GetAttribute("LegacyUI") == true then
		return true
	end
	return LEGACY_SCREEN_GUI_NAMES[gui.Name] == true
end

local function clean()
	for _, child in ipairs(playerGui:GetChildren()) do
		if shouldRemove(child) then
			warnOnce(child.Name)
			child:Destroy()
		end
	end
end

clean()
playerGui.ChildAdded:Connect(function(child)
	if child:IsA("ScreenGui") then
		task.defer(function()
			if child.Parent == playerGui and shouldRemove(child) then
				warnOnce(child.Name)
				child:Destroy()
			end
		end)
	end
end)

-- Safety sweep for old UI that appears after delayed scripts.
task.spawn(function()
	while player.Parent do
		clean()
		task.wait(2)
	end
end)
]]></string>
          </Properties>
        </Item>
        <Item class="LocalScript" referent="132">
          <Properties>
            <string name="Name">LiveLeaderboardUI</string>
            <string name="Source"><![CDATA[local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")

local localPlayer = Players.LocalPlayer
local ClientUIRoot = require(ReplicatedStorage:WaitForChild("ClientUIRoot"))

local DARK = Color3.fromRGB(35, 38, 45)
local PANEL = Color3.fromRGB(22, 14, 20)
local WHITE = Color3.fromRGB(255, 255, 255)
local MUTED = Color3.fromRGB(218, 210, 224)
local LINE = Color3.fromRGB(80, 56, 68)

local STAT_NAMES = { "Color", "Gems", "Coins" }
local COLUMN_WIDTHS = {
	Color = 58,
	Gems = 52,
	Coins = 58,
}
local PANEL_WIDTH = 320
local STATS_WIDTH = 168
local leaderboardHidden = true

local function formatCompact(value)
	value = tonumber(value) or 0
	if value >= 1000000000 then
		return string.format("%.1fB", value / 1000000000)
	elseif value >= 1000000 then
		return string.format("%.1fM", value / 1000000)
	elseif value >= 1000 then
		return string.format("%.1fK", value / 1000)
	end
	return tostring(value)
end

local function getStat(player, statName)
	local stats = player:FindFirstChild("leaderstats")
	return stats and stats:FindFirstChild(statName)
end

local function getStatValue(player, statName)
	local stat = getStat(player, statName)
	return stat and stat.Value or 0
end

local screenGui = ClientUIRoot.GetLayer(localPlayer:WaitForChild("PlayerGui"), "LiveLeaderboardUI")

local panel = Instance.new("Frame")
panel.Name = "Panel"
panel.AnchorPoint = Vector2.new(1, 0)
panel.Size = UDim2.new(0, PANEL_WIDTH, 0, 86)
panel.Position = UDim2.new(1, -18, 0, 132)
panel.BackgroundColor3 = PANEL
panel.BackgroundTransparency = 0.08
panel.BorderSizePixel = 0
panel.Parent = screenGui

local corner = Instance.new("UICorner")
corner.CornerRadius = UDim.new(0, 8)
corner.Parent = panel

local stroke = Instance.new("UIStroke")
stroke.Color = Color3.fromRGB(70, 38, 50)
stroke.Transparency = 0.45
stroke.Thickness = 1
stroke.Parent = panel

local toggleButton = Instance.new("TextButton")
toggleButton.Name = "ToggleButton"
toggleButton.AnchorPoint = Vector2.new(1, 0)
toggleButton.Size = UDim2.new(0, 62, 0, 34)
toggleButton.Position = UDim2.new(1, -18, 0, 92)
toggleButton.BackgroundColor3 = Color3.fromRGB(118, 238, 244)
toggleButton.AutoButtonColor = false
toggleButton.BorderSizePixel = 0
toggleButton.Font = Enum.Font.GothamBlack
toggleButton.TextScaled = true
toggleButton.TextSize = 14
toggleButton.TextColor3 = Color3.fromRGB(255, 255, 255)
toggleButton.TextStrokeColor3 = DARK
toggleButton.TextStrokeTransparency = 0
toggleButton.Text = "STATS"
toggleButton:SetAttribute("ForceReadableText", true)
toggleButton:SetAttribute("NoReadableHover", true)
toggleButton.Parent = screenGui

local toggleTextSize = Instance.new("UITextSizeConstraint")
toggleTextSize.MinTextSize = 10
toggleTextSize.MaxTextSize = 16
toggleTextSize.Parent = toggleButton

local toggleCorner = Instance.new("UICorner")
toggleCorner.CornerRadius = UDim.new(0, 12)
toggleCorner.Parent = toggleButton

local toggleStroke = Instance.new("UIStroke")
toggleStroke.Color = DARK
toggleStroke.Thickness = 3
toggleStroke.Parent = toggleButton

local function applyLeaderboardVisibility()
	panel.Visible = not leaderboardHidden
	toggleButton.Text = leaderboardHidden and "STATS" or "HIDE"
	toggleButton.BackgroundColor3 = leaderboardHidden and Color3.fromRGB(16, 38, 56) or Color3.fromRGB(225, 52, 98)
end

toggleButton.MouseButton1Click:Connect(function()
	leaderboardHidden = not leaderboardHidden
	applyLeaderboardVisibility()
end)

local header = Instance.new("Frame")
header.Name = "Header"
header.Size = UDim2.new(1, -20, 0, 28)
header.Position = UDim2.new(0, 10, 0, 6)
header.BackgroundTransparency = 1
header.Parent = panel

local peopleHeader = Instance.new("TextLabel")
peopleHeader.Size = UDim2.new(1, -270, 1, 0)
peopleHeader.BackgroundTransparency = 1
peopleHeader.Font = Enum.Font.GothamMedium
peopleHeader.TextSize = 12
peopleHeader.TextColor3 = MUTED
peopleHeader.TextXAlignment = Enum.TextXAlignment.Left
peopleHeader.Text = "Players"
peopleHeader.Parent = header

local x = 0
for _, statName in ipairs(STAT_NAMES) do
	local width = COLUMN_WIDTHS[statName]
	local label = Instance.new("TextLabel")
	label.Name = statName .. "Header"
	label.AnchorPoint = Vector2.new(1, 0)
	label.Size = UDim2.new(0, width, 1, 0)
	label.Position = UDim2.new(1, -x, 0, 0)
	label.BackgroundTransparency = 1
	label.Font = Enum.Font.GothamMedium
	label.TextSize = 12
	label.TextColor3 = MUTED
	label.TextXAlignment = Enum.TextXAlignment.Right
	label.Text = statName
		label.Parent = header
		x += width
end
peopleHeader.Size = UDim2.new(1, -STATS_WIDTH - 18, 1, 0)

local rows = Instance.new("Frame")
rows.Name = "Rows"
rows.Size = UDim2.new(1, 0, 1, -36)
rows.Position = UDim2.new(0, 0, 0, 36)
rows.BackgroundTransparency = 1
rows.Parent = panel

local layout = Instance.new("UIListLayout")
layout.FillDirection = Enum.FillDirection.Vertical
layout.SortOrder = Enum.SortOrder.LayoutOrder
layout.Parent = rows

local rowConnections = {}
local statConnections = {}

local function disconnectList(list)
	for _, connection in ipairs(list) do
		connection:Disconnect()
	end
	table.clear(list)
end

local function sortedPlayers()
	local list = Players:GetPlayers()
	table.sort(list, function(a, b)
		local aCoins = getStatValue(a, "Coins")
		local bCoins = getStatValue(b, "Coins")
		if aCoins == bCoins then
			return a.Name < b.Name
		end
		return aCoins > bCoins
	end)
	return list
end

local function makeValueLabel(parent, statName, index)
	local width = COLUMN_WIDTHS[statName]
	local offset = 0
	for i = 1, index - 1 do
		offset += COLUMN_WIDTHS[STAT_NAMES[i]]
	end

	local label = Instance.new("TextLabel")
	label.Name = statName
	label.AnchorPoint = Vector2.new(1, 0)
	label.Size = UDim2.new(0, width, 1, 0)
	label.Position = UDim2.new(1, -offset - 10, 0, 0)
	label.BackgroundTransparency = 1
	label.Font = Enum.Font.GothamBold
	label.TextSize = 14
	label.TextColor3 = WHITE
	label.TextXAlignment = Enum.TextXAlignment.Right
	label.Text = "0"
	label.Parent = parent
	return label
end

local function rebuild()
	for _, child in ipairs(rows:GetChildren()) do
		if child ~= layout then
			child:Destroy()
		end
	end

	for playerIndex, listedPlayer in ipairs(sortedPlayers()) do
		local row = Instance.new("Frame")
		row.Name = listedPlayer.Name
		row.Size = UDim2.new(1, 0, 0, 38)
		row.BackgroundColor3 = listedPlayer == localPlayer and Color3.fromRGB(58, 12, 18) or PANEL
		row.BackgroundTransparency = listedPlayer == localPlayer and 0.12 or 0.24
		row.BorderSizePixel = 0
		row.LayoutOrder = playerIndex
		row.Parent = rows

		local divider = Instance.new("Frame")
		divider.Name = "Divider"
		divider.Size = UDim2.new(1, 0, 0, 1)
		divider.Position = UDim2.new(0, 0, 1, -1)
		divider.BackgroundColor3 = LINE
		divider.BackgroundTransparency = 0.35
		divider.BorderSizePixel = 0
		divider.Parent = row

		local nameLabel = Instance.new("TextLabel")
		nameLabel.Name = "PlayerName"
	nameLabel.Size = UDim2.new(1, -STATS_WIDTH - 54, 1, 0)
		nameLabel.Position = UDim2.new(0, 36, 0, 0)
		nameLabel.BackgroundTransparency = 1
		nameLabel.Font = Enum.Font.GothamBold
		nameLabel.TextSize = 14
		nameLabel.TextColor3 = WHITE
		nameLabel.TextXAlignment = Enum.TextXAlignment.Left
		nameLabel.TextTruncate = Enum.TextTruncate.AtEnd
		nameLabel.Text = listedPlayer.DisplayName
		nameLabel.Parent = row

		local icon = Instance.new("TextLabel")
		icon.Name = "Icon"
		icon.Size = UDim2.new(0, 24, 1, 0)
		icon.Position = UDim2.new(0, 10, 0, 0)
		icon.BackgroundTransparency = 1
		icon.Font = Enum.Font.GothamBold
		icon.TextSize = 16
		icon.TextColor3 = listedPlayer == localPlayer and Color3.fromRGB(255, 220, 120) or MUTED
		icon.Text = listedPlayer == localPlayer and "*" or "-"
		icon.Parent = row

		for statIndex, statName in ipairs(STAT_NAMES) do
			local valueLabel = makeValueLabel(row, statName, statIndex)
			valueLabel.Text = formatCompact(getStatValue(listedPlayer, statName))
		end
	end

	local height = 36 + math.max(1, #Players:GetPlayers()) * 38
	panel.Size = UDim2.new(0, PANEL_WIDTH, 0, math.clamp(height, 74, 120))
end

local tutorialActive = ReplicatedStorage:FindFirstChild("TutorialWelcomeActive")
if not tutorialActive then
	tutorialActive = Instance.new("BoolValue")
	tutorialActive.Name = "TutorialWelcomeActive"
	tutorialActive.Value = false
	tutorialActive.Parent = ReplicatedStorage
end
local function refreshTutorialVisibility()
	screenGui.Visible = not tutorialActive.Value
	applyLeaderboardVisibility()
end
tutorialActive:GetPropertyChangedSignal("Value"):Connect(refreshTutorialVisibility)
refreshTutorialVisibility()

local scheduled = false
local function scheduleRebuild()
	if scheduled then
		return
	end
	scheduled = true
	task.defer(function()
		scheduled = false
		rebuild()
	end)
end

local function watchPlayer(listedPlayer)
	disconnectList(rowConnections[listedPlayer] or {})
	disconnectList(statConnections[listedPlayer] or {})
	rowConnections[listedPlayer] = {}
	statConnections[listedPlayer] = {}

	local function hookStats(stats)
		disconnectList(statConnections[listedPlayer])
		table.insert(statConnections[listedPlayer], stats.ChildAdded:Connect(scheduleRebuild))
		table.insert(statConnections[listedPlayer], stats.ChildRemoved:Connect(scheduleRebuild))
		for _, statName in ipairs(STAT_NAMES) do
			local value = stats:FindFirstChild(statName)
			if value and value:IsA("ValueBase") then
				table.insert(statConnections[listedPlayer], value:GetPropertyChangedSignal("Value"):Connect(scheduleRebuild))
			end
		end
		scheduleRebuild()
	end

	local stats = listedPlayer:FindFirstChild("leaderstats")
	if stats then
		hookStats(stats)
	end

	table.insert(rowConnections[listedPlayer], listedPlayer.ChildAdded:Connect(function(child)
		if child.Name == "leaderstats" then
			hookStats(child)
		end
	end))
	table.insert(rowConnections[listedPlayer], listedPlayer:GetPropertyChangedSignal("DisplayName"):Connect(scheduleRebuild))
end

Players.PlayerAdded:Connect(function(listedPlayer)
	watchPlayer(listedPlayer)
	scheduleRebuild()
end)

Players.PlayerRemoving:Connect(function(listedPlayer)
	disconnectList(rowConnections[listedPlayer] or {})
	disconnectList(statConnections[listedPlayer] or {})
	rowConnections[listedPlayer] = nil
	statConnections[listedPlayer] = nil
	scheduleRebuild()
end)

for _, listedPlayer in ipairs(Players:GetPlayers()) do
	watchPlayer(listedPlayer)
end
scheduleRebuild()
]]></string>
          </Properties>
        </Item>
        <Item class="LocalScript" referent="133">
          <Properties>
            <string name="Name">ManualMenuHookup</string>
            <string name="Source"><![CDATA[-- Retired runtime window builder.
-- UIController.client.luau owns the handmade StarterGui.ClientUIRoot.MainHUD UI.
-- Keep this file as a harmless compatibility shim so old Rojo/Studio copies do not
-- keep generating full menu windows at runtime.
print("ManualMenuHookup: disabled; UIController uses editor-built MainHUD windows.")
]]></string>
          </Properties>
        </Item>
        <Item class="LocalScript" referent="134">
          <Properties>
            <string name="Name">MutationHatchVFX</string>
            <string name="Source"><![CDATA[-- Adds an extra visual burst whenever a hatched Color has a mutation.
-- This is intentionally separate from EggShopUI so the existing hatch animation stays editable/stable.

local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local TweenService = game:GetService("TweenService")
local Debris = game:GetService("Debris")

local player = Players.LocalPlayer
local playerGui = player:WaitForChild("PlayerGui")

local ColorMutationData = require(ReplicatedStorage:WaitForChild("ColorMutationData"))
local Events = ReplicatedStorage:WaitForChild("Events")
local hatchEvent = Events:WaitForChild("HatchEgg")

local gui = Instance.new("ScreenGui")
gui.Name = "MutationHatchVFX"
gui.ResetOnSpawn = false
gui.IgnoreGuiInset = true
gui.DisplayOrder = 950
gui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
gui.Parent = playerGui

local function isMutationId(value)
	if type(value) ~= "string" then
		return false
	end
	return ColorMutationData.isMutated(value)
end

local function findMutationPayload(...)
	local visited = {}

	local function scan(value, depth)
		if depth > 5 then
			return nil
		end

		if type(value) ~= "table" then
			return nil
		end
		if visited[value] then
			return nil
		end
		visited[value] = true

		local mutationId = value.mutationId
			or value.MutationId
			or value.mutation
			or value.Mutation
			or value.mutationName
			or value.MutationName

		if value.hasMutation == true or value.HasMutation == true or isMutationId(mutationId) then
			mutationId = ColorMutationData.normalize(mutationId or value.mutationName or value.MutationName)
			local mutation = ColorMutationData.get(mutationId)
			if mutation and mutation.IsMutation then
				return {
					id = mutation.Id,
					name = value.mutationName or value.MutationName or mutation.DisplayName,
					typeName = value.mutationType or value.MutationType or mutation.Type,
					rarity = value.mutationRarity or value.MutationRarity or mutation.Rarity,
					description = value.mutationDescription or value.MutationDescription or mutation.Description,
					auraColor = value.mutationAuraColor or value.MutationAuraColor or value.auraColor or mutation.AuraColor,
					typeColor = value.mutationTypeColor or value.MutationTypeColor or mutation.TypeColor,
				}
			end
		end

		for _, child in pairs(value) do
			local found = scan(child, depth + 1)
			if found then
				return found
			end
		end

		return nil
	end

	for index = 1, select("#", ...) do
		local found = scan(select(index, ...), 1)
		if found then
			return found
		end
	end

	return nil
end

local function makeCorner(parent, radius)
	local corner = Instance.new("UICorner")
	corner.CornerRadius = radius or UDim.new(1, 0)
	corner.Parent = parent
	return corner
end

local function makeStroke(parent, color, thickness, transparency)
	local stroke = Instance.new("UIStroke")
	stroke.Color = color
	stroke.Thickness = thickness or 2
	stroke.Transparency = transparency or 0
	stroke.Parent = parent
	return stroke
end

local function showMutationBurst(payload)
	local accent = payload.typeColor or payload.auraColor or Color3.fromRGB(180, 80, 255)
	local aura = payload.auraColor or accent

	local holder = Instance.new("Frame")
	holder.Name = "MutationBurst"
	holder.Size = UDim2.fromScale(1, 1)
	holder.BackgroundTransparency = 1
	holder.ZIndex = 1
	holder.Parent = gui

	local flash = Instance.new("Frame")
	flash.Name = "Flash"
	flash.Size = UDim2.fromScale(1, 1)
	flash.BackgroundColor3 = accent
	flash.BackgroundTransparency = 1
	flash.BorderSizePixel = 0
	flash.ZIndex = 1
	flash.Parent = holder

	local burst = Instance.new("Frame")
	burst.Name = "BurstRing"
	burst.AnchorPoint = Vector2.new(0.5, 0.5)
	burst.Position = UDim2.fromScale(0.5, 0.46)
	burst.Size = UDim2.fromOffset(80, 80)
	burst.BackgroundColor3 = aura
	burst.BackgroundTransparency = 0.45
	burst.BorderSizePixel = 0
	burst.ZIndex = 2
	burst.Parent = holder
	makeCorner(burst, UDim.new(1, 0))
	makeStroke(burst, Color3.new(1, 1, 1), 5, 0.1)

	local inner = Instance.new("Frame")
	inner.Name = "InnerGlow"
	inner.AnchorPoint = Vector2.new(0.5, 0.5)
	inner.Position = UDim2.fromScale(0.5, 0.5)
	inner.Size = UDim2.fromScale(0.62, 0.62)
	inner.BackgroundColor3 = Color3.new(1, 1, 1)
	inner.BackgroundTransparency = 0.35
	inner.BorderSizePixel = 0
	inner.ZIndex = 3
	inner.Parent = burst
	makeCorner(inner, UDim.new(1, 0))

	local banner = Instance.new("Frame")
	banner.Name = "Banner"
	banner.AnchorPoint = Vector2.new(0.5, 0.5)
	banner.Position = UDim2.fromScale(0.5, 0.68)
	banner.Size = UDim2.fromOffset(520, 118)
	banner.BackgroundColor3 = Color3.fromRGB(24, 26, 36)
	banner.BackgroundTransparency = 0.08
	banner.BorderSizePixel = 0
	banner.ZIndex = 5
	banner.Parent = holder
	makeCorner(banner, UDim.new(0, 22))
	makeStroke(banner, accent, 5, 0)

	local title = Instance.new("TextLabel")
	title.Name = "Title"
	title.Size = UDim2.new(1, -36, 0, 44)
	title.Position = UDim2.new(0, 18, 0, 12)
	title.BackgroundTransparency = 1
	title.Font = Enum.Font.LuckiestGuy
	title.Text = "MUTATION HATCHED!"
	title.TextScaled = true
	title.TextColor3 = accent
	title.TextStrokeTransparency = 0
	title.TextStrokeColor3 = Color3.fromRGB(5, 5, 8)
	title.ZIndex = 6
	title.Parent = banner

	local name = Instance.new("TextLabel")
	name.Name = "MutationName"
	name.Size = UDim2.new(1, -36, 0, 34)
	name.Position = UDim2.new(0, 18, 0, 57)
	name.BackgroundTransparency = 1
	name.Font = Enum.Font.GothamBlack
	name.Text = string.upper(tostring(payload.rarity or "") .. " " .. tostring(payload.typeName or "") .. " • " .. tostring(payload.name or "Mutation"))
	name.TextScaled = true
	name.TextColor3 = Color3.new(1, 1, 1)
	name.TextStrokeTransparency = 0.45
	name.TextStrokeColor3 = Color3.fromRGB(5, 5, 8)
	name.ZIndex = 6
	name.Parent = banner

	local desc = Instance.new("TextLabel")
	desc.Name = "Description"
	desc.Size = UDim2.new(1, -36, 0, 20)
	desc.Position = UDim2.new(0, 18, 1, -26)
	desc.BackgroundTransparency = 1
	desc.Font = Enum.Font.GothamBold
	desc.Text = tostring(payload.description or "Special mutated Color bonus.")
	desc.TextScaled = true
	desc.TextColor3 = Color3.fromRGB(230, 235, 255)
	desc.TextTransparency = 0.1
	desc.ZIndex = 6
	desc.Parent = banner

	TweenService:Create(flash, TweenInfo.new(0.12), { BackgroundTransparency = 0.28 }):Play()
	TweenService:Create(flash, TweenInfo.new(0.5, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), { BackgroundTransparency = 1 }):Play()
	TweenService:Create(burst, TweenInfo.new(0.7, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
		Size = UDim2.fromOffset(390, 390),
		BackgroundTransparency = 0.82,
	}):Play()
	TweenService:Create(banner, TweenInfo.new(0.18, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
		Size = UDim2.fromOffset(560, 128),
	}):Play()

	for i = 1, 28 do
		local particle = Instance.new("Frame")
		particle.Name = "MutationSpark"
		particle.AnchorPoint = Vector2.new(0.5, 0.5)
		particle.Position = UDim2.fromScale(0.5, 0.46)
		local size = math.random(7, 16)
		particle.Size = UDim2.fromOffset(size, size)
		particle.BackgroundColor3 = i % 3 == 0 and Color3.new(1, 1, 1) or accent:Lerp(aura, math.random())
		particle.BackgroundTransparency = 0.05
		particle.BorderSizePixel = 0
		particle.Rotation = math.random(0, 360)
		particle.ZIndex = 4
		particle.Parent = holder
		makeCorner(particle, UDim.new(0, math.random(3, 8)))

		local angle = math.rad((360 / 28) * i + math.random(-16, 16))
		local dist = math.random(145, 310)
		local x = math.cos(angle) * dist
		local y = math.sin(angle) * dist
		TweenService:Create(particle, TweenInfo.new(math.random(52, 88) / 100, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
			Position = UDim2.new(0.5, x, 0.46, y),
			BackgroundTransparency = 1,
			Rotation = particle.Rotation + math.random(-180, 180),
		}):Play()
	end

	Debris:AddItem(holder, 2.8)
end

hatchEvent.OnClientEvent:Connect(function(success, ...)
	if success == false then
		return
	end

	local payload = findMutationPayload(...)
	if payload then
		showMutationBurst(payload)
	end
end)

print("MutationHatchVFX ready")
]]></string>
          </Properties>
        </Item>
        <Item class="LocalScript" referent="135">
          <Properties>
            <string name="Name">MutationStationUI</string>
            <string name="Source"><![CDATA[local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local RunService = game:GetService("RunService")
local TweenService = game:GetService("TweenService")

local player = Players.LocalPlayer
local events = ReplicatedStorage:WaitForChild("Events")
local remote = events:WaitForChild("MutationStation")
local ClientUIRoot = require(ReplicatedStorage:WaitForChild("ClientUIRoot"))
local ColorMutationData = require(ReplicatedStorage:WaitForChild("ColorMutationData"))
local UIManager = require(ReplicatedStorage:WaitForChild("UIManager"))
local UITheme = require(ReplicatedStorage:WaitForChild("UITheme"))

local DARK = Color3.fromRGB(10, 12, 26)
local PANEL = Color3.fromRGB(17, 18, 42)
local PANEL_2 = Color3.fromRGB(26, 24, 62)
local CYAN = Color3.fromRGB(71, 229, 255)
local BLUE = Color3.fromRGB(44, 144, 255)
local PINK = Color3.fromRGB(255, 59, 221)
local PURPLE = Color3.fromRGB(159, 67, 255)
local GOLD = Color3.fromRGB(255, 213, 66)
local GREEN = Color3.fromRGB(106, 245, 32)
local RED = Color3.fromRGB(255, 48, 77)
local WHITE = Color3.fromRGB(255, 255, 255)
local MUTED = Color3.fromRGB(208, 215, 255)

local gui = ClientUIRoot.GetLayer(player:WaitForChild("PlayerGui"), "MutationStationGui")
for _, child in ipairs(gui:GetChildren()) do
	child:Destroy()
end
gui.Visible = false

local function corner(parent, radius)
	local item = Instance.new("UICorner")
	item.CornerRadius = UDim.new(0, radius)
	item.Parent = parent
	return item
end

local function stroke(parent, color, thickness, transparency)
	local item = Instance.new("UIStroke")
	item.Color = color
	item.Thickness = thickness or 2
	item.Transparency = transparency or 0
	item.Parent = parent
	return item
end

local function label(parent, props)
	local item = Instance.new("TextLabel")
	item.BackgroundTransparency = 1
	item.BorderSizePixel = 0
	item.Font = props.Font or Enum.Font.GothamBold
	item.Text = props.Text or ""
	item.TextColor3 = props.TextColor3 or WHITE
	item.TextSize = props.TextSize or 18
	item.TextWrapped = props.TextWrapped ~= false
	item.TextXAlignment = props.TextXAlignment or Enum.TextXAlignment.Left
	item.TextYAlignment = props.TextYAlignment or Enum.TextYAlignment.Center
	item.TextStrokeTransparency = props.TextStrokeTransparency or 1
	item.TextStrokeColor3 = props.TextStrokeColor3 or Color3.new()
	item.ZIndex = props.ZIndex or 160
	item.Parent = parent
	if props.Size then
		item.Size = props.Size
	end
	if props.Position then
		item.Position = props.Position
	end
	return item
end

local function button(parent, props)
	local item = Instance.new("TextButton")
	item.AutoButtonColor = false
	item.BorderSizePixel = 0
	item.BackgroundColor3 = props.BackgroundColor3 or CYAN
	item.Font = props.Font or Enum.Font.LuckiestGuy
	item.Text = props.Text or "BUTTON"
	item.TextColor3 = props.TextColor3 or WHITE
	item.TextSize = props.TextSize or 22
	item.TextStrokeTransparency = props.TextStrokeTransparency or 0
	item.TextStrokeColor3 = props.TextStrokeColor3 or DARK
	item.ZIndex = props.ZIndex or 170
	item.Parent = parent
	if props.Size then
		item.Size = props.Size
	end
	if props.Position then
		item.Position = props.Position
	end
	corner(item, props.CornerRadius or 14)
	stroke(item, props.StrokeColor or Color3.fromRGB(255, 255, 255), props.StrokeThickness or 2, props.StrokeTransparency or 0.5)
	UITheme.ApplyTouchTarget(item, math.max(44, item.AbsoluteSize.Y))
	return item
end

local function section(parent, titleText, numberText, position, size, accent)
	local frame = Instance.new("Frame")
	frame.BackgroundColor3 = Color3.fromRGB(15, 16, 42)
	frame.BorderSizePixel = 0
	frame.Position = position
	frame.Size = size
	frame.ZIndex = 161
	frame.Parent = parent
	corner(frame, 18)
	stroke(frame, accent, 3, 0.05)

	local header = Instance.new("Frame")
	header.BackgroundColor3 = Color3.fromRGB(54, 28, 115)
	header.BorderSizePixel = 0
	header.Size = UDim2.new(1, 0, 0, 48)
	header.ZIndex = 162
	header.Parent = frame
	corner(header, 18)

	local badge = Instance.new("TextLabel")
	badge.BackgroundColor3 = accent
	badge.Size = UDim2.fromOffset(42, 42)
	badge.Position = UDim2.fromOffset(10, 3)
	badge.Font = Enum.Font.LuckiestGuy
	badge.Text = numberText
	badge.TextColor3 = WHITE
	badge.TextSize = 23
	badge.TextStrokeTransparency = 0
	badge.TextStrokeColor3 = DARK
	badge.ZIndex = 164
	badge.Parent = header
	corner(badge, 21)
	stroke(badge, Color3.fromRGB(255, 255, 255), 2, 0.45)

	label(header, {
		Text = titleText,
		Position = UDim2.fromOffset(64, 0),
		Size = UDim2.new(1, -76, 1, 0),
		Font = Enum.Font.LuckiestGuy,
		TextSize = 24,
		TextStrokeTransparency = 0,
		TextStrokeColor3 = DARK,
		ZIndex = 164,
	})

	return frame
end

