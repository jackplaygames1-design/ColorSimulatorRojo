		Id = "BlueBrush", DisplayName = "Blue Brush", ShortName = "BB", Rarity = "Rare",
		Description = "Future light magnet effect.", Cost = 42000, World = "Blue Sector", SortOrder = 7, RequiredColor = "Blue",
		PowerMultiplier = 2.05, CollectPowerMultiplier = 2.05, SweepWidthMultiplier = 1.56, UseSpeedMultiplier = 1.24, PickupRadiusMultiplier = 1.28,
		PassiveId = "WaterPull", PassiveDescription = "Future light magnet effect.", PassiveEnabled = false, VisualType = "Brush",
		HandleColor = rgb(80, 130, 230), HeadColor = rgb(120, 210, 255), PaintColor = rgb(70, 145, 255),
		MaxTargets = 15, MaxServerRange = 31,
	}),
	TideRoller = makeTool({
		Id = "TideRoller", DisplayName = "Tide Roller", ShortName = "TR", Rarity = "Rare",
		Description = "A stronger wide roller for Blue Sector.", Cost = 95000, World = "Blue Sector", SortOrder = 8, RequiredColor = "Blue",
		PowerMultiplier = 2.42, CollectPowerMultiplier = 2.42, SweepWidthMultiplier = 1.70, UseSpeedMultiplier = 1.28, PickupRadiusMultiplier = 1.32,
		PassiveId = "TideTrail", PassiveDescription = "Future short collection trail.", PassiveEnabled = false, VisualType = "Roller",
		HandleColor = rgb(72, 145, 255), HeadColor = rgb(118, 238, 244), PaintColor = rgb(56, 110, 230),
		MaxTargets = 16, MaxServerRange = 32,
	}),

	-- Yellow Sector.
	SunBrush = makeTool({
		Id = "SunBrush", DisplayName = "Sun Brush", ShortName = "SU", Rarity = "Rare",
		Description = "Future chance to double pickup.", Cost = 240000, World = "Yellow Sector", SortOrder = 9, RequiredColor = "Yellow",
		PowerMultiplier = 2.86, CollectPowerMultiplier = 2.86, SweepWidthMultiplier = 1.78, UseSpeedMultiplier = 1.32, PickupRadiusMultiplier = 1.36,
		PassiveId = "SunlitColor", PassiveDescription = "Future chance to double pickup.", PassiveEnabled = false, VisualType = "Brush",
		HandleColor = rgb(255, 198, 92), HeadColor = rgb(255, 235, 105), PaintColor = rgb(255, 178, 70),
		MaxTargets = 17, MaxServerRange = 33,
	}),
	DesertRoller = makeTool({
		Id = "DesertRoller", DisplayName = "Desert Roller", ShortName = "DR", Rarity = "Epic",
		Description = "Future speed build-up while collecting.", Cost = 550000, World = "Yellow Sector", SortOrder = 10, RequiredColor = "Yellow",
		PowerMultiplier = 3.38, CollectPowerMultiplier = 3.38, SweepWidthMultiplier = 1.92, UseSpeedMultiplier = 1.36, PickupRadiusMultiplier = 1.40,
		PassiveId = "HeatMomentum", PassiveDescription = "Future speed build-up while collecting.", PassiveEnabled = false, VisualType = "Roller",
		HandleColor = rgb(255, 220, 110), HeadColor = rgb(255, 178, 70), PaintColor = rgb(255, 238, 120),
		MaxTargets = 18, MaxServerRange = 34,
	}),

	-- Green Sector.
	LeafBrush = makeTool({
		Id = "LeafBrush", DisplayName = "Leaf Brush", ShortName = "LB", Rarity = "Epic",
		Description = "Future small movement bonus.", Cost = 1300000, World = "Green Sector", SortOrder = 11, RequiredColor = "Green",
		PowerMultiplier = 4.00, CollectPowerMultiplier = 4.00, SweepWidthMultiplier = 2.00, UseSpeedMultiplier = 1.40, PickupRadiusMultiplier = 1.44,
		PassiveId = "NaturesBoost", PassiveDescription = "Future small movement bonus.", PassiveEnabled = false, VisualType = "Brush",
		HandleColor = rgb(120, 190, 90), HeadColor = rgb(116, 232, 158), PaintColor = rgb(56, 210, 105),
		MaxTargets = 19, MaxServerRange = 35,
	}),
	VineRoller = makeTool({
		Id = "VineRoller", DisplayName = "Vine Roller", ShortName = "VR", Rarity = "Epic",
		Description = "Future side collection bonus.", Cost = 3100000, World = "Green Sector", SortOrder = 12, RequiredColor = "Green",
		PowerMultiplier = 4.72, CollectPowerMultiplier = 4.72, SweepWidthMultiplier = 2.14, UseSpeedMultiplier = 1.44, PickupRadiusMultiplier = 1.48,
		PassiveId = "VineReach", PassiveDescription = "Future side collection bonus.", PassiveEnabled = false, VisualType = "Roller",
		HandleColor = rgb(85, 160, 90), HeadColor = rgb(125, 230, 105), PaintColor = rgb(52, 175, 95),
		MaxTargets = 21, MaxServerRange = 37,
	}),

	-- Purple Sector.
	CrystalBrush = makeTool({
		Id = "CrystalBrush", DisplayName = "Crystal Brush", ShortName = "CB", Rarity = "Epic",
		Description = "Future critical pickup chance.", Cost = 7500000, World = "Purple Sector", SortOrder = 13, RequiredColor = "Purple",
		PowerMultiplier = 5.58, CollectPowerMultiplier = 5.58, SweepWidthMultiplier = 2.22, UseSpeedMultiplier = 1.48, PickupRadiusMultiplier = 1.52,
		PassiveId = "CrystalCrit", PassiveDescription = "Future critical pickup chance.", PassiveEnabled = false, VisualType = "Brush",
		HandleColor = rgb(110, 75, 170), HeadColor = rgb(202, 176, 255), PaintColor = rgb(178, 95, 255),
		MaxTargets = 23, MaxServerRange = 39,
	}),
	AmethystRoller = makeTool({
		Id = "AmethystRoller", DisplayName = "Amethyst Roller", ShortName = "AR", Rarity = "Legendary",
		Description = "Future mutation luck bonus.", Cost = 17500000, World = "Purple Sector", SortOrder = 14, RequiredColor = "Purple",
		PowerMultiplier = 6.60, CollectPowerMultiplier = 6.60, SweepWidthMultiplier = 2.36, UseSpeedMultiplier = 1.52, PickupRadiusMultiplier = 1.56,
		PassiveId = "AmethystPulse", PassiveDescription = "Future mutation luck bonus.", PassiveEnabled = false, VisualType = "Roller",
		HandleColor = rgb(140, 80, 210), HeadColor = rgb(185, 120, 255), PaintColor = rgb(215, 190, 255),
		MaxTargets = 25, MaxServerRange = 41,
	}),

	-- Neon Sector.
	NeonBrush = makeTool({
		Id = "NeonBrush", DisplayName = "Neon Brush", ShortName = "NB", Rarity = "Legendary",
		Description = "Future speed burst effect.", Cost = 42000000, World = "Neon Sector", SortOrder = 15, RequiredColor = "Neon",
		PowerMultiplier = 7.80, CollectPowerMultiplier = 7.80, SweepWidthMultiplier = 2.44, UseSpeedMultiplier = 1.56, PickupRadiusMultiplier = 1.60,
		PassiveId = "NeonCharge", PassiveDescription = "Future speed burst effect.", PassiveEnabled = false, VisualType = "Brush",
		HandleColor = rgb(48, 52, 64), HeadColor = rgb(155, 218, 255), PaintColor = rgb(0, 255, 200),
		MaxTargets = 27, MaxServerRange = 43,
	}),
	LaserRoller = makeTool({
		Id = "LaserRoller", DisplayName = "Laser Roller", ShortName = "LR", Rarity = "Legendary",
		Description = "Future forward beam collection.", Cost = 100000000, World = "Neon Sector", SortOrder = 16, RequiredColor = "Neon",
		PowerMultiplier = 9.25, CollectPowerMultiplier = 9.25, SweepWidthMultiplier = 2.58, UseSpeedMultiplier = 1.60, PickupRadiusMultiplier = 1.64,
		PassiveId = "LaserLine", PassiveDescription = "Future forward beam collection.", PassiveEnabled = false, VisualType = "Roller",
		HandleColor = rgb(35, 40, 55), HeadColor = rgb(30, 255, 145), PaintColor = rgb(0, 180, 255),
		MaxTargets = 31, MaxServerRange = 46,
	}),

	-- Rainbow Sector.
	PrismBrush = makeTool({
		Id = "PrismBrush", DisplayName = "Prism Brush", ShortName = "PB", Rarity = "Legendary",
		Description = "Future bonus pickup split effect.", Cost = 240000000, World = "Rainbow Sector", SortOrder = 17, RequiredColor = "Rainbow",
		PowerMultiplier = 10.95, CollectPowerMultiplier = 10.95, SweepWidthMultiplier = 2.72, UseSpeedMultiplier = 1.64, PickupRadiusMultiplier = 1.68,
		PassiveId = "PrismSplit", PassiveDescription = "Future bonus pickup split effect.", PassiveEnabled = false, VisualType = "Brush",
		HandleColor = rgb(255, 235, 145), HeadColor = rgb(202, 176, 255), PaintColor = rgb(255, 130, 188),
		MaxTargets = 35, MaxServerRange = 49,
	}),
	PrismRoller = makeTool({
		Id = "PrismRoller", DisplayName = "Prism Roller", ShortName = "PR", Rarity = "Legendary",
		Description = "Endgame rainbow roller with the best collection stats.", Cost = 600000000, World = "Rainbow Sector", SortOrder = 18, RequiredColor = "Rainbow",
		PowerMultiplier = 13.00, CollectPowerMultiplier = 13.00, SweepWidthMultiplier = 2.90, UseSpeedMultiplier = 1.70, PickupRadiusMultiplier = 1.75,
		PassiveId = "RainbowSurge", PassiveDescription = "Future endgame rainbow pulse.", PassiveEnabled = false, VisualType = "Roller",
		HandleColor = rgb(255, 235, 145), HeadColor = rgb(255, 255, 255), PaintColor = rgb(255, 150, 230),
		MaxTargets = 40, MaxServerRange = 52,
	}),
}

ToolData.Order = {
	"StarterBrush", "SoftBrush", "WideRoller", "SplashBrush",
	"OrangeBrush", "GroveRoller",
	"BlueBrush", "TideRoller",
	"SunBrush", "DesertRoller",
	"LeafBrush", "VineRoller",
	"CrystalBrush", "AmethystRoller",
	"NeonBrush", "LaserRoller",
	"PrismBrush", "PrismRoller",
}

ToolData.RarityColors = {
	Common = rgb(185, 190, 205),
	Uncommon = rgb(116, 232, 158),
	Rare = rgb(118, 184, 255),
	Epic = rgb(202, 176, 255),
	Legendary = rgb(255, 218, 110),
}

local function warnInvalidBrushIdOnce(brushId)
	local key = tostring(brushId)
	if warnedInvalidBrushIds[key] then
		return
	end
	warnedInvalidBrushIds[key] = true
	warn("ToolData: invalid brush id '" .. key .. "'; using Starter Brush.")
end

local function getMultiplier(tool, fieldName, fallback)
	local value = tonumber(tool and tool[fieldName])
	if value and value > 0 then
		return value
	end
	return fallback
end

function ToolData.GetBrush(brushId)
	local tool = ToolData.Tools[brushId or ""]
	if tool then
		return tool
	end

	if brushId ~= nil and brushId ~= "" then
		warnInvalidBrushIdOnce(brushId)
	end
	return ToolData.Tools[STARTER_BRUSH_ID]
end

function ToolData.GetStarterBrush()
	return ToolData.Tools[STARTER_BRUSH_ID]
end

function ToolData.GetOrderedBrushes()
	local tools = {}
	for _, toolId in ipairs(ToolData.Order) do
		local tool = ToolData.Tools[toolId]
		if tool then
			table.insert(tools, tool)
		end
	end
	return tools
end

function ToolData.GetBrushesForWorldColor(colorType)
	local worldBrushIds = nil
	local colorData = rawget(_G, "__ColorSimulatorColorData")
	if not colorData then
		local ok, module = pcall(function()
			return require(script.Parent:WaitForChild("ColorData"))
		end)
		if ok then
			colorData = module
		end
	end

	local world = colorData and colorData.getWorldByColor and colorData.getWorldByColor(colorType or "Red")
	worldBrushIds = world and world.BrushIds

	if type(worldBrushIds) == "table" then
		local brushes = {}
		for _, brushId in ipairs(worldBrushIds) do
			local tool = ToolData.Tools[brushId]
			if tool then
				table.insert(brushes, tool)
			end
		end
		return brushes
	end

	local brushes = {}
	for _, toolId in ipairs(ToolData.Order) do
		local tool = ToolData.Tools[toolId]
		if tool and (tool.RequiredColor or "Red") == (colorType or "Red") then
			table.insert(brushes, tool)
		end
	end
	return brushes
end

function ToolData.GetEffectiveStats(brushId)
	local tool = ToolData.GetBrush(brushId)
	local collectPower = getMultiplier(tool, "CollectPowerMultiplier", getMultiplier(tool, "PowerMultiplier", 1))
	local sweepWidth = getMultiplier(tool, "SweepWidthMultiplier", 1)
	local useSpeed = getMultiplier(tool, "UseSpeedMultiplier", 1)
	local pickupRadius = getMultiplier(tool, "PickupRadiusMultiplier", 1)
	local gemDamage = getMultiplier(tool, "GemDamage", math.max(1, collectPower))

	local passiveEnabled = tool.PassiveEnabled == true

	return {
		Id = tool.Id,
		CollectPowerMultiplier = collectPower,
		GemDamage = gemDamage,
		SweepWidthMultiplier = sweepWidth,
		UseSpeedMultiplier = useSpeed,
		PickupRadiusMultiplier = pickupRadius,
		PassiveId = passiveEnabled and (tool.PassiveId or "None") or "None",
		PassiveDescription = passiveEnabled and (tool.PassiveDescription or "") or "",
		PassiveEnabled = passiveEnabled,
	}
end

function ToolData.get(toolId)
	return ToolData.GetBrush(toolId)
end

function ToolData.isValid(toolId)
	return ToolData.Tools[toolId or ""] ~= nil
end

function ToolData.getOrderedTools()
	return ToolData.GetOrderedBrushes()
end

return ToolData
]]></string>
      </Properties>
    </Item>
    <Item class="ModuleScript" referent="61">
      <Properties>
        <string name="Name">UIManager</string>
        <string name="Source"><![CDATA[-- ModuleScript in ReplicatedStorage named "UIManager"
local UIManager = {}

-- Registry: { [name] = { open=fn, close=fn, isOpen=fn } }
local registry = {}
local currentOpen = nil
local currentContext = nil
local warnedMissing = {}

local function getRegisteredNamesText()
	local names = {}
	for name in pairs(registry) do
		table.insert(names, tostring(name))
	end
	table.sort(names)
	return #names > 0 and table.concat(names, ", ") or "none"
end

function UIManager.register(name, openFn, closeFn, isOpenFn)
	registry[name] = {
		open   = openFn,
		close  = closeFn,
		isOpen = isOpenFn,
	}
end

function UIManager.closeAll(except)
	for name, entry in pairs(registry) do
		if name ~= except then
			local ok, err = pcall(function()
				if entry.isOpen() then entry.close({ immediate = true }) end
			end)
			if not ok then warn("UIManager closeAll error on "..name..": "..tostring(err)) end
		end
	end
	if currentOpen == except then return end
	currentOpen = nil
	currentContext = nil
end

function UIManager.open(name, context)
	UIManager.closeAll(name)
	local entry = registry[name]
	if not entry then
		if not warnedMissing[name] then
			warnedMissing[name] = true
			warn("UIManager: no window registered as '"..name.."'. Registered: " .. getRegisteredNamesText())
		end
		return false
	end
	local ok, err = pcall(function()
		entry.open(context)
	end)
	if not ok then
		warn("UIManager open error on " .. tostring(name) .. ": " .. tostring(err))
		currentOpen = nil
		currentContext = nil
		return false
	end
	local stayedOpen = true
	if entry.isOpen then
		local isOpenOk, result = pcall(entry.isOpen)
		stayedOpen = isOpenOk and result == true
	end
	if stayedOpen then
		currentOpen = name
		currentContext = context
	else
		currentOpen = nil
		currentContext = nil
	end
	return true
end

UIManager.OpenWindow = UIManager.open

function UIManager.close(name)
	local entry = registry[name]
	if not entry then return end
	entry.close()
	if currentOpen == name then
		currentOpen = nil
		currentContext = nil
	end
end

UIManager.CloseWindow = UIManager.close
UIManager.CloseAllWindows = UIManager.closeAll

function UIManager.toggle(name, context)
	local entry = registry[name]
	if not entry then
		if not warnedMissing[name] then
			warnedMissing[name] = true
			warn("UIManager: no window registered as '"..name.."'. Registered: " .. getRegisteredNamesText())
		end
		return false
	end
	if entry.isOpen() then
		entry.close()
		if currentOpen == name then
			currentOpen = nil
			currentContext = nil
		end
	else
		UIManager.open(name, context)
	end
	return true
end

function UIManager.isOpen(name)
	local entry = registry[name]
	if not entry then return false end
	local ok, result = pcall(entry.isOpen)
	return ok and result or false
end

function UIManager.getCurrent()
	for name, entry in pairs(registry) do
		local ok, result = pcall(entry.isOpen)
		if ok and result then
			currentOpen = name
			return name
		end
	end
	currentOpen = nil
	currentContext = nil
	return nil
end

function UIManager.isRegistered(name)
	return registry[name] ~= nil
end

function UIManager.GetActiveWindow()
	return UIManager.getCurrent()
end

function UIManager.GetOpenContext()
	return currentContext
end

function UIManager.IsModalOpen()
	return UIManager.getCurrent() ~= nil
end

return UIManager
]]></string>
      </Properties>
    </Item>
    <Item class="ModuleScript" referent="62">
      <Properties>
        <string name="Name">UITheme</string>
        <string name="Source"><![CDATA[-- Shared UI styling helpers for Color Simulator.
local RunService = game:GetService("RunService")

local UserInputService = nil
if RunService:IsClient() then
	local ok, service = pcall(function()
		return game:GetService("UserInputService")
	end)
	if ok then
		UserInputService = service
	end
end

local Theme = {}

local function getFont(name, fallback)
	local ok, font = pcall(function()
		return Enum.Font[name]
	end)
	return (ok and font) or fallback
end

Theme.Colors = {
	BackgroundDim = Color3.fromRGB(0, 0, 0),
	PanelCream = Color3.fromRGB(255, 250, 238),
	PanelWhite = Color3.fromRGB(255, 255, 255),
	PanelLavender = Color3.fromRGB(238, 226, 255),
	PanelBlueSoft = Color3.fromRGB(225, 244, 255),
	PanelPinkSoft = Color3.fromRGB(255, 226, 239),
	PanelYellowSoft = Color3.fromRGB(255, 245, 190),
	PanelGreenSoft = Color3.fromRGB(224, 255, 232),

	OutlineDark = Color3.fromRGB(34, 31, 42),
	OutlineSoft = Color3.fromRGB(78, 68, 105),
	TextDark = Color3.fromRGB(42, 37, 56),
	TextMuted = Color3.fromRGB(116, 101, 139),
	TextWhite = Color3.fromRGB(255, 255, 255),

	PrimaryCyan = Color3.fromRGB(91, 230, 235),
	PrimaryCyanDark = Color3.fromRGB(35, 180, 196),
	PrimaryPurple = Color3.fromRGB(177, 141, 255),
	PrimaryPurpleDark = Color3.fromRGB(122, 89, 210),
	PrimaryPink = Color3.fromRGB(255, 105, 165),
	PrimaryPinkDark = Color3.fromRGB(219, 67, 124),
	PrimaryYellow = Color3.fromRGB(255, 218, 74),
	PrimaryYellowDark = Color3.fromRGB(228, 168, 35),
	PrimaryGreen = Color3.fromRGB(91, 228, 126),
	PrimaryGreenDark = Color3.fromRGB(48, 178, 83),
	PrimaryBlue = Color3.fromRGB(88, 174, 255),
	PrimaryBlueDark = Color3.fromRGB(42, 116, 220),
	PrimaryOrange = Color3.fromRGB(255, 174, 72),
	PrimaryOrangeDark = Color3.fromRGB(216, 112, 38),
	ErrorRed = Color3.fromRGB(255, 91, 104),
	ErrorRedDark = Color3.fromRGB(196, 47, 65),

	CoinGold = Color3.fromRGB(255, 210, 64),
	DiamondBlue = Color3.fromRGB(107, 218, 255),
	ColorPink = Color3.fromRGB(255, 75, 200),
}

Theme.RarityColors = {
	Common = Color3.fromRGB(220, 220, 220),
	Uncommon = Color3.fromRGB(92, 224, 117),
	Rare = Color3.fromRGB(80, 154, 255),
	Epic = Color3.fromRGB(183, 91, 255),
	Legendary = Color3.fromRGB(255, 196, 54),
	Mythic = Color3.fromRGB(255, 78, 126),
	Secret = Color3.fromRGB(60, 55, 85),
	Event = Color3.fromRGB(255, 135, 42),
}

Theme.Sizes = {
	CornerSmall = UDim.new(0, 8),
	CornerMedium = UDim.new(0, 14),
	CornerLarge = UDim.new(0, 22),
	CornerHuge = UDim.new(0, 30),
}

Theme.Strokes = {
	StrokeThin = 2,
	StrokeMedium = 3,
	StrokeThick = 4,
	StrokeHuge = 5,
}

Theme.Spacing = {
	PaddingSmall = 6,
	PaddingMedium = 10,
	PaddingLarge = 16,
	PaddingHuge = 24,
}

Theme.Fonts = {
	Titles = getFont("FredokaOne", Enum.Font.GothamBlack),
	Buttons = getFont("FredokaOne", Enum.Font.GothamBold),
	Body = Enum.Font.GothamMedium,
	Small = Enum.Font.Gotham,
}

function Theme.ApplyCorner(instance, size)
	local corner = instance:FindFirstChildOfClass("UICorner") or Instance.new("UICorner")
	corner.CornerRadius = size or Theme.Sizes.CornerMedium
	corner.Parent = instance
	return corner
end

function Theme.ApplyStroke(instance, color, thickness)
	local stroke = instance:FindFirstChildOfClass("UIStroke") or Instance.new("UIStroke")
	stroke.Color = color or Theme.Colors.OutlineDark
	stroke.Thickness = thickness or Theme.Strokes.StrokeMedium
	stroke.Parent = instance
	return stroke
end

function Theme.ApplyPadding(instance, padding)
	local pad = instance:FindFirstChildOfClass("UIPadding") or Instance.new("UIPadding")
	padding = padding or Theme.Spacing.PaddingMedium
	pad.PaddingTop = UDim.new(0, padding)
	pad.PaddingBottom = UDim.new(0, padding)
	pad.PaddingLeft = UDim.new(0, padding)
	pad.PaddingRight = UDim.new(0, padding)
	pad.Parent = instance
	return pad
end

function Theme.ApplyTextSizeConstraint(instance, minSize, maxSize)
	local constraint = instance:FindFirstChildOfClass("UITextSizeConstraint") or Instance.new("UITextSizeConstraint")
	constraint.MinTextSize = minSize or 10
	constraint.MaxTextSize = maxSize or instance.TextSize or 18
	constraint.Parent = instance
	return constraint
end

function Theme.GetViewportSize()
	local camera = workspace.CurrentCamera
	return camera and camera.ViewportSize or Vector2.new(1280, 720)
end

function Theme.IsTouchDevice()
	return UserInputService and UserInputService.TouchEnabled == true
end

function Theme.ApplyTouchTarget(instance, minSize)
	local size = minSize or 44
	local constraint = instance:FindFirstChild("TouchTargetConstraint")
	if not constraint then
		constraint = Instance.new("UISizeConstraint")
		constraint.Name = "TouchTargetConstraint"
		constraint.Parent = instance
	end
	constraint.MinSize = Vector2.new(size, size)
	return constraint
end

function Theme.ApplyResponsiveScale(instance, baseWidth, baseHeight, minScale, margin)
	local scale = instance:FindFirstChild("ResponsiveScale")
	if not scale then
		scale = Instance.new("UIScale")
		scale.Name = "ResponsiveScale"
		scale.Parent = instance
	end

	baseWidth = baseWidth or 600
	baseHeight = baseHeight or 400
	minScale = minScale or 0.7
	margin = margin or 28

	local function updateScale()
		local viewport = Theme.GetViewportSize()
		local touch = Theme.IsTouchDevice()
		local effectiveMargin = touch and math.max(margin, 36) or margin
		local minimum = touch and math.max(minScale, 0.72) or minScale
		local fitWidth = math.max(viewport.X - effectiveMargin * 2, 280) / baseWidth
		local fitHeight = math.max(viewport.Y - effectiveMargin * 2, 220) / baseHeight
		local fitScale = math.min(fitWidth, fitHeight, 1)

		-- If the viewport is tighter than our preferred minimum, fit the panel
		-- instead of letting it overflow off-screen.
		scale.Scale = fitScale < minimum and fitScale or math.clamp(fitScale, minimum, 1)
	end

	updateScale()
	local camera = workspace.CurrentCamera
	if camera then
		camera:GetPropertyChangedSignal("ViewportSize"):Connect(updateScale)
	end
	workspace:GetPropertyChangedSignal("CurrentCamera"):Connect(updateScale)

	return scale
end

function Theme.ApplyShadow(parent)
	local shadow = Instance.new("Frame")
	shadow.Name = "Shadow"
	shadow.Size = UDim2.new(1, 0, 1, 0)
	shadow.Position = UDim2.new(0, 6, 0, 6)
	shadow.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
	shadow.BackgroundTransparency = 0.75
	shadow.BorderSizePixel = 0
	shadow.ZIndex = math.max((parent.ZIndex or 1) - 1, 0)
	shadow.Parent = parent.Parent
	Theme.ApplyCorner(shadow, parent:FindFirstChildOfClass("UICorner") and parent:FindFirstChildOfClass("UICorner").CornerRadius or Theme.Sizes.CornerLarge)
	return shadow
end

function Theme.MakeButtonStyle(button, color, darkerColor)
	button.BackgroundColor3 = color or Theme.Colors.PrimaryCyan
	button.AutoButtonColor = false
	button.Font = Theme.Fonts.Buttons
	button.TextColor3 = Theme.Colors.TextWhite
	button.TextStrokeTransparency = 0
	button.TextStrokeColor3 = Theme.Colors.OutlineDark
	Theme.ApplyCorner(button, Theme.Sizes.CornerMedium)
	Theme.ApplyStroke(button, darkerColor or Theme.Colors.OutlineDark, Theme.Strokes.StrokeMedium)
	return button
end

function Theme.FormatNumber(value)
	value = tonumber(value) or 0
	if math.abs(value) >= 1000000000 then
		return string.format("%.2fB", value / 1000000000):gsub("%.00", "")
	elseif math.abs(value) >= 1000000 then
		return string.format("%.2fM", value / 1000000):gsub("%.00", "")
	elseif math.abs(value) >= 1000 then
		return string.format("%.1fK", value / 1000):gsub("%.0K", "K")
	end
	return tostring(math.floor(value))
end

function Theme.CreateDimOverlay(parent, zIndex)
	local overlay = Instance.new("TextButton")
	overlay.Name = "DimOverlay"
	overlay.Size = UDim2.fromScale(1, 1)
	overlay.BackgroundColor3 = Theme.Colors.BackgroundDim
	overlay.BackgroundTransparency = 0.4
	overlay.BorderSizePixel = 0
	overlay.AutoButtonColor = false
	overlay.Text = ""
	overlay.Visible = false
	overlay.ZIndex = zIndex or 50
	overlay.Parent = parent
	return overlay
end

return Theme
]]></string>
      </Properties>
    </Item>
    <Item class="ModuleScript" referent="63">
      <Properties>
        <string name="Name">UpdateLogData</string>
        <string name="Source"><![CDATA[local UpdateLogData = {}

UpdateLogData.CurrentVersion = "Beta 0.1.3.6"
UpdateLogData.LastUpdated = "May 9, 2026"
UpdateLogData.Status = "EARLY BETA"

UpdateLogData.FeaturedCode = {
	Code = "RELEASE",
	Reward = "Free starter reward",
}

UpdateLogData.Latest = {
	Title = "HUD + Beta Polish Update",
	Subtitle = "A smaller beta pass with cleaner mobile controls, handmade HUD support, and better Color previews.",
	Changes = {
		"Physical Studio HUD buttons wired into live UI",
		"Mobile HUD spacing for menu, shop, world, and quests",
		"Inventory Color previews now avoid Unknown blanks",
		"Daily quest access improved on mobile",
		"Red to Orange beta path cleanup",
		"Safer HUD fallbacks without replacing Studio visuals",
	},
}

UpdateLogData.HowToPlay = {
	"Walk over glowing color spills to clean them",
	"Earn Coins from spills and hatch new Colors",
	"Break gem deposits with your Brush and Colors",
	"Spend Gems on future upgrades and progression",
	"Unlock Sectors to find new eggs, colors, and features",
}

UpdateLogData.LiveFeatures = {
	"Start Sector tutorial flow",
	"Orange Sector preview and Mutation Core room",
	"Zork brush merchant and daily quests",
	"Mobile-safe HUD controls",
	"Handmade HUD button support",
	"Group rewards: +Luck, +Coins, daily Gems",
	"Editable Color appearance studio for future pets",
}

UpdateLogData.ComingSoon = {
	"More hatchable Colors after beta polish",
	"More daily quest rewards",
	"More Sector progression polish",
	"More mutation visuals and effects",
}

UpdateLogData.PlaytestFocus = {
	"First 10 minutes",
	"Mobile HUD layout",
	"Inventory Color previews",
	"Red to Orange flow",
}

UpdateLogData.Footer = "Join the community for playtests, codes, and update news!"

return UpdateLogData
]]></string>
