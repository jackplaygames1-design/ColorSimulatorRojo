            <string name="Name">GamepassUI</string>
            <string name="Source"><![CDATA[-- GamepassUI.client.luau
if true then
	warn("GamepassUI disabled; editable MainHUD.ModalWindows.Windows.ShopWindow is bound by EditorWindowBinder.")
	return
