      <Item class="Script" referent="106">
        <Properties>
          <string name="Name">WildColorHandler</string>
          <token name="RunContext">0</token>
          <string name="Source"><![CDATA[local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local TweenService = game:GetService("TweenService")
local Debris = game:GetService("Debris")
local ServerStorage = game:GetService("ServerStorage")

local ColorData = require(ReplicatedStorage:WaitForChild("ColorData"))
local GameBalance = require(ReplicatedStorage:WaitForChild("GameBalance"))
local BuffService = require(script.Parent:WaitForChild("BuffService"))

local FEATURE_ENABLED = not (GameBalance.FeatureFlags and GameBalance.FeatureFlags.WildColorsEnabled == false)
local WILD_CONFIG = GameBalance.WildGameplay and GameBalance.WildGameplay.WildColors or {}
local ROLL_INTERVAL = WILD_CONFIG.RollInterval or 25
local SPAWN_CHANCE = WILD_CONFIG.SpawnChance or 0.20
local MAX_PER_ZONE = WILD_CONFIG.MaxPerZone or 1
local PER_COLOR_MAX = WILD_CONFIG.PerColorMax or {}
local DESPAWN_AFTER = WILD_CONFIG.DespawnAfter
if DESPAWN_AFTER == nil then
	DESPAWN_AFTER = 120
end
local COLLECT_RANGE = 10

local WILD_TYPES = {
	{
		Id = "Gold",
		BuffId = "CoinsRush",
		Color = Color3.fromRGB(255, 214, 55),
		Material = Enum.Material.Neon,
		Weight = 28,
	},
	{
		Id = "Lime",
		BuffId = "SpeedRush",
		Color = Color3.fromRGB(136, 255, 70),
		Material = Enum.Material.Neon,
		Weight = 26,
	},
	{
		Id = "Cyan",
		BuffId = "BrushFrenzy",
		Color = Color3.fromRGB(70, 225, 255),
		Material = Enum.Material.Neon,
		Weight = 24,
	},
	{
		Id = "Purple",
		BuffId = "LuckyAura",
		Color = Color3.fromRGB(180, 105, 255),
		Material = Enum.Material.Neon,
		Weight = 18,
	},
	{
		Id = "Rainbow",
		BuffId = "GemSurge",
		Color = Color3.fromRGB(255, 255, 255),
		Material = Enum.Material.Neon,
		Weight = 4,
	},
}

local rootFolder = workspace:FindFirstChild("DynamicGameplay")
if not rootFolder then
	rootFolder = Instance.new("Folder")
	rootFolder.Name = "DynamicGameplay"
	rootFolder.Parent = workspace
end

local wildFolder = rootFolder:FindFirstChild("WildColors")
if not wildFolder then
	wildFolder = Instance.new("Folder")
	wildFolder.Name = "WildColors"
	wildFolder.Parent = rootFolder
end

local activeByColor = {}
local lastRollAt = 0
local collectDebounce = {}
local zonePartCache = {}

local function reportDailyQuestProgress(player, questId, amount)
	local event = ServerStorage:FindFirstChild("DailyQuestProgress")
	if event and event:IsA("BindableEvent") then
		event:Fire(player, questId, amount)
	end
end

local function inferColorFromMapPart(part)
	local attrColor = part:GetAttribute("ColorType") or part:GetAttribute("WorldColor") or part:GetAttribute("AreaColor")
	local partName = string.lower(part.Name or "")
	local parentName = part.Parent and string.lower(part.Parent.Name or "") or ""
	local looksLikeFloor = string.find(partName, "floor")
		or string.find(partName, "ground")
		or string.find(partName, "zone")
		or string.find(partName, "area")
		or string.find(partName, "sector")
		or string.find(parentName, "floor")
		or string.find(parentName, "zone")
		or string.find(parentName, "area")
		or string.find(parentName, "sector")
	local largeFlatSurface = (part.Size.X * part.Size.Z) >= 1600
		and part.Size.X >= 35
		and part.Size.Z >= 35
		and part.Size.Y <= math.max(8, math.min(part.Size.X, part.Size.Z) * 0.3)
	local blockedName = string.find(partName, "pipe", 1, true)
		or string.find(parentName, "pipe", 1, true)
		or partName == "core"
		or partName == "glowshell"
		or partName == "highlight"
		or string.find(partName, "floatcore", 1, true)
	if ColorData.getWorldByColor(attrColor) and not blockedName and (part:GetAttribute("PlayableSectorFloor") == true or looksLikeFloor or largeFlatSurface) then
		return attrColor
	end

	for _, world in ipairs(ColorData.Worlds or {}) do
		local color = world.primaryColor
		local loweredColor = string.lower(color)
		if looksLikeFloor and (string.find(partName, loweredColor) or string.find(parentName, loweredColor)) then
			return color
		end
	end

	return nil
end

local function inferPlayableSectorColorFromName(part)
	if not part or not part:IsA("BasePart") then
		return nil
	end

	local partName = string.lower(part.Name or "")
	local parentName = part.Parent and string.lower(part.Parent.Name or "") or ""
	local namedAsSurface = string.find(partName, "floor")
		or string.find(partName, "ground")
		or string.find(partName, "zone")
		or string.find(partName, "area")
		or string.find(partName, "sector")
		or string.find(parentName, "floor")
		or string.find(parentName, "zone")
		or string.find(parentName, "area")
		or string.find(parentName, "sector")

	if not namedAsSurface then
		return nil
	end

	for _, world in ipairs(ColorData.Worlds or {}) do
		local color = world.primaryColor
		if color then
			local loweredColor = string.lower(color)
			if string.find(partName, loweredColor, 1, true) or string.find(parentName, loweredColor, 1, true) then
				return color
			end
		end
	end

	return nil
end

local function configureColorZonePart(part)
	local partName = string.lower(part.Name or "")
	local parentName = part.Parent and string.lower(part.Parent.Name or "") or ""
	if part:GetAttribute("BreakableType")
		or part:GetAttribute("PaintPuddleVersion")
		or part:GetAttribute("GemDeposit")
		or part:GetAttribute("WildColor")
		or part:FindFirstAncestor("DynamicGameplay") ~= nil
		or part:FindFirstAncestor("PetAppearanceStudio") ~= nil
		or part:GetAttribute("EggStation") == true
		or part:GetAttribute("TutorialEgg") == true
		or part:GetAttribute("EggId") ~= nil
		or part:GetAttribute("MutationStation") == true
		or part:GetAttribute("MutationUnlockStation") == true
		or part:GetAttribute("FeatureUnlock") == "Mutations"
		or string.find(partName, "pipe", 1, true)
		or string.find(parentName, "pipe", 1, true)
		or partName == "core"
		or partName == "glowshell"
		or partName == "highlight"
		or string.find(partName, "floatcore", 1, true)
	then
		if part:GetAttribute("ColorZone") == true then
			part:SetAttribute("ColorZone", false)
		end
		return nil
	end

	local playableSectorFloor = part:GetAttribute("PlayableSectorFloor") == true
	local namedPlayableSectorColor = inferPlayableSectorColorFromName(part)
	if not playableSectorFloor and (part:GetAttribute("DistantSectorColumn")
		or part:GetAttribute("SectorAnchor")
		or part:GetAttribute("DecorativeOnly")
		or part:FindFirstAncestor("DistantSectors") ~= nil)
		and not namedPlayableSectorColor
	then
		if part:GetAttribute("ColorZone") == true then
			part:SetAttribute("ColorZone", false)
		end
		return nil
	end

	local colorType = inferColorFromMapPart(part)
	if not colorType then
		return nil
	end

	if part:GetAttribute("ColorZone") ~= true then
		part:SetAttribute("ColorZone", true)
	end
	if part:GetAttribute("ColorType") ~= colorType then
		part:SetAttribute("ColorType", colorType)
	end
	if namedPlayableSectorColor == colorType and part:GetAttribute("PlayableSectorFloor") ~= true then
		part:SetAttribute("PlayableSectorFloor", true)
	end
	return colorType
end

local function isUnlocked(player, colorType)
	local progression = GameBalance.Progression or {}
	local maxPlayableIndex = tonumber(progression.MaxPlayableSectorIndex) or math.huge
	local index = ColorData.getWorldIndex(colorType) or math.huge
	if index > maxPlayableIndex then
		return false
	end

	local storage = player:FindFirstChild("ColorStorage")
	local unlocked = storage and storage:FindFirstChild("UnlockedColors")
	return ColorData.isColorUnlocked(unlocked and unlocked.Value or "Red", colorType)
end

local function isPointInside(part, worldPosition, margin)
	local localPoint = part.CFrame:PointToObjectSpace(worldPosition)
	local half = part.Size * 0.5 + Vector3.new(margin or 0, margin or 0, margin or 0)
	return math.abs(localPoint.X) <= half.X
		and math.abs(localPoint.Y) <= half.Y
		and math.abs(localPoint.Z) <= half.Z
end

local function isPlayerInsideColorZone(player, colorType)
	local root = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
	if not root then
		return false
	end

	for _, obj in ipairs(workspace:GetDescendants()) do
		if obj:IsA("BasePart") then
			local zoneColor = configureColorZonePart(obj)
			if zoneColor == colorType and obj:GetAttribute("ColorZone") == true and isPointInside(obj, root.Position, 12) then
				return true
			end
		end
	end
	return false
end

local function isWorldActive(colorType)
	local progression = GameBalance.Progression or {}
	if colorType == (progression.StartSectorColor or "Red") and #Players:GetPlayers() > 0 then
		return true
	end

	for _, player in ipairs(Players:GetPlayers()) do
		if isUnlocked(player, colorType) or isPlayerInsideColorZone(player, colorType) then
			return true
		end
	end
	return false
end

local function pickWildType()
	local totalWeight = 0
	for _, wildType in ipairs(WILD_TYPES) do
		totalWeight += wildType.Weight or 1
	end
	local roll = math.random() * totalWeight
	local running = 0
	for _, wildType in ipairs(WILD_TYPES) do
		running += wildType.Weight or 1
		if roll <= running then
			return wildType
		end
	end
	return WILD_TYPES[1]
end

local function getActiveList(colorType)
	local list = activeByColor[colorType]
	if not list then
		list = {}
		activeByColor[colorType] = list
	end
	for index = #list, 1, -1 do
		local model = list[index]
		if not model or not model.Parent or model:GetAttribute("Collected") == true then
			table.remove(list, index)
		end
	end
	return list
end

local function getMaxForColor(colorType)
	return math.max(0, tonumber(PER_COLOR_MAX[colorType]) or MAX_PER_ZONE)
end

local function findZonePart(colorType)
	local cached = zonePartCache[colorType]
	if cached and cached.Parent then
		return cached
	end

	local fallback = nil
	local best = nil
	local bestArea = -math.huge
	for _, obj in ipairs(workspace:GetDescendants()) do
		if obj:IsA("BasePart") then
			local attrColor = configureColorZonePart(obj)
			if attrColor == colorType then
				local area = obj.Size.X * obj.Size.Z
				if obj:GetAttribute("ColorZone") and area > bestArea then
					best = obj
					bestArea = area
				end
				fallback = fallback or obj
			end
		end
	end
	if best then
		zonePartCache[colorType] = best
		return best
	end
	zonePartCache[colorType] = fallback
	return fallback
end

local function isBadSpawnNeighbor(part, zone)
	if not part or part:IsDescendantOf(wildFolder) then
		return false
	end
	if part == zone or part:GetAttribute("PlayableSectorFloor") == true or part:GetAttribute("ColorZone") == true then
		return false
	end
	if part:GetAttribute("SellZone")
		or part:GetAttribute("SellLocation")
		or part:GetAttribute("BrushShop")
		or part:GetAttribute("CombinedShop")
		or part:GetAttribute("ShopStation")
		or part:GetAttribute("UpgradeStation")
		or part:GetAttribute("EggStation")
		or part:GetAttribute("AreaGate")
		or part:GetAttribute("GateInteraction")
		or part:GetAttribute("DistantSectorColumn")
		or part:GetAttribute("SectorAnchor")
		or part:GetAttribute("DecorativeOnly")
	then
		return true
	end
	local name = string.lower(part.Name)
	return string.find(name, "wall")
		or string.find(name, "portal")
		or string.find(name, "gate")
		or string.find(name, "sell")
		or string.find(name, "shop")
		or string.find(name, "upgrade")
		or string.find(name, "egg")
		or string.find(name, "sector")
		or string.find(name, "column")
end

local function isSafePosition(position, zone)
	local params = OverlapParams.new()
	params.FilterType = Enum.RaycastFilterType.Exclude
	params.FilterDescendantsInstances = { wildFolder }
	for _, part in ipairs(workspace:GetPartBoundsInRadius(position, 8, params)) do
		if isBadSpawnNeighbor(part, zone) then
			return false
		end
	end
	return true
end

local function getSpawnPosition(world)
	local zone = findZonePart(world.primaryColor)
	if not zone then
		return nil
	end

	local rayParams = RaycastParams.new()
	rayParams.FilterType = Enum.RaycastFilterType.Exclude
	rayParams.FilterDescendantsInstances = { wildFolder }

	for _ = 1, 38 do
		local x = (math.random() - 0.5) * math.max(8, zone.Size.X * 0.78)
		local z = (math.random() - 0.5) * math.max(8, zone.Size.Z * 0.78)
		local above = zone.CFrame:PointToWorldSpace(Vector3.new(x, zone.Size.Y * 0.5 + 45, z))
		local result = workspace:Raycast(above, Vector3.new(0, -120, 0), rayParams)
		local position = result and result.Position + Vector3.new(0, 2.6, 0)
			or zone.CFrame:PointToWorldSpace(Vector3.new(x, zone.Size.Y * 0.5 + 2.6, z))
		if isSafePosition(position, zone) then
			return position
		end
	end
	return nil
end

local function makeBurst(position, color)
	local part = Instance.new("Part")
	part.Name = "WildColorBurst"
	part.Size = Vector3.new(0.2, 0.2, 0.2)
	part.Transparency = 1
	part.Anchored = true
	part.CanCollide = false
	part.CanTouch = false
	part.CanQuery = false
	part.CFrame = CFrame.new(position)
	part.Parent = workspace

	local burst = Instance.new("ParticleEmitter")
	burst.Texture = "rbxasset://textures/particles/sparkles_main.dds"
	burst.Color = ColorSequence.new(color, Color3.fromRGB(255, 255, 255))
	burst.LightEmission = 1
	burst.Lifetime = NumberRange.new(0.45, 0.9)
	burst.Speed = NumberRange.new(7, 14)
	burst.SpreadAngle = Vector2.new(180, 180)
	burst.Rate = 0
	burst.Parent = part
	burst:Emit(36)
	Debris:AddItem(part, 1)
end

local function getPlayerFromHit(hit)
	local character = hit and hit.Parent
	if not character then
		return nil
	end
	local humanoid = character:FindFirstChildOfClass("Humanoid")
	if not humanoid and character.Parent then
		character = character.Parent
		humanoid = character:FindFirstChildOfClass("Humanoid")
	end
	if not humanoid or humanoid.Health <= 0 then
		return nil
	end
	return Players:GetPlayerFromCharacter(character)
end

local function collectWildColor(player, model)
	if not player or not model or not model.Parent or model:GetAttribute("Collected") == true then
		return
	end
	local core = model.PrimaryPart
	local colorType = model:GetAttribute("ColorType")
	if not core or not colorType or not isUnlocked(player, colorType) then
		return
	end
	local root = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
	if not root or (root.Position - core.Position).Magnitude > COLLECT_RANGE then
		return
	end

	local key = tostring(player.UserId) .. ":" .. tostring(model)
	local t = os.clock()
	if collectDebounce[key] and t - collectDebounce[key] < 0.75 then
		return
	end
	collectDebounce[key] = t

	model:SetAttribute("Collected", true)
	local wildType = model:GetAttribute("WildType")
	local buffId = model:GetAttribute("BuffId")
	BuffService.Grant(player, buffId)
	makeBurst(core.Position, core.Color)
	local list = activeByColor[colorType]
	if list then
		for index = #list, 1, -1 do
			if list[index] == model then
				table.remove(list, index)
				break
			end
		end
	end
	model:Destroy()
	reportDailyQuestProgress(player, "CollectOrbs", 1)
	print("WildColor: " .. player.Name .. " collected " .. tostring(wildType) .. " in " .. tostring(colorType))
end

local function makeWildColor(world, position, wildType)
	local model = Instance.new("Model")
	model.Name = world.primaryColor .. wildType.Id .. "WildColor"
	model:SetAttribute("WildColor", true)
	model:SetAttribute("WildType", wildType.Id)
	model:SetAttribute("BuffId", wildType.BuffId)
	model:SetAttribute("ColorType", world.primaryColor)
	model:SetAttribute("Collected", false)

	local core = Instance.new("Part")
	core.Name = "Core"
	core.Shape = Enum.PartType.Ball
	core.Size = Vector3.new(2.4, 2.4, 2.4)
	core.CFrame = CFrame.new(position)
	core.Color = wildType.Color
	core.Material = wildType.Material
	core.Anchored = true
	core.CanCollide = false
	core.CanTouch = true
	core.CanQuery = true
	core.CastShadow = false
	core:SetAttribute("WildColor", true)
	core:SetAttribute("WildType", wildType.Id)
	core:SetAttribute("BuffId", wildType.BuffId)
	core:SetAttribute("ColorType", world.primaryColor)
	core.Parent = model
	model.PrimaryPart = core

	local light = Instance.new("PointLight")
	light.Name = "WildGlow"
	light.Color = wildType.Color
	light.Range = 14
	light.Brightness = 2
	light.Shadows = false
	light.Parent = core

	local sparkles = Instance.new("ParticleEmitter")
	sparkles.Name = "WildSparkles"
	sparkles.Texture = "rbxasset://textures/particles/sparkles_main.dds"
	sparkles.Color = ColorSequence.new(wildType.Color, Color3.fromRGB(255, 255, 255))
	sparkles.LightEmission = 0.9
	sparkles.Rate = 12
	sparkles.Lifetime = NumberRange.new(0.75, 1.4)
	sparkles.Speed = NumberRange.new(0.35, 1.2)
	sparkles.SpreadAngle = Vector2.new(180, 180)
	sparkles.Parent = core

	model.Parent = wildFolder

	local tween = TweenService:Create(core, TweenInfo.new(1.5, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut, -1, true), {
		CFrame = core.CFrame * CFrame.new(0, 0.45, 0),
	})
	tween:Play()

	core.Touched:Connect(function(hit)
		local player = getPlayerFromHit(hit)
		if player then
			collectWildColor(player, model)
		end
	end)

	if DESPAWN_AFTER and DESPAWN_AFTER > 0 then
		task.delay(DESPAWN_AFTER, function()
			if model.Parent and model:GetAttribute("Collected") ~= true then
				local list = activeByColor[world.primaryColor]
				if list then
					for index = #list, 1, -1 do
						if list[index] == model then
							table.remove(list, index)
							break
						end
					end
				end
				model:Destroy()
			end
		end)
	end

	return model
end

local function trySpawnForWorld(world, force)
	local colorType = world.primaryColor
	if not isWorldActive(colorType) then
		return
	end

	local list = getActiveList(colorType)
	local maxForColor = getMaxForColor(colorType)
	if maxForColor <= 0 or #list >= maxForColor then
		return
	end

	if not force and math.random() > SPAWN_CHANCE then
		return
	end

	local spawned = 0
	for _ = #list + 1, maxForColor do
		local position = getSpawnPosition(world)
		if not position then
			break
		end
		local wildType = pickWildType()
		table.insert(list, makeWildColor(world, position, wildType))
		spawned += 1
		print("WildColor: spawned " .. tostring(wildType.Id) .. " power in " .. tostring(colorType) .. ".")
	end
end

local function requestImmediateSpawn(colorType)
	local world = ColorData.getWorldByColor(colorType)
	if world then
		trySpawnForWorld(world, true)
	end
end

Players.PlayerAdded:Connect(function(player)
	task.delay(2, function()
		if player.Parent then
			requestImmediateSpawn("Red")
			local activeColor = player:GetAttribute("ActiveWorldColor")
			if activeColor and activeColor ~= "Red" then
				requestImmediateSpawn(activeColor)
			end
		end
	end)

	player:GetAttributeChangedSignal("ActiveWorldColor"):Connect(function()
		local activeColor = player:GetAttribute("ActiveWorldColor")
		if activeColor and activeColor ~= "" then
			requestImmediateSpawn(activeColor)
		end
	end)

	task.spawn(function()
		local storage = player:WaitForChild("ColorStorage", 20)
		local currentWorld = storage and storage:FindFirstChild("CurrentWorld")
		if currentWorld and currentWorld:IsA("StringValue") then
			currentWorld:GetPropertyChangedSignal("Value"):Connect(function()
				if currentWorld.Value ~= "" then
					requestImmediateSpawn(currentWorld.Value)
				end
			end)
		end
	end)
end)

task.delay(2, function()
	if #Players:GetPlayers() > 0 then
		requestImmediateSpawn("Red")
	end
end)

task.spawn(function()
	while true do
		task.wait(1)
		if FEATURE_ENABLED and os.clock() - lastRollAt >= ROLL_INTERVAL then
			lastRollAt = os.clock()
			for _, world in ipairs(ColorData.Worlds or {}) do
				if MAX_PER_ZONE > 0 then
					trySpawnForWorld(world)
				end
			end
		end
	end
end)
]]></string>
        </Properties>
      </Item>
      <Item class="Script" referent="107">
        <Properties>
          <string name="Name">WorldTravelHandler</string>
          <token name="RunContext">0</token>
          <string name="Source"><![CDATA[-- Server-authoritative quick travel for small HUD shortcuts.
local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")

local ColorData = require(ReplicatedStorage:WaitForChild("ColorData"))
local PetData = require(ReplicatedStorage:WaitForChild("PetData"))
local GameBalance = require(ReplicatedStorage:WaitForChild("GameBalance"))

local Events = ReplicatedStorage:WaitForChild("Events")
local travelEvent = Events:FindFirstChild("TravelToWorldSpot")
if not travelEvent then
	travelEvent = Instance.new("RemoteEvent")
	travelEvent.Name = "TravelToWorldSpot"
	travelEvent.Parent = Events
end
local dataDirtyEvent = Events:FindFirstChild("PlayerDataDirty")

local cooldowns = {}
local COOLDOWN = 2
local MAP_NAME = "ColorSimulatorMap"
local SPAWN_TUTORIAL_EGG_NAME = "SpawnEgg"
local RUNTIME_WORLD_BUILDING_ENABLED = GameBalance.FeatureFlags and GameBalance.FeatureFlags.RuntimeWorldBuildingEnabled == true
local RUNTIME_WORLD_LABELS_ENABLED = GameBalance.FeatureFlags and GameBalance.FeatureFlags.RuntimeWorldLabelsEnabled == true
local PROGRESSION_CONFIG = GameBalance.Progression or {}
local MAX_PLAYABLE_SECTOR_INDEX = tonumber(PROGRESSION_CONFIG.MaxPlayableSectorIndex) or math.huge
local zonePartsCache = nil
local destinationCache = {}

local function isSectorPlayable(colorType)
	local index = ColorData.getWorldIndex(colorType)
	return index ~= nil and index <= MAX_PLAYABLE_SECTOR_INDEX
end

local COLORS = {
	dark = Color3.fromRGB(35, 38, 45),
	cyan = Color3.fromRGB(118, 238, 244),
	yellow = Color3.fromRGB(255, 224, 104),
	pink = Color3.fromRGB(255, 130, 188),
	green = Color3.fromRGB(116, 232, 158),
	purple = Color3.fromRGB(192, 154, 255),
}

local function getRoot(player)
	local character = player.Character
	return character and character:FindFirstChild("HumanoidRootPart")
end

local function getUnlockedValue(player)
	local storage = player:FindFirstChild("ColorStorage")
	return storage and storage:FindFirstChild("UnlockedColors")
end

local function isUnlocked(player, colorType)
	local unlocked = getUnlockedValue(player)
	return isSectorPlayable(colorType) and ColorData.isColorUnlocked(unlocked and unlocked.Value or "Red", colorType)
end

local function setCurrentWorld(player, colorType, reason)
	local world = ColorData.getWorldByColor(colorType)
	if not world or not isUnlocked(player, world.primaryColor) then
		return false
	end

	player:SetAttribute("ActiveWorldColor", world.primaryColor)
	local storage = player:FindFirstChild("ColorStorage")
	local currentWorld = storage and storage:FindFirstChild("CurrentWorld")
	if currentWorld and currentWorld:IsA("StringValue") and currentWorld.Value ~= world.primaryColor then
		currentWorld.Value = world.primaryColor
	end
	if dataDirtyEvent and dataDirtyEvent:IsA("BindableEvent") then
		dataDirtyEvent:Fire(player, reason or "current-world")
	end
	return true
end

local function getStoredCurrentWorldColor(player)
	local storage = player:FindFirstChild("ColorStorage")
	local currentWorld = storage and storage:FindFirstChild("CurrentWorld")
	local colorType = currentWorld and currentWorld.Value or player:GetAttribute("ActiveWorldColor")
	local world = ColorData.getWorldByColor(colorType)
	if world and isUnlocked(player, world.primaryColor) then
		return world.primaryColor
	end
	return nil
end

local function isPointInside(part, worldPosition, margin)
	local localPoint = part.CFrame:PointToObjectSpace(worldPosition)
	local half = part.Size * 0.5 + Vector3.new(margin, margin, margin)
	return math.abs(localPoint.X) <= half.X
		and math.abs(localPoint.Y) <= half.Y
		and math.abs(localPoint.Z) <= half.Z
end

local function getZoneParts()
	if zonePartsCache then
		local valid = true
		for _, zone in ipairs(zonePartsCache) do
			if not zone.Parent then
				valid = false
				break
			end
		end
		if valid then
			return zonePartsCache
		end
	end

	local zones = {}
	for _, obj in ipairs(workspace:GetDescendants()) do
		if obj:IsA("BasePart") and obj:GetAttribute("ColorZone") and obj:GetAttribute("ColorType") then
			table.insert(zones, obj)
		end
	end
	zonePartsCache = zones
	return zones
end

local function getMap()
	local map = workspace:FindFirstChild(MAP_NAME)
	if not map and RUNTIME_WORLD_BUILDING_ENABLED then
		map = Instance.new("Folder")
		map.Name = MAP_NAME
		map.Parent = workspace
	end
	return map
end

local function getExistingMap()
	return workspace:FindFirstChild(MAP_NAME)
end

local function shouldUseBakedMap()
	local mapConfig = GameBalance.Map or {}
	return mapConfig.UseBakedMap ~= false
end

local function isBakedEditableMap(map)
	return map
		and (map:GetAttribute("BakedEditableMap") == true or map:FindFirstChild("Lobby") or map:FindFirstChild("RedZone"))
end

local function shouldAvoidRuntimeStationCreation()
	return shouldUseBakedMap() and isBakedEditableMap(getExistingMap())
end

local function createPart(parent, name, size, cframe, color, material)
	local part = Instance.new("Part")
	part.Name = name
	part.Size = size
	part.CFrame = cframe
	part.Color = color
	part.Material = material or Enum.Material.SmoothPlastic
	part.Anchored = true
	part.CanCollide = true
	part.TopSurface = Enum.SurfaceType.Smooth
	part.BottomSurface = Enum.SurfaceType.Smooth
	part.Parent = parent
	return part
end

local function addShopBillboard(parent)
	if not RUNTIME_WORLD_LABELS_ENABLED then
		return
	end

	for _, child in ipairs(parent:GetChildren()) do
		if child:IsA("BillboardGui") and (child.Name == "BrushShopLabel" or child.Name == "UpgradeStationLabel") then
			child:Destroy()
		end
	end

	local billboard = Instance.new("BillboardGui")
	billboard.Name = "BrushShopLabel"
	billboard:SetAttribute("ProximityWorldLabel", true)
	billboard:SetAttribute("ShowDistance", 42)
	billboard:SetAttribute("HideDistance", 52)
	billboard.Size = UDim2.new(0, 220, 0, 42)
	billboard.StudsOffset = Vector3.new(0, 7.2, 0)
	billboard.AlwaysOnTop = true
	billboard.MaxDistance = 80
	billboard.Enabled = false
	billboard.Parent = parent

	local title = Instance.new("TextLabel")
	title.Size = UDim2.new(1, 0, 1, 0)
	title.BackgroundTransparency = 1
	title.Font = Enum.Font.LuckiestGuy
	title.TextSize = 18
	title.TextColor3 = Color3.new(1, 1, 1)
	title.TextStrokeTransparency = 0
	title.TextStrokeColor3 = COLORS.dark
	title.Text = "BRUSH SHOP"
	title.Parent = billboard
end

local function addShopPrompt(part)
	local oldUpgradePrompt = part:FindFirstChild("UpgradeStationPrompt")
	if oldUpgradePrompt then
		oldUpgradePrompt:Destroy()
	end

	local prompt = part:FindFirstChild("BrushShopPrompt")
	if not prompt then
		prompt = Instance.new("ProximityPrompt")
		prompt.Name = "BrushShopPrompt"
		prompt.ActionText = "Open"
		prompt.HoldDuration = 0
		prompt.MaxActivationDistance = 15
		prompt.RequiresLineOfSight = false
		prompt.Parent = part
	end
	prompt.ObjectText = "Brush Shop"
	prompt:SetAttribute("BrushShopPrompt", true)
	prompt:SetAttribute("CombinedShopPrompt", true)
end

local function addUpgradeBillboard(parent)
	for _, child in ipairs(parent:GetChildren()) do
		if child:IsA("BillboardGui") and child.Name == "UpgradeStationLabel" then
			child:Destroy()
		end
	end
	return
end

local function addUpgradePrompt(part)
	local prompt = part:FindFirstChild("UpgradeStationPrompt")
	if prompt then
		prompt:Destroy()
	end
	return
end

local function addDisabledUpgradeBillboard(parent)
	if not RUNTIME_WORLD_LABELS_ENABLED then
		return
	end

	for _, child in ipairs(parent:GetChildren()) do
		if child:IsA("BillboardGui") and child.Name == "UpgradeStationLabel" then
			child:Destroy()
		end
	end

	local billboard = Instance.new("BillboardGui")
	billboard.Name = "UpgradeStationLabel"
	billboard:SetAttribute("ProximityWorldLabel", true)
	billboard:SetAttribute("ShowDistance", 42)
	billboard:SetAttribute("HideDistance", 52)
	billboard.Size = UDim2.new(0, 190, 0, 48)
	billboard.StudsOffset = Vector3.new(0, 7.2, 0)
	billboard.AlwaysOnTop = true
	billboard.MaxDistance = 80
	billboard.Enabled = false
	billboard.Parent = parent

	local title = Instance.new("TextLabel")
	title.Size = UDim2.new(1, 0, 1, 0)
	title.BackgroundTransparency = 1
	title.Font = Enum.Font.LuckiestGuy
	title.TextSize = 20
	title.TextColor3 = Color3.new(1, 1, 1)
	title.TextStrokeTransparency = 0
	title.TextStrokeColor3 = COLORS.dark
	title.Text = "UPGRADE"
	title.Parent = billboard
end

local function addDisabledUpgradePrompt(part)
	local prompt = part:FindFirstChild("UpgradeStationPrompt")
	if not prompt then
		prompt = Instance.new("ProximityPrompt")
		prompt.Name = "UpgradeStationPrompt"
		prompt.Parent = part
	end
	prompt.ActionText = "Open"
	prompt.ObjectText = "Upgrade Station"
	prompt.HoldDuration = 0
	prompt.MaxActivationDistance = 15
	prompt.RequiresLineOfSight = false
	prompt:SetAttribute("UpgradeStationPrompt", true)
end

local function addEggBillboard(parent, world, eggData)
	if not RUNTIME_WORLD_LABELS_ENABLED then
		return
	end

	for _, child in ipairs(parent:GetChildren()) do
		if child:IsA("BillboardGui") and child.Name == "WorldEggLabel" then
			child:Destroy()
		end
	end

	local billboard = Instance.new("BillboardGui")
	billboard.Name = "WorldEggLabel"
	billboard:SetAttribute("ProximityWorldLabel", true)
	billboard:SetAttribute("ShowDistance", 48)
	billboard:SetAttribute("HideDistance", 58)
	billboard.Size = UDim2.new(0, 220, 0, 68)
	billboard.StudsOffset = Vector3.new(0, 9.8, 0)
	billboard.AlwaysOnTop = true
	billboard.MaxDistance = 120
	billboard.Enabled = false
	billboard.Parent = parent

	local title = Instance.new("TextLabel")
	title.Size = UDim2.new(1, 0, 0, 42)
	title.BackgroundTransparency = 1
	title.Font = Enum.Font.LuckiestGuy
	title.TextSize = 24
	title.TextColor3 = Color3.new(1, 1, 1)
	title.TextStrokeTransparency = 0
	title.TextStrokeColor3 = COLORS.dark
	title.Text = eggData and string.upper(eggData.displayName or "EGG") or "EGG"
	title.Parent = billboard

	local sub = Instance.new("TextLabel")
	sub.Size = UDim2.new(1, 0, 0, 24)
	sub.Position = UDim2.new(0, 0, 0, 40)
	sub.BackgroundTransparency = 1
	sub.Font = Enum.Font.GothamBold
	sub.TextSize = 14
	sub.TextColor3 = COLORS.yellow
	sub.TextStrokeTransparency = 0.1
	sub.TextStrokeColor3 = COLORS.dark
	sub.Text = world and world.name or "Sector Egg"
	sub.Parent = billboard
end

local function addEggPrompt(part)
	local prompt = part:FindFirstChild("EggShopPrompt")
	if not prompt then
		prompt = Instance.new("ProximityPrompt")
		prompt.Name = "EggShopPrompt"
		prompt.Parent = part
	end
	part:SetAttribute("EggStation", true)
	part.CanCollide = true
	part.CanTouch = false
	part.CanQuery = true
	prompt.ActionText = "Open"
	prompt.ObjectText = "Egg"
	prompt.HoldDuration = 0
	prompt.MaxActivationDistance = 16
	prompt.RequiresLineOfSight = false
	prompt:SetAttribute("EggShopPrompt", true)
end

local function configureSpawnTutorialEgg(obj)
	if not obj or not obj:IsA("BasePart") or obj.Name ~= SPAWN_TUTORIAL_EGG_NAME then
		return nil
	end

	obj:SetAttribute("EggId", "ColorEgg")
	obj:SetAttribute("ColorType", "Red")
	obj:SetAttribute("AreaColor", "Red")
	obj:SetAttribute("EggStation", true)
	obj:SetAttribute("TutorialEgg", true)
	obj:SetAttribute("BakedTutorialEgg", true)
	obj.CanQuery = true
	addEggPrompt(obj)
	destinationCache["egg:Red"] = obj
	return obj
end

local function findSpawnTutorialEgg()
	local direct = workspace:FindFirstChild(SPAWN_TUTORIAL_EGG_NAME, true)
	local configured = configureSpawnTutorialEgg(direct)
	if configured then
		return configured
	end
	for _, obj in ipairs(workspace:GetDescendants()) do
		configured = configureSpawnTutorialEgg(obj)
		if configured then
			return configured
		end
	end
	return nil
end

local function findZonePart(colorType)
	local fallback
	for _, zone in ipairs(getZoneParts()) do
		fallback = fallback or zone
		if zone:GetAttribute("ColorType") == colorType then
			return zone
		end
	end
	return colorType == "Red" and fallback or nil
end

local function getCurrentWorldColor(player)
	local root = getRoot(player)
	local storedColor = getStoredCurrentWorldColor(player)
	if not root then
		return storedColor or "Red"
	end

	local fallbackColor = storedColor or "Red"
	local nearestDist = math.huge
	for _, zone in ipairs(getZoneParts()) do
		local colorType = zone:GetAttribute("ColorType")
		if colorType and isUnlocked(player, colorType) then
			if isPointInside(zone, root.Position, 8) then
				setCurrentWorld(player, colorType, "current-world")
				return colorType
			end

			local dist = (root.Position - zone.Position).Magnitude
			if dist < nearestDist then
				nearestDist = dist
				fallbackColor = colorType
			end
		end
	end

	if storedColor then
		return storedColor
	end

	return fallbackColor
end

local function getEggIdForColor(colorType)
	for eggId, egg in pairs(PetData.Eggs) do
		if egg.areaColor == colorType then
			return eggId
		end
	end
	return nil
end

local function getBestPartForEggObject(obj)
	if obj:IsA("BasePart") then
		return obj
	end
	if obj:IsA("Model") then
		return obj.PrimaryPart or obj:FindFirstChildWhichIsA("BasePart", true)
	end
	return nil
end

local function isDebugAppearanceObject(obj)
	return obj:FindFirstAncestor("PetAppearanceStudio") ~= nil
end

local function configureEggObject(obj, colorType, eggId)
	if isDebugAppearanceObject(obj) then
		return nil
	end
	local part = getBestPartForEggObject(obj)
	if not part then
		return nil
	end

	local function configurePart(basePart)
		basePart:SetAttribute("EggId", eggId)
		basePart:SetAttribute("ColorType", colorType)
		basePart:SetAttribute("AreaColor", colorType)
		basePart:SetAttribute("EggStation", true)
		basePart:SetAttribute("ColorZone", false)
		basePart.CanCollide = true
		basePart.CanTouch = false
		basePart.CanQuery = true
	end

	if obj:IsA("BasePart") then
		configurePart(obj)
	else
		obj:SetAttribute("EggId", eggId)
		obj:SetAttribute("ColorType", colorType)
		obj:SetAttribute("AreaColor", colorType)
		for _, descendant in ipairs(obj:GetDescendants()) do
			if descendant:IsA("BasePart") then
				configurePart(descendant)
			end
		end
	end

	addEggPrompt(part)
	addEggBillboard(part, ColorData.getWorldByColor(colorType), PetData.Eggs[eggId])
	return part
end

local function findEggPart(colorType)
	local cacheKey = "egg:" .. tostring(colorType)
	local cached = destinationCache[cacheKey]
	if cached and cached.Parent then
		return cached
	end

	local eggId = getEggIdForColor(colorType)
	if colorType == "Red" then
		local spawnEgg = findSpawnTutorialEgg()
		if spawnEgg then
			return spawnEgg
		end
	end

	for _, obj in ipairs(workspace:GetDescendants()) do
		if obj.Name == tostring(colorType) .. "Egg" and not isDebugAppearanceObject(obj) then
			local configured = configureEggObject(obj, colorType, eggId)
			if configured then
				destinationCache[cacheKey] = configured
				return configured
			end
		end
	end

	for _, obj in ipairs(workspace:GetDescendants()) do
		if obj:IsA("BasePart") and obj:GetAttribute("EggId") and not isDebugAppearanceObject(obj) then
			local eggColor = obj:GetAttribute("ColorType") or obj:GetAttribute("AreaColor")
			if eggColor == colorType or obj:GetAttribute("EggId") == eggId then
				obj:SetAttribute("ColorType", colorType)
				obj:SetAttribute("AreaColor", colorType)
				addEggPrompt(obj)
				addEggBillboard(obj, ColorData.getWorldByColor(colorType), PetData.Eggs[eggId or obj:GetAttribute("EggId")])
				destinationCache[cacheKey] = obj
				return obj
			end
		end
	end
	if not eggId then
		return nil
	end

	local zone = findZonePart(colorType)
	if not zone then
		return nil
	end
	if not RUNTIME_WORLD_BUILDING_ENABLED then
		return nil
	end

	local map = getMap()
	if not map then
		return nil
	end
	local eggsFolder = map:FindFirstChild("Eggs")
	if not eggsFolder then
		eggsFolder = Instance.new("Folder")
		eggsFolder.Name = "Eggs"
		eggsFolder.Parent = map
	end

	local world = ColorData.getWorldByColor(colorType)
	local eggData = PetData.Eggs[eggId]
	local accent = eggData and eggData.color or (ColorData.Colors[colorType] and ColorData.Colors[colorType].color) or COLORS.pink
	local basePos = zone.Position + Vector3.new(math.min(zone.Size.X * 0.24, 78), zone.Size.Y * 0.5 + 7.2, math.max(zone.Size.Z * 0.24, 72))
	local egg = createPart(eggsFolder, tostring(colorType) .. "Egg", Vector3.new(12, 15, 12), CFrame.new(basePos), accent, Enum.Material.SmoothPlastic)
	egg.Shape = Enum.PartType.Ball
	egg:SetAttribute("EggId", eggId)
	egg:SetAttribute("ColorType", colorType)
	egg:SetAttribute("AreaColor", colorType)
	addEggPrompt(egg)
	addEggBillboard(egg, world, eggData)

	local pedestal = createPart(eggsFolder, tostring(colorType) .. "EggPedestal", Vector3.new(28, 2.4, 28), CFrame.new(basePos - Vector3.new(0, 7, 0)), COLORS.dark, Enum.Material.SmoothPlastic)
	pedestal:SetAttribute("EggStationDecor", true)
	pedestal:SetAttribute("ColorType", colorType)

	local glow = createPart(eggsFolder, tostring(colorType) .. "EggGlow", Vector3.new(23, 0.35, 23), CFrame.new(basePos - Vector3.new(0, 5.65, 0)), accent, Enum.Material.Neon)
	glow.Transparency = 0.18
	glow.CanCollide = false
	glow:SetAttribute("EggStationDecor", true)
	glow:SetAttribute("ColorType", colorType)

	print("Created Egg Station for " .. tostring(colorType))
	destinationCache[cacheKey] = egg
	return egg
end

local function findSellPart(colorType)
	local cacheKey = "sell:" .. tostring(colorType)
	local cached = destinationCache[cacheKey]
	if cached and cached.Parent then
		local cachedColor = cached:GetAttribute("ColorType")
			or cached:GetAttribute("AreaColor")
			or cached:GetAttribute("SellColor")
		if cachedColor == colorType then
			return cached
		end
		destinationCache[cacheKey] = nil
	end

	local worldIndex = ColorData.getWorldIndex(colorType)
	for _, name in ipairs({
		colorType .. "SellZone",
		colorType .. "SellStation",
		colorType .. "SellPad",
		colorType .. "_Sell",
		worldIndex and ("World" .. tostring(worldIndex) .. "Sell") or nil,
	}) do
		local named = name and workspace:FindFirstChild(name, true)
		if named and named:IsA("BasePart") then
			named:SetAttribute("SellZone", true)
			named:SetAttribute("SellLocation", true)
			named:SetAttribute("ColorType", colorType)
			named:SetAttribute("AreaColor", colorType)
			destinationCache[cacheKey] = named
			return named
		end
	end

	if worldIndex then
		local named = workspace:FindFirstChild("World" .. tostring(worldIndex) .. "_Sell", true)
		if named and named:IsA("BasePart") then
			named:SetAttribute("SellZone", true)
			named:SetAttribute("SellLocation", true)
			named:SetAttribute("ColorType", colorType)
			named:SetAttribute("AreaColor", colorType)
			destinationCache[cacheKey] = named
			return named
		end
	end

	cached = destinationCache[cacheKey]
	if cached and cached.Parent then
		return cached
	end

	local fallback = nil
	for _, obj in ipairs(workspace:GetDescendants()) do
		if obj:IsA("BasePart")
			and (obj:GetAttribute("SellZone")
				or obj:GetAttribute("SellLocation")
				or obj.Name == "SellZone"
				or obj.Name == "Sell"
				or obj.Name == "SellPad"
				or obj.Name == colorType .. "SellPad"
				or obj.Name == colorType .. "SellStation"
				or obj.Name == "SellPart"
				or string.match(obj.Name, "^World%d+_Sell$")
				or string.match(obj.Name, "^World%d+Sell$")
				or string.match(obj.Name, "SellStation$"))
		then
			fallback = fallback or obj
			local sellColor = obj:GetAttribute("ColorType") or obj:GetAttribute("AreaColor") or obj:GetAttribute("SellColor")
			if sellColor == colorType then
				destinationCache[cacheKey] = obj
				return obj
			end
		end
	end
	if colorType == "Red" and fallback then
		return fallback
	end

	local zone = findZonePart(colorType)
	if not zone then
		return nil
	end
	if not RUNTIME_WORLD_BUILDING_ENABLED then
		return nil
	end

	local map = getMap()
	if not map then
		return nil
	end
	local stationsFolder = map:FindFirstChild("SellStations")
	if not stationsFolder then
		stationsFolder = Instance.new("Folder")
		stationsFolder.Name = "SellStations"
		stationsFolder.Parent = map
	end

	local worldIndex = ColorData.getWorldIndex(colorType) or 1
	local accent = ColorData.Colors[colorType] and ColorData.Colors[colorType].color or COLORS.green
	local basePos = zone.Position + Vector3.new(-math.max(34, zone.Size.X * 0.22), zone.Size.Y * 0.5 + 0.8, math.max(32, zone.Size.Z * 0.24))
	local sell = createPart(stationsFolder, "World" .. tostring(worldIndex) .. "_Sell", Vector3.new(42, 1.2, 30), CFrame.new(basePos), accent:Lerp(COLORS.green, 0.45), Enum.Material.Neon)
	sell.Transparency = 0.08
	sell.CanCollide = false
	sell.CanTouch = true
	sell:SetAttribute("SellZone", true)
	sell:SetAttribute("SellLocation", true)
	sell:SetAttribute("ColorType", colorType)
	sell:SetAttribute("AreaColor", colorType)
	sell:SetAttribute("SellColor", colorType)

	print("Created Sell Station for " .. tostring(colorType))
	destinationCache[cacheKey] = sell
	return sell
end

local function findShopPart(colorType)
	local cacheKey = "shop:" .. tostring(colorType)
	for _, obj in ipairs(workspace:GetDescendants()) do
		if obj:IsA("BasePart")
			and obj:GetAttribute("BrushNpc") == true
			and obj:GetAttribute("BrushShop") == true
			and (obj:GetAttribute("ColorType") or obj:GetAttribute("ShopColor")) == colorType
		then
			addShopPrompt(obj)
			destinationCache[cacheKey] = obj
			return obj
		end
	end

	local cached = destinationCache[cacheKey]
	if cached and cached.Parent then
		return cached
	end

	local map = getExistingMap()
	local shopsFolder = map and map:FindFirstChild("BrushShops")
	if shopsFolder then
		for _, obj in ipairs(shopsFolder:GetChildren()) do
			if obj:IsA("BasePart") and obj:GetAttribute("BrushShop") and obj:GetAttribute("ColorType") == colorType then
				addShopBillboard(obj)
				addShopPrompt(obj)
				destinationCache[cacheKey] = obj
				return obj
			end
		end
	end

	for _, obj in ipairs(workspace:GetDescendants()) do
		if obj:IsA("BasePart")
			and (obj:GetAttribute("BrushShop")
				or obj:GetAttribute("CombinedShop")
				or obj:GetAttribute("ShopStation")
				or obj.Name == "BrushShop"
				or obj.Name == "EquipmentShop"
				or obj.Name == "Shop"
				or obj.Name == "CombinedShop"
				or obj.Name == "ShopAndUpgrades"
				or obj.Name == "UnlockTraits"
				or obj.Name == colorType .. "Shop"
				or obj.Name == colorType .. "BrushShop"
				or obj.Name == colorType .. "CombinedShop"
				or string.match(obj.Name, "^World%d+_Shop$"))
		then
			local shopColor = obj:GetAttribute("ColorType") or obj:GetAttribute("AreaColor")
			local worldIndex = ColorData.getWorldIndex(colorType)
			if not shopColor and worldIndex and obj.Name == "World" .. tostring(worldIndex) .. "_Shop" then
				shopColor = colorType
			end
			if not shopColor and obj.Name == "UnlockTraits" and colorType == "Orange" then
				shopColor = colorType
			end
			if shopColor == colorType then
				obj:SetAttribute("BrushShop", true)
				obj:SetAttribute("CombinedShop", true)
				obj:SetAttribute("ShopStation", true)
				obj:SetAttribute("ColorType", colorType)
				obj:SetAttribute("AreaColor", colorType)
				addShopBillboard(obj)
				addShopPrompt(obj)
				destinationCache[cacheKey] = obj
				return obj
			end
		end
	end

	local zone = findZonePart(colorType)
	if not zone then
		return nil
	end
	if not RUNTIME_WORLD_BUILDING_ENABLED then
		return nil
	end

	map = getMap()
	if not map then
		return nil
	end
	shopsFolder = map:FindFirstChild("BrushShops")
	if not shopsFolder then
		shopsFolder = Instance.new("Folder")
		shopsFolder.Name = "BrushShops"
		shopsFolder.Parent = map
	end

	local colorInfo = ColorData.Colors[colorType]
	local accent = colorInfo and colorInfo.color or COLORS.yellow
	local basePos = zone.Position + Vector3.new(math.max(-zone.Size.X * 0.28, -90), zone.Size.Y * 0.5 + 0.8, -zone.Size.Z * 0.28)
	local pad = createPart(shopsFolder, colorType .. "BrushShop", Vector3.new(28, 1.6, 20), CFrame.new(basePos), accent:Lerp(Color3.new(1, 1, 1), 0.25), Enum.Material.Neon)
	pad:SetAttribute("BrushShop", true)
	pad:SetAttribute("CombinedShop", true)
	pad:SetAttribute("ShopStation", true)
	pad:SetAttribute("ColorType", colorType)
	pad.CanCollide = false
	addShopBillboard(pad)
	addShopPrompt(pad)

	local back = createPart(shopsFolder, colorType .. "BrushShopSign", Vector3.new(24, 9, 1.2), CFrame.new(basePos + Vector3.new(0, 5, 8.8)), COLORS.dark)
	back:SetAttribute("BrushShopDecor", true)
	back:SetAttribute("ColorType", colorType)

	local counter = createPart(shopsFolder, colorType .. "BrushShopCounter", Vector3.new(20, 4, 3), CFrame.new(basePos + Vector3.new(0, 2.3, 5.6)), COLORS.yellow)
	counter:SetAttribute("BrushShopDecor", true)
	counter:SetAttribute("ColorType", colorType)

	print("Created Brush Shop for " .. tostring(colorType))
	destinationCache[cacheKey] = pad
	return pad
end

local function findUpgradePart(colorType)
	local combinedShop = findShopPart(colorType)
	if combinedShop then
		return combinedShop
	end

	local cacheKey = "upgrade:" .. tostring(colorType)
	local cached = destinationCache[cacheKey]
	if cached and cached.Parent then
		return cached
	end

	local map = getExistingMap()
	local stationsFolder = map and map:FindFirstChild("UpgradeStations")
	if stationsFolder then
		for _, obj in ipairs(stationsFolder:GetChildren()) do
			if obj:IsA("BasePart") and obj:GetAttribute("UpgradeStation") and obj:GetAttribute("ColorType") == colorType then
				addUpgradeBillboard(obj)
				addUpgradePrompt(obj)
				destinationCache[cacheKey] = obj
				return obj
			end
		end
	end

	for _, obj in ipairs(workspace:GetDescendants()) do
		if obj:IsA("BasePart")
			and (obj:GetAttribute("UpgradeStation")
				or obj.Name == "UpgradeStation"
				or obj.Name == "UpgradePad"
				or obj.Name == "Upgrade"
				or obj.Name == colorType .. "UpgradeStation"
				or string.match(obj.Name, "^World%d+_Upgrade$"))
		then
			local upgradeColor = obj:GetAttribute("ColorType") or obj:GetAttribute("AreaColor")
			local worldIndex = ColorData.getWorldIndex(colorType)
			if not upgradeColor and worldIndex and obj.Name == "World" .. tostring(worldIndex) .. "_Upgrade" then
				upgradeColor = colorType
			end
			if upgradeColor == colorType then
				obj:SetAttribute("UpgradeStation", true)
				obj:SetAttribute("ColorType", colorType)
				obj:SetAttribute("AreaColor", colorType)
				addUpgradeBillboard(obj)
				addUpgradePrompt(obj)
				destinationCache[cacheKey] = obj
				return obj
			end
		end
	end

	local zone = findZonePart(colorType)
	if not zone then
		return nil
	end
	if not RUNTIME_WORLD_BUILDING_ENABLED then
		return nil
	end

	map = getMap()
	if not map then
		return nil
	end
	stationsFolder = map:FindFirstChild("UpgradeStations")
	if not stationsFolder then
		stationsFolder = Instance.new("Folder")
		stationsFolder.Name = "UpgradeStations"
		stationsFolder.Parent = map
	end

	local colorInfo = ColorData.Colors[colorType]
	local accent = colorInfo and colorInfo.color or COLORS.purple
	local basePos = zone.Position + Vector3.new(math.min(zone.Size.X * 0.24, 80), zone.Size.Y * 0.5 + 0.8, -zone.Size.Z * 0.08)
	local pad = createPart(stationsFolder, colorType .. "UpgradeStation", Vector3.new(30, 1.4, 22), CFrame.new(basePos), accent:Lerp(COLORS.purple, 0.35), Enum.Material.SmoothPlastic)
	pad:SetAttribute("UpgradeStation", true)
	pad:SetAttribute("ColorType", colorType)
	pad.CanCollide = false
	addUpgradeBillboard(pad)
	addUpgradePrompt(pad)

	print("Created Upgrade Station for " .. tostring(colorType))
	destinationCache[cacheKey] = pad
	return pad
end

local function teleportNear(player, target, extraDistance)
	local root = getRoot(player)
	if not root or not target then
		return false
	end

	local distance = extraDistance or math.max(target.Size.Z * 0.5 + 7, 12)
	local destination = target.CFrame * CFrame.new(0, 4, -distance)
	root.CFrame = CFrame.lookAt(destination.Position, target.Position)
	return true
end

local function useCooldown(player)
	local now = os.clock()
	if cooldowns[player] and now - cooldowns[player] < COOLDOWN then
		return false
	end
	cooldowns[player] = now
	return true
end

travelEvent.OnServerEvent:Connect(function(player, destinationType)
	local startedAt = os.clock()
	if destinationType ~= "sell" and destinationType ~= "egg" and destinationType ~= "shop" and destinationType ~= "upgrade" then
		travelEvent:FireClient(player, false, destinationType, "Sector travel failed. Try again.")
		return
	end
	if destinationType == "sell" then
		travelEvent:FireClient(player, false, destinationType, "Selling is disabled. Break Color to earn Coins instantly.")
		return
	end
	if not useCooldown(player) then
		return
	end

	local worldColor = getCurrentWorldColor(player)
	if not isUnlocked(player, worldColor) then
		worldColor = "Red"
	end

	local world = ColorData.getWorldByColor(worldColor)
	local target
	if destinationType == "sell" then
		target = findSellPart(worldColor)
	elseif destinationType == "egg" then
		target = findEggPart(worldColor)
	elseif destinationType == "shop" then
		target = findShopPart(worldColor)
	else
		target = findUpgradePart(worldColor)
	end
	if not target then
		local message = ({
			sell = "No sell zone found.",
			egg = "No egg found for this Sector.",
			shop = "No brush shop found.",
			upgrade = "No upgrade station found.",
		})[destinationType] or "No destination found."
		warn("Quick travel failed for " .. player.Name .. ": " .. message)
		travelEvent:FireClient(player, false, destinationType, message)
		return
	end

	if teleportNear(player, target) then
		setCurrentWorld(player, worldColor, "current-world")
		local label = ({
			sell = "Sell Zone",
			egg = (world and world.name or worldColor) .. " Egg",
			shop = "Brush Shop",
			upgrade = "Brush Shop",
		})[destinationType] or "Destination"
		print(player.Name .. " quick traveled to " .. label .. " in " .. tostring(worldColor))
		travelEvent:FireClient(player, true, destinationType, "Traveling to " .. label)
		local elapsed = os.clock() - startedAt
		print("SectorTravel: " .. player.Name .. " -> " .. tostring(destinationType) .. " in " .. string.format("%.2f", elapsed) .. "s")
		print("Quick travel completed: " .. tostring(destinationType) .. " in " .. string.format("%.3f", elapsed) .. "s")
		if elapsed > 0.5 then
			warn("SectorTravel slow: " .. tostring(destinationType) .. " took " .. string.format("%.2f", elapsed) .. "s")
		end
	else
		travelEvent:FireClient(player, false, destinationType, "Sector travel failed. Try again.")
	end
end)

Players.PlayerRemoving:Connect(function(player)
	cooldowns[player] = nil
end)

workspace.DescendantAdded:Connect(function(obj)
	if configureSpawnTutorialEgg(obj) then
		print("WorldTravel: hooked baked tutorial SpawnEgg as ColorEgg.")
	end
end)

local function ensureAllWorldStations()
	for _, world in ipairs(ColorData.Worlds or {}) do
		findEggPart(world.primaryColor)
		findShopPart(world.primaryColor)
		findUpgradePart(world.primaryColor)
	end
end

task.defer(ensureAllWorldStations)
task.delay(3, ensureAllWorldStations)
task.delay(8, ensureAllWorldStations)
]]></string>
        </Properties>
      </Item>
      <Item class="Script" referent="108">
        <Properties>
          <string name="Name">WorldTravelService</string>
          <token name="RunContext">0</token>
          <string name="Source"><![CDATA[-- Server-authoritative world/zone travel for the editable WorldsWindow UI.
-- Clients may only request a locationId; this script validates unlock state and teleports safely.
local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local ServerScriptService = game:GetService("ServerScriptService")

local ColorData = require(ReplicatedStorage:WaitForChild("ColorData"))
local Events = ReplicatedStorage:WaitForChild("Events")
local dataDirtyEvent = Events:FindFirstChild("PlayerDataDirty")

local requestTravel = Events:FindFirstChild("RequestTravelToLocation")
if not requestTravel then
	requestTravel = Instance.new("RemoteEvent")
	requestTravel.Name = "RequestTravelToLocation"
	requestTravel.Parent = Events
end

local travelResult = Events:FindFirstChild("TravelToLocationResult")
if not travelResult then
	travelResult = Instance.new("RemoteEvent")
	travelResult.Name = "TravelToLocationResult"
	travelResult.Parent = Events
end

local COOLDOWN_SECONDS = 1.5
local cooldownByPlayer = {}

local LOCATION_CONFIG = {
	OriginSector = {
		DisplayName = "Origin Sector",
		SpawnNames = { "OriginSectorSpawn", "StartSectorSpawn", "SpawnWorldSpawn", "SpawnLocation" },
		AlwaysUnlocked = true,
		CurrentWorld = "Red",
		AutoUnlockTeleport = true,
	},
	RedWastelands = {
		DisplayName = "Red Wastelands",
		SpawnNames = { "RedWastelandsSpawn", "RedZoneSpawn", "StartSectorSpawn", "SpawnLocation" },
		AlwaysUnlocked = true,
		CurrentWorld = "Red",
		AutoUnlockTeleport = true,
	},
	ZorkShop = {
		DisplayName = "Zork Shop",
		SpawnNames = { "ZorkShopSpawn", "ShopSpawn", "ShopEntranceSpawn", "StartSectorSpawn", "SpawnLocation" },
		AlwaysUnlocked = true,
		CurrentWorld = "Red",
		AutoUnlockTeleport = true,
	},
	InsidePipes = {
		DisplayName = "Inside the Pipes",
		SpawnNames = { "PipeExitSpawn", "InsidePipesSpawn", "MutationZoneSpawn" },
		RequiredColor = "Orange",
		CurrentWorld = "Orange",
		RequiresTeleportUnlock = true,
	},
	OrangeSector = {
		DisplayName = "Orange Sector",
		SpawnNames = { "OrangeSectorSpawn", "OrangeZoneSpawn", "OrangeSpawn" },
		RequiredColor = "Orange",
		CurrentWorld = "Orange",
		AutoUnlockTeleport = true,
	},
	FutureSector = {
		DisplayName = "Future Sector",
		SpawnNames = {},
		Locked = true,
	},
}

for locationId, config in pairs(LOCATION_CONFIG) do
	config.LocationId = locationId
end

local LOCATION_ID_ALIASES = {
	SpawnWorld = "OriginSector",
	StartSector = "OriginSector",
	RedArea = "RedWastelands",
	Shop = "ZorkShop",
	Zork = "ZorkShop",
	Pipes = "InsidePipes",
	OrangePipes = "InsidePipes",
}

local function resolveLocationId(locationId)
	return LOCATION_ID_ALIASES[locationId] or locationId
end

local function fireResult(player, success, locationId, message, extra)
	local payload = {
		Success = success,
		LocationId = locationId,
		Message = message,
	}
	if type(extra) == "table" then
		for key, value in pairs(extra) do
			payload[key] = value
		end
	end
	travelResult:FireClient(player, {
		Success = payload.Success,
		LocationId = payload.LocationId,
		Message = payload.Message,
		UnlockedTeleport = payload.UnlockedTeleport,
		DisplayName = payload.DisplayName,
		UnlockedTeleports = payload.UnlockedTeleports,
	})
end

local function markDataDirty(player, reason)
	local event = dataDirtyEvent
	if not event or not event.Parent then
		event = Events:FindFirstChild("PlayerDataDirty")
		dataDirtyEvent = event
	end
	if event and event:IsA("BindableEvent") then
		event:Fire(player, reason or "world-travel")
	end
end

local function findSpawn(spawnNames)
	for _, spawnName in ipairs(spawnNames or {}) do
		local found = workspace:FindFirstChild(spawnName, true)
		if found and found:IsA("BasePart") then
			return found
		end
	end
	return nil
end

local function listContains(list, value)
	if type(list) ~= "table" then
		return false
	end
	for _, item in ipairs(list) do
		if item == value then
			return true
		end
	end
	return false
end

local function getPlayerDataFromDataManager(player)
	-- DataManager is a Script in this project, not a ModuleScript. If a future
	-- build exposes a module/profile accessor, this handles it safely without
	-- breaking the current server.
	local dataManager = ServerScriptService:FindFirstChild("DataManager")
	if not dataManager or not dataManager:IsA("ModuleScript") then
		return nil
	end

	local ok, manager = pcall(require, dataManager)
	if not ok then
		warn("WorldTravelService: failed to require DataManager:", manager)
		return nil
	end

	if type(manager.GetProfile) == "function" then
		local profile = manager:GetProfile(player)
		return profile and profile.Data
	end
	if type(manager.Profiles) == "table" and manager.Profiles[player] then
		return manager.Profiles[player].Data
	end
	return nil
end

local function getUnlockedColorsFromAttributes(player)
	local csv = player:GetAttribute("UnlockedColors")
	if type(csv) == "string" then
		return ColorData.getUnlockedColorSet(csv)
	end

	for _, folderName in ipairs({ "ColorStorage", "Values", "Data", "PlayerData" }) do
		local valuesFolder = player:FindFirstChild(folderName)
		if valuesFolder then
			local unlockedValue = valuesFolder:FindFirstChild("UnlockedColors")
			if unlockedValue and unlockedValue:IsA("StringValue") then
				return ColorData.getUnlockedColorSet(unlockedValue.Value)
			end
		end
	end

	return nil
end

local function isColorUnlocked(player, colorName)
	if not colorName or colorName == "Red" then
		return true
	end

	local data = getPlayerDataFromDataManager(player)
	if data then
		if listContains(data.UnlockedColors, colorName) then
			return true
		end
		if data.CurrentWorld == colorName or data.ActiveWorldColor == colorName or data.HighestUnlockedWorld == colorName then
			return true
		end
	end

	local unlockedSet = getUnlockedColorsFromAttributes(player)
	if unlockedSet and unlockedSet[colorName] == true then
		return true
	end

	-- Studio/dev fallback: if the world config itself says this is the next ready
	-- sector but no player data is exposed, deny rather than allowing progression exploits.
	return false
end

local function getUnlockedTeleportSet(player)
	local storage = player:FindFirstChild("ColorStorage")
	local value = storage and storage:FindFirstChild("UnlockedTeleports")
	local set = { OriginSector = true }
	if value and value:IsA("StringValue") then
		for _, locationId in ipairs(string.split(value.Value, ",")) do
			if locationId ~= "" then
				set[locationId] = true
			end
		end
	end
	return set, value
end

local function serializeTeleports(set)
	local ordered = {}
	for locationId in pairs(LOCATION_CONFIG) do
		if set[locationId] then
			table.insert(ordered, locationId)
		end
	end
	table.sort(ordered)
	return table.concat(ordered, ",")
end

local function unlockTeleport(player, locationId)
	local set, value = getUnlockedTeleportSet(player)
	if set[locationId] then
		return false, value and value.Value or serializeTeleports(set)
	end
	set[locationId] = true
	local serialized = serializeTeleports(set)
	if value and value:IsA("StringValue") then
		value.Value = serialized
	end
	player:SetAttribute("UnlockedTeleports", serialized)
	markDataDirty(player, "unlocked-teleport")
	return true, serialized
end

local function isTeleportUnlocked(player, locationId)
	local set = getUnlockedTeleportSet(player)
	return set[locationId] == true
end

local function setCurrentWorld(player, colorType)
	if not colorType then
		return
	end
	local world = ColorData.getWorldByColor(colorType)
	if not world or not isColorUnlocked(player, world.primaryColor) then
		return
	end

	player:SetAttribute("ActiveWorldColor", world.primaryColor)
	local storage = player:FindFirstChild("ColorStorage")
	local currentWorld = storage and storage:FindFirstChild("CurrentWorld")
	if currentWorld and currentWorld:IsA("StringValue") and currentWorld.Value ~= world.primaryColor then
		currentWorld.Value = world.primaryColor
	end
	markDataDirty(player, "current-world")
end

local function canTravel(player, config)
	if config.Locked then
		return false, "Locked"
	end
	if config.AlwaysUnlocked then
		return true
	end
	if config.RequiredColor then
		if isColorUnlocked(player, config.RequiredColor) then
			if config.RequiresTeleportUnlock and not isTeleportUnlocked(player, config.LocationId) then
				return false, "Visit " .. config.DisplayName .. " first to unlock its teleport."
			end
			return true
		end
		return false, config.DisplayName .. " is locked"
	end
	return true
end

local function safelyTeleport(player, spawnPart)
	local character = player.Character
	if not character then
		return false, "Character not loaded"
	end

	local root = character:FindFirstChild("HumanoidRootPart")
	if not root then
		return false, "HumanoidRootPart missing"
	end

	player:SetAttribute("IsTeleporting", true)
	root.AssemblyLinearVelocity = Vector3.zero
	root.AssemblyAngularVelocity = Vector3.zero
	root.CFrame = spawnPart.CFrame + Vector3.new(0, 5, 0)

	task.delay(1, function()
		if player and player.Parent then
			player:SetAttribute("IsTeleporting", false)
		end
	end)

	return true
end

requestTravel.OnServerEvent:Connect(function(player, locationId)
	if typeof(locationId) ~= "string" then
		return
	end
	locationId = resolveLocationId(locationId)

	local now = os.clock()
	if cooldownByPlayer[player] and now - cooldownByPlayer[player] < COOLDOWN_SECONDS then
		return
	end
	cooldownByPlayer[player] = now

	local config = LOCATION_CONFIG[locationId]
	if not config then
		warn("WorldTravelService: invalid location", player.Name, locationId)
		fireResult(player, false, locationId, "Invalid location")
		return
	end

	local allowed, reason = canTravel(player, config)
	if not allowed then
		warn("WorldTravelService: blocked locked travel", player.Name, locationId, reason)
		fireResult(player, false, locationId, reason or "Locked")
		return
	end

	local spawnPart = findSpawn(config.SpawnNames)
	if not spawnPart then
		warn("WorldTravelService: missing spawn part for", locationId)
		fireResult(player, false, locationId, "Missing spawn")
		return
	end

	local success, message = safelyTeleport(player, spawnPart)
	if success then
		player:SetAttribute("LastTravelLocation", locationId)
		if config.CurrentWorld then
			player:SetAttribute("RequestedWorld", config.CurrentWorld)
			setCurrentWorld(player, config.CurrentWorld)
		end
		local unlockedNow = false
		local unlockedTeleports
		if config.AutoUnlockTeleport then
			unlockedNow, unlockedTeleports = unlockTeleport(player, locationId)
		else
			local _, currentTeleports = getUnlockedTeleportSet(player)
			unlockedTeleports = currentTeleports and currentTeleports.Value
		end
		fireResult(player, true, locationId, "Traveled to " .. config.DisplayName, {
			DisplayName = config.DisplayName,
			UnlockedTeleport = unlockedNow,
			UnlockedTeleports = unlockedTeleports,
		})
	else
		fireResult(player, false, locationId, message or "Travel failed")
	end
end)

Players.PlayerRemoving:Connect(function(player)
	cooldownByPlayer[player] = nil
end)
]]></string>
        </Properties>
      </Item>
      <Item class="Script" referent="109">
        <Properties>
          <string name="Name">ZoneSpawner</string>
          <token name="RunContext">0</token>
          <string name="Source"><![CDATA[-- Script in ServerScriptService named "ZoneSpawner"
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local ServerScriptService = game:GetService("ServerScriptService")
local Players = game:GetService("Players")
local ColorData = require(ReplicatedStorage:WaitForChild("ColorData"))
local GameBalance = require(ReplicatedStorage:WaitForChild("GameBalance"))

local featureFlags = GameBalance.FeatureFlags or {}
if featureFlags.RuntimeColorPopulationEnabled == false then
	warn("ZoneSpawner: runtime color population disabled.")
	return
end

local SPAWN_CONFIG = {
	PaintBlob    = 0.66,
	PaintGlob    = 0.25,
	PaintBoulder = 0.09,
}

local PUDDLE_VERSION = "paint-puddle-v8"
local MAP_NAME = "ColorSimulatorMap"
local RUNTIME_BLOB_FOLDER_NAME = "RuntimeColorBlobs"
local COLLECTOR_BASE_TRANSPARENCY = 0.985
local CLUSTER_COUNT_MULTIPLIER = 1
local DEBUG_LOGS = false
local SPAWN_RETRY_LIMIT = 28
local DEFAULT_EXCLUSION_PADDING = 8
local EGG_EXCLUSION_PADDING = 34
local SHOP_EXCLUSION_PADDING = 10
local PROGRESSION_CONFIG = GameBalance.Progression or {}
local MAX_PLAYABLE_SECTOR_INDEX = tonumber(PROGRESSION_CONFIG.MaxPlayableSectorIndex) or math.huge
local objectHealth = {}
local lastPopulatedAt = {}
local populateRequest = ServerScriptService:FindFirstChild("RequestPopulateColorZone")
if not populateRequest then
	populateRequest = Instance.new("BindableEvent")
	populateRequest.Name = "RequestPopulateColorZone"
	populateRequest.Parent = ServerScriptService
end

local function getMapConfig()
	return GameBalance.Map or {}
end

local function getZonePopulationConfig()
	return GameBalance.ZonePopulation or {}
end

local function isSectorPlayable(colorType)
	local index = ColorData.getWorldIndex(colorType)
	return index ~= nil and index <= MAX_PLAYABLE_SECTOR_INDEX
end

local function isPointInside(part, worldPosition, margin)
	local localPoint = part.CFrame:PointToObjectSpace(worldPosition)
	local half = part.Size * 0.5 + Vector3.new(margin, margin, margin)
	return math.abs(localPoint.X) <= half.X
		and math.abs(localPoint.Y) <= half.Y
		and math.abs(localPoint.Z) <= half.Z
end

local function inferPlayableSectorColorFromName(part)
	if not part or not part:IsA("BasePart") then
		return nil
	end

	local partName = string.lower(part.Name or "")
	local parentName = part.Parent and string.lower(part.Parent.Name or "") or ""
	local namedAsSurface = string.find(partName, "floor")
		or string.find(partName, "ground")
		or string.find(partName, "zone")
		or string.find(partName, "area")
		or string.find(partName, "sector")
		or string.find(parentName, "floor")
		or string.find(parentName, "zone")
		or string.find(parentName, "area")
		or string.find(parentName, "sector")

	if not namedAsSurface then
		return nil
	end

	for _, world in ipairs(ColorData.Worlds or {}) do
		local color = world.primaryColor
		if color then
			local loweredColor = string.lower(color)
			if string.find(partName, loweredColor, 1, true) or string.find(parentName, loweredColor, 1, true) then
				return color
			end
		end
	end

	return nil
end

local function hasProtectedEggAncestor(part)
	local current = part
	while current do
		local name = string.lower(current.Name or "")
		if string.find(name, "egg", 1, true)
			or current:GetAttribute("EggStation") == true
			or current:GetAttribute("TutorialEgg") == true
			or current:GetAttribute("BakedTutorialEgg") == true
			or current:GetAttribute("EggId") ~= nil
		then
			return true
		end
		current = current.Parent
	end
	return false
end

local function shouldNeverBeColorZone(part)
	if not part or not part:IsA("BasePart") then
		return false
	end
	local partName = string.lower(part.Name or "")
	local parentName = part.Parent and string.lower(part.Parent.Name or "") or ""
	local floorishName = string.find(partName, "floor", 1, true)
		or string.find(partName, "ground", 1, true)
		or string.find(partName, "zone", 1, true)
		or string.find(partName, "area", 1, true)
		or string.find(parentName, "floor", 1, true)
		or string.find(parentName, "ground", 1, true)
		or string.find(parentName, "zone", 1, true)
		or string.find(parentName, "area", 1, true)
	local namedPlayableSectorColor = inferPlayableSectorColorFromName(part)
	local playableSectorFloor = part:GetAttribute("PlayableSectorFloor") == true
	local playableNamedSectorFloor = floorishName and namedPlayableSectorColor and isSectorPlayable(namedPlayableSectorColor)

	if part.Name == "SpawnEgg"
		or part:FindFirstAncestor("SpawnEgg") ~= nil
		or part:FindFirstAncestor("PetAppearanceStudio") ~= nil
		or part:GetAttribute("BreakableType") ~= nil
		or part:GetAttribute("PaintPuddleVersion") ~= nil
		or part:GetAttribute("GemDeposit") == true
		or part:GetAttribute("WildColor") == true
		or part:FindFirstAncestor("DynamicGameplay") ~= nil
		or hasProtectedEggAncestor(part)
		or part:GetAttribute("EggStation") == true
		or part:GetAttribute("EggId") ~= nil
		or part:GetAttribute("TutorialEgg") == true
		or part:GetAttribute("BrushShop") == true
		or part:GetAttribute("CombinedShop") == true
		or part:GetAttribute("ShopStation") == true
		or part:GetAttribute("ShopEntrance") == true
		or part:GetAttribute("MutationStation") == true
		or part:GetAttribute("MutationUnlockStation") == true
		or part:GetAttribute("FeatureUnlock") == "Mutations"
		or part:GetAttribute("SectorInterior") == true
		or part:GetAttribute("MutationUnlockArea") == true
		or part:GetAttribute("DecorativeOnly") == true
		or part:GetAttribute("AreaSpawn") == true
		or part:GetAttribute("WorldSpawn") == true
		or part:GetAttribute("LobbySpawn") == true
		or part:GetAttribute("AreaGate") == true
		or part:GetAttribute("GateInteraction") == true
		or part:GetAttribute("ColorBlobSpawn") == true
	then
		return true
	end
	if playableSectorFloor or playableNamedSectorFloor then
		return false
	end

	if part:GetAttribute("DistantSectorColumn") == true
		or part:GetAttribute("SectorAnchor") == true
	then
		return true
	end

	local map = workspace:FindFirstChild(MAP_NAME)
	local shop = map and map:FindFirstChild("Shop")
	local distantSectors = map and map:FindFirstChild("DistantSectors")
	return (shop ~= nil and part:IsDescendantOf(shop))
		or (distantSectors ~= nil and part:IsDescendantOf(distantSectors)
			and part:GetAttribute("PlayableSectorFloor") ~= true
			and not namedPlayableSectorColor)
end

local function looksLikeZoneSurface(part)
	if part:GetAttribute("PlayableSectorFloor") == true then
		return true
	end
	local partName = string.lower(part.Name or "")
	local parentName = part.Parent and string.lower(part.Parent.Name or "") or ""
	if string.find(partName, "pipe", 1, true)
		or string.find(parentName, "pipe", 1, true)
		or partName == "core"
		or partName == "glowshell"
		or partName == "highlight"
		or string.find(partName, "floatcore", 1, true)
	then
		return false
	end
	local horizontalArea = part.Size.X * part.Size.Z
	local largeFlatSurface = horizontalArea >= 1600 and part.Size.X >= 35 and part.Size.Z >= 35 and part.Size.Y <= math.max(8, math.min(part.Size.X, part.Size.Z) * 0.3)
	local namedSurface = string.find(partName, "floor")
		or string.find(partName, "ground")
		or string.find(partName, "zone")
		or string.find(partName, "area")
		or string.find(partName, "sector")
		or string.find(parentName, "floor")
		or string.find(parentName, "zone")
		or string.find(parentName, "area")
		or string.find(parentName, "sector")
	return largeFlatSurface or namedSurface
end

local function inferColorFromMapPart(part)
	local attrColor = part:GetAttribute("ColorType") or part:GetAttribute("WorldColor") or part:GetAttribute("AreaColor")
	if ColorData.getWorldByColor(attrColor) and looksLikeZoneSurface(part) then
		return attrColor
	end

	local partName = string.lower(part.Name or "")
	local parentName = part.Parent and string.lower(part.Parent.Name or "") or ""
	local looksLikeFloor = string.find(partName, "floor") or string.find(partName, "ground") or string.find(partName, "zone") or string.find(partName, "area")
	for _, world in ipairs(ColorData.Worlds or {}) do
		local color = world.primaryColor
		local loweredColor = string.lower(color)
		if looksLikeFloor and (string.find(partName, loweredColor) or string.find(parentName, loweredColor)) then
			return color
		end
	end

	return nil
end

local function getZoneScore(part)
	local area = math.max(1, part.Size.X * part.Size.Z)
	if part:GetAttribute("PlayableSectorFloor") == true then
		area *= 10
	end
	if part:GetAttribute("ColorZone") == true then
		area *= 2
	end
	return area
end

local function configureColorZonePart(part)
	if shouldNeverBeColorZone(part) then
		if part:GetAttribute("ColorZone") == true then
			part:SetAttribute("ColorZone", false)
		end
		return nil
	end
	if not looksLikeZoneSurface(part) then
		if part:GetAttribute("ColorZone") == true then
			part:SetAttribute("ColorZone", false)
		end
		return nil
	end

	local colorType = inferColorFromMapPart(part)
	if not colorType then
		return nil
	end

	if part:GetAttribute("ColorZone") ~= true then
		part:SetAttribute("ColorZone", true)
	end
	if part:GetAttribute("ColorType") ~= colorType then
		part:SetAttribute("ColorType", colorType)
	end
	if inferPlayableSectorColorFromName(part) == colorType and part:GetAttribute("PlayableSectorFloor") ~= true then
		part:SetAttribute("PlayableSectorFloor", true)
	end
	return colorType
end

local function shouldClearGeneratedMapOnStart()
	return getMapConfig().ClearGeneratedMapOnStart == true
end

local function isBakedEditableMap(map)
	return map
		and (map:GetAttribute("BakedEditableMap") == true or map:FindFirstChild("Lobby") or map:FindFirstChild("RedZone"))
end

local function getRuntimeBlobParent()
	local map = workspace:FindFirstChild(MAP_NAME)
	if not map then
		return workspace
	end

	local folder = map:FindFirstChild(RUNTIME_BLOB_FOLDER_NAME)
	if not folder then
		folder = Instance.new("Folder")
		folder.Name = RUNTIME_BLOB_FOLDER_NAME
		folder:SetAttribute("RuntimeGenerated", true)
		folder.Parent = map
	end
	return folder
end

local function getVisualColor(colorType)
	if colorType == "Rainbow" then
		return Color3.fromHSV(math.random(), 0.72, 1)
	end

	local colorInfo = ColorData.Colors[colorType]
	return colorInfo and colorInfo.color or Color3.new(1, 1, 1)
end

local function getBaseVisualColor(colorType)
	if colorType == "Rainbow" then
		return Color3.fromRGB(215, 180, 255)
	end

	local colorInfo = ColorData.Colors[colorType]
	return colorInfo and colorInfo.color or Color3.new(1, 1, 1)
end

local function getVariedThemeColor(colorType)
	if colorType == "Rainbow" then
		return getVisualColor(colorType)
	end

	local base = getVisualColor(colorType)
	local hue, saturation, value = base:ToHSV()
	hue = (hue + math.random(-3, 3) / 100) % 1
	saturation = math.clamp(saturation + math.random(8, 18) / 100, 0.72, 0.96)
	value = math.clamp(value + math.random(10, 22) / 100, 0.88, 1)

	return Color3.fromHSV(hue, saturation, value)
end

local function getStoredColor(part, colorType)
	local stored = part and part:GetAttribute("SpawnColor")
	if typeof(stored) == "Color3" then
		return stored
	end
	return getBaseVisualColor(colorType)
end

local function randomPositionInZone(zonePart)
	local size = zonePart.Size
	local cf   = zonePart.CFrame
	local rx = math.random() * size.X - size.X / 2
	local rz = math.random() * size.Z - size.Z / 2
	local ry = size.Y / 2
	return cf:PointToWorldSpace(Vector3.new(rx, ry, rz))
end

local function isRuntimeBlobPart(part)
	return part
		and part:IsA("BasePart")
		and part:GetAttribute("BreakableType") ~= nil
		and part:GetAttribute("PaintPuddleVersion") == PUDDLE_VERSION
end

local function isProtectedSpawnBlocker(part, zone)
	if not part or not part:IsA("BasePart") or part == zone or isRuntimeBlobPart(part) then
		return false
	end
	if shouldNeverBeColorZone(part) then
		return true
	end
	if part:GetAttribute("ColorZone") == true or part:GetAttribute("ColorBlobSpawn") == true then
		return false
	end

	if part.Name == "SpawnEgg"
		or part.Name == "ShopEntrance"
		or part.Name == "Door"
		or part.Name == "Entrance"
		or part:FindFirstAncestor("SpawnEgg") ~= nil
		or hasProtectedEggAncestor(part)
		or part:GetAttribute("EggStation") == true
		or part:GetAttribute("TutorialEgg") == true
		or part:GetAttribute("BrushShop") == true
		or part:GetAttribute("CombinedShop") == true
		or part:GetAttribute("ShopStation") == true
		or part:GetAttribute("ShopEntrance") == true
	then
		return true
	end

	local map = workspace:FindFirstChild(MAP_NAME)
	local shop = map and map:FindFirstChild("Shop")
	if shop and part:IsDescendantOf(shop) then
		return true
	end

	if map and part:IsDescendantOf(map) and not part:GetAttribute("ColorZone") then
		local ancestor = part.Parent
		while ancestor and ancestor ~= map do
			local name = string.lower(ancestor.Name or "")
			if string.find(name, "shop", 1, true)
				or string.find(name, "egg", 1, true)
				or string.find(name, "spawn", 1, true)
			then
				return true
			end
			ancestor = ancestor.Parent
		end
	end

	return false
end

local function collectSpawnExclusions(zone)
	local exclusions = {}
	for _, obj in ipairs(workspace:GetDescendants()) do
		if isProtectedSpawnBlocker(obj, zone) then
			table.insert(exclusions, obj)
		end
	end
	return exclusions
end

local function getExclusionPadding(part, defaultPadding)
	if part.Name == "SpawnEgg"
		or part:FindFirstAncestor("SpawnEgg") ~= nil
		or hasProtectedEggAncestor(part)
		or part:GetAttribute("EggStation") == true
		or part:GetAttribute("TutorialEgg") == true
	then
		return EGG_EXCLUSION_PADDING
	end
	if part:GetAttribute("BrushShop") == true
		or part:GetAttribute("CombinedShop") == true
		or part:GetAttribute("ShopStation") == true
		or part:GetAttribute("ShopEntrance") == true
		or part:FindFirstAncestor("Shop") ~= nil
	then
		return SHOP_EXCLUSION_PADDING
	end
	return defaultPadding or DEFAULT_EXCLUSION_PADDING
end

local function isPositionInsidePartFootprint(position, part, padding)
	local localPoint = part.CFrame:PointToObjectSpace(position)
	return math.abs(localPoint.X) <= part.Size.X * 0.5 + padding
		and math.abs(localPoint.Z) <= part.Size.Z * 0.5 + padding
end

local function isPositionAllowed(position, exclusions, padding)
	for _, part in ipairs(exclusions or {}) do
		if part.Parent and isPositionInsidePartFootprint(position, part, getExclusionPadding(part, padding)) then
			return false
		end
	end
	return true
end

local function getSpawnPosition(zone, forcedPosition, exclusions)
	if forcedPosition and isPositionAllowed(forcedPosition, exclusions, DEFAULT_EXCLUSION_PADDING) then
		return forcedPosition
	end

	for _ = 1, SPAWN_RETRY_LIMIT do
		local candidate = randomPositionInZone(zone)
		if isPositionAllowed(candidate, exclusions, DEFAULT_EXCLUSION_PADDING) then
			return candidate
		end
	end

	return nil
end

local function markerMatchesZone(marker, zone, colorType)
	local markerColor = marker:GetAttribute("ColorType") or marker:GetAttribute("AreaColor")
	if markerColor and markerColor ~= colorType then
		return false
	end

	local markerZoneId = marker:GetAttribute("ZoneId")
	if markerZoneId and markerZoneId ~= zone.Name and markerZoneId ~= colorType and markerZoneId ~= colorType .. "Zone" then
		return false
	end

	return marker:GetAttribute("SpawnType") == "ColorBlob" or marker:GetAttribute("ColorBlobSpawn") == true
end

local function getSpawnMarkers(zone, colorType)
	local map = workspace:FindFirstChild(MAP_NAME)
	if not map then
		return {}
	end

	local roots = {}
	if zone.Parent then
		table.insert(roots, zone.Parent)
	end
	local globalSpawns = map:FindFirstChild("ColorBlobSpawns")
	if globalSpawns then
		table.insert(roots, globalSpawns)
	end
	table.insert(roots, map)

	local markers = {}
	local seen = {}
	for _, root in ipairs(roots) do
		for _, obj in ipairs(root:GetDescendants()) do
			if obj:IsA("BasePart") and not seen[obj] and markerMatchesZone(obj, zone, colorType) then
				seen[obj] = true
				table.insert(markers, obj)
			end
		end
	end

	return markers
end

local function randomPositionAtMarker(marker, zone)
	local size = marker.Size
	local rx = (math.random() - 0.5) * math.max(size.X, 4)
	local rz = (math.random() - 0.5) * math.max(size.Z, 4)
	local point = marker.CFrame:PointToWorldSpace(Vector3.new(rx, 0, rz))
	local zoneSurfaceY = zone.Position.Y + zone.Size.Y / 2
	return Vector3.new(point.X, math.max(point.Y, zoneSurfaceY), point.Z)
end

local function getPuddleSize(baseSize)
	local spreadX = math.random(158, 202) / 100
	local spreadZ = math.random(138, 184) / 100
	local thickness = math.random(38, 56) / 100
	return Vector3.new(
		math.max(1.15, baseSize.X * spreadX),
		math.max(0.35, baseSize.Y * thickness),
		math.max(1.15, baseSize.Z * spreadZ)
	)
end

local function setPuddleDetailsVisible(part, visible)
	for _, child in ipairs(part:GetDescendants()) do
		if child:IsA("BasePart") and child:GetAttribute("PuddleDetail") then
			child.Transparency = visible and (child:GetAttribute("VisibleTransparency") or 0) or 1
		end
	end
end

local function addPuddlePiece(root, name, localCFrame, size, color, transparency, material)
	local piece = Instance.new("Part")
	piece.Name = name
	piece.Shape = Enum.PartType.Ball
	piece.Size = size
	piece.CFrame = root.CFrame * localCFrame
	piece.Color = color
	piece.Transparency = transparency or 0
	piece.Material = material or root.Material
	piece.Anchored = true
	piece.CanCollide = false
	piece.CanTouch = false
	piece.CanQuery = false
	piece.CastShadow = false
	piece.Massless = true
	piece:SetAttribute("PuddleDetail", true)
	piece:SetAttribute("VisibleTransparency", piece.Transparency)
	piece.Parent = root

	return piece
end

local function addPuddleDetails(part)
	local baseColor = part.Color
	local baseSize = part.Size
	local darker = baseColor:Lerp(Color3.fromRGB(60, 48, 68), 0.1)
	local lighter = baseColor:Lerp(Color3.new(1, 1, 1), 0.22)
	local glossy = baseColor:Lerp(Color3.new(1, 1, 1), 0.48)
	local yTop = baseSize.Y * 0.34

	addPuddlePiece(
		part,
		"PuddleSoftShadow",
		CFrame.new(0, -baseSize.Y * 0.58, 0),
		Vector3.new(baseSize.X * 1.2, math.max(0.08, baseSize.Y * 0.2), baseSize.Z * 1.18),
		Color3.fromRGB(75, 28, 58),
		0.72,
		Enum.Material.SmoothPlastic
	)

	local lobeCount = math.random(3, 4)
	for i = 1, lobeCount do
		local angle = (math.pi * 2 / lobeCount) * i + math.random(-45, 45) / 100
		local offset = Vector3.new(math.cos(angle) * baseSize.X * math.random(24, 48) / 100, -baseSize.Y * 0.06, math.sin(angle) * baseSize.Z * math.random(22, 44) / 100)
		local lobeSize = Vector3.new(
			baseSize.X * math.random(58, 82) / 100,
			math.max(0.24, baseSize.Y * math.random(64, 90) / 100),
			baseSize.Z * math.random(54, 78) / 100
		)
		local lobeColor = (i % 2 == 0) and lighter or darker:Lerp(baseColor, 0.72)
		addPuddlePiece(part, "PuddleLobe", CFrame.new(offset) * CFrame.Angles(0, angle, 0), lobeSize, lobeColor, 0, part.Material)
	end

	addPuddlePiece(
		part,
		"PuddleGloss",
		CFrame.new(-baseSize.X * 0.16, yTop, -baseSize.Z * 0.08) * CFrame.Angles(0, math.rad(math.random(-24, 24)), 0),
		Vector3.new(baseSize.X * 0.36, math.max(0.1, baseSize.Y * 0.2), baseSize.Z * 0.12),
		glossy,
		0.16,
		Enum.Material.Neon
	)

	addPuddlePiece(
		part,
		"PuddleGlossDot",
		CFrame.new(baseSize.X * 0.18, yTop + 0.02, baseSize.Z * 0.14),
		Vector3.new(baseSize.X * 0.13, math.max(0.1, baseSize.Y * 0.18), baseSize.Z * 0.13),
		glossy,
		0.08,
		Enum.Material.Neon
	)

	for i = 1, math.random(2, 3) do
		local angle = math.random() * math.pi * 2
		local distance = math.random(66, 112) / 100
		local splashSize = math.random(18, 31) / 100
		addPuddlePiece(
			part,
			"PuddleSplash",
			CFrame.new(math.cos(angle) * baseSize.X * distance, -baseSize.Y * 0.06, math.sin(angle) * baseSize.Z * distance),
			Vector3.new(baseSize.X * splashSize * 1.3, math.max(0.08, baseSize.Y * 0.18), baseSize.X * splashSize),
			baseColor:Lerp(Color3.new(1, 1, 1), math.random(8, 26) / 100),
			0,
			part.Material
		)
	end
end

local function spawnObject(zone, breakableType, colorType, forcedPosition, exclusions)
	local data = ColorData.Breakables[breakableType]
	if not data then return end
	local world = ColorData.getWorldByColor(colorType)
	local configuredRewardMult = world and tonumber(world.rewardMultiplier)
	local zoneRewardMult = tonumber(zone:GetAttribute("RewardMultiplier"))
	local rewardMult = configuredRewardMult
		or zoneRewardMult
		or (world and math.max(1, world.breakableHealth / 10))
		or 1
	if configuredRewardMult and zoneRewardMult then
		rewardMult = math.min(zoneRewardMult, configuredRewardMult)
	end

	local part = Instance.new("Part")
	part.Name        = breakableType
	part.Shape       = Enum.PartType.Ball
	local sizeScale = math.random(104, 128) / 100
	part.Size        = getPuddleSize(data.size * sizeScale)
	part.Anchored    = true
	part.CanCollide  = false
	part.CanTouch    = GameBalance.Collection and GameBalance.Collection.AllowTouchCollectionFallback == true
	part.CanQuery    = true
	part.CastShadow  = false
	part.Material    = math.random() < 0.22 and Enum.Material.Neon or Enum.Material.SmoothPlastic

	part.Color = getVariedThemeColor(colorType)

	part:SetAttribute("BreakableType", breakableType)
	part:SetAttribute("ColorType",     colorType)
	part:SetAttribute("ClusterSize", data.clusterSize or breakableType)
	part:SetAttribute("BaseColorReward", data.baseReward or data.rewardMin or 1)
	part:SetAttribute("RewardMultiplier", rewardMult)
	part:SetAttribute("SpawnColor", part.Color)
	part:SetAttribute("OriginalSize", part.Size)
	part:SetAttribute("PaintPuddleVersion", PUDDLE_VERSION)
	part:SetAttribute("CollectorBaseTransparency", COLLECTOR_BASE_TRANSPARENCY)
	part:SetAttribute("ClusterOnlyVisual", true)

	local pos = getSpawnPosition(zone, forcedPosition, exclusions)
	if not pos then
		return nil
	end
	part.CFrame = CFrame.new(pos + Vector3.new(0, part.Size.Y / 2, 0)) * CFrame.Angles(0, math.rad(math.random(0, 359)), 0)
	part:SetAttribute("IdleBaseCFrame", part.CFrame)
	addPuddleDetails(part)
	part.Transparency = COLLECTOR_BASE_TRANSPARENCY

	part.Parent = getRuntimeBlobParent()
	objectHealth[part] = data.health
	return part
end

local function countExistingActiveBlobs(colorType, zone)
	local count = 0
	local parent = getRuntimeBlobParent()
	for _, obj in ipairs(parent:GetChildren()) do
		if obj:IsA("BasePart")
			and obj:GetAttribute("BreakableType")
			and obj:GetAttribute("ColorType") == colorType
			and obj:GetAttribute("PaintPuddleVersion") == PUDDLE_VERSION
			and not obj:GetAttribute("IsCollected")
			and (not zone or isPointInside(zone, obj.Position, 4))
		then
			count += 1
		end
	end
	return count
end

local function removeOldBreakables()
	local removed = 0
	for _, obj in ipairs(workspace:GetDescendants()) do
		if obj:IsA("BasePart") and obj:GetAttribute("BreakableType") and obj:GetAttribute("PaintPuddleVersion") ~= PUDDLE_VERSION then
			obj:Destroy()
			removed += 1
		end
	end

	if DEBUG_LOGS and removed > 0 then
		print("ZoneSpawner: removed " .. tostring(removed) .. " old Color blobs before spawning updated puddles.")
	end
end

local function removeBlockedRuntimeBreakables(zone)
	local removed = 0
	local exclusions = collectSpawnExclusions(zone)
	local parent = getRuntimeBlobParent()
	for _, obj in ipairs(parent:GetChildren()) do
		if isRuntimeBlobPart(obj) and obj:GetAttribute("ColorType") == zone:GetAttribute("ColorType") then
			if not isPositionAllowed(obj.Position, exclusions, DEFAULT_EXCLUSION_PADDING) then
				objectHealth[obj] = nil
				obj:Destroy()
				removed += 1
			end
		end
	end
	if DEBUG_LOGS and removed > 0 then
		print("ZoneSpawner: removed " .. tostring(removed) .. " Color blobs blocked by baked gameplay objects.")
	end
	return removed
end

local function scheduleRespawn(part, breakableType, colorType, delay)
	part:SetAttribute("Respawning", true)
	task.wait(delay)
	if part and part.Parent then
		local data = ColorData.Breakables[breakableType]
		if data then
			objectHealth[part] = data.health
			part.Transparency  = part:GetAttribute("CollectorBaseTransparency") or COLLECTOR_BASE_TRANSPARENCY
			part.CanCollide    = false
			part.CanQuery      = true
			part:SetAttribute("IsCollected", false)
			setPuddleDetailsVisible(part, true)

			local ci = ColorData.Colors[colorType]
			if ci then
				local visualColor = getStoredColor(part, colorType)
				part.Color = visualColor
				local light = part:FindFirstChildOfClass("PointLight")
				if light then light.Color = visualColor end
			end

			local origSize = part:GetAttribute("OriginalSize") or data.size
			part.Size = Vector3.new(0.1, 0.1, 0.1)
			for i = 1, 8 do
				task.wait(0.04)
				if part and part.Parent then
					part.Size = origSize * (i / 8)
				end
			end
			if part and part.Parent then part.Size = origSize end
		end
	end
	if part and part.Parent then
		part:SetAttribute("Respawning", false)
	end
end

local function watchObject(part)
	local breakableType = part:GetAttribute("BreakableType")
	local colorType     = part:GetAttribute("ColorType")
	if not breakableType or not colorType then return end

	part:GetPropertyChangedSignal("Transparency"):Connect(function()
		setPuddleDetailsVisible(part, part.Transparency < 1)
		if part.Transparency >= 1 and not part:GetAttribute("Respawning") then
			scheduleRespawn(part, breakableType, colorType, 4)
		end
	end)
end

local function populateZone(zone)
	local startedAt = os.clock()
	local colorType = zone:GetAttribute("ColorType") or "Red"
	if not isSectorPlayable(colorType) then
		return
	end
	if DEBUG_LOGS then
		print("Populating zone: " .. zone.Name .. " (" .. colorType .. ")")
	end

	local spawned = 0
	local world = ColorData.getWorldByColor(colorType)
	local configuredCount = world and world.blobCount or 44
	local requestedCount = math.floor(math.max(tonumber(zone:GetAttribute("BlobCount")) or 0, configuredCount) * CLUSTER_COUNT_MULTIPLIER)
	local populationConfig = getZonePopulationConfig()
	local maxBlobsPerZone = tonumber(populationConfig.MaxBlobsPerZone) or 80
	local targetCount = math.min(requestedCount, maxBlobsPerZone)
	if requestedCount > maxBlobsPerZone then
		warn("ZoneSpawner warning: requested " .. tostring(requestedCount) .. " blobs, clamped to " .. tostring(maxBlobsPerZone))
	end

	local existingCount = countExistingActiveBlobs(colorType, zone)
	if existingCount > 0 then
		local removedBlocked = removeBlockedRuntimeBreakables(zone)
		if removedBlocked > 0 then
			existingCount = math.max(0, existingCount - removedBlocked)
		end
	end
	local repopulateCooldown = tonumber(populationConfig.RepopulateCooldown) or 20
	if existingCount >= targetCount then
		lastPopulatedAt[zone] = lastPopulatedAt[zone] or os.clock()
		print("ZoneSpawner: populated " .. zone.Name .. " with 0 blobs in " .. string.format("%.2f", os.clock() - startedAt) .. "s; existing=" .. tostring(existingCount) .. "/" .. tostring(targetCount))
		return
	end
	if lastPopulatedAt[zone] and os.clock() - lastPopulatedAt[zone] < repopulateCooldown then
		if DEBUG_LOGS then
			print("ZoneSpawner: skipped " .. zone.Name .. " repopulation during cooldown; existing=" .. tostring(existingCount) .. "/" .. tostring(targetCount))
		end
		return
	end
	lastPopulatedAt[zone] = os.clock()

	local remainingToSpawn = math.max(0, targetCount - existingCount)
	local spawnMarkers = getSpawnMarkers(zone, colorType)
	local spawnExclusions = collectSpawnExclusions(zone)
	local spawnIndex = 0
	local spawnedSinceYield = 0
	local spawnBatchSize = math.max(1, tonumber(populationConfig.SpawnBatchSize) or 10)
	local spawnBatchDelay = tonumber(populationConfig.SpawnBatchDelay) or 0.03
	local orderedTypes = { "PaintBlob", "PaintGlob", "PaintBoulder" }
	for index, breakableType in ipairs(orderedTypes) do
		local ratio = SPAWN_CONFIG[breakableType] or 0
		local count = math.floor(remainingToSpawn * ratio)
		if index == #orderedTypes then
			count = remainingToSpawn - spawned
		end
		for i = 1, count do
			if spawned >= remainingToSpawn then
				break
			end
			spawnIndex += 1
			local marker = (#spawnMarkers > 0) and spawnMarkers[((spawnIndex - 1) % #spawnMarkers) + 1] or nil
			local forcedPosition = marker and randomPositionAtMarker(marker, zone) or nil
			local part = spawnObject(zone, breakableType, colorType, forcedPosition, spawnExclusions)
			if part then
				watchObject(part)
				spawned = spawned + 1
				spawnedSinceYield += 1
				if spawnedSinceYield >= spawnBatchSize then
					spawnedSinceYield = 0
					task.wait(spawnBatchDelay)
				end
			end
		end
	end
	local elapsed = os.clock() - startedAt
	print("ZoneSpawner: populated " .. zone.Name .. " with " .. spawned .. " blobs in " .. string.format("%.2f", elapsed) .. "s; existing=" .. tostring(existingCount) .. ", target=" .. tostring(targetCount) .. ", markers=" .. tostring(#spawnMarkers))
	if elapsed > 0.5 then
		warn("ZoneSpawner: population took over 0.5s for " .. zone.Name .. "; work was batched over frames.")
	end
end

local function findZoneByColor(colorType)
	local best = nil
	local bestScore = -math.huge
	for _, obj in ipairs(workspace:GetDescendants()) do
		if obj:IsA("BasePart") then
			local zoneColor = configureColorZonePart(obj)
			if obj:GetAttribute("ColorZone") and (obj:GetAttribute("ColorType") == colorType or zoneColor == colorType) then
				local score = getZoneScore(obj)
				if score > bestScore then
					best = obj
					bestScore = score
				end
			end
		end
	end
	return best
end

populateRequest.Event:Connect(function(colorType)
	local zone = findZoneByColor(colorType)
	if not zone then
		warn("ZoneSpawner: populate request failed; missing zone for " .. tostring(colorType))
		return
	end

	task.spawn(function()
		populateZone(zone)
	end)
end)

local function requestPopulateForColor(colorType)
	if not colorType or colorType == "" or not isSectorPlayable(colorType) then
		return
	end

	local zone = findZoneByColor(colorType)
	if zone then
		task.spawn(populateZone, zone)
	end
end

local function requestPopulateForPlayer(player)
	if not player or not player.Parent then
		return
	end

	local storage = player:FindFirstChild("ColorStorage")
	local currentWorld = storage and storage:FindFirstChild("CurrentWorld")
	local activeColor = player:GetAttribute("ActiveWorldColor") or (currentWorld and currentWorld.Value)
	requestPopulateForColor(activeColor)
end

task.wait(2)

if shouldClearGeneratedMapOnStart() then
	removeOldBreakables()
end

local foundZones = 0
local populationConfig = getZonePopulationConfig()
local populateAllOnStartup = populationConfig.PopulateAllZonesOnStartup == true
for _, obj in ipairs(workspace:GetDescendants()) do
	if obj:IsA("BasePart") and configureColorZonePart(obj) then
		foundZones = foundZones + 1
		local colorType = obj:GetAttribute("ColorType")
		if populateAllOnStartup or colorType == "Red" then
			populateZone(obj)
		end
	end
end

local function hookPlayer(player)
	task.delay(2, function()
		requestPopulateForPlayer(player)
	end)

	player:GetAttributeChangedSignal("ActiveWorldColor"):Connect(function()
		requestPopulateForPlayer(player)
	end)

	task.spawn(function()
		local storage = player:WaitForChild("ColorStorage", 20)
		local currentWorld = storage and storage:FindFirstChild("CurrentWorld")
		if currentWorld and currentWorld:IsA("StringValue") then
			currentWorld:GetPropertyChangedSignal("Value"):Connect(function()
				requestPopulateForPlayer(player)
			end)
			requestPopulateForPlayer(player)
		end
	end)
end

for _, player in ipairs(Players:GetPlayers()) do
	hookPlayer(player)
end

Players.PlayerAdded:Connect(hookPlayer)

workspace.DescendantAdded:Connect(function(obj)
	if obj:IsA("BasePart") and obj:GetAttribute("BreakableType") then
		if obj:GetAttribute("PaintPuddleVersion") ~= PUDDLE_VERSION then
			if not shouldClearGeneratedMapOnStart() then
				return
			end
			task.defer(function()
				if obj and obj.Parent and obj:GetAttribute("PaintPuddleVersion") ~= PUDDLE_VERSION then
					obj:Destroy()
				end
			end)
			return
		end
		watchObject(obj)
	end
end)

task.spawn(function()
	while true do
		task.wait(8)
		for _, player in ipairs(Players:GetPlayers()) do
			local activeColor = player:GetAttribute("ActiveWorldColor")
			local storage = player:FindFirstChild("ColorStorage")
			local currentWorld = storage and storage:FindFirstChild("CurrentWorld")
			activeColor = activeColor or (currentWorld and currentWorld.Value)
			local root = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
			local zone = activeColor and activeColor ~= "Red" and findZoneByColor(activeColor) or nil
			if root then
				for _, obj in ipairs(workspace:GetDescendants()) do
					if obj:IsA("BasePart") then
						local zoneColor = configureColorZonePart(obj)
						if obj:GetAttribute("ColorZone") == true
							and zoneColor
							and zoneColor ~= "Red"
							and isPointInside(obj, root.Position, 12)
						then
							if not zone or getZoneScore(obj) > getZoneScore(zone) then
								zone = obj
							end
						end
					end
				end
			end
			if zone then
				local colorType = zone:GetAttribute("ColorType")
				if colorType and isSectorPlayable(colorType) then
					task.spawn(populateZone, zone)
				end
			elseif activeColor and activeColor ~= "Red" then
				zone = findZoneByColor(activeColor)
				if zone then
					task.spawn(populateZone, zone)
				end
			end
		end
	end
end)

if DEBUG_LOGS then
	print("ZoneSpawner ready! Found " .. foundZones .. " zones.")
end
]]></string>
