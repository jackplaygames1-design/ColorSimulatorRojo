      <Item class="Script" referent="88">
        <Properties>
          <string name="Name">LobbyPortalHandler</string>
          <token name="RunContext">0</token>
          <string name="Source"><![CDATA[-- Server-owned lobby portal travel for baked/editable maps.
local Players = game:GetService("Players")
local Workspace = game:GetService("Workspace")

local MAP_NAME = "ColorSimulatorMap"
local COOLDOWN = 0.75
local cooldowns = {}

local function getRoot(player)
	local character = player.Character
	return character and character:FindFirstChild("HumanoidRootPart")
end

local function getPlayerFromHit(hit)
	local character = hit and hit:FindFirstAncestorOfClass("Model")
	return character and Players:GetPlayerFromCharacter(character)
end

local function isPortalPart(part)
	return part:IsA("BasePart")
		and (part:GetAttribute("LobbyRedZonePortal") == true or part.Name == "RedZonePortal")
end

local function getRedZoneDestination()
	local map = Workspace:FindFirstChild(MAP_NAME)
	if not map then
		return nil
	end

	local named = map:FindFirstChild("RedZoneArrivalSpawn", true)
	if named and named:IsA("BasePart") then
		return named
	end

	for _, obj in ipairs(map:GetDescendants()) do
		if obj:IsA("BasePart") and obj:GetAttribute("LobbyPortalArrival") == true then
			return obj
		end
	end

	for _, obj in ipairs(map:GetDescendants()) do
		if obj:IsA("BasePart") then
			local spawnColor = obj:GetAttribute("AreaSpawnColor") or obj:GetAttribute("SpawnColor") or obj:GetAttribute("TeleportColor")
			if spawnColor == "Red" then
				return obj
			end
		end
	end

	return nil
end

local function useCooldown(player)
	local now = os.clock()
	if cooldowns[player] and now - cooldowns[player] < COOLDOWN then
		return false
	end
	cooldowns[player] = now
	return true
end

local function teleportToRedZone(player)
	if not useCooldown(player) then
		return
	end

	local root = getRoot(player)
	local destination = getRedZoneDestination()
	if not root or not destination then
		warn("LobbyPortalHandler: missing character root or RedZoneArrivalSpawn.")
		return
	end

	root.CFrame = destination.CFrame + Vector3.new(0, 5, 0)
	print(player.Name .. " entered Red Zone from Lobby")
end

local function hookPrompt(prompt)
	if not prompt:IsA("ProximityPrompt") then
		return
	end

	local parent = prompt.Parent
	if not parent or not isPortalPart(parent) then
		return
	end
	if prompt:GetAttribute("LobbyPortalHooked") then
		return
	end

	prompt:SetAttribute("LobbyPortalHooked", true)
	prompt.Triggered:Connect(teleportToRedZone)
end

local function hookPortal(part)
	if not isPortalPart(part) then
		return
	end
	if part:GetAttribute("LobbyPortalTouchedHooked") then
		return
	end

	part:SetAttribute("LobbyPortalTouchedHooked", true)
	part.Touched:Connect(function(hit)
		local player = getPlayerFromHit(hit)
		if player then
			teleportToRedZone(player)
		end
	end)

	for _, child in ipairs(part:GetChildren()) do
		hookPrompt(child)
	end
end

for _, obj in ipairs(Workspace:GetDescendants()) do
	if obj:IsA("BasePart") then
		hookPortal(obj)
	elseif obj:IsA("ProximityPrompt") then
		hookPrompt(obj)
	end
end

Workspace.DescendantAdded:Connect(function(obj)
	if obj:IsA("BasePart") then
		hookPortal(obj)
	elseif obj:IsA("ProximityPrompt") then
		hookPrompt(obj)
	end
end)

Players.PlayerRemoving:Connect(function(player)
	cooldowns[player] = nil
end)
]]></string>
        </Properties>
      </Item>
      <Item class="Script" referent="89">
        <Properties>
          <string name="Name">MutationStationService</string>
          <token name="RunContext">0</token>
          <string name="Source"><![CDATA[-- Hooks baked mutation station parts. The station unlocks mutation rolls; it does not build map geometry.
local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local RunService = game:GetService("RunService")
local Workspace = game:GetService("Workspace")

local Events = ReplicatedStorage:WaitForChild("Events")
local ColorMutationData = require(ReplicatedStorage:WaitForChild("ColorMutationData"))
local remote = Events:FindFirstChild("MutationStation")
if not remote then
	remote = Instance.new("RemoteEvent")
	remote.Name = "MutationStation"
	remote.Parent = Events
end

local noticeEvent = Events:FindFirstChild("WildBuffNotice")
local dataDirtyEvent = Events:FindFirstChild("PlayerDataDirty")

local PROMPT_NAME = "MutationStationPrompt"
local TOUCH_COOLDOWN = 1.35
local NEAR_DISTANCE = 34
local hooked = {}
local pads = {}
local lastTouchedAt = {}

local function getCharacterRoot(player)
	local character = player and player.Character
	return character and character:FindFirstChild("HumanoidRootPart")
end

local function getPlayerFromTouchedPart(part)
	local character = part and part.Parent
	local humanoid = character and character:FindFirstChildOfClass("Humanoid")
	if not humanoid then
		return nil
	end
	return Players:GetPlayerFromCharacter(character)
end

local function isPointInside(part, position, margin)
	local localPoint = part.CFrame:PointToObjectSpace(position)
	local half = part.Size * 0.5 + Vector3.new(margin, margin, margin)
	return math.abs(localPoint.X) <= half.X
		and math.abs(localPoint.Y) <= half.Y
		and math.abs(localPoint.Z) <= half.Z
end

local function isLikelyMutationStation(part)
	if not part or not part:IsA("BasePart") then
		return false
	end
	if part:GetAttribute("MutationUnlockStation") == true
		or part:GetAttribute("MutationStation") == true
		or part:GetAttribute("FeatureUnlock") == "Mutations"
	then
		return true
	end

	local lowerName = string.lower(part.Name or "")
	if string.find(lowerName, "mutation", 1, true) or string.find(lowerName, "mutate", 1, true) then
		return true
	end

	local interior = part:FindFirstAncestor("OrangeSectorInterior")
	if not interior then
		return false
	end

	local color = part.Color
	local isBrightPink = color.R > 0.78 and color.B > 0.72 and color.G < 0.48
	local isFlatPad = part.Size.X >= 10 and part.Size.Z >= 10 and part.Size.Y <= 4
	return isBrightPink and isFlatPad
end

local function ensureProgressBool(player, name)
	local folder = player:FindFirstChild("TutorialProgress")
	if not folder then
		folder = Instance.new("Folder")
		folder.Name = "TutorialProgress"
		folder.Parent = player
	end

	local value = folder:FindFirstChild(name)
	if not value then
		value = Instance.new("BoolValue")
		value.Name = name
		value.Parent = folder
	end
	return value
end

local function ensureProgressValues(player)
	return ensureProgressBool(player, "MutationsUnlocked"), ensureProgressBool(player, "HasSeenMutationTutorial")
end

local function getUnlocked(player)
	local progress = player and player:FindFirstChild("TutorialProgress")
	local value = progress and progress:FindFirstChild("MutationsUnlocked")
	return value and value:IsA("BoolValue") and value.Value == true
end

local function getHasSeenTutorial(player)
	local progress = player and player:FindFirstChild("TutorialProgress")
	local value = progress and progress:FindFirstChild("HasSeenMutationTutorial")
	return value and value:IsA("BoolValue") and value.Value == true
end

local function makeState(player, justUnlocked)
	return {
		unlocked = getUnlocked(player),
		justUnlocked = justUnlocked == true,
		hasSeenTutorial = getHasSeenTutorial(player),
		title = "Mutation Core",
		description = "Mutations are now active for future hatches.",
		detail = "New hatches can roll rare Dark, Light, or Corrupted Color variants. Mutation names appear in hatch results and inventory.",
	}
end

local function notify(player, message, color)
	if noticeEvent and noticeEvent:IsA("RemoteEvent") then
		noticeEvent:FireClient(player, {
			type = "message",
			message = message,
			color = color or Color3.fromRGB(255, 92, 235),
		})
	end
end

local function markDirty(player)
	if dataDirtyEvent and dataDirtyEvent:IsA("BindableEvent") then
		dataDirtyEvent:Fire(player, "tutorial-progress")
	end
end

local function unlockForPlayer(player)
	local value, seenTutorial = ensureProgressValues(player)
	local justUnlocked = false
	if value.Value ~= true then
		value.Value = true
		justUnlocked = true
		player:SetAttribute("MutationsUnlocked", true)
		markDirty(player)
		notify(player, "Mutations unlocked!", Color3.fromRGB(255, 92, 235))
	else
		player:SetAttribute("MutationsUnlocked", true)
	end

	local state = makeState(player, justUnlocked)
	if seenTutorial.Value ~= true then
		remote:FireClient(player, "ShowUnlocked", state)
	else
		if not justUnlocked then
			notify(player, "Mutations are already unlocked.", Color3.fromRGB(154, 80, 255))
		end
		remote:FireClient(player, "OpenIndex", state)
	end
	return justUnlocked
end

local function isNearAnyPad(player)
	local root = getCharacterRoot(player)
	if not root then
		return false
	end

	for pad in pairs(pads) do
		if pad.Parent and (root.Position - pad.Position).Magnitude <= NEAR_DISTANCE then
			return true
		end
	end
	return false
end

local function handlePlayer(player, pad)
	if not player or not player.Parent then
		return
	end
	if pad and pad.Parent then
		local root = getCharacterRoot(player)
		if not root or (root.Position - pad.Position).Magnitude > NEAR_DISTANCE then
			return
		end
	elseif not isNearAnyPad(player) then
		return
	end

	local now = os.clock()
	if lastTouchedAt[player] and now - lastTouchedAt[player] < TOUCH_COOLDOWN then
		return
	end
	lastTouchedAt[player] = now
	unlockForPlayer(player)
end

local function configurePad(part)
	if not isLikelyMutationStation(part) or hooked[part] then
		return
	end

	hooked[part] = true
	pads[part] = true
	part:SetAttribute("MutationStation", true)
	part:SetAttribute("MutationUnlockStation", true)
	part:SetAttribute("FeatureUnlock", "Mutations")
	part:SetAttribute("ColorZone", false)
	part.CanTouch = true
	part.CanQuery = true

	local prompt = part:FindFirstChild(PROMPT_NAME)
	if not prompt then
		prompt = Instance.new("ProximityPrompt")
		prompt.Name = PROMPT_NAME
		prompt.ObjectText = "Mutation Core"
		prompt.ActionText = "Unlock Mutations"
		prompt.KeyboardKeyCode = Enum.KeyCode.E
		prompt.HoldDuration = 0
		prompt.MaxActivationDistance = 14
		prompt.RequiresLineOfSight = false
		prompt.Parent = part
	end
	prompt.Triggered:Connect(function(player)
		handlePlayer(player, part)
	end)

	part.Touched:Connect(function(hit)
		local player = getPlayerFromTouchedPart(hit)
		if player then
			handlePlayer(player, part)
		end
	end)
end

local function configureExisting()
	for _, obj in ipairs(Workspace:GetDescendants()) do
		if obj:IsA("BasePart") then
			configurePad(obj)
		end
	end
end

remote.OnServerEvent:Connect(function(player, action, value)
	if action == "Get" then
		remote:FireClient(player, "State", makeState(player, false))
	elseif action == "Unlock" then
		if isNearAnyPad(player) then
			unlockForPlayer(player)
		end
	elseif action == "MarkTutorialSeen" then
		local unlocked, seenTutorial = ensureProgressValues(player)
		if unlocked.Value == true and seenTutorial.Value ~= true then
			seenTutorial.Value = true
			markDirty(player)
		end
	elseif RunService:IsStudio() and action == "DebugUnlock" then
		local _, seenTutorial = ensureProgressValues(player)
		seenTutorial.Value = false
		markDirty(player)
		unlockForPlayer(player)
	elseif RunService:IsStudio() and action == "DebugResetTutorial" then
		local unlocked, seenTutorial = ensureProgressValues(player)
		seenTutorial.Value = false
		markDirty(player)
		if unlocked.Value == true then
			remote:FireClient(player, "ShowUnlocked", makeState(player, false))
		end
	elseif RunService:IsStudio() and action == "DebugForceMutation" then
		local mutationId = ColorMutationData.normalize(value)
		if mutationId ~= ColorMutationData.NoneId then
			player:SetAttribute("ForceNextMutation", mutationId)
			player:SetAttribute("ForceMutationsUnlocked", true)
			notify(player, "Next hatch mutation forced: " .. mutationId, ColorMutationData.get(mutationId).TypeColor)
		end
	end
end)

Players.PlayerAdded:Connect(function(player)
	task.defer(function()
		local value = ensureProgressValues(player)
		player:SetAttribute("MutationsUnlocked", value.Value == true)
		value:GetPropertyChangedSignal("Value"):Connect(function()
			player:SetAttribute("MutationsUnlocked", value.Value == true)
		end)
	end)
end)

for _, player in ipairs(Players:GetPlayers()) do
	task.defer(function()
		local value = ensureProgressValues(player)
		player:SetAttribute("MutationsUnlocked", value.Value == true)
		value:GetPropertyChangedSignal("Value"):Connect(function()
			player:SetAttribute("MutationsUnlocked", value.Value == true)
		end)
	end)
end

Players.PlayerRemoving:Connect(function(player)
	lastTouchedAt[player] = nil
end)

configureExisting()
Workspace.DescendantAdded:Connect(function(obj)
	if obj:IsA("BasePart") then
		task.defer(configurePad, obj)
	end
end)

task.spawn(function()
	while true do
		task.wait(0.5)
		for pad in pairs(pads) do
			if not pad.Parent then
				pads[pad] = nil
			else
				for _, player in ipairs(Players:GetPlayers()) do
					local root = getCharacterRoot(player)
					if root and isPointInside(pad, root.Position, 3) then
						handlePlayer(player, pad)
					end
				end
			end
		end
	end
end)
]]></string>
        </Properties>
      </Item>
      <Item class="Script" referent="90">
        <Properties>
          <string name="Name">MutationUnlockSync</string>
          <token name="RunContext">0</token>
          <string name="Source"><![CDATA[-- Keeps the server-side mutation unlock flag in sync with world progression.
-- PetHandler checks player:GetAttribute("MutationsUnlocked") and TutorialProgress.MutationsUnlocked
-- before allowing hatch rolls to receive mutations, so this script is the single bridge from
-- progression -> mutation availability.

local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")

local ColorData = require(ReplicatedStorage:WaitForChild("ColorData"))
local GameBalance = require(ReplicatedStorage:WaitForChild("GameBalance"))

local Events = ReplicatedStorage:WaitForChild("Events")
local dataDirtyEvent = Events:FindFirstChild("PlayerDataDirty")

local function getRequiredWorldIndex()
	if GameBalance.getFeatureUnlockWorldIndex then
		return tonumber(GameBalance.getFeatureUnlockWorldIndex("Mutations")) or tonumber(GameBalance.MutationsUnlockWorldIndex) or 2
	end
	return tonumber(GameBalance.MutationsUnlockWorldIndex) or 2
end

local function getHighestUnlockedWorldIndex(player)
	local storage = player:FindFirstChild("ColorStorage")
	local unlockedValue = storage and storage:FindFirstChild("UnlockedColors")
	local unlocked = ColorData.getUnlockedColorSet(unlockedValue and unlockedValue.Value or "Red")

	local highest = 1
	for index, world in ipairs(ColorData.Worlds or {}) do
		if unlocked[world.primaryColor] then
			highest = math.max(highest, index)
		end
	end

	return highest
end

local function getTutorialProgressFolder(player)
	local folder = player:FindFirstChild("TutorialProgress")
	if not folder then
		folder = Instance.new("Folder")
		folder.Name = "TutorialProgress"
		folder.Parent = player
	end
	return folder
end

local function getOrCreateBool(parent, name, defaultValue)
	local value = parent:FindFirstChild(name)
	if value and value:IsA("BoolValue") then
		return value
	end

	if value then
		value:Destroy()
	end

	value = Instance.new("BoolValue")
	value.Name = name
	value.Value = defaultValue == true
	value.Parent = parent
	return value
end

local function markDirty(player, reason)
	if dataDirtyEvent and dataDirtyEvent:IsA("BindableEvent") then
		dataDirtyEvent:Fire(player, reason or "mutations-unlocked")
	end
end

local function syncPlayer(player)
	if not player or not player.Parent then
		return
	end

	local requiredIndex = getRequiredWorldIndex()
	local highestIndex = getHighestUnlockedWorldIndex(player)
	local unlockedNow = highestIndex >= requiredIndex

	local progress = getTutorialProgressFolder(player)
	local unlockedValue = getOrCreateBool(progress, "MutationsUnlocked", false)
	local hadUnlocked = unlockedValue.Value == true or player:GetAttribute("MutationsUnlocked") == true

	-- Once unlocked, keep it unlocked. This avoids taking mutations away if a save temporarily
	-- reports an older world during load/migration.
	local finalUnlocked = hadUnlocked or unlockedNow
	unlockedValue.Value = finalUnlocked
	player:SetAttribute("MutationsUnlocked", finalUnlocked)

	if finalUnlocked and not hadUnlocked then
		print("MutationUnlockSync: mutations unlocked for " .. player.Name .. " at world index " .. tostring(highestIndex))
		markDirty(player, "mutations-unlocked")
	end
end

local function hookPlayer(player)
	local function deferredSync()
		task.defer(syncPlayer, player)
	end

	if player:GetAttribute("DataManagerReady") ~= true then
		player:GetAttributeChangedSignal("DataManagerReady"):Connect(deferredSync)
	end

	deferredSync()

	task.spawn(function()
		local storage = player:WaitForChild("ColorStorage", 20)
		local unlocked = storage and storage:WaitForChild("UnlockedColors", 20)
		if unlocked then
			unlocked:GetPropertyChangedSignal("Value"):Connect(deferredSync)
			deferredSync()
		end
	end)
end

Players.PlayerAdded:Connect(hookPlayer)
for _, player in ipairs(Players:GetPlayers()) do
	hookPlayer(player)
end
]]></string>
        </Properties>
      </Item>
      <Item class="Script" referent="91">
        <Properties>
          <string name="Name">PaintToolShopHandler</string>
          <token name="RunContext">0</token>
          <string name="Source"><![CDATA[-- Server-owned paintbrush shop and equipment state.
local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local ServerStorage = game:GetService("ServerStorage")

local ToolData = require(ReplicatedStorage:WaitForChild("ToolData"))
local ColorData = require(ReplicatedStorage:WaitForChild("ColorData"))

local Events = ReplicatedStorage:WaitForChild("Events")
local purchaseEvent = Events:WaitForChild("PurchasePaintTool")
local equipEvent = Events:WaitForChild("EquipPaintTool")
local dirtyEvent = Events:FindFirstChild("PlayerDataDirty")

local cooldowns = {}
local COOLDOWN = 0.35

local function isDataReady(player)
	return player and player:GetAttribute("DataManagerReady") == true
end

local function reportDailyQuestProgress(player, questId, amount)
	local event = ServerStorage:FindFirstChild("DailyQuestProgress")
	if event and event:IsA("BindableEvent") then
		event:Fire(player, questId, amount)
	end
end

local function markDirty(player, reason)
	if dirtyEvent then
		dirtyEvent:Fire(player, reason)
	end
end

local function ensureToolsFolder(player)
	local folder = player:FindFirstChild("PaintTools")
	if not folder then
		folder = Instance.new("Folder")
		folder.Name = "PaintTools"
		folder.Parent = player
	end

	local owned = folder:FindFirstChild("Owned")
	if not owned then
		owned = Instance.new("StringValue")
		owned.Name = "Owned"
		owned.Value = "StarterBrush"
		owned.Parent = folder
	end
	if owned.Value == "" then
		owned.Value = "StarterBrush"
	end

	local equipped = folder:FindFirstChild("Equipped")
	if not equipped then
		equipped = Instance.new("StringValue")
		equipped.Name = "Equipped"
		equipped.Value = "StarterBrush"
		equipped.Parent = folder
	end
	if equipped.Value == "" or not ToolData.isValid(equipped.Value) then
		equipped.Value = "StarterBrush"
	end

	return folder, owned, equipped
end

local function csvSet(value)
	local set = {}
	for _, part in ipairs(string.split(value or "", ",")) do
		if part ~= "" then
			set[part] = true
		end
	end
	return set
end

local function setToCsv(set)
	local parts = {}
	for _, toolId in ipairs(ToolData.Order) do
		if set[toolId] then
			table.insert(parts, toolId)
		end
	end
	return table.concat(parts, ",")
end

local function ownsTool(player, toolId)
	local _, owned = ensureToolsFolder(player)
	return csvSet(owned.Value)[toolId] == true
end

local function isToolUnlocked(player, tool)
	local requiredColor = tool and tool.RequiredColor or "Red"
	if requiredColor == "Red" then
		return true
	end

	local storage = player:FindFirstChild("ColorStorage")
	local unlocked = storage and storage:FindFirstChild("UnlockedColors")
	return unlocked and ColorData.isColorUnlocked(unlocked.Value, requiredColor)
end

local function getToolWorldName(tool)
	local world = ColorData.getWorldByColor(tool and tool.RequiredColor or "Red")
	return world and world.name or "Starter Field"
end

local function useCooldown(player)
	local now = os.clock()
	if cooldowns[player] and now - cooldowns[player] < COOLDOWN then
		return false
	end
	cooldowns[player] = now
	return true
end

purchaseEvent.OnServerEvent:Connect(function(player, toolId)
	if not useCooldown(player) then
		return
	end
	if not isDataReady(player) then
		purchaseEvent:FireClient(player, false, toolId, "Data is still loading.")
		return
	end

	local tool = ToolData.Tools[toolId or ""]
	if not tool then
		purchaseEvent:FireClient(player, false, toolId, "Unknown brush.")
		return
	end
	if not isToolUnlocked(player, tool) then
		purchaseEvent:FireClient(player, false, tool.Id, "Unlock " .. getToolWorldName(tool) .. " first.")
		return
	end

	local _, owned, equipped = ensureToolsFolder(player)
	local ownedSet = csvSet(owned.Value)
	if ownedSet[tool.Id] then
		equipped.Value = tool.Id
		markDirty(player, "paint-tool-equipped")
		purchaseEvent:FireClient(player, true, tool.Id, "Equipped " .. tool.DisplayName)
		equipEvent:FireClient(player, true, tool.Id, "Equipped " .. tool.DisplayName)
		return
	end

	local stats = player:FindFirstChild("leaderstats")
	local coins = stats and stats:FindFirstChild("Coins")
	local cost = tonumber(tool.Cost) or 0
	if not coins or coins.Value < cost then
		purchaseEvent:FireClient(player, false, tool.Id, "Need " .. tostring(cost) .. " Coins.")
		return
	end

	coins.Value -= cost
	ownedSet[tool.Id] = true
	owned.Value = setToCsv(ownedSet)
	equipped.Value = tool.Id
	markDirty(player, "paint-tool-purchased")
	reportDailyQuestProgress(player, "BuyBrush", 1)

	print(player.Name .. " bought and equipped " .. tool.DisplayName .. " for " .. tostring(cost) .. " Coins")
	purchaseEvent:FireClient(player, true, tool.Id, "Bought " .. tool.DisplayName)
	equipEvent:FireClient(player, true, tool.Id, "Equipped " .. tool.DisplayName)
end)

equipEvent.OnServerEvent:Connect(function(player, toolId, equippedRequested)
	if not useCooldown(player) then
		return
	end
	if not isDataReady(player) then
		equipEvent:FireClient(player, false, toolId, "Data is still loading.")
		return
	end

	local tool = ToolData.Tools[toolId or ""]
	if not tool then
		equipEvent:FireClient(player, false, toolId, "Unknown brush.")
		return
	end
	if not isToolUnlocked(player, tool) then
		equipEvent:FireClient(player, false, tool.Id, "Unlock " .. getToolWorldName(tool) .. " first.")
		return
	end

	local _, _, equipped = ensureToolsFolder(player)
	if not ownsTool(player, tool.Id) then
		equipEvent:FireClient(player, false, tool.Id, "You do not own this brush.")
		return
	end

	if equippedRequested == false and equipped.Value == tool.Id then
		equipped.Value = "StarterBrush"
		equipEvent:FireClient(player, true, "StarterBrush", "Equipped Starter Brush")
	else
		equipped.Value = tool.Id
		equipEvent:FireClient(player, true, tool.Id, "Equipped " .. tool.DisplayName)
	end

	markDirty(player, "paint-tool-equipped")
end)

Players.PlayerAdded:Connect(function(player)
	task.defer(function()
		if player:GetAttribute("DataManagerReady") ~= true then
			player:GetAttributeChangedSignal("DataManagerReady"):Wait()
		end
		if not isDataReady(player) then
			return
		end
		ensureToolsFolder(player)
	end)
end)

Players.PlayerRemoving:Connect(function(player)
	cooldowns[player] = nil
end)
]]></string>
        </Properties>
      </Item>
      <Item class="Script" referent="92">
        <Properties>
          <string name="Name">PetAppearancePublisher</string>
          <token name="RunContext">0</token>
          <string name="Source"><![CDATA[local PetVisualService = require(script.Parent:WaitForChild("PetVisualService"))

local publishedCount = PetVisualService.PublishToReplicatedStorage()
if publishedCount > 0 then
	print("PetAppearancePublisher: published " .. tostring(publishedCount) .. " editable Color templates from PetAppearanceStudio.")
else
	print("PetAppearancePublisher: no PetAppearanceStudio source found yet; generated PetModels fallback will be used.")
end
