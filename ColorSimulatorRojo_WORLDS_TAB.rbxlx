listPadding.Parent = list

local function formatPrice(price)
	return tostring(tonumber(price) or 0) .. " ROBUX"
end

local function applyModalLayer()
	panel.ZIndex = 60
	for _, obj in ipairs(panel:GetDescendants()) do
		if obj:IsA("GuiObject") and obj.ZIndex < 61 then
			obj.ZIndex = 61
		end
	end
	closeBtn.ZIndex = 70
end

local function checkOwned(pass)
	local grantedAttribute = player:GetAttribute("Pass_" .. tostring(pass.id))
	if grantedAttribute == true then
		ownedPasses[pass.id] = true
		return true
	end

	if not pass.gamepassId or pass.gamepassId <= 0 then
		ownedPasses[pass.id] = false
		return false
	end

	if ownedPasses[pass.id] ~= nil then
		return ownedPasses[pass.id]
	end

	local ok, result = pcall(function()
		return MarketplaceService:UserOwnsGamePassAsync(player.UserId, pass.gamepassId)
	end)
	ownedPasses[pass.id] = ok and result == true
	return ownedPasses[pass.id]
end

local function clearCards()
	for _, child in ipairs(list:GetChildren()) do
		if not child:IsA("UIListLayout") and not child:IsA("UIPadding") then
			child:Destroy()
		end
	end
end

local function addCorner(parent, radius)
	Instance.new("UICorner", parent).CornerRadius = UDim.new(0, radius)
end

local function addStroke(parent, color, thickness)
	local stroke = Instance.new("UIStroke")
	stroke.Color = color
	stroke.Thickness = thickness
	stroke.Parent = parent
	return stroke
end

local function makeIconLabel(parent, text, size, position, textSize, color, strokeColor)
	local label = Instance.new("TextLabel")
	label.Size = size
	label.Position = position
	label.BackgroundTransparency = 1
	label.Font = Enum.Font.LuckiestGuy
	label.Text = text
	label.TextSize = textSize
	label.TextColor3 = color or WHITE
	label.TextStrokeTransparency = 0
	label.TextStrokeColor3 = strokeColor or DARK
	label.TextScaled = false
	label.ZIndex = 65
	label:SetAttribute("NoTextGlow", true)
	label.Parent = parent
	return label
end

local function makeRoundedIconPart(parent, name, size, position, color, radius, zIndex)
	local part = Instance.new("Frame")
	part.Name = name
	part.Size = size
	part.Position = position
	part.BackgroundColor3 = color
	part.BorderSizePixel = 0
	part.ZIndex = zIndex or 64
	part.Parent = parent
	addCorner(part, radius)
	return part
end

local function makeCircle(parent, name, size, position, color, zIndex)
	local circle = makeRoundedIconPart(parent, name, size, position, color, 999, zIndex)
	addStroke(circle, DARK, 3)
	local shine = makeRoundedIconPart(circle, "Shine", UDim2.fromScale(0.32, 0.22), UDim2.fromScale(0.17, 0.14), Color3.fromRGB(255, 255, 255), 999, (zIndex or 64) + 1)
	shine.BackgroundTransparency = 0.22
	return circle
end

local function createGamepassIcon(parent, pass, accent)
	local block = Instance.new("Frame")
	block.Name = pass.id .. "Icon"
	block.Size = UDim2.new(0, 96, 0, 96)
	block.Position = UDim2.new(0, 18, 0.5, -48)
	block.BackgroundColor3 = (PASS_THEME[pass.id] and PASS_THEME[pass.id].icon or accent):Lerp(WHITE, 0.16)
	block.BorderSizePixel = 0
	block.ClipsDescendants = true
	block.ZIndex = 64
	block.Parent = parent
	addCorner(block, 18)
	addStroke(block, DARK, 3)

	local glow = Instance.new("Frame")
	glow.Name = "IconGlow"
	glow.Size = UDim2.new(1, 10, 1, 10)
	glow.Position = UDim2.new(0, -5, 0, -5)
	glow.BackgroundColor3 = accent
	glow.BackgroundTransparency = 0.82
	glow.BorderSizePixel = 0
	glow.ZIndex = 63
	glow.Parent = parent
	addCorner(glow, 22)

	if pass.iconImage and tostring(pass.iconImage) ~= "" then
		local image = Instance.new("ImageLabel")
		image.Size = UDim2.new(1, -10, 1, -10)
		image.Position = UDim2.new(0, 5, 0, 5)
		image.BackgroundTransparency = 1
		image.Image = tostring(pass.iconImage)
		image.ScaleType = Enum.ScaleType.Fit
		image.ZIndex = 65
		image.Parent = block
		return block
	end

	local id = pass.id
	if id == "AutoSell" then
		local bucket = makeRoundedIconPart(block, "PaintBucket", UDim2.new(0, 50, 0, 48), UDim2.new(0, 14, 0, 34), Color3.fromRGB(247, 249, 255), 10)
		addStroke(bucket, DARK, 3)
		makeRoundedIconPart(bucket, "PaintRed", UDim2.new(0.25, 0, 0, 16), UDim2.new(0, 0, 0, 0), Color3.fromRGB(255, 80, 100), 5, 65)
		makeRoundedIconPart(bucket, "PaintBlue", UDim2.new(0.25, 0, 0, 16), UDim2.new(0.25, 0, 0, 0), Color3.fromRGB(64, 178, 255), 5, 65)
		makeRoundedIconPart(bucket, "PaintGreen", UDim2.new(0.25, 0, 0, 16), UDim2.new(0.5, 0, 0, 0), Color3.fromRGB(78, 225, 92), 5, 65)
		makeRoundedIconPart(bucket, "PaintYellow", UDim2.new(0.25, 0, 0, 16), UDim2.new(0.75, 0, 0, 0), Color3.fromRGB(255, 224, 70), 5, 65)
		makeCircle(block, "Coin", UDim2.new(0, 28, 0, 28), UDim2.new(0, 55, 0, 54), Color3.fromRGB(255, 218, 74), 66)
		makeIconLabel(block, "$", UDim2.new(0, 28, 0, 28), UDim2.new(0, 55, 0, 54), 20, Color3.fromRGB(255, 255, 190), Color3.fromRGB(174, 111, 20))
	elseif id == "Plus3Colors" then
		makeCircle(block, "RedColor", UDim2.new(0, 36, 0, 36), UDim2.new(0, 12, 0, 21), Color3.fromRGB(255, 83, 92), 64)
		makeCircle(block, "GreenColor", UDim2.new(0, 36, 0, 36), UDim2.new(0, 42, 0, 26), Color3.fromRGB(82, 230, 84), 64)
		makeCircle(block, "BlueColor", UDim2.new(0, 36, 0, 36), UDim2.new(0, 26, 0, 52), Color3.fromRGB(77, 177, 255), 64)
		makeIconLabel(block, "+3", UDim2.new(1, 0, 0, 34), UDim2.new(0, 0, 1, -38), 31, WHITE, DARK)
	elseif id == "DoubleCoins" then
		makeCircle(block, "CoinBack", UDim2.new(0, 36, 0, 36), UDim2.new(0, 12, 0, 43), Color3.fromRGB(255, 194, 45), 64)
		makeCircle(block, "CoinMid", UDim2.new(0, 42, 0, 42), UDim2.new(0, 36, 0, 38), Color3.fromRGB(255, 218, 74), 65)
		makeIconLabel(block, "2x", UDim2.new(1, 0, 0, 52), UDim2.new(0, 0, 0, 8), 39, Color3.fromRGB(255, 247, 168), DARK)
	elseif id == "VIP" then
		local crownBase = makeRoundedIconPart(block, "CrownBase", UDim2.new(0, 56, 0, 18), UDim2.new(0, 18, 0, 62), Color3.fromRGB(255, 198, 35), 7)
		addStroke(crownBase, DARK, 3)
		makeCircle(block, "CrownLeft", UDim2.new(0, 22, 0, 22), UDim2.new(0, 13, 0, 28), Color3.fromRGB(255, 226, 65), 64)
		makeCircle(block, "CrownCenter", UDim2.new(0, 28, 0, 28), UDim2.new(0, 32, 0, 17), Color3.fromRGB(255, 226, 65), 65)
		makeCircle(block, "CrownRight", UDim2.new(0, 22, 0, 22), UDim2.new(0, 57, 0, 28), Color3.fromRGB(255, 226, 65), 64)
		makeIconLabel(block, "VIP", UDim2.new(1, 0, 0, 34), UDim2.new(0, 0, 1, -36), 27, Color3.fromRGB(255, 255, 180), DARK)
	elseif id == "LuckyHatch" then
		local egg = makeRoundedIconPart(block, "Egg", UDim2.new(0, 48, 0, 58), UDim2.new(0, 22, 0, 20), Color3.fromRGB(255, 249, 240), 999)
		addStroke(egg, DARK, 3)
		makeRoundedIconPart(egg, "EggPink", UDim2.new(0.4, 0, 0.6, 0), UDim2.new(0, 0, 0, 0), Color3.fromRGB(255, 82, 176), 999, 65)
		makeRoundedIconPart(egg, "EggBlue", UDim2.new(0.4, 0, 0.6, 0), UDim2.new(0.28, 0, 0, 0), Color3.fromRGB(82, 198, 255), 999, 65)
		makeRoundedIconPart(egg, "EggGreen", UDim2.new(0.44, 0, 0.6, 0), UDim2.new(0.58, 0, 0, 0), Color3.fromRGB(90, 232, 90), 999, 65)
		makeIconLabel(block, "*", UDim2.new(0, 32, 0, 32), UDim2.new(0, 52, 0, 14), 32, Color3.fromRGB(255, 234, 78), DARK)
	elseif id == "SupportDev" then
		makeIconLabel(block, "<3", UDim2.new(1, 0, 0, 52), UDim2.new(0, 0, 0, 21), 38, Color3.fromRGB(255, 86, 136), DARK)
		makeCircle(block, "SparkLeft", UDim2.new(0, 16, 0, 16), UDim2.new(0, 15, 0, 18), Color3.fromRGB(255, 225, 235), 64)
		makeCircle(block, "SparkRight", UDim2.new(0, 14, 0, 14), UDim2.new(0, 67, 0, 70), Color3.fromRGB(255, 225, 235), 64)
	else
		makeIconLabel(block, tostring(pass.icon or ""), UDim2.new(1, 0, 1, 0), UDim2.fromOffset(0, 0), 34, WHITE, DARK)
	end

	return block
end

local function buildPassCard(pass, order)
	local owned = checkOwned(pass)
	local theme = PASS_THEME[pass.id] or {}
	local accent = theme.accent or pass.color or GREEN
	local buttonColor = theme.button or accent
	local needsId = not pass.gamepassId or pass.gamepassId <= 0

	local card = Instance.new("Frame")
	card.Name = pass.id .. "Card"
	card.LayoutOrder = order
	card.Size = UDim2.new(1, 0, 0, 128)
	card.BackgroundColor3 = WHITE:Lerp(accent, 0.05)
	card.BorderSizePixel = 0
	card.ZIndex = 61
	card.Parent = list
	Instance.new("UICorner", card).CornerRadius = UDim.new(0, 18)
	local stroke = Instance.new("UIStroke")
	stroke.Color = owned and GREEN or DARK
	stroke.Thickness = owned and 4 or 3
	stroke.Parent = card

	local accentStrip = Instance.new("Frame")
	accentStrip.Name = "AccentStrip"
	accentStrip.Size = UDim2.new(0, 9, 1, -18)
	accentStrip.Position = UDim2.new(0, 8, 0, 9)
	accentStrip.BackgroundColor3 = accent
	accentStrip.BorderSizePixel = 0
	accentStrip.ZIndex = 62
	accentStrip.Parent = card
	Instance.new("UICorner", accentStrip).CornerRadius = UDim.new(0, 8)

	local highlight = Instance.new("Frame")
	highlight.Name = "GlossHighlight"
	highlight.Size = UDim2.new(1, -34, 0, 30)
	highlight.Position = UDim2.new(0, 17, 0, 10)
	highlight.BackgroundColor3 = WHITE
	highlight.BackgroundTransparency = 0.68
	highlight.BorderSizePixel = 0
	highlight.ZIndex = 62
	highlight.Parent = card
	Instance.new("UICorner", highlight).CornerRadius = UDim.new(0, 14)

	createGamepassIcon(card, pass, accent)

	local name = Instance.new("TextLabel")
	name.Size = UDim2.new(1, -300, 0, 30)
	name.Position = UDim2.new(0, 130, 0, 18)
	name.BackgroundTransparency = 1
	name.Font = Enum.Font.LuckiestGuy
	name.TextSize = 25
	name.TextColor3 = TEXT_DARK
	name.TextStrokeTransparency = 1
	name.TextXAlignment = Enum.TextXAlignment.Left
	name.Text = pass.displayName
	name:SetAttribute("NoTextGlow", true)
	name.ZIndex = 65
	name.Parent = card
	UITheme.ApplyTextSizeConstraint(name, 18, 26)

	local desc = Instance.new("TextLabel")
	desc.Size = UDim2.new(1, -300, 0, 38)
	desc.Position = UDim2.new(0, 130, 0, 50)
	desc.BackgroundTransparency = 1
	desc.Font = Enum.Font.GothamBold
	desc.TextSize = 14
	desc.TextWrapped = true
	desc.TextColor3 = TEXT_BODY
	desc.TextXAlignment = Enum.TextXAlignment.Left
	desc.TextYAlignment = Enum.TextYAlignment.Top
	desc.Text = pass.description
	desc:SetAttribute("NoTextGlow", true)
	desc.ZIndex = 65
	desc.Parent = card

	local tag = Instance.new("TextLabel")
	tag.Size = UDim2.new(0, 128, 0, 24)
	tag.Position = UDim2.new(0, 130, 1, -34)
	tag.BackgroundColor3 = accent:Lerp(WHITE, 0.34)
	tag.BorderSizePixel = 0
	tag.Font = Enum.Font.GothamBlack
	tag.TextSize = 11
	tag.TextColor3 = TEXT_DARK
	tag.TextStrokeTransparency = 1
	tag.Text = tostring(pass.badge or "PERMANENT")
	tag.TextXAlignment = Enum.TextXAlignment.Center
	tag:SetAttribute("NoTextGlow", true)
	tag.ZIndex = 65
	tag.Parent = card
	Instance.new("UICorner", tag).CornerRadius = UDim.new(0, 12)
	local tagStroke = Instance.new("UIStroke")
	tagStroke.Color = accent:Lerp(DARK, 0.18)
	tagStroke.Thickness = 2
	tagStroke.Transparency = 0.2
	tagStroke.Parent = tag

	local buy = Instance.new("TextButton")
	buy.Size = UDim2.new(0, 144, 0, 58)
	buy.Position = UDim2.new(1, -164, 0.5, -29)
	buy.BackgroundColor3 = owned and GREEN or (needsId and Color3.fromRGB(205, 210, 225) or buttonColor)
	buy.AutoButtonColor = not owned and not needsId
	buy.Font = Enum.Font.GothamBold
	buy.Text = ""
	buy.ZIndex = 65
	buy.Parent = card
	Instance.new("UICorner", buy).CornerRadius = UDim.new(0, 16)
	local buyStroke = Instance.new("UIStroke")
	buyStroke.Color = DARK
	buyStroke.Thickness = 4
	buyStroke.Parent = buy

	local buyTop = Instance.new("TextLabel")
	buyTop.Name = "BuyTop"
	buyTop.Size = UDim2.new(1, -10, 0, owned and 58 or 24)
	buyTop.Position = UDim2.new(0, 5, 0, owned and 0 or 7)
	buyTop.BackgroundTransparency = 1
	buyTop.Font = Enum.Font.LuckiestGuy
	buyTop.TextSize = owned and 19 or 18
	buyTop.TextColor3 = WHITE
	buyTop.TextStrokeTransparency = 0.55
	buyTop.TextStrokeColor3 = DARK
	buyTop.Text = owned and "OWNED" or (needsId and "SET ID" or "BUY")
	buyTop.ZIndex = 66
	buyTop:SetAttribute("NoTextGlow", true)
	buyTop.Parent = buy
	UITheme.ApplyTextSizeConstraint(buyTop, 13, owned and 20 or 18)

	if not owned then
		local price = Instance.new("TextLabel")
		price.Name = "Price"
		price.Size = UDim2.new(1, -10, 0, 24)
		price.Position = UDim2.new(0, 5, 0, 29)
		price.BackgroundTransparency = 1
		price.Font = Enum.Font.GothamBlack
		price.TextSize = 14
		price.TextColor3 = WHITE
		price.TextStrokeTransparency = 0.72
		price.TextStrokeColor3 = DARK
		price.Text = needsId and "CONFIGURE" or formatPrice(pass.price)
		price.ZIndex = 66
		price:SetAttribute("NoTextGlow", true)
		price.Parent = buy
		UITheme.ApplyTextSizeConstraint(price, 10, 14)
	end

	buy.MouseButton1Click:Connect(function()
		if owned then
			status.Text = "You already own " .. pass.displayName
			status.TextColor3 = Color3.fromRGB(35, 130, 55)
			return
		end
		if needsId then
			status.Text = "Add the real Roblox gamepass ID for " .. pass.displayName
			status.TextColor3 = RED
			return
		end
		status.Text = "Opening Roblox purchase prompt..."
		status.TextColor3 = TEXT_BODY
		MarketplaceService:PromptGamePassPurchase(player, pass.gamepassId)
	end)

	buy.MouseButton1Down:Connect(function()
		if owned or needsId then
			return
		end
		TweenService:Create(buy, TweenInfo.new(0.08), {
			Size = UDim2.new(0, 136, 0, 54),
			Position = UDim2.new(1, -160, 0.5, -27),
		}):Play()
	end)

	buy.MouseButton1Up:Connect(function()
		TweenService:Create(buy, TweenInfo.new(0.16, Enum.EasingStyle.Back), {
			Size = UDim2.new(0, 144, 0, 58),
			Position = UDim2.new(1, -164, 0.5, -29),
		}):Play()
	end)

	card.MouseEnter:Connect(function()
		TweenService:Create(card, TweenInfo.new(0.12), {
			BackgroundColor3 = WHITE:Lerp(accent, 0.1),
		}):Play()
	end)

	card.MouseLeave:Connect(function()
		TweenService:Create(card, TweenInfo.new(0.12), {
			BackgroundColor3 = WHITE:Lerp(accent, 0.05),
		}):Play()
	end)
end

local function refresh()
	clearCards()
	local passes = RobuxShopConfig.getSortedGamepasses and RobuxShopConfig.getSortedGamepasses() or (RobuxShopConfig.Gamepasses or {})
	for index, pass in ipairs(passes) do
		buildPassCard(pass, index)
	end
	list.CanvasSize = UDim2.new(0, 0, 0, layout.AbsoluteContentSize.Y + 48)
	applyModalLayer()
end

MarketplaceService.PromptGamePassPurchaseFinished:Connect(function(purchasingPlayer, gamepassId, wasPurchased)
	if purchasingPlayer ~= player then
		return
	end
	for _, pass in ipairs(RobuxShopConfig.Gamepasses or {}) do
		if pass.gamepassId == gamepassId then
			if wasPurchased then
				ownedPasses[pass.id] = true
				status.Text = "Thank you! " .. pass.displayName .. " unlocked."
				status.TextColor3 = Color3.fromRGB(35, 130, 55)
			else
				status.Text = "Purchase canceled."
				status.TextColor3 = Color3.fromRGB(100, 105, 125)
			end
			refresh()
			break
		end
	end
end)

local isOpen = false
local openedFromMenu = false
local function toggleGamepass(open, context)
	isOpen = open
	if open then
		openedFromMenu = context and context.from == "Menu" or false
		backBtn.Visible = openedFromMenu
		title.Position = openedFromMenu and UDim2.new(0, 72, 0, 0) or UDim2.new(0, 26, 0, 0)
		title.Size = openedFromMenu and UDim2.new(1, -138, 1, 0) or UDim2.new(1, -92, 1, 0)
		refresh()
		overlay.Visible = true
		overlay.BackgroundTransparency = 1
		panel.Visible = true
		panelShadow.Visible = true
		panel.Size = UDim2.new(0, 80, 0, 80)
		panel.Position = UDim2.fromScale(0.5, 0.5)
		panelShadow.Size = panel.Size
		panelShadow.Position = UDim2.new(0.5, 7, 0.5, 7)
		TweenService:Create(overlay, TweenInfo.new(0.18), {
			BackgroundTransparency = 0.4,
		}):Play()
		TweenService:Create(panel, TweenInfo.new(0.28, Enum.EasingStyle.Back), {
			Size = UDim2.new(0, PANEL_WIDTH, 0, PANEL_HEIGHT),
			Position = UDim2.fromScale(0.5, 0.5),
		}):Play()
		TweenService:Create(panelShadow, TweenInfo.new(0.28, Enum.EasingStyle.Back), {
			Size = UDim2.new(0, PANEL_WIDTH, 0, PANEL_HEIGHT),
			Position = UDim2.new(0.5, 7, 0.5, 7),
		}):Play()
	else
		openedFromMenu = false
		backBtn.Visible = false
		if context and context.immediate then
			panel.Visible = false
			panelShadow.Visible = false
			overlay.Visible = false
			overlay.BackgroundTransparency = 1
			return
		end
		TweenService:Create(overlay, TweenInfo.new(0.16), {
			BackgroundTransparency = 1,
		}):Play()
		TweenService:Create(panel, TweenInfo.new(0.16), {
			Size = UDim2.new(0, 0, 0, 0),
			Position = UDim2.fromScale(0.5, 0.5),
		}):Play()
		TweenService:Create(panelShadow, TweenInfo.new(0.16), {
			Size = UDim2.new(0, 0, 0, 0),
			Position = UDim2.new(0.5, 7, 0.5, 7),
		}):Play()
		task.delay(0.16, function()
			if not isOpen then
				panel.Visible = false
				panelShadow.Visible = false
				overlay.Visible = false
			end
		end)
	end
end

backBtn.MouseButton1Click:Connect(function()
	if openedFromMenu then
		UIManager.open("Menu")
	end
end)

closeBtn.MouseButton1Click:Connect(function()
	UIManager.close("Gamepass")
end)

overlay.MouseButton1Click:Connect(function()
	UIManager.close("Gamepass")
end)

UIManager.register("Gamepass", function(context) toggleGamepass(true, context) end, function(context) toggleGamepass(false, context) end, function() return isOpen end)

local gamepassBtn = ReplicatedStorage:WaitForChild("HudButton_GAMEPASS", 10)
if gamepassBtn then
	gamepassBtn.Event:Connect(function() UIManager.toggle("Gamepass") end)
end

for _, pass in ipairs(RobuxShopConfig.Gamepasses or {}) do
	player:GetAttributeChangedSignal("Pass_" .. tostring(pass.id)):Connect(function()
		ownedPasses[pass.id] = nil
		if isOpen then
			refresh()
		end
	end)
end
]]></string>
          </Properties>
        </Item>
        <Item class="LocalScript" referent="127">
          <Properties>
            <string name="Name">GroupRewardsUI</string>
            <string name="Source"><![CDATA[local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")

local player = Players.LocalPlayer
local events = ReplicatedStorage:WaitForChild("Events")
local remote = events:WaitForChild("GroupRewards")
local ClientUIRoot = require(ReplicatedStorage:WaitForChild("ClientUIRoot"))
local UIManager = require(ReplicatedStorage:WaitForChild("UIManager"))
local UITheme = require(ReplicatedStorage:WaitForChild("UITheme"))

local DARK = Color3.fromRGB(35, 38, 45)
local CREAM = Color3.fromRGB(255, 249, 239)
local CYAN = Color3.fromRGB(118, 238, 244)
local GREEN = Color3.fromRGB(116, 245, 42)
local GOLD = Color3.fromRGB(255, 216, 82)
local RED = Color3.fromRGB(255, 24, 96)
local MUTED = Color3.fromRGB(95, 101, 118)

local gui = ClientUIRoot.GetLayer(player:WaitForChild("PlayerGui"), "GroupRewardsGui")
gui.Visible = false

local dim = Instance.new("TextButton")
dim.Name = "Dim"
dim.Size = UDim2.fromScale(1, 1)
dim.BackgroundColor3 = Color3.fromRGB(8, 14, 20)
dim.BackgroundTransparency = 0.42
dim.BorderSizePixel = 0
dim.Text = ""
dim.AutoButtonColor = false
dim.ZIndex = 80
dim.Parent = gui

local frame = Instance.new("Frame")
frame.Name = "GroupRewardsPanel"
frame.AnchorPoint = Vector2.new(0.5, 0.5)
frame.Position = UDim2.fromScale(0.5, 0.5)
frame.Size = UDim2.fromOffset(430, 380)
frame.BackgroundColor3 = CREAM
frame.BorderSizePixel = 0
frame.ZIndex = 81
frame.Parent = gui
UITheme.ApplyResponsiveScale(frame, 430, 380, 0.76, 28)

local frameCorner = Instance.new("UICorner")
frameCorner.CornerRadius = UDim.new(0, 22)
frameCorner.Parent = frame
local frameStroke = Instance.new("UIStroke")
frameStroke.Color = DARK
frameStroke.Thickness = 5
frameStroke.Parent = frame

local header = Instance.new("Frame")
header.Size = UDim2.new(1, 0, 0, 64)
header.BackgroundColor3 = CYAN
header.BorderSizePixel = 0
header.ZIndex = 82
header.Parent = frame
local headerCorner = Instance.new("UICorner")
headerCorner.CornerRadius = UDim.new(0, 22)
headerCorner.Parent = header

local title = Instance.new("TextLabel")
title.BackgroundTransparency = 1
title.Size = UDim2.new(1, -80, 1, 0)
title.Position = UDim2.fromOffset(20, 0)
title.Font = Enum.Font.LuckiestGuy
title.TextSize = 28
title.TextColor3 = Color3.new(1, 1, 1)
title.TextStrokeTransparency = 0
title.TextStrokeColor3 = DARK
title.TextXAlignment = Enum.TextXAlignment.Left
title.Text = "GROUP REWARDS"
title.ZIndex = 83
title.Parent = header

local close = Instance.new("TextButton")
close.Size = UDim2.fromOffset(42, 42)
close.Position = UDim2.new(1, -54, 0.5, -21)
close.BackgroundColor3 = RED
close.AutoButtonColor = false
close.Font = Enum.Font.LuckiestGuy
close.TextSize = 22
close.TextColor3 = Color3.new(1, 1, 1)
close.TextStrokeTransparency = 0
close.TextStrokeColor3 = DARK
close.Text = "X"
close.ZIndex = 84
close.Parent = header
local closeCorner = Instance.new("UICorner")
closeCorner.CornerRadius = UDim.new(1, 0)
closeCorner.Parent = close
UITheme.ApplyTouchTarget(close, 44)

local content = Instance.new("Frame")
content.Name = "Content"
content.BackgroundTransparency = 1
content.Position = UDim2.fromOffset(24, 84)
content.Size = UDim2.new(1, -48, 1, -108)
content.ZIndex = 82
content.Parent = frame
local layout = Instance.new("UIListLayout")
layout.Padding = UDim.new(0, 10)
layout.SortOrder = Enum.SortOrder.LayoutOrder
layout.Parent = content

local status = Instance.new("TextLabel")
status.BackgroundTransparency = 1
status.Size = UDim2.new(1, 0, 0, 50)
status.Font = Enum.Font.GothamBold
status.TextSize = 18
status.TextColor3 = DARK
status.TextWrapped = true
status.TextXAlignment = Enum.TextXAlignment.Left
status.TextYAlignment = Enum.TextYAlignment.Top
status.ZIndex = 83
status.Parent = content

local function makeLine(text, color)
	local label = Instance.new("TextLabel")
	label.BackgroundColor3 = Color3.fromRGB(245, 250, 250)
	label.BorderSizePixel = 0
	label.Size = UDim2.new(1, 0, 0, 38)
	label.Font = Enum.Font.GothamBlack
	label.TextSize = 17
	label.TextColor3 = color or DARK
	label.TextXAlignment = Enum.TextXAlignment.Left
	label.Text = "  " .. text
	label.ZIndex = 83
	label.Parent = content
	local corner = Instance.new("UICorner")
	corner.CornerRadius = UDim.new(0, 10)
	corner.Parent = label
	local stroke = Instance.new("UIStroke")
	stroke.Color = DARK
	stroke.Thickness = 2
	stroke.Transparency = 0.75
	stroke.Parent = label
	return label
end

local luckLine = makeLine("+5% Luck", GOLD)
local coinsLine = makeLine("+5% Coins", GOLD)
local dailyLine = makeLine("100 Gems every day", GREEN)

local info = Instance.new("TextLabel")
info.BackgroundTransparency = 1
info.Size = UDim2.new(1, 0, 0, 48)
info.Font = Enum.Font.GothamBold
info.TextSize = 15
info.TextColor3 = MUTED
info.TextWrapped = true
info.TextXAlignment = Enum.TextXAlignment.Left
info.TextYAlignment = Enum.TextYAlignment.Top
info.ZIndex = 83
info.Parent = content

local buttonRow = Instance.new("Frame")
buttonRow.BackgroundTransparency = 1
buttonRow.Size = UDim2.new(1, 0, 0, 48)
buttonRow.ZIndex = 83
buttonRow.Parent = content

local actionButton = Instance.new("TextButton")
actionButton.AnchorPoint = Vector2.new(1, 0)
actionButton.Position = UDim2.new(1, 0, 0, 0)
actionButton.Size = UDim2.fromOffset(170, 44)
actionButton.BackgroundColor3 = GREEN
actionButton.AutoButtonColor = false
actionButton.Font = Enum.Font.LuckiestGuy
actionButton.TextSize = 18
actionButton.TextColor3 = Color3.new(1, 1, 1)
actionButton.TextStrokeTransparency = 0
actionButton.TextStrokeColor3 = DARK
actionButton.ZIndex = 84
actionButton.Parent = buttonRow
local actionCorner = Instance.new("UICorner")
actionCorner.CornerRadius = UDim.new(0, 12)
actionCorner.Parent = actionButton
UITheme.ApplyTouchTarget(actionButton, 44)

local currentState = nil

local function formatTime(seconds)
	seconds = math.max(0, tonumber(seconds) or 0)
	local hours = math.floor(seconds / 3600)
	local minutes = math.floor((seconds % 3600) / 60)
	return string.format("%02dh %02dm", hours, minutes)
end

local function render(data)
	currentState = data or currentState
	data = currentState or {}

	if data.isMember then
		status.Text = "Thanks for joining the Color Simulator group. Your boosts are active."
		luckLine.Text = "  +" .. tostring(data.luckPercent or 5) .. "% Luck ACTIVE"
		coinsLine.Text = "  +" .. tostring(data.coinPercent or 5) .. "% Coins ACTIVE"
		dailyLine.Text = "  Claim " .. tostring(data.dailyGems or 100) .. " Gems"
		if data.canClaim then
			info.Text = "Your daily group reward is ready."
			actionButton.Text = "CLAIM"
			actionButton.BackgroundColor3 = GREEN
			actionButton.Active = true
		else
			info.Text = "Already claimed today. Resets in " .. formatTime(data.resetIn) .. "."
			actionButton.Text = "CLAIMED"
			actionButton.BackgroundColor3 = Color3.fromRGB(150, 156, 170)
			actionButton.Active = false
		end
	else
		status.Text = "Join the Color Simulator group to unlock rewards!"
		luckLine.Text = "  +5% Luck"
		coinsLine.Text = "  +5% Coins"
		dailyLine.Text = "  100 Gems every day"
		info.Text = "Search for \"Color Simulator!\" by Jacksocks on Roblox Communities, then reopen this panel."
		actionButton.Text = "JOIN GROUP"
		actionButton.BackgroundColor3 = CYAN
		actionButton.Active = true
	end
end

local function openGui()
	gui.Visible = true
	remote:FireServer("Get")
end

local function closeGui()
	gui.Visible = false
end

close.MouseButton1Click:Connect(closeGui)
dim.MouseButton1Click:Connect(closeGui)

actionButton.MouseButton1Click:Connect(function()
	if currentState and currentState.isMember then
		if currentState.canClaim then
			actionButton.Text = "..."
			actionButton.Active = false
			remote:FireServer("ClaimDaily")
		end
	else
		info.Text = "Open Roblox Communities and join \"Color Simulator!\" by Jacksocks. Then press this again after joining."
		remote:FireServer("Refresh")
	end
end)

remote.OnClientEvent:Connect(function(action, data)
	if action == "State" then
		render(data)
	elseif action == "Open" then
		gui.Visible = true
		render(data)
	end
end)

UIManager.register("GroupRewards", openGui, closeGui, function()
	return gui.Visible == true
end)

local groupButton = ReplicatedStorage:WaitForChild("HudButton_GROUPREWARDS", 10)
if groupButton then
	groupButton.Event:Connect(openGui)
end

remote:FireServer("Get")
]]></string>
          </Properties>
        </Item>
        <Item class="LocalScript" referent="128">
          <Properties>
            <string name="Name">HudUI</string>
            <string name="Source"><![CDATA[-- Legacy generated HUD disabled.
-- The active HUD/menu/currency must be handmade under PlayerGui.ClientUIRoot.
local Players = game:GetService("Players")

local player = Players.LocalPlayer
local playerGui = player:WaitForChild("PlayerGui")

local root = playerGui:WaitForChild("ClientUIRoot", 8)
if root then
	playerGui:SetAttribute("StudioMainHUDPresent", true)
	root:SetAttribute("UsesPhysicalMainHUD", true)
	print("HudUI: legacy generated HUD disabled; using handmade ClientUIRoot.")
else
	warn("HudUI: legacy generated HUD disabled, but PlayerGui.ClientUIRoot was not found.")
end
]]></string>
          </Properties>
        </Item>
        <Item class="LocalScript" referent="129">
          <Properties>
            <string name="Name">InputHandler</string>
            <string name="Source"><![CDATA[-- LocalScript in StarterPlayerScripts named "InputHandler"
local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local RunService = game:GetService("RunService")
local TweenService = game:GetService("TweenService")
local Debris = game:GetService("Debris")

local player = Players.LocalPlayer
local mouse  = player:GetMouse()

local PetData = require(ReplicatedStorage:WaitForChild("PetData"))
local ColorTraitData = require(ReplicatedStorage:WaitForChild("ColorTraitData"))
local ColorMutationData = require(ReplicatedStorage:WaitForChild("ColorMutationData"))
local ClientUIRoot = require(ReplicatedStorage:WaitForChild("ClientUIRoot"))

local Events       = ReplicatedStorage:WaitForChild("Events", 10)
if not Events then
	warn("Collection remote missing, using touch fallback only.")
	return
end
local collectEvent = Events:WaitForChild("CollectColor", 10)
local hatchEvent   = Events:WaitForChild("HatchEgg", 10)
if not collectEvent then
	warn("Collection remote missing, using touch fallback only.")
	return
end
local openEggShopEvent = ReplicatedStorage:FindFirstChild("OpenEggShop")
if not openEggShopEvent then
	openEggShopEvent = Instance.new("BindableEvent")
	openEggShopEvent.Name = "OpenEggShop"
	openEggShopEvent.Parent = ReplicatedStorage
end

local DEFAULT_HOVER_RANGE = 20
local pendingCollectPart = nil

local function getClientSetting(key, defaultValue)
	local value = player:GetAttribute("Setting" .. key)
	return type(value) == "boolean" and value or defaultValue
end

local function parseInventory(str)
	local inventory = {}
	if not str or str == "" then
		return inventory
	end

	for _, part in ipairs(string.split(str, ",")) do
		local segments = string.split(part, ":")
		local variantKey
		local petId
		local stackIndex
		if tonumber(segments[2]) then
			petId = segments[1]
			stackIndex = 2
		else
			variantKey = segments[1]
			petId = segments[2]
			stackIndex = 3
		end
		if petId and petId ~= "" then
			local traitId = PetData.normalizeTraitId(segments[stackIndex + 1])
			local personalityId = PetData.normalizePersonalityId(segments[stackIndex + 3] or "Neutral")
			local mutationId = PetData.normalizeMutationId(segments[stackIndex + 4] or "None")
			variantKey = variantKey or PetData.makeVariantKey(petId, personalityId, mutationId, traitId)
			inventory[variantKey] = {
				traitId = traitId,
				personalityId = personalityId,
				mutationId = mutationId,
			}
		end
	end

	return inventory
end

local function getEquippedPickupMultiplier()
	local petFolder = player:FindFirstChild("PetData")
	local invVal = petFolder and petFolder:FindFirstChild("Inventory")
	local equippedVal = petFolder and petFolder:FindFirstChild("Equipped")
	if not invVal or not equippedVal or equippedVal.Value == "" then
		return 1
	end

	local multiplier = 1
	local inventory = parseInventory(invVal.Value)
	for _, variantKey in ipairs(string.split(equippedVal.Value, ",")) do
		local data = inventory[variantKey]
		if data then
			local trait = ColorTraitData.get(data.traitId)
			local mutation = ColorMutationData.get(data.mutationId)
			multiplier *= (trait.Effects and trait.Effects.BrushRangeMultiplier) or 1
			multiplier *= (mutation.Effects and mutation.Effects.BrushRangeMultiplier) or 1
		end
	end

	return multiplier
end

local function getHoverRange()
	local range = DEFAULT_HOVER_RANGE
	local upgrades = player:FindFirstChild("Upgrades")
	local pickupRange = upgrades and upgrades:FindFirstChild("PickupRange")
	if pickupRange then
		range = pickupRange.Value
	end

	local boostFolder = player:FindFirstChild("Boosts")
	local rangeBoost = boostFolder and boostFolder:FindFirstChild("range")
	if rangeBoost and os.time() < rangeBoost.Value then
		range *= 1.5
	end

	range *= getEquippedPickupMultiplier()
	return range
end

local function hasPaintToolEquipped()
	local character = player.Character
	if not character then
		return false
	end

	for _, child in ipairs(character:GetChildren()) do
		if child:IsA("Tool") and child:GetAttribute("PaintToolId") then
			return true
		end
	end

	return false
end

local feedbackGui = ClientUIRoot.GetLayer(player:WaitForChild("PlayerGui"), "CollectFeedbackUI")

local function playWorldCollectBurst(part)
	if not getClientSetting("Popups", true) then
		return
	end
	if not part or not part.Parent or not part:IsA("BasePart") then
		return
	end

	local attachment = Instance.new("Attachment")
	attachment.Name = "CollectBurst"
	attachment.Parent = part

	local particles = Instance.new("ParticleEmitter")
	particles.Texture = "rbxasset://textures/particles/sparkles_main.dds"
	particles.Color = ColorSequence.new(part.Color, Color3.new(1, 1, 1))
	particles.LightEmission = 0.8
	particles.Size = NumberSequence.new({
		NumberSequenceKeypoint.new(0, 0.35),
		NumberSequenceKeypoint.new(1, 0),
	})
	particles.Speed = NumberRange.new(8, 16)
	particles.SpreadAngle = Vector2.new(180, 180)
	particles.Lifetime = NumberRange.new(0.35, 0.65)
	particles.Rate = 0
	particles.Parent = attachment
	particles:Emit(getClientSetting("LowFX", false) and 8 or 28)

	Debris:AddItem(attachment, 1)
end

local function showCollectFeedback(success, amount, message)
	if success and amount and amount > 0 then
		playWorldCollectBurst(pendingCollectPart)
	end
	pendingCollectPart = nil

	local text
	local color

	if success then
		if amount and amount > 0 then
			text = "+" .. amount .. " COINS"
			color = Color3.fromRGB(255, 220, 90)
		else
			text = message or "NO REWARD"
			color = Color3.fromRGB(255, 220, 90)
		end
	elseif message == "Slow down." or message == "Already collected." then
		return
	else
		text = message or "CAN'T COLLECT"
		color = Color3.fromRGB(255, 110, 140)
	end

	if not getClientSetting("Popups", true) then
		return
	end

	local label = Instance.new("TextLabel")
	label.AnchorPoint = Vector2.new(0.5, 0.5)
	label.Size = UDim2.new(0, 170, 0, 36)
	label.Position = UDim2.new(0, mouse.X, 0, mouse.Y - 24)
	label.BackgroundTransparency = 1
	label.Font = Enum.Font.LuckiestGuy
	label.TextSize = 22
	label.TextColor3 = color
	label.TextStrokeTransparency = 0
	label.TextStrokeColor3 = Color3.fromRGB(35, 38, 45)
	label.Text = text
	label.ZIndex = 100
	label.Parent = feedbackGui

	TweenService:Create(label, TweenInfo.new(0.45, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
		Position = label.Position - UDim2.new(0, 0, 0, 42),
		TextTransparency = 1,
		TextStrokeTransparency = 1,
	}):Play()

	task.delay(0.5, function()
		if label and label.Parent then
			label:Destroy()
		end
	end)
end

-- ========================
--   HOVER OUTLINE
-- ========================
local currentHover = nil
local currentHighlights = {}

local function clearHighlight()
	for _, hl in ipairs(currentHighlights) do
		if hl and hl.Parent then
			hl:Destroy()
		end
	end
	table.clear(currentHighlights)
	currentHover = nil
end

local function addHoverHighlight(adornee)
	local hl = Instance.new("Highlight")
	hl.Name             = "HoverHighlight"
	hl.FillColor        = Color3.fromRGB(255, 255, 255)
	hl.OutlineColor     = Color3.fromRGB(255, 255, 255)
	hl.FillTransparency = 0.82
	hl.OutlineTransparency = 0
	hl.DepthMode        = Enum.HighlightDepthMode.AlwaysOnTop
	hl.Adornee          = adornee
	hl.Parent           = adornee
	table.insert(currentHighlights, hl)
end

local function setHighlight(part)
	if currentHover == part then return end
	clearHighlight()
	if not part then return end

	addHoverHighlight(part)
	for _, child in ipairs(part:GetDescendants()) do
		if child:IsA("BasePart") and child:GetAttribute("PuddleDetail") and child.Transparency < 1 then
			addHoverHighlight(child)
		end
	end

	currentHover = part
end

-- Update hover every frame
RunService.Heartbeat:Connect(function()
	local target = mouse.Target
	if not target then
		clearHighlight()
		return
	end

	local char = player.Character
	if not char then return end
	local root = char:FindFirstChild("HumanoidRootPart")
	if not root then return end

	-- Only highlight breakables that are in range
	if target:GetAttribute("BreakableType") then
		local dist = (root.Position - target.Position).Magnitude
		if dist <= getHoverRange() then
			setHighlight(target)
			return
		end
	end

	clearHighlight()
end)

-- ========================
--   CLICK TO BREAK / HATCH
-- ========================
mouse.Button1Down:Connect(function()
	local target = mouse.Target
	if not target then return end

	if target:GetAttribute("BreakableType") then
		if hasPaintToolEquipped() then
			return
		end
		pendingCollectPart = target
		collectEvent:FireServer(target)
	elseif target:GetAttribute("EggId") then
		openEggShopEvent:Fire(target:GetAttribute("EggId"))
	end
end)

collectEvent.OnClientEvent:Connect(showCollectFeedback)
