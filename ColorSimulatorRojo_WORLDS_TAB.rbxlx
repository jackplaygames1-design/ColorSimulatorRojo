      <Item class="Script" referent="78">
        <Properties>
          <string name="Name">DevTools</string>
          <token name="RunContext">0</token>
          <string name="Source"><![CDATA[local ReplicatedStorage = game:GetService("ReplicatedStorage")
local RunService = game:GetService("RunService")
local Players = game:GetService("Players")

local Events = ReplicatedStorage:WaitForChild("Events")
local PetData = require(ReplicatedStorage:WaitForChild("PetData"))
local ColorTraitData = require(ReplicatedStorage:WaitForChild("ColorTraitData"))
local ColorMutationData = require(ReplicatedStorage:WaitForChild("ColorMutationData"))
local GamepassBenefits = require(script.Parent:WaitForChild("GamepassBenefits"))
local AdminConfig = require(ReplicatedStorage:WaitForChild("AdminConfig"))
local grantCoinsEvent = Events:WaitForChild("DevGrantCoins")
local resetProfileRemote = Events:FindFirstChild("DevResetProfile")
if not resetProfileRemote then
	resetProfileRemote = Instance.new("RemoteEvent")
	resetProfileRemote.Name = "DevResetProfile"
	resetProfileRemote.Parent = Events
end
local resetProfileFunction = ReplicatedStorage:FindFirstChild("StudioResetProfile")
if not resetProfileFunction then
	resetProfileFunction = Instance.new("BindableFunction")
	resetProfileFunction.Name = "StudioResetProfile"
	resetProfileFunction.Parent = ReplicatedStorage
end
local grantRainbowFunction = ReplicatedStorage:FindFirstChild("StudioGrantRainbowColor")
if not grantRainbowFunction then
	grantRainbowFunction = Instance.new("BindableFunction")
	grantRainbowFunction.Name = "StudioGrantRainbowColor"
	grantRainbowFunction.Parent = ReplicatedStorage
end
local forceMutationFunction = ReplicatedStorage:FindFirstChild("StudioForceNextMutation")
if not forceMutationFunction then
	forceMutationFunction = Instance.new("BindableFunction")
	forceMutationFunction.Name = "StudioForceNextMutation"
	forceMutationFunction.Parent = ReplicatedStorage
end
local grantAllGamepassesFunction = ReplicatedStorage:FindFirstChild("StudioGrantAllGamepasses")
if not grantAllGamepassesFunction then
	grantAllGamepassesFunction = Instance.new("BindableFunction")
	grantAllGamepassesFunction.Name = "StudioGrantAllGamepasses"
	grantAllGamepassesFunction.Parent = ReplicatedStorage
end

local DEV_COIN_AMOUNT = 2000000000

local DEFAULTS = {
	Coins = 0,
	Gems = 0,
	Diamonds = 0,
	Rebirths = 0,
	UnlockedColors = "Red",
	CurrentWorld = "Red",
	MaxPetSlots = 3,
	WalkSpeed = 44,
}

local function findPlayerByName(name)
	if not name or tostring(name) == "" then
		return Players:GetPlayers()[1]
	end

	local wanted = string.lower(tostring(name))
	for _, candidate in ipairs(Players:GetPlayers()) do
		if string.lower(candidate.Name) == wanted or string.lower(candidate.DisplayName) == wanted then
			return candidate
		end
	end

	return Players:FindFirstChild(tostring(name))
end

local function canUseGamepassGrant(actor)
	if RunService:IsStudio() then
		return true
	end
	if not actor then
		return false
	end
	if game.CreatorType == Enum.CreatorType.User and actor.UserId == game.CreatorId then
		return true
	end
	return AdminConfig.isModeratorName(actor.Name)
end

grantCoinsEvent.OnServerEvent:Connect(function(player)
	if not RunService:IsStudio() then
		warn("DevTools: blocked coin grant outside Studio for " .. player.Name)
		return
	end

	local leaderstats = player:FindFirstChild("leaderstats")
	local coins = leaderstats and leaderstats:FindFirstChild("Coins")
	if not coins or not coins:IsA("IntValue") then
		return
	end

	coins.Value = DEV_COIN_AMOUNT
	print("DevTools: set " .. player.Name .. " coins to " .. tostring(DEV_COIN_AMOUNT))
end)

local function clearChildren(folder)
	if not folder then
		return
	end

	for _, child in ipairs(folder:GetChildren()) do
		child:Destroy()
	end
end

local function setValue(parent, name, value)
	local child = parent and parent:FindFirstChild(name)
	if child and child:IsA("ValueBase") then
		child.Value = value
	end
end

local function resetPlayer(player)
	if not RunService:IsStudio() then
		warn("DevTools: blocked profile reset outside Studio for " .. tostring(player and player.Name))
		return false
	end
	player:SetAttribute("IntentionalProfileReset", true)

	local leaderstats = player:FindFirstChild("leaderstats")
	if leaderstats then
		setValue(leaderstats, "Coins", DEFAULTS.Coins)
		setValue(leaderstats, "Gems", DEFAULTS.Gems)
		setValue(leaderstats, "Diamonds", DEFAULTS.Diamonds)
		setValue(leaderstats, "Rebirths", DEFAULTS.Rebirths)
	end

	local storage = player:FindFirstChild("ColorStorage")
	if storage then
		setValue(storage, "UnlockedColors", DEFAULTS.UnlockedColors)
		setValue(storage, "CurrentWorld", DEFAULTS.CurrentWorld)
	end
	player:SetAttribute("ActiveWorldColor", DEFAULTS.CurrentWorld)

	local petFolder = player:FindFirstChild("PetData")
	if petFolder then
		setValue(petFolder, "Inventory", "")
		setValue(petFolder, "Equipped", "")
		local maxSlots = petFolder:FindFirstChild("MaxSlots")
		if not maxSlots then
			maxSlots = Instance.new("IntValue")
			maxSlots.Name = "MaxSlots"
			maxSlots.Parent = petFolder
		end
		maxSlots.Value = DEFAULTS.MaxPetSlots
	end

	local upgrades = player:FindFirstChild("Upgrades")
	if upgrades then
		for _, child in ipairs(upgrades:GetChildren()) do
			if child:IsA("IntValue") and child.Name:find("_Level") then
				child.Value = 0
			elseif child:IsA("NumberValue") or child:IsA("IntValue") then
				if child.Name == "PickupRange" then
					child.Value = 8
				elseif child.Name == "ColorMultiplier" then
					child.Value = 1
				elseif child.Name == "HatchSpeed" then
					child.Value = 1
				elseif child.Name == "WalkSpeed" then
					child.Value = DEFAULTS.WalkSpeed
				elseif child.Name == "PetSlots" then
					child.Value = DEFAULTS.MaxPetSlots
				end
			end
		end
	end

	clearChildren(player:FindFirstChild("RedeemedCodes"))
	clearChildren(player:FindFirstChild("Boosts"))
	clearChildren(player:FindFirstChild("ItemFlags"))

	local character = player.Character
	local humanoid = character and character:FindFirstChildOfClass("Humanoid")
	if humanoid then
		humanoid.WalkSpeed = DEFAULTS.WalkSpeed
	end

	print("Studio profile reset complete")
	print("DevTools: reset profile stats for " .. player.Name)
	return true
end

resetProfileFunction.OnInvoke = function(playerName)
	if not RunService:IsStudio() then
		warn("DevTools: blocked profile reset outside Studio")
		return false
	end

	local player = playerName and Players:FindFirstChild(tostring(playerName)) or Players:GetPlayers()[1]
	if not player then
		warn("DevTools: no player found to reset")
		return false
	end

	return resetPlayer(player)
end

resetProfileRemote.OnServerEvent:Connect(function(player)
	if not RunService:IsStudio() then
		warn("DevTools: blocked remote profile reset outside Studio for " .. player.Name)
		return
	end

	resetPlayer(player)
end)

local function grantRainbowColor(player)
	if not RunService:IsStudio() then
		warn("DevTools: blocked Rainbow Color grant outside Studio")
		return false
	end
	if not player then
		warn("DevTools: no player found for Rainbow Color grant")
		return false
	end

	local grantPetFunction = ReplicatedStorage:FindFirstChild("ServerGrantPet")
	if not grantPetFunction or not grantPetFunction:IsA("BindableFunction") then
		warn("DevTools: ServerGrantPet function is missing")
		return false
	end

	local ok, entry = grantPetFunction:Invoke(player, "DevRainbowPet", 1, "SuperLucky", "None", false)
	if ok then
		print("DevTools: added Rainbow Pet to " .. player.Name .. "'s inventory")
	else
		warn("DevTools: failed to add Rainbow Pet to " .. player.Name .. "'s inventory")
	end
	return ok, entry
end

grantRainbowFunction.OnInvoke = function(playerName)
	if not RunService:IsStudio() then
		warn("DevTools: blocked Rainbow Color grant outside Studio")
		return false
	end

	local player = playerName and Players:FindFirstChild(tostring(playerName)) or Players:GetPlayers()[1]
	return grantRainbowColor(player)
end

forceMutationFunction.OnInvoke = function(playerName, mutationId)
	if not RunService:IsStudio() then
		warn("DevTools: blocked forced mutation outside Studio")
		return false
	end

	local player = playerName and Players:FindFirstChild(tostring(playerName)) or Players:GetPlayers()[1]
	if not player then
		warn("DevTools: no player found for forced mutation")
		return false
	end

	local normalizedMutationId = ColorMutationData.normalize(mutationId or "BlackHole")
	if normalizedMutationId == ColorMutationData.NoneId then
		warn("DevTools: unknown mutation " .. tostring(mutationId))
		return false
	end

	player:SetAttribute("ForceNextMutation", normalizedMutationId)
	print("DevTools: next hatch mutation for " .. player.Name .. " forced to " .. normalizedMutationId)
	return true, normalizedMutationId
end

local function grantAllGamepasses(player, actor)
	if not canUseGamepassGrant(actor) then
		warn("DevTools: blocked gamepass grant from " .. tostring(actor and actor.Name or "server"))
		return false
	end
	if not player then
		warn("DevTools: no player found for gamepass grant")
		return false
	end

	local ok, granted = GamepassBenefits.grantAll(player)
	if ok then
		print("DevTools: granted all gamepasses to " .. player.Name .. ": " .. table.concat(granted, ", "))
	else
		warn("DevTools: failed to grant gamepasses to " .. player.Name)
	end
	return ok, granted
end

grantAllGamepassesFunction.OnInvoke = function(playerName)
	if not RunService:IsStudio() then
		warn("DevTools: blocked gamepass grant outside Studio")
		return false
	end

	local player = findPlayerByName(playerName)
	return grantAllGamepasses(player, nil)
end

Players.PlayerAdded:Connect(function(player)
	player.Chatted:Connect(function(message)
		local normalized = string.lower(tostring(message or ""))
		local parts = string.split(tostring(message or ""), " ")
		local command = string.lower(parts[1] or "")
		if command == "/grantpasses" or command == "/grantallgamepasses" then
			local target = parts[2] and findPlayerByName(parts[2]) or player
			grantAllGamepasses(target, player)
			return
		end

		if not RunService:IsStudio() then
			return
		end

		if normalized == "/resetprofile" or normalized == "!resetprofile" or normalized == "/reset" then
			resetPlayer(player)
			return
		end

		if command == "/printpetdata" or command == "/printcolordata" then
			local printPetDataFunction = ReplicatedStorage:FindFirstChild("PrintPetData")
			if printPetDataFunction and printPetDataFunction:IsA("BindableFunction") then
				printPetDataFunction:Invoke(player.Name)
			else
				warn("DevTools: PrintPetData function is missing")
			end
		elseif command == "/forceMutation" or command == "/forcemutation" then
			local mutationId = ColorMutationData.normalize(parts[2] or "BlackHole")
			if mutationId ~= ColorMutationData.NoneId then
				player:SetAttribute("ForceNextMutation", mutationId)
				print("DevTools: next hatch mutation for " .. player.Name .. " forced to " .. mutationId)
			else
				warn("DevTools: unknown mutation " .. tostring(parts[2]))
			end
		elseif command == "/givecolor" then
			local petId = parts[2] or "RedCubey"
			local traitId = PetData.normalizeTraitId(parts[3] or "Neutral")
			local mutationId = PetData.normalizeMutationId(parts[4] or "None")
			if not PetData.Pets[petId] then
				warn("DevTools: unknown Color " .. tostring(petId))
				return
			end

			local grantPetFunction = ReplicatedStorage:FindFirstChild("ServerGrantPet")
			if grantPetFunction and grantPetFunction:IsA("BindableFunction") then
				local ok, entry = grantPetFunction:Invoke(player, petId, 1, traitId, mutationId)
				print("DevTools: givecolor " .. tostring(ok) .. " " .. tostring(entry and entry.displayName or petId)
					.. " trait=" .. tostring(ColorTraitData.get(traitId).DisplayName)
					.. " mutation=" .. tostring(ColorMutationData.get(mutationId).DisplayName))
			end
		elseif command == "/giverainbow" or command == "/giverainbowcolor" then
			grantRainbowColor(player)
		elseif command == "/printcoloreffects" then
			local handler = script.Parent:FindFirstChild("ColorEffectHandler")
			if handler then
				local ColorEffectHandler = require(handler)
				local effects = ColorEffectHandler.CalculateEquippedColorEffects(player)
				print("DevTools Color Effects for " .. player.Name .. ":")
				for key, value in pairs(effects) do
					print("  " .. tostring(key) .. " = " .. tostring(value))
				end
			end
		end
	end)
end)
]]></string>
        </Properties>
      </Item>
      <Item class="Script" referent="79">
        <Properties>
          <string name="Name">EarlySupporterHandler</string>
          <token name="RunContext">0</token>
          <string name="Source"><![CDATA[-- Marks players who own the Support Dev gamepass so chat can show an Early Supporter tag.
local MarketplaceService = game:GetService("MarketplaceService")
local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")

local RobuxShopConfig = require(ReplicatedStorage:WaitForChild("RobuxShopConfig"))
local AdminConfig = require(ReplicatedStorage:WaitForChild("AdminConfig"))

local SUPPORT_PASS_ID
for _, pass in ipairs(RobuxShopConfig.Gamepasses or {}) do
	if pass.id == "SupportDev" or pass.earlySupporterTag then
		SUPPORT_PASS_ID = pass.gamepassId
		break
	end
end

local function setSupporter(player, owns)
	if owns ~= true and player:GetAttribute("Pass_SupportDev") == true then
		owns = true
	end
	player:SetAttribute("EarlySupporter", owns == true)
end

local function refreshSupporter(player)
	if player:GetAttribute("Pass_SupportDev") == true then
		setSupporter(player, true)
		return
	end

	if AdminConfig.isEarlyTesterName(player.Name) then
		setSupporter(player, true)
		return
	end

	if not SUPPORT_PASS_ID or SUPPORT_PASS_ID <= 0 then
		setSupporter(player, false)
		return
	end

	local ok, owns = pcall(function()
		return MarketplaceService:UserOwnsGamePassAsync(player.UserId, SUPPORT_PASS_ID)
	end)
	setSupporter(player, ok and owns == true)
end

Players.PlayerAdded:Connect(function(player)
	setSupporter(player, false)
	task.defer(function()
		refreshSupporter(player)
	end)
end)

MarketplaceService.PromptGamePassPurchaseFinished:Connect(function(player, gamepassId, wasPurchased)
	if gamepassId == SUPPORT_PASS_ID and wasPurchased then
		setSupporter(player, true)
	end
end)
]]></string>
        </Properties>
      </Item>
      <Item class="Script" referent="80">
        <Properties>
          <string name="Name">EditableInventoryBridge</string>
          <token name="RunContext">0</token>
          <string name="Source"><![CDATA[-- Server bridge for the editable Studio InventoryWindow.
-- Client receives display data and requests actions; this script delegates
-- inventory mutations to the existing authoritative game systems.
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local ServerStorage = game:GetService("ServerStorage")

local PetData = require(ReplicatedStorage:WaitForChild("PetData"))
local ToolData = require(ReplicatedStorage:WaitForChild("ToolData"))
local ItemsData = require(ReplicatedStorage:WaitForChild("ItemsData"))
local PetDefinitions = require(ReplicatedStorage:WaitForChild("Modules"):WaitForChild("PetDefinitions"))

local remotes = ReplicatedStorage:FindFirstChild("Remotes")
if not remotes then
	remotes = Instance.new("Folder")
	remotes.Name = "Remotes"
	remotes.Parent = ReplicatedStorage
end

local inventoryRequest = remotes:FindFirstChild("InventoryRequest")
if not inventoryRequest then
	inventoryRequest = Instance.new("RemoteFunction")
	inventoryRequest.Name = "InventoryRequest"
	inventoryRequest.Parent = remotes
end

local inventoryAction = remotes:FindFirstChild("InventoryAction")
if not inventoryAction then
	inventoryAction = Instance.new("RemoteEvent")
	inventoryAction.Name = "InventoryAction"
	inventoryAction.Parent = remotes
end

local Events = ReplicatedStorage:WaitForChild("Events")
local dataDirtyEvent = Events:FindFirstChild("PlayerDataDirty")
local equipPaintToolEvent = Events:WaitForChild("EquipPaintTool")
local useItemEvent = Events:WaitForChild("UseItem")

local COLOR_CAPACITY = 75

local function splitCsv(value)
	local out = {}
	for _, item in ipairs(string.split(value or "", ",")) do
		if item ~= "" then
			table.insert(out, item)
		end
	end
	return out
end

local function setFromCsv(value)
	local set = {}
	for _, item in ipairs(splitCsv(value)) do
		set[item] = true
	end
	return set
end

local function waitForPlayerPetData(player)
	if player:GetAttribute("DataManagerReady") ~= true then
		local ready = false
		local connection
		connection = player:GetAttributeChangedSignal("DataManagerReady"):Connect(function()
			if player:GetAttribute("DataManagerReady") == true then
				ready = true
				if connection then
					connection:Disconnect()
				end
			end
		end)
		local startedAt = os.clock()
		while player.Parent and not ready and player:GetAttribute("DataManagerReady") ~= true and os.clock() - startedAt < 10 do
			task.wait(0.1)
		end
		if connection and connection.Connected then
			connection:Disconnect()
		end
	end

	local petFolder = player:WaitForChild("PetData", 10)
	local inventoryValue = petFolder and petFolder:WaitForChild("Inventory", 10)
	local equippedValue = petFolder and petFolder:WaitForChild("Equipped", 10)
	local lockedValue = petFolder and petFolder:WaitForChild("Locked", 10)
	if inventoryValue and inventoryValue.Value == "" then
		local startedAt = os.clock()
		while player.Parent and inventoryValue.Parent and inventoryValue.Value == "" and os.clock() - startedAt < 2 do
			task.wait(0.1)
		end
	end
	return petFolder, inventoryValue, equippedValue, lockedValue
end

local function parsePetInventory(value)
	local entries = {}
	for _, encoded in ipairs(splitCsv(value)) do
		local segments = string.split(encoded, ":")
		local variantKey
		local petId
		local stackIndex
		if #segments == 1 then
			local legacyParts = string.split(encoded, "|")
			petId = legacyParts[1]
			variantKey = encoded

			local stackAmount = 1
			local traitId = PetData.normalizeTraitId(legacyParts[2] or "Neutral")
			local mutationId = PetData.normalizeMutationId(legacyParts[3] or "None")
			local personalityId = "Neutral"
			local entry = PetData.buildPetEntry(petId, stackAmount, false, personalityId, mutationId, traitId)
			if entry then
				entry.variantKey = variantKey
				entry.petId = petId
				entry.modelName = petId
				entry.legacyColorKey = encoded
				table.insert(entries, entry)
			else
				warn("EditableInventoryBridge: could not display saved Color entry " .. tostring(encoded))
			end
			continue
		elseif tonumber(segments[2]) then
			petId = segments[1]
			stackIndex = 2
		else
			variantKey = segments[1]
			petId = segments[2]
			stackIndex = 3
		end

		if petId and petId ~= "" then
			local legacyParts = string.split(petId, "|")
			local stackAmount = math.max(1, tonumber(segments[stackIndex]) or 1)
			local traitId = PetData.normalizeTraitId(segments[stackIndex + 1])
			local shinyStr = segments[stackIndex + 2] or "normal"
			local personalityId = PetData.normalizePersonalityId(segments[stackIndex + 3] or "Neutral")
			local mutationId = PetData.normalizeMutationId(segments[stackIndex + 4] or "None")
			if not PetData.Pets[petId] and #legacyParts >= 3 and PetData.Pets[legacyParts[1]] then
				petId = legacyParts[1]
				traitId = PetData.normalizeTraitId(legacyParts[2])
				mutationId = PetData.normalizeMutationId(legacyParts[3])
			end
			variantKey = variantKey or PetData.makeVariantKey(petId, personalityId, mutationId, traitId)

			local entry = PetData.buildPetEntry(
				petId,
				stackAmount,
				shinyStr == "shiny" or shinyStr == "true",
				personalityId,
				mutationId,
				traitId
			)
			if entry then
				entry.variantKey = variantKey
				entry.petId = petId
				if string.find(tostring(variantKey), "|", 1, true) then
					entry.legacyColorKey = variantKey
					entry.modelName = petId
				end
				table.insert(entries, entry)
			end
		end
	end
	return entries
end

local function buildColorRows(player)
	local petFolder, inventoryValue, equippedValue, lockedValue = waitForPlayerPetData(player)
	print("[InventoryBridge] PetData folder", petFolder)
	print("[InventoryBridge] Inventory raw", inventoryValue and inventoryValue.Value)
	local equipped = setFromCsv(equippedValue and equippedValue.Value or "")
	local locked = setFromCsv(lockedValue and lockedValue.Value or "")

	local rows = {}
	for _, entry in ipairs(parsePetInventory(inventoryValue and inventoryValue.Value or "")) do
		local pet = PetData.Pets[entry.petId] or {}
		local definition = PetDefinitions.Get(entry.petId)
		local mutationName = entry.mutationId or entry.mutationName or "None"
		if mutationName == "" then
			mutationName = "None"
		end
		local displayName = entry.displayName or pet.displayName or entry.petId
		if entry.petId == "DevRainbowPet" and displayName == "Rainbow Pet" then
			displayName = "Dev Rainbow Pet"
		end
		local rarity = entry.rarity or pet.rarity or "Color"
		if entry.legacyColorKey and entry.traitId and entry.traitId ~= "Neutral" then
			rarity = entry.traitId
		end
		table.insert(rows, {
			Id = entry.variantKey,
			Kind = "Color",
			Name = displayName,
			Rarity = rarity,
			Amount = math.max(1, tonumber(entry.stackAmount) or 1),
			Equipped = equipped[entry.variantKey] == true or equipped[entry.petId] == true,
			Locked = locked[entry.variantKey] == true,
			Mutation = mutationName,
			Trait = entry.traitName,
			Power = tostring(entry.finalPower or entry.effectivePower or 0),
			Bonus = "Coins x" .. string.format("%.2f", tonumber(entry.coinMult) or 1),
			Description = tostring(entry.traitDescription or entry.mutationDescription or "Color companion."),
			IconImage = pet.IconImage or pet.iconImage,
			IconText = entry.petId == "DevRainbowPet" and "RA" or string.upper(string.sub(displayName, 1, 2)),
			IconColor = (definition and definition.IconColor) or pet.iconColor or pet.color,
			ModelName = entry.modelName or (definition and definition.ModelName) or pet.modelName or entry.petId,
			PetId = entry.petId,
			Stats = {
				"Power: " .. tostring(entry.finalPower or entry.effectivePower or 0),
				"Color Gain: x" .. string.format("%.2f", tonumber(entry.colorMult) or 1),
				"Coin Bonus: x" .. string.format("%.2f", tonumber(entry.coinMult) or 1),
			},
		})
	end
	print("[InventoryBridge] Parsed color count", #rows)

	table.sort(rows, function(a, b)
		if a.Equipped ~= b.Equipped then
			return a.Equipped
		end
		return tostring(a.Name) < tostring(b.Name)
	end)
	return rows
end

local function buildBrushRows(player)
	local toolsFolder = player:FindFirstChild("PaintTools")
	local ownedValue = toolsFolder and toolsFolder:FindFirstChild("Owned")
	local equippedValue = toolsFolder and toolsFolder:FindFirstChild("Equipped")
	local owned = setFromCsv(ownedValue and ownedValue.Value or "StarterBrush")
	owned.StarterBrush = true
	local equippedId = equippedValue and equippedValue.Value or "StarterBrush"

	local rows = {}
	for _, toolId in ipairs(ToolData.Order or {}) do
		local tool = ToolData.Tools[toolId]
		if tool and owned[toolId] then
			table.insert(rows, {
				Id = tool.Id,
				Kind = "Brush",
				Name = tool.DisplayName or tool.Id,
				Level = 1,
				Rarity = tool.Rarity or "Brush",
				Equipped = equippedId == tool.Id,
				Power = tonumber(tool.PowerMultiplier or tool.CollectPowerMultiplier) or 1,
				Description = tool.Description or tool.PassiveDescription or "Paint tool.",
				IconText = tool.ShortName or "BR",
				IconImage = tool.IconImage or tool.iconImage,
				ModelName = tool.ModelName or tool.Id,
				Stats = {
					"Power: x" .. string.format("%.2f", tonumber(tool.PowerMultiplier or tool.CollectPowerMultiplier) or 1),
					"Range: " .. tostring(tool.Range or "-"),
					"Width: " .. tostring(tool.Width or "-"),
				},
			})
		end
	end
	return rows
end

local function getItemsFromService(player)
	local bridge = ServerStorage:FindFirstChild("InventoryItemsBridge")
	if not bridge or not bridge:IsA("BindableFunction") then
		return {}
	end
	local ok, success, items = pcall(function()
		return bridge:Invoke(player, "GetInventory")
	end)
	if ok and success == true and type(items) == "table" then
		return items
	end
	return {}
end

local function isPotion(item)
	return item and (item.boostType ~= nil or item.category == "Boosts")
end

local function makeStats(...)
	local stats = {}
	for index = 1, select("#", ...) do
		local value = select(index, ...)
		if value ~= nil and value ~= "" then
			table.insert(stats, tostring(value))
		end
	end
	return stats
end

local function buildItemRows(player, wantPotions)
	local rows = {}
	for itemId, quantity in pairs(getItemsFromService(player)) do
		local item = ItemsData.Items[itemId]
		quantity = math.floor(tonumber(quantity) or 0)
		if item and quantity > 0 and isPotion(item) == wantPotions then
			table.insert(rows, {
				Id = itemId,
				Kind = wantPotions and "Potion" or "Item",
				Name = item.displayName or itemId,
				Rarity = item.rarity or "Common",
				Amount = quantity,
				Duration = item.boostDuration and (tostring(math.floor(item.boostDuration / 60)) .. " min") or nil,
				Description = item.description or "Inventory item.",
				Usable = item.usable == true,
				IconText = item.icon or string.upper(string.sub(item.displayName or itemId, 1, 2)),
				IconImage = item.IconImage or item.iconImage,
				Stats = makeStats(
					item.boostType and ("Boost: " .. tostring(item.boostType)) or nil,
					item.boostDuration and ("Duration: " .. tostring(item.boostDuration) .. "s") or nil
				),
			})
		end
	end
	table.sort(rows, function(a, b)
		return tostring(a.Name) < tostring(b.Name)
	end)
	return rows
end

local function buildInventory(player)
	local colors = buildColorRows(player)
	local colorAmount = 0
	for _, color in ipairs(colors) do
		colorAmount += math.max(1, tonumber(color.Amount) or 1)
	end
	return {
		Colors = colors,
		Brushes = buildBrushRows(player),
		Potions = buildItemRows(player, true),
		Items = buildItemRows(player, false),
		Count = colorAmount,
		Capacity = COLOR_CAPACITY,
	}
end

local function markDirty(player, reason)
	if dataDirtyEvent and dataDirtyEvent:IsA("BindableEvent") then
		dataDirtyEvent:Fire(player, reason)
	end
end

local function equipBrush(player, brushId)
	local toolsFolder = player:FindFirstChild("PaintTools")
	local ownedValue = toolsFolder and toolsFolder:FindFirstChild("Owned")
	local equippedValue = toolsFolder and toolsFolder:FindFirstChild("Equipped")
	local tool = ToolData.Tools[brushId or ""]
	if not tool or not ownedValue or not equippedValue then
		return false, "Brush data is not ready."
	end
	local owned = setFromCsv(ownedValue.Value)
	owned.StarterBrush = true
	if not owned[tool.Id] then
		return false, "You do not own this brush."
	end
	equippedValue.Value = tool.Id
	markDirty(player, "paint-tool-equipped")
	equipPaintToolEvent:FireClient(player, true, tool.Id, "Equipped " .. (tool.DisplayName or tool.Id))
	return true, "Brush equipped."
end

local function runPetAction(player, action, id, value)
	local bridge = ServerStorage:FindFirstChild("InventoryPetAction")
	if not bridge or not bridge:IsA("BindableFunction") then
		return false, "Color inventory action bridge is not ready."
	end
	local ok, success, message = pcall(function()
		return bridge:Invoke(player, action, id, value)
	end)
	if not ok then
		warn("EditableInventoryBridge pet action failed: " .. tostring(success))
		return false, "Color action failed."
	end
	return success == true, tostring(message or (success and "Done." or "Action failed."))
end

local function useItem(player, itemId)
	local bridge = ServerStorage:FindFirstChild("InventoryItemsBridge")
	if not bridge or not bridge:IsA("BindableFunction") then
		return false, "Item inventory is not ready."
	end
	local ok, success, message = pcall(function()
		return bridge:Invoke(player, "UseItem", itemId, 1)
	end)
	if not ok then
		warn("EditableInventoryBridge item action failed: " .. tostring(success))
		return false, "Item action failed."
	end
	return success == true, tostring(message or (success and "Item used." or "Item action failed."))
end

inventoryRequest.OnServerInvoke = function(player, action)
	if action ~= nil and action ~= "GetInventory" then
		return nil
	end
	return buildInventory(player)
end

inventoryAction.OnServerEvent:Connect(function(player, action, payload)
	payload = type(payload) == "table" and payload or {}
	local id = tostring(payload.Id or payload.id or "")
	local kind = tostring(payload.Kind or payload.kind or "")
	local ok = false
	local message = "Unknown inventory action."

	if action == "Equip" and kind == "Color" then
		ok, message = runPetAction(player, "EquipColor", id)
	elseif action == "Unequip" and kind == "Color" then
		ok, message = runPetAction(player, "UnequipColor", id)
	elseif action == "Lock" and kind == "Color" then
		ok, message = runPetAction(player, "LockColor", id, payload.Locked == true)
	elseif action == "Delete" and kind == "Color" then
		ok, message = runPetAction(player, "DeleteColor", id)
	elseif action == "Equip" and kind == "Brush" then
		ok, message = equipBrush(player, id)
	elseif action == "Use" and (kind == "Potion" or kind == "Item") then
		ok, message = useItem(player, id)
	end

	inventoryAction:FireClient(player, {
		Success = ok,
		Message = message,
		Action = action,
		Kind = kind,
		Id = id,
		Inventory = buildInventory(player),
	})
end)
]]></string>
        </Properties>
      </Item>
      <Item class="Script" referent="81">
        <Properties>
          <string name="Name">EggStationSetup</string>
          <token name="RunContext">0</token>
          <string name="Source"><![CDATA[-- Normalizes baked egg models so they are solid, hatchable, and labeled cleanly.
-- This does not create map layout; it only tags/fixes egg objects the player placed.
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Workspace = game:GetService("Workspace")

local ColorData = require(ReplicatedStorage:WaitForChild("ColorData"))
local PetData = require(ReplicatedStorage:WaitForChild("PetData"))

local DARK = Color3.fromRGB(26, 26, 30)
local GOLD = Color3.fromRGB(255, 228, 86)
local configured = {}

local function isDebugAppearanceObject(obj)
	return obj:FindFirstAncestor("PetAppearanceStudio") ~= nil
end

local function compactName(name)
	return string.lower(tostring(name or "")):gsub("%s+", "")
end

local function getEggIdForColor(colorType)
	local world = ColorData.getWorldByColor(colorType)
	if world and world.EggIds and world.EggIds[1] then
		return world.EggIds[1]
	end
	return tostring(colorType) .. "Egg"
end

local function inferEggInfo(obj)
	local current = obj
	while current and current ~= Workspace do
		local eggId = current:GetAttribute("EggId")
		if eggId and PetData.Eggs[eggId] then
			local egg = PetData.Eggs[eggId]
			return egg.areaColor, eggId
		end

		local lowered = compactName(current.Name)
		for _, world in ipairs(ColorData.Worlds or {}) do
			local colorType = world.primaryColor
			local expectedEggId = getEggIdForColor(colorType)
			if lowered == compactName(expectedEggId)
				or lowered == compactName(colorType .. "Egg")
				or (string.find(lowered, string.lower(colorType), 1, true) and string.find(lowered, "egg", 1, true))
			then
				return colorType, expectedEggId
			end
		end
		current = current.Parent
	end
	return nil, nil
end

local function getParts(root)
	local parts = {}
	if root:IsA("BasePart") then
		table.insert(parts, root)
	end
	for _, descendant in ipairs(root:GetDescendants()) do
		if descendant:IsA("BasePart") then
			table.insert(parts, descendant)
		end
	end
	return parts
end

local function getBestPart(root)
	if root:IsA("BasePart") then
		return root
	end
	if root:IsA("Model") then
		return root.PrimaryPart or root:FindFirstChildWhichIsA("BasePart", true)
	end
	return root:FindFirstChildWhichIsA("BasePart", true)
end

local function getDisplayName(eggId)
	local egg = PetData.Eggs[eggId]
	if egg and egg.displayName and egg.displayName ~= "" then
		return egg.displayName
	end
	local spaced = tostring(eggId or "Egg"):gsub("(%l)(%u)", "%1 %2")
	return spaced
end

local configureEgg

local function findEggModelAncestor(part)
	local current = part and part.Parent
	while current and current ~= Workspace do
		if current:IsA("Model") then
			local colorType, eggId = inferEggInfo(current)
			if colorType and eggId then
				return current
			end
		end
		current = current.Parent
	end
	return nil
end

local function removeBadEggLabels(holder)
	for _, child in ipairs(holder:GetChildren()) do
		if child:IsA("BillboardGui") and (child.Name == "WorldEggLabel" or child.Name == "PreviewLabel" or child.Name == "EggStationLabel") then
			child:Destroy()
		end
	end
end

local function ensureLabel(holder, colorType, eggId)
	removeBadEggLabels(holder)

	local billboard = Instance.new("BillboardGui")
	billboard.Name = "EggStationLabel"
	billboard:SetAttribute("ProximityWorldLabel", true)
	billboard:SetAttribute("ShowDistance", 54)
	billboard:SetAttribute("HideDistance", 64)
	billboard.Size = UDim2.fromOffset(220, 62)
	billboard.StudsOffset = Vector3.new(0, 9.5, 0)
	billboard.AlwaysOnTop = true
	billboard.MaxDistance = 120
	billboard.Enabled = false
	billboard.Parent = holder

	local title = Instance.new("TextLabel")
	title.BackgroundTransparency = 1
	title.Size = UDim2.new(1, 0, 0, 38)
	title.Font = Enum.Font.LuckiestGuy
	title.TextSize = 23
	title.TextColor3 = Color3.new(1, 1, 1)
	title.TextStrokeTransparency = 0
	title.TextStrokeColor3 = DARK
	title.Text = string.upper(getDisplayName(eggId))
	title.Parent = billboard

	local sub = Instance.new("TextLabel")
	sub.BackgroundTransparency = 1
	sub.Position = UDim2.fromOffset(0, 35)
	sub.Size = UDim2.new(1, 0, 0, 22)
	sub.Font = Enum.Font.GothamBold
	sub.TextSize = 14
	sub.TextColor3 = GOLD
	sub.TextStrokeTransparency = 0.08
	sub.TextStrokeColor3 = DARK
	sub.Text = "HATCH COLORS"
	sub.Parent = billboard

	return billboard
end

local function ensurePrompt(holder)
	local prompt = holder:FindFirstChild("EggShopPrompt")
	if not prompt then
		prompt = Instance.new("ProximityPrompt")
		prompt.Name = "EggShopPrompt"
		prompt.Parent = holder
	end
	prompt.ActionText = "Hatch"
	prompt.ObjectText = "Egg"
	prompt.HoldDuration = 0
	prompt.MaxActivationDistance = math.max(prompt.MaxActivationDistance, 18)
	prompt.RequiresLineOfSight = false
	prompt.KeyboardKeyCode = Enum.KeyCode.E
	prompt.GamepadKeyCode = Enum.KeyCode.ButtonX
	prompt:SetAttribute("EggShopPrompt", true)
	return prompt
end

function configureEgg(root)
	if not root or not root.Parent or isDebugAppearanceObject(root) or configured[root] then
		return
	end

	if root:IsA("BasePart") then
		local eggModel = findEggModelAncestor(root)
		if eggModel then
			configureEgg(eggModel)
			return
		end
	end

	local colorType, eggId = inferEggInfo(root)
	if not colorType or not eggId or not PetData.Eggs[eggId] then
		return
	end

	local holder = getBestPart(root)
	if not holder then
		return
	end

	configured[root] = true
	if root:IsA("Model") then
		root:SetAttribute("EggId", eggId)
		root:SetAttribute("ColorType", colorType)
		root:SetAttribute("AreaColor", colorType)
		if not root.PrimaryPart then
			root.PrimaryPart = holder
		end
	end

	for _, part in ipairs(getParts(root)) do
		part:SetAttribute("EggId", eggId)
		part:SetAttribute("ColorType", colorType)
		part:SetAttribute("AreaColor", colorType)
		part:SetAttribute("EggStation", true)
		part:SetAttribute("ColorZone", false)
		part:SetAttribute("ColorBlobSpawn", false)
		part:SetAttribute("PlayableSectorFloor", false)
		part.CanCollide = true
		part.CanQuery = true
		part.CanTouch = false
	end

	holder:SetAttribute("EggId", eggId)
	holder:SetAttribute("EggStation", true)
	holder.CanCollide = true
	holder.CanQuery = true
	ensurePrompt(holder)
	ensureLabel(holder, colorType, eggId)
end

local function configureExisting()
	for _, obj in ipairs(Workspace:GetDescendants()) do
		if obj:IsA("Model") or obj:IsA("BasePart") then
			configureEgg(obj)
		end
	end
end

configureExisting()
task.delay(2, configureExisting)

Workspace.DescendantAdded:Connect(function(obj)
	if obj:IsA("Model") or obj:IsA("BasePart") then
		task.defer(configureEgg, obj)
	end
end)
]]></string>
        </Properties>
      </Item>
      <Item class="ModuleScript" referent="82">
        <Properties>
          <string name="Name">GamepassBenefits</string>
          <string name="Source"><![CDATA[local MarketplaceService = game:GetService("MarketplaceService")
local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local RunService = game:GetService("RunService")

local RobuxShopConfig = require(ReplicatedStorage:WaitForChild("RobuxShopConfig"))

local GamepassBenefits = {}
local ownershipCache = {}
local Events = ReplicatedStorage:WaitForChild("Events")
local playerDataDirtyEvent = Events:FindFirstChild("PlayerDataDirty")
if not playerDataDirtyEvent then
	playerDataDirtyEvent = Instance.new("BindableEvent")
	playerDataDirtyEvent.Name = "PlayerDataDirty"
	playerDataDirtyEvent.Parent = Events
end

local function getCache(player)
	ownershipCache[player] = ownershipCache[player] or {}
	return ownershipCache[player]
end

local function getGrantFolder(player)
	return player and player:FindFirstChild("GamepassGrants")
end

local function hasGrantedPass(player, passId)
	local folder = getGrantFolder(player)
	local value = folder and folder:FindFirstChild(tostring(passId))
	return value and value:IsA("BoolValue") and value.Value == true
end

local function setPassAttributes(player, pass, owns)
	if not player or not pass then
		return
	end

	player:SetAttribute("Pass_" .. pass.id, owns == true)
	if pass.id == "VIP" then
		player:SetAttribute("IsVIP", owns == true)
	end
	if (pass.id == "SupportDev" or pass.earlySupporterTag == true) and owns == true then
		player:SetAttribute("EarlySupporter", true)
	end
end

local function hasRealId(pass)
	return pass and tonumber(pass.gamepassId) and tonumber(pass.gamepassId) > 0
end

function GamepassBenefits.owns(player, passId)
	if not player then
		return false
	end

	local pass = RobuxShopConfig.getGamepass(passId)
	if hasGrantedPass(player, passId) then
		local cache = getCache(player)
		cache[passId] = true
		setPassAttributes(player, pass, true)
		return true
	end

	if not hasRealId(pass) then
		return player:GetAttribute("Pass_" .. tostring(passId)) == true
	end

	local cache = getCache(player)
	if cache[passId] ~= nil then
		return cache[passId]
	end

	local ok, owns = pcall(function()
		return MarketplaceService:UserOwnsGamePassAsync(player.UserId, pass.gamepassId)
	end)

	cache[passId] = ok and owns == true
	setPassAttributes(player, pass, cache[passId])
	return cache[passId]
end

function GamepassBenefits.invalidate(player, passId)
	if not player then
		return
	end
	local cache = getCache(player)
	cache[passId] = nil
end

function GamepassBenefits.refreshPlayer(player)
	if not player then
		return
	end

	for _, pass in ipairs(RobuxShopConfig.Gamepasses or {}) do
		local owns = GamepassBenefits.owns(player, pass.id)
		setPassAttributes(player, pass, owns)
	end
	player:SetAttribute("IsVIP", GamepassBenefits.owns(player, "VIP"))
	if GamepassBenefits.owns(player, "SupportDev") then
		player:SetAttribute("EarlySupporter", true)
	end
end

function GamepassBenefits.grant(player, passId)
	if not player then
		return false
	end

	local pass = RobuxShopConfig.getGamepass(passId)
	if not pass then
		warn("GamepassBenefits: cannot grant unknown pass " .. tostring(passId))
		return false
	end

	local folder = getGrantFolder(player)
	if not folder then
		folder = Instance.new("Folder")
		folder.Name = "GamepassGrants"
		folder.Parent = player
	end

	local value = folder:FindFirstChild(pass.id)
	if not value then
		value = Instance.new("BoolValue")
		value.Name = pass.id
		value.Parent = folder
	end

	value.Value = true
	local cache = getCache(player)
	cache[pass.id] = true
	setPassAttributes(player, pass, true)
	playerDataDirtyEvent:Fire(player, "gamepass-grants")
	return true
end

function GamepassBenefits.grantAll(player)
	if not player then
		return false, {}
	end

	local granted = {}
	for _, pass in ipairs(RobuxShopConfig.Gamepasses or {}) do
		if GamepassBenefits.grant(player, pass.id) then
			table.insert(granted, pass.id)
		end
	end

	GamepassBenefits.refreshPlayer(player)
	return #granted > 0, granted
end

function GamepassBenefits.getCoinMultiplier(player)
	local multiplier = 1
	if GamepassBenefits.owns(player, "DoubleCoins") then
		multiplier *= 2
	end
	return multiplier
end

function GamepassBenefits.getLuckMultiplier(player)
	local multiplier = 1
	if GamepassBenefits.owns(player, "LuckyHatch") then
		multiplier *= 1.35
	end
	if GamepassBenefits.owns(player, "VIP") then
		multiplier *= 1.1
	end
	return multiplier
end

function GamepassBenefits.getExtraEquippedColorSlots(player)
	local extra = 0
	if GamepassBenefits.owns(player, "Plus3Colors") then
		extra += 3
	end
	if GamepassBenefits.owns(player, "VIP") then
		extra += 1
	end
	return extra
end

function GamepassBenefits.hasAutoSell(player)
	return false
end

Players.PlayerAdded:Connect(function(player)
	for _, pass in ipairs(RobuxShopConfig.Gamepasses or {}) do
		player:SetAttribute("Pass_" .. pass.id, false)
	end
	player:SetAttribute("IsVIP", false)
	player:SetAttribute("EarlySupporter", false)
	task.defer(function()
		GamepassBenefits.refreshPlayer(player)
	end)
end)

Players.PlayerRemoving:Connect(function(player)
	ownershipCache[player] = nil
end)

MarketplaceService.PromptGamePassPurchaseFinished:Connect(function(player, gamepassId, wasPurchased)
	if not wasPurchased then
		return
	end

	local pass = RobuxShopConfig.getGamepassByRobloxId(gamepassId)
	if not pass then
		return
	end

	local cache = getCache(player)
	cache[pass.id] = true
	setPassAttributes(player, pass, true)

	print("GamepassBenefits: " .. player.Name .. " unlocked " .. pass.id)
end)

if RunService:IsStudio() then
	ReplicatedStorage:SetAttribute("GamepassBenefitsReady", true)
end

return GamepassBenefits
]]></string>
        </Properties>
      </Item>
      <Item class="Script" referent="83">
        <Properties>
          <string name="Name">GemDepositHandler</string>
          <token name="RunContext">0</token>
          <string name="Source"><![CDATA[local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local TweenService = game:GetService("TweenService")
local Debris = game:GetService("Debris")
local ServerStorage = game:GetService("ServerStorage")

local ColorData = require(ReplicatedStorage:WaitForChild("ColorData"))
local ToolData = require(ReplicatedStorage:WaitForChild("ToolData"))
local GameBalance = require(ReplicatedStorage:WaitForChild("GameBalance"))
local BuffService = require(script.Parent:WaitForChild("BuffService"))
local ColorEffectHandler = require(script.Parent:WaitForChild("ColorEffectHandler"))

local FEATURE_ENABLED = not (GameBalance.FeatureFlags and GameBalance.FeatureFlags.GemDepositsEnabled == false)
local DEPOSIT_CONFIG = GameBalance.WildGameplay and GameBalance.WildGameplay.GemDeposits or {}
local MAX_PER_ZONE = DEPOSIT_CONFIG.MaxPerZone or 2
local PER_COLOR_MAX = DEPOSIT_CONFIG.PerColorMax or {}
local INITIAL_SPAWN_DELAY = DEPOSIT_CONFIG.InitialSpawnDelay or 8
local SPAWN_CHECK_INTERVAL = DEPOSIT_CONFIG.SpawnCheckInterval or 5
local RESPAWN_MIN = DEPOSIT_CONFIG.RespawnMin or 30
local RESPAWN_MAX = DEPOSIT_CONFIG.RespawnMax or 60
local BRUSH_MAX_RANGE = 38
local PASSIVE_RANGE = 25
local PASSIVE_INTERVAL = 0.75
local PASSIVE_DAMAGE_PER_COLOR = 1
local PASSIVE_DAMAGE_CAP = 6
local PET_PRIORITY_SECONDS = 6

local HEALTH_BY_COLOR = {
	Red = 25,
	Orange = 40,
	Blue = 60,
	Yellow = 85,
	Green = 120,
	Purple = 170,
	Neon = 240,
	Rainbow = 325,
}

local events = ReplicatedStorage:WaitForChild("Events")
local paintSweepEvent = events:WaitForChild("PaintToolSweep")
local noticeEvent = events:FindFirstChild("WildBuffNotice")
local tutorialGemBrokenEvent = events:FindFirstChild("TutorialGemBroken")
if not tutorialGemBrokenEvent then
	tutorialGemBrokenEvent = Instance.new("BindableEvent")
	tutorialGemBrokenEvent.Name = "TutorialGemBroken"
	tutorialGemBrokenEvent.Parent = events
end

local rootFolder = workspace:FindFirstChild("DynamicGameplay")
if not rootFolder then
	rootFolder = Instance.new("Folder")
	rootFolder.Name = "DynamicGameplay"
	rootFolder.Parent = workspace
end

local depositsFolder = rootFolder:FindFirstChild("GemDeposits")
if not depositsFolder then
	depositsFolder = Instance.new("Folder")
	depositsFolder.Name = "GemDeposits"
	depositsFolder.Parent = rootFolder
end

local activeByColor = {}
local nextSpawnAt = {}
local lastPassiveAt = 0
local lastBrushDamageAt = {}
local zonePartCache = {}
local syncHealthAttributes

local function reportDailyQuestProgress(player, questId, amount)
	local event = ServerStorage:FindFirstChild("DailyQuestProgress")
	if event and event:IsA("BindableEvent") then
		event:Fire(player, questId, amount)
	end
end

local function inferColorFromMapPart(part)
	local attrColor = part:GetAttribute("ColorType") or part:GetAttribute("WorldColor") or part:GetAttribute("AreaColor")
	local partName = string.lower(part.Name or "")
	local parentName = part.Parent and string.lower(part.Parent.Name or "") or ""
	local looksLikeFloor = string.find(partName, "floor")
		or string.find(partName, "ground")
		or string.find(partName, "zone")
		or string.find(partName, "area")
		or string.find(partName, "sector")
		or string.find(parentName, "floor")
		or string.find(parentName, "zone")
		or string.find(parentName, "area")
		or string.find(parentName, "sector")
	local largeFlatSurface = (part.Size.X * part.Size.Z) >= 1600
		and part.Size.X >= 35
		and part.Size.Z >= 35
		and part.Size.Y <= math.max(8, math.min(part.Size.X, part.Size.Z) * 0.3)
	local blockedName = string.find(partName, "pipe", 1, true)
		or string.find(parentName, "pipe", 1, true)
		or partName == "core"
		or partName == "glowshell"
		or partName == "highlight"
		or string.find(partName, "floatcore", 1, true)
	if ColorData.getWorldByColor(attrColor) and not blockedName and (part:GetAttribute("PlayableSectorFloor") == true or looksLikeFloor or largeFlatSurface) then
		return attrColor
	end

	for _, world in ipairs(ColorData.Worlds or {}) do
		local color = world.primaryColor
		local loweredColor = string.lower(color)
		if looksLikeFloor and (string.find(partName, loweredColor) or string.find(parentName, loweredColor)) then
			return color
		end
	end

	return nil
end

local function configureColorZonePart(part)
	local partName = string.lower(part.Name or "")
	local parentName = part.Parent and string.lower(part.Parent.Name or "") or ""
	if part:GetAttribute("BreakableType")
		or part:GetAttribute("PaintPuddleVersion")
		or part:GetAttribute("GemDeposit")
		or part:GetAttribute("WildColor")
		or part:FindFirstAncestor("DynamicGameplay") ~= nil
		or part:FindFirstAncestor("PetAppearanceStudio") ~= nil
		or part:GetAttribute("EggStation") == true
		or part:GetAttribute("TutorialEgg") == true
		or part:GetAttribute("EggId") ~= nil
		or part:GetAttribute("MutationStation") == true
		or part:GetAttribute("MutationUnlockStation") == true
		or part:GetAttribute("FeatureUnlock") == "Mutations"
		or string.find(partName, "pipe", 1, true)
		or string.find(parentName, "pipe", 1, true)
		or partName == "core"
		or partName == "glowshell"
		or partName == "highlight"
		or string.find(partName, "floatcore", 1, true)
	then
		if part:GetAttribute("ColorZone") == true then
			part:SetAttribute("ColorZone", false)
		end
		return nil
	end

	local playableSectorFloor = part:GetAttribute("PlayableSectorFloor") == true
	if not playableSectorFloor and (part:GetAttribute("DistantSectorColumn")
		or part:GetAttribute("SectorAnchor")
		or part:GetAttribute("DecorativeOnly")
		or part:FindFirstAncestor("DistantSectors") ~= nil)
	then
		if part:GetAttribute("ColorZone") == true then
			part:SetAttribute("ColorZone", false)
		end
		return nil
	end

	local colorType = inferColorFromMapPart(part)
	if not colorType then
		return nil
	end

	if part:GetAttribute("ColorZone") ~= true then
		part:SetAttribute("ColorZone", true)
	end
	if part:GetAttribute("ColorType") ~= colorType then
		part:SetAttribute("ColorType", colorType)
	end
	return colorType
end

local function isUnlocked(player, colorType)
	local progression = GameBalance.Progression or {}
	local maxPlayableIndex = tonumber(progression.MaxPlayableSectorIndex) or math.huge
	local index = ColorData.getWorldIndex(colorType) or math.huge
	if index > maxPlayableIndex then
		return false
	end

	local storage = player:FindFirstChild("ColorStorage")
	local unlocked = storage and storage:FindFirstChild("UnlockedColors")
	return ColorData.isColorUnlocked(unlocked and unlocked.Value or "Red", colorType)
end

local function isPointInside(part, worldPosition, margin)
	local localPoint = part.CFrame:PointToObjectSpace(worldPosition)
	local half = part.Size * 0.5 + Vector3.new(margin or 0, margin or 0, margin or 0)
	return math.abs(localPoint.X) <= half.X
		and math.abs(localPoint.Y) <= half.Y
		and math.abs(localPoint.Z) <= half.Z
end

local function isPlayerInsideColorZone(player, colorType)
	local root = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
	if not root then
		return false
	end

	for _, obj in ipairs(workspace:GetDescendants()) do
		if obj:IsA("BasePart") then
			local zoneColor = configureColorZonePart(obj)
			if zoneColor == colorType and obj:GetAttribute("ColorZone") == true and isPointInside(obj, root.Position, 12) then
				return true
			end
		end
	end
	return false
end

local function isWorldActive(colorType)
	local progression = GameBalance.Progression or {}
	if colorType == (progression.StartSectorColor or "Red") and #Players:GetPlayers() > 0 then
		return true
	end

	for _, player in ipairs(Players:GetPlayers()) do
		if isUnlocked(player, colorType) or isPlayerInsideColorZone(player, colorType) then
			return true
		end
	end
	return false
end

local function getWorldColor(world)
	local info = ColorData.Colors[world.primaryColor]
	return info and info.color or Color3.fromRGB(82, 255, 110)
end

local function getActiveList(colorType)
	local list = activeByColor[colorType]
	if not list then
		list = {}
		activeByColor[colorType] = list
	end
	for index = #list, 1, -1 do
		local model = list[index]
		if not model or not model.Parent or model:GetAttribute("Broken") == true then
			table.remove(list, index)
		end
	end
	return list
end

local function getMaxForColor(colorType)
	return math.max(0, tonumber(PER_COLOR_MAX[colorType]) or MAX_PER_ZONE)
end

local function findZonePart(colorType)
	local cached = zonePartCache[colorType]
	if cached and cached.Parent then
		return cached
	end

	local fallback = nil
	local best = nil
	local bestArea = -math.huge
	for _, obj in ipairs(workspace:GetDescendants()) do
		if obj:IsA("BasePart") then
			local attrColor = configureColorZonePart(obj)
			if attrColor == colorType then
				local area = obj.Size.X * obj.Size.Z
				if obj:GetAttribute("ColorZone") and area > bestArea then
					best = obj
					bestArea = area
				end
				fallback = fallback or obj
			end
		end
	end
	if best then
		zonePartCache[colorType] = best
		return best
	end
	zonePartCache[colorType] = fallback
	return fallback
end

local function isBadSpawnNeighbor(part, zone)
	if not part or part:IsDescendantOf(depositsFolder) then
		return false
	end
	if part == zone or part:GetAttribute("PlayableSectorFloor") == true or part:GetAttribute("ColorZone") == true then
		return false
	end
	if part:GetAttribute("SellZone")
		or part:GetAttribute("SellLocation")
		or part:GetAttribute("BrushShop")
		or part:GetAttribute("CombinedShop")
		or part:GetAttribute("ShopStation")
		or part:GetAttribute("UpgradeStation")
		or part:GetAttribute("EggStation")
		or part:GetAttribute("AreaGate")
		or part:GetAttribute("GateInteraction")
		or part:GetAttribute("DistantSectorColumn")
		or part:GetAttribute("SectorAnchor")
		or part:GetAttribute("DecorativeOnly")
	then
		return true
	end
	local name = string.lower(part.Name)
	return string.find(name, "wall")
		or string.find(name, "portal")
		or string.find(name, "gate")
		or string.find(name, "sell")
		or string.find(name, "shop")
		or string.find(name, "upgrade")
		or string.find(name, "egg")
		or string.find(name, "sector")
		or string.find(name, "column")
end

local function isSafePosition(position, zone)
	local params = OverlapParams.new()
	params.FilterType = Enum.RaycastFilterType.Exclude
	params.FilterDescendantsInstances = { depositsFolder }
	for _, part in ipairs(workspace:GetPartBoundsInRadius(position, 8, params)) do
		if isBadSpawnNeighbor(part, zone) then
			return false
		end
	end
	return true
end

local function getSpawnPosition(world)
	local zone = findZonePart(world.primaryColor)
	if not zone then
		return nil
	end

	local rayParams = RaycastParams.new()
	rayParams.FilterType = Enum.RaycastFilterType.Exclude
	rayParams.FilterDescendantsInstances = { depositsFolder }

	for _ = 1, 42 do
		local x = (math.random() - 0.5) * math.max(8, zone.Size.X * 0.78)
		local z = (math.random() - 0.5) * math.max(8, zone.Size.Z * 0.78)
		local above = zone.CFrame:PointToWorldSpace(Vector3.new(x, zone.Size.Y * 0.5 + 45, z))
		local result = workspace:Raycast(above, Vector3.new(0, -120, 0), rayParams)
		local position = result and result.Position + Vector3.new(0, 2.2, 0)
			or zone.CFrame:PointToWorldSpace(Vector3.new(x, zone.Size.Y * 0.5 + 2.2, z))
		if isSafePosition(position, zone) then
			return position
		end
	end
	return nil
end

local function makeDeposit(world, position)
	local colorType = world.primaryColor
	local health = HEALTH_BY_COLOR[colorType] or 60
	local model = Instance.new("Model")
	model.Name = colorType .. "GemDeposit"
	model:SetAttribute("GemDeposit", true)
	model:SetAttribute("ColorType", colorType)
	model:SetAttribute("WorldName", world.name)
	model:SetAttribute("Health", health)
	model:SetAttribute("MaxHealth", health)
	model:SetAttribute("Broken", false)

	local core = Instance.new("Part")
	core.Name = "Core"
	core.Size = Vector3.new(2.2, 2.2, 2.2)
	core.CFrame = CFrame.new(position) * CFrame.Angles(0, math.rad(45), math.rad(45))
	core.Shape = Enum.PartType.Block
	core.Color = Color3.fromRGB(50, 255, 90)
	core.Material = Enum.Material.Neon
	core.Anchored = true
	core.CanCollide = false
	core.CanTouch = false
	core.CanQuery = true
	core.CastShadow = false
	core:SetAttribute("GemDeposit", true)
	core:SetAttribute("ColorType", colorType)
	core:SetAttribute("Health", health)
	core:SetAttribute("MaxHealth", health)
	core.Parent = model
	model.PrimaryPart = core

	local light = Instance.new("PointLight")
	light.Name = "GemGlow"
	light.Color = Color3.fromRGB(80, 255, 120)
	light.Range = 12
	light.Brightness = 1.8
	light.Shadows = false
	light.Parent = core

	local sparkle = Instance.new("ParticleEmitter")
	sparkle.Name = "GemSparkles"
	sparkle.Texture = "rbxasset://textures/particles/sparkles_main.dds"
	sparkle.Color = ColorSequence.new(Color3.fromRGB(120, 255, 150), Color3.fromRGB(255, 255, 255))
	sparkle.LightEmission = 0.75
	sparkle.Rate = 8
	sparkle.Lifetime = NumberRange.new(0.8, 1.3)
	sparkle.Speed = NumberRange.new(0.4, 1.1)
	sparkle.SpreadAngle = Vector2.new(180, 180)
	sparkle.Parent = core

	local healthGui = Instance.new("BillboardGui")
	healthGui.Name = "GemDepositHealthBar"
	healthGui.AlwaysOnTop = true
	healthGui.Size = UDim2.new(0, 82, 0, 14)
	healthGui.StudsOffset = Vector3.new(0, 3, 0)
	healthGui.MaxDistance = 100
	healthGui.Parent = core

	local barBack = Instance.new("Frame")
	barBack.Name = "BarBack"
	barBack.Size = UDim2.fromScale(1, 1)
	barBack.BackgroundColor3 = Color3.fromRGB(24, 28, 32)
	barBack.BorderSizePixel = 0
	barBack.Parent = healthGui
	local backCorner = Instance.new("UICorner")
	backCorner.CornerRadius = UDim.new(1, 0)
	backCorner.Parent = barBack
	local backStroke = Instance.new("UIStroke")
	backStroke.Color = Color3.fromRGB(255, 255, 255)
	backStroke.Thickness = 1
	backStroke.Transparency = 0.2
	backStroke.Parent = barBack

	local fill = Instance.new("Frame")
	fill.Name = "Fill"
	fill.Size = UDim2.fromScale(1, 1)
	fill.BackgroundColor3 = Color3.fromRGB(82, 255, 110)
	fill.BorderSizePixel = 0
	fill.Parent = barBack
	local fillCorner = Instance.new("UICorner")
	fillCorner.CornerRadius = UDim.new(1, 0)
	fillCorner.Parent = fill
	syncHealthAttributes(model)

	model.Parent = depositsFolder

	local tween = TweenService:Create(core, TweenInfo.new(1.4, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut, -1, true), {
		CFrame = core.CFrame * CFrame.new(0, 0.35, 0),
	})
	tween:Play()

	return model
end

syncHealthAttributes = function(model)
	local core = model.PrimaryPart
	if core then
		local health = tonumber(model:GetAttribute("Health")) or 0
		local maxHealth = math.max(1, tonumber(model:GetAttribute("MaxHealth")) or 1)
		core:SetAttribute("Health", health)
		core:SetAttribute("MaxHealth", maxHealth)

		local healthGui = core:FindFirstChild("GemDepositHealthBar")
		local barBack = healthGui and healthGui:FindFirstChild("BarBack")
		local fill = barBack and barBack:FindFirstChild("Fill")
		if fill and fill:IsA("Frame") then
			local progress = math.clamp(health / maxHealth, 0, 1)
			fill.Size = UDim2.fromScale(progress, 1)
			fill.BackgroundColor3 = Color3.fromRGB(255, 80, 80):Lerp(Color3.fromRGB(82, 255, 110), progress)
		end
	end
end

local function markPetPriorityTarget(player, model)
	if not player or not model or not model.Parent then
		return
	end
	model:SetAttribute("PetPriorityOwnerUserId", player.UserId)
	model:SetAttribute("PetPriorityUntil", os.clock() + PET_PRIORITY_SECONDS)
	model:SetAttribute("PetPrioritySetAt", os.clock())
end

local function makeRewardPopup(position, amount)
	return
end

local function makeBurst(position)
	local part = Instance.new("Part")
	part.Name = "GemBurst"
	part.Size = Vector3.new(0.2, 0.2, 0.2)
	part.Transparency = 1
	part.Anchored = true
	part.CanCollide = false
	part.CanTouch = false
	part.CanQuery = false
	part.CFrame = CFrame.new(position)
	part.Parent = workspace

	local burst = Instance.new("ParticleEmitter")
	burst.Texture = "rbxasset://textures/particles/sparkles_main.dds"
	burst.Color = ColorSequence.new(Color3.fromRGB(80, 255, 120), Color3.fromRGB(255, 255, 255))
	burst.LightEmission = 1
	burst.Lifetime = NumberRange.new(0.45, 0.9)
	burst.Speed = NumberRange.new(8, 15)
	burst.SpreadAngle = Vector2.new(180, 180)
	burst.Rate = 0
	burst.Parent = part
	burst:Emit(32)
	Debris:AddItem(part, 1)
end

local function breakDeposit(player, model)
	if not model or not model.Parent or model:GetAttribute("Broken") == true then
		return
	end
	model:SetAttribute("Broken", true)
	local core = model.PrimaryPart
	local position = core and core.Position or model:GetPivot().Position

	local stats = player and player:FindFirstChild("leaderstats")
	local gems = stats and stats:FindFirstChild("Gems")
	local reward = math.random(5, 10)
	reward = math.floor(reward * BuffService.GetMultiplier(player, "GemRewardMultiplier"))
	if player then
		reward = math.floor(reward * (ColorEffectHandler.CalculateEquippedColorEffects(player).GemRewardMultiplier or 1))
	end
	if gems then
		gems.Value += reward
	end
	reportDailyQuestProgress(player, "GemDepositsBroken", 1)

	if noticeEvent then
		noticeEvent:FireClient(player, {
			type = "gems",
			amount = reward,
		})
	end
	if tutorialGemBrokenEvent and tutorialGemBrokenEvent:IsA("BindableEvent") then
		tutorialGemBrokenEvent:Fire(player, reward, model)
	end
	makeRewardPopup(position, reward)
	makeBurst(position)
	model:Destroy()
end

local function damageDeposit(player, core, amount, shouldMarkPriority)
	if not FEATURE_ENABLED or not player or not core or not core.Parent then
		return false
	end
	local model = core:FindFirstAncestorWhichIsA("Model")
	if not model or model:GetAttribute("GemDeposit") ~= true or model:GetAttribute("Broken") == true then
		return false
	end
	local colorType = model:GetAttribute("ColorType")
	if not colorType or not isUnlocked(player, colorType) then
		return false
	end

	local root = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
	local humanoid = player.Character and player.Character:FindFirstChildOfClass("Humanoid")
	if not root or not humanoid or humanoid.Health <= 0 then
		return false
	end
	if (root.Position - core.Position).Magnitude > BRUSH_MAX_RANGE then
		return false
	end

	amount = math.max(0, tonumber(amount) or 0)
	amount *= BuffService.GetMultiplier(player, "GemDamageMultiplier")
	amount *= ColorEffectHandler.CalculateEquippedColorEffects(player).GemDamageMultiplier or 1
	if amount <= 0 then
		return false
	end

	local health = math.max(0, tonumber(model:GetAttribute("Health")) or 0)
	health = math.max(0, health - amount)
	if shouldMarkPriority then
		markPetPriorityTarget(player, model)
	end
	model:SetAttribute("Health", health)
	syncHealthAttributes(model)
	core.Color = Color3.fromRGB(50, 255, 90):Lerp(Color3.fromRGB(255, 255, 255), math.clamp(1 - health / math.max(1, tonumber(model:GetAttribute("MaxHealth")) or 1), 0, 0.35))
	if health <= 0 then
		breakDeposit(player, model)
	end
	return true
end

local function getToolGemDamage(player, toolId)
	local toolsFolder = player:FindFirstChild("PaintTools")
	local equippedValue = toolsFolder and toolsFolder:FindFirstChild("Equipped")
	local equippedId = equippedValue and equippedValue.Value ~= "" and equippedValue.Value or "StarterBrush"
	local tool = ToolData.get(equippedId)
	if toolId and tool and tool.Id ~= toolId then
		tool = ToolData.get(equippedId)
	end
	local stats = ToolData.GetEffectiveStats and ToolData.GetEffectiveStats(tool and tool.Id or "StarterBrush") or {}
	return math.max(1, tonumber(stats.GemDamage) or tonumber(stats.CollectPowerMultiplier) or 1)
end

paintSweepEvent.OnServerEvent:Connect(function(player, toolId, candidates, mode)
	if type(candidates) ~= "table" then
		return
	end
	local t = os.clock()
	if lastBrushDamageAt[player] and t - lastBrushDamageAt[player] < 0.18 then
		return
	end
	lastBrushDamageAt[player] = t

	local damage = getToolGemDamage(player, toolId)
	if mode == "walk" then
		damage *= 0.5
	end

	local seen = {}
	local hits = 0
	for _, part in ipairs(candidates) do
		if hits >= 4 then
			break
		end
		if typeof(part) == "Instance" and part:IsA("BasePart") and part:GetAttribute("GemDeposit") and not seen[part] then
			seen[part] = true
			if damageDeposit(player, part, damage, true) then
				hits += 1
			end
		end
	end
end)

Players.PlayerRemoving:Connect(function(player)
	lastBrushDamageAt[player] = nil
end)

local function getEquippedColorCount(player)
	local folder = player:FindFirstChild("PetData")
	local equipped = folder and folder:FindFirstChild("Equipped")
	if not equipped or equipped.Value == "" then
		return 0
	end
	local count = 0
	for _, key in ipairs(string.split(equipped.Value, ",")) do
		if key ~= "" then
			count += 1
		end
	end
	return count
end

local function findPriorityDeposit(player)
	local bestModel = nil
	local bestSetAt = -math.huge
	local now = os.clock()
	for _, list in pairs(activeByColor) do
		for _, model in ipairs(list) do
			local core = model and model.PrimaryPart
			if core
				and model.Parent
				and model:GetAttribute("Broken") ~= true
				and model:GetAttribute("PetPriorityOwnerUserId") == player.UserId
				and (tonumber(model:GetAttribute("PetPriorityUntil")) or 0) > now
			then
				local setAt = tonumber(model:GetAttribute("PetPrioritySetAt")) or 0
				if setAt > bestSetAt then
					bestModel = model
					bestSetAt = setAt
				end
			end
		end
	end
	return bestModel
end

local function passiveDamageTick()
	for _, player in ipairs(Players:GetPlayers()) do
		local root = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
		local count = getEquippedColorCount(player)
		if not root or count <= 0 then
			continue
		end

		local effects = ColorEffectHandler.CalculateEquippedColorEffects(player)
		local damage = math.min(PASSIVE_DAMAGE_CAP * (effects.GemDamageMultiplier or 1), count * PASSIVE_DAMAGE_PER_COLOR * (effects.GemDamageMultiplier or 1))
		local priority = findPriorityDeposit(player)
		local priorityCore = priority and priority.PrimaryPart
		if priorityCore and (root.Position - priorityCore.Position).Magnitude <= PASSIVE_RANGE then
			damageDeposit(player, priorityCore, damage, false)
			continue
		end

		for _, list in pairs(activeByColor) do
			for _, model in ipairs(list) do
				local core = model and model.PrimaryPart
				if core
					and model.Parent
					and model:GetAttribute("Broken") ~= true
					and (root.Position - core.Position).Magnitude <= PASSIVE_RANGE
				then
					damageDeposit(player, core, damage, false)
					break
				end
			end
		end
	end
end

local function trySpawnForWorld(world)
	local colorType = world.primaryColor
	if not isWorldActive(colorType) then
		return
	end

	local list = getActiveList(colorType)
	local maxForColor = getMaxForColor(colorType)
	if maxForColor <= 0 or #list >= maxForColor then
		return
	end

	local t = os.clock()
	if not nextSpawnAt[colorType] then
		nextSpawnAt[colorType] = t + INITIAL_SPAWN_DELAY
	end
	if t < nextSpawnAt[colorType] then
		return
	end

	local position = getSpawnPosition(world)
	if not position then
		nextSpawnAt[colorType] = t + 3
		return
	end
	nextSpawnAt[colorType] = t + math.random(RESPAWN_MIN, RESPAWN_MAX)

	local model = makeDeposit(world, position)
	table.insert(list, model)
	print("GemDeposit: spawned " .. tostring(world.primaryColor) .. " deposit on existing zone part.")
end

local function requestImmediateSpawn(colorType)
	local world = ColorData.getWorldByColor(colorType)
	if not world then
		return
	end
	nextSpawnAt[world.primaryColor] = 0
	trySpawnForWorld(world)
end

Players.PlayerAdded:Connect(function(player)
	task.delay(math.max(1, INITIAL_SPAWN_DELAY), function()
		if player.Parent then
			requestImmediateSpawn("Red")
			local activeColor = player:GetAttribute("ActiveWorldColor")
			if activeColor and activeColor ~= "Red" then
				requestImmediateSpawn(activeColor)
			end
		end
	end)

	player:GetAttributeChangedSignal("ActiveWorldColor"):Connect(function()
		local activeColor = player:GetAttribute("ActiveWorldColor")
		if activeColor and activeColor ~= "" then
			requestImmediateSpawn(activeColor)
		end
	end)

	task.spawn(function()
		local storage = player:WaitForChild("ColorStorage", 20)
		local currentWorld = storage and storage:FindFirstChild("CurrentWorld")
		if currentWorld and currentWorld:IsA("StringValue") then
			currentWorld:GetPropertyChangedSignal("Value"):Connect(function()
				if currentWorld.Value ~= "" then
					requestImmediateSpawn(currentWorld.Value)
				end
			end)
		end
	end)
end)

task.delay(math.max(1, INITIAL_SPAWN_DELAY), function()
	if #Players:GetPlayers() > 0 then
		requestImmediateSpawn("Red")
	end
end)

task.spawn(function()
	while true do
		task.wait(SPAWN_CHECK_INTERVAL)
		if FEATURE_ENABLED then
			for _, world in ipairs(ColorData.Worlds or {}) do
				trySpawnForWorld(world)
			end
		end
	end
end)

task.spawn(function()
	while true do
		task.wait(0.2)
		local t = os.clock()
		if t - lastPassiveAt >= PASSIVE_INTERVAL then
			lastPassiveAt = t
			passiveDamageTick()
		end
	end
end)
]]></string>
        </Properties>
