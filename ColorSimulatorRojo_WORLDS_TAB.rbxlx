      <Item class="Script" referent="84">
        <Properties>
          <string name="Name">GroupRewardsHandler</string>
          <token name="RunContext">0</token>
          <string name="Source"><![CDATA[local GroupRewardsService = require(script.Parent:WaitForChild("GroupRewardsService"))

GroupRewardsService.Init()
]]></string>
