      <Item class="Script" referent="97">
        <Properties>
          <string name="Name">RobuxProductReceiptHandler</string>
          <token name="RunContext">0</token>
          <string name="Source"><![CDATA[-- Server-authoritative Developer Product rewards for the editable Robux shop.
local MarketplaceService = game:GetService("MarketplaceService")
local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")

local RobuxShopConfig = require(ReplicatedStorage:WaitForChild("RobuxShopConfig"))

local Events = ReplicatedStorage:FindFirstChild("Events")
local dataDirtyEvent = Events and Events:FindFirstChild("PlayerDataDirty")

local productsById = {}
for _, product in ipairs(RobuxShopConfig.DevProducts or {}) do
	local productId = tonumber(product.productId)
	if productId and productId > 0 then
		productsById[productId] = product
	end
end

local function markDirty(player, reason)
	if dataDirtyEvent and dataDirtyEvent:IsA("BindableEvent") then
		dataDirtyEvent:Fire(player, reason)
	end
end

local function addCurrency(player, currencyName, amount)
	amount = math.floor(tonumber(amount) or 0)
	if amount <= 0 then
		return true
	end

	local leaderstats = player:FindFirstChild("leaderstats")
	local value = leaderstats and leaderstats:FindFirstChild(currencyName)
	if not value or not value:IsA("ValueBase") then
		return false
	end

	value.Value += amount
	markDirty(player, "developer-product-" .. string.lower(currencyName))
	return true
end

MarketplaceService.ProcessReceipt = function(receiptInfo)
	local player = Players:GetPlayerByUserId(receiptInfo.PlayerId)
	if not player then
		return Enum.ProductPurchaseDecision.NotProcessedYet
	end

	local product = productsById[tonumber(receiptInfo.ProductId)]
	if not product then
		warn("RobuxProductReceiptHandler: unknown Developer Product " .. tostring(receiptInfo.ProductId))
		return Enum.ProductPurchaseDecision.NotProcessedYet
	end

	if product.coinReward and not addCurrency(player, "Coins", product.coinReward) then
		return Enum.ProductPurchaseDecision.NotProcessedYet
	end
	if product.gemReward and not addCurrency(player, "Gems", product.gemReward) then
		return Enum.ProductPurchaseDecision.NotProcessedYet
	end
	if product.diamondReward and not addCurrency(player, "Diamonds", product.diamondReward) then
		return Enum.ProductPurchaseDecision.NotProcessedYet
	end

	print("RobuxProductReceiptHandler: granted " .. tostring(product.id) .. " to " .. player.Name)
	return Enum.ProductPurchaseDecision.PurchaseGranted
end
]]></string>
        </Properties>
      </Item>
      <Item class="Script" referent="98">
        <Properties>
          <string name="Name">SectorAnchorSetup</string>
          <token name="RunContext">0</token>
          <string name="Source"><![CDATA[-- Tags user-built distant sector models so gameplay systems treat them as landmarks,
-- not color zones or spawn surfaces.
local Workspace = game:GetService("Workspace")
local ServerScriptService = game:GetService("ServerScriptService")

local MAP_NAME = "ColorSimulatorMap"
local DISTANT_SECTORS_FOLDER = "DistantSectors"

local SECTOR_MODELS = {
	sector1 = {
		displayName = "Orange Sector",
		sectorColor = "Orange",
		sectorIndex = 2,
		locked = false,
		playable = true,
	},
}

local function getOrCreateDistantSectorsFolder()
	local map = Workspace:FindFirstChild(MAP_NAME)
	if not map then
		return nil
	end

	local folder = map:FindFirstChild(DISTANT_SECTORS_FOLDER)
	if not folder then
		folder = Instance.new("Folder")
		folder.Name = DISTANT_SECTORS_FOLDER
		folder.Parent = map
	end
	return folder
end

local function applySectorAttributes(instance, config)
	instance:SetAttribute("DistantSectorColumn", true)
	instance:SetAttribute("SectorAnchor", true)
	instance:SetAttribute("DecorativeOnly", false)
	instance:SetAttribute("SectorName", config.displayName)
	instance:SetAttribute("SectorColor", config.sectorColor)
	instance:SetAttribute("SectorIndex", config.sectorIndex)
	instance:SetAttribute("SectorLocked", config.locked == true)
	instance:SetAttribute("ColorZone", false)
	instance:SetAttribute("ColorBlobSpawn", false)
	instance:SetAttribute("AreaGate", false)
	instance:SetAttribute("GateInteraction", false)
	instance:SetAttribute("ColorType", config.sectorColor)
end

local function getAncestorNamed(instance, name)
	local current = instance
	while current do
		if string.lower(current.Name or "") == string.lower(name) then
			return current
		end
		current = current.Parent
	end
	return nil
end

local function isEggPart(part, config)
	local loweredColor = string.lower(config.sectorColor or "")
	local current = part
	while current do
		local loweredName = string.lower(current.Name or "")
		if string.find(loweredName, "egg") and string.find(loweredName, loweredColor) then
			return true
		end
		current = current.Parent
	end
	return false
end

local function applyPlayableFloorAttributes(part, config)
	part:SetAttribute("DistantSectorColumn", false)
	part:SetAttribute("SectorAnchor", false)
	part:SetAttribute("DecorativeOnly", false)
	part:SetAttribute("PlayableSectorFloor", true)
	part:SetAttribute("SectorName", config.displayName)
	part:SetAttribute("SectorColor", config.sectorColor)
	part:SetAttribute("SectorIndex", config.sectorIndex)
	part:SetAttribute("SectorLocked", config.locked == true)
	part:SetAttribute("ColorZone", true)
	part:SetAttribute("ColorBlobSpawn", false)
	part:SetAttribute("AreaGate", false)
	part:SetAttribute("GateInteraction", false)
	part:SetAttribute("ColorType", config.sectorColor)
	part:SetAttribute("AreaColor", config.sectorColor)
end

local function ensureEggPrompt(part)
	local prompt = part:FindFirstChild("EggShopPrompt")
	if not prompt then
		prompt = Instance.new("ProximityPrompt")
		prompt.Name = "EggShopPrompt"
		prompt.Parent = part
	end

	prompt.ActionText = "Hatch"
	prompt.ObjectText = "Egg"
	prompt.HoldDuration = 0
	prompt.MaxActivationDistance = math.max(prompt.MaxActivationDistance, 18)
	prompt.RequiresLineOfSight = false
	prompt.KeyboardKeyCode = Enum.KeyCode.E
	prompt.GamepadKeyCode = Enum.KeyCode.ButtonX
	prompt:SetAttribute("EggShopPrompt", true)
	return prompt
end

local function applyEggAttributes(part, config)
	part:SetAttribute("DistantSectorColumn", false)
	part:SetAttribute("SectorAnchor", false)
	part:SetAttribute("DecorativeOnly", false)
	part:SetAttribute("PlayableSectorFloor", false)
	part:SetAttribute("ColorZone", false)
	part:SetAttribute("ColorBlobSpawn", false)
	part:SetAttribute("EggStation", true)
	part:SetAttribute("EggId", config.sectorColor .. "Egg")
	part:SetAttribute("ColorType", config.sectorColor)
	part:SetAttribute("AreaColor", config.sectorColor)
	part.CanCollide = true
	part.CanTouch = false
	part.CanQuery = true
	ensureEggPrompt(part)
end

local function isLargeHorizontalFloor(part)
	local size = part.Size
	local horizontalArea = size.X * size.Z
	local smallestHorizontal = math.max(1, math.min(size.X, size.Z))
	return size.X >= 35 and size.Z >= 35 and horizontalArea >= 1600 and size.Y <= smallestHorizontal * 0.28
end

local function shouldBePlayableFloor(part, config)
	if part:GetAttribute("PlayableSectorFloor") == true then
		return true
	end
	if isEggPart(part, config) then
		return false
	end
	if part:GetAttribute("BrushShop") or part:GetAttribute("ShopStation") or part:GetAttribute("CombinedShop") then
		return false
	end
	return isLargeHorizontalFloor(part)
end

local function setupSectorModel(model, config)
	if not model or not model.Parent then
		return false
	end

	local folder = not config.playable and getOrCreateDistantSectorsFolder() or nil
	if folder and not config.playable and model.Parent ~= folder then
		model.Parent = folder
	end

	model:SetAttribute("SectorName", config.displayName)
	model:SetAttribute("SectorColor", config.sectorColor)
	model:SetAttribute("SectorIndex", config.sectorIndex)
	model:SetAttribute("SectorLocked", config.locked == true)
	model:SetAttribute("ColorType", config.sectorColor)
	model:SetAttribute("DecorativeOnly", config.playable ~= true)

	for _, descendant in ipairs(model:GetDescendants()) do
		if descendant:IsA("BasePart") then
			descendant.Anchored = true
			descendant.CanCollide = true
			descendant.CanTouch = false
			descendant.CanQuery = true
			if config.playable and isEggPart(descendant, config) then
				applyEggAttributes(descendant, config)
			elseif config.playable and shouldBePlayableFloor(descendant, config) then
				applyPlayableFloorAttributes(descendant, config)
			else
				applySectorAttributes(descendant, config)
			end
		end
	end

	local eggModel = getAncestorNamed(model, config.sectorColor .. "Egg") or model:FindFirstChild(config.sectorColor .. "Egg", true)
	if eggModel then
		if eggModel:IsA("BasePart") then
			applyEggAttributes(eggModel, config)
		else
			for _, descendant in ipairs(eggModel:GetDescendants()) do
				if descendant:IsA("BasePart") then
					applyEggAttributes(descendant, config)
				end
			end
		end
	end

	if config.playable then
		local populateRequest = ServerScriptService:FindFirstChild("RequestPopulateColorZone")
		if populateRequest and populateRequest:IsA("BindableEvent") then
			task.defer(function()
				populateRequest:Fire(config.sectorColor)
			end)
			task.delay(3, function()
				populateRequest:Fire(config.sectorColor)
			end)
		end
	end

	return true
end

local function setupAllSectorModels()
	for name, config in pairs(SECTOR_MODELS) do
		local model = Workspace:FindFirstChild(name)
		if not model then
			local map = Workspace:FindFirstChild(MAP_NAME)
			model = map and map:FindFirstChild(name, true)
		end

		if model then
			setupSectorModel(model, config)
		end
	end
end

task.defer(setupAllSectorModels)
task.delay(2, setupAllSectorModels)

Workspace.ChildAdded:Connect(function(child)
	local config = SECTOR_MODELS[string.lower(child.Name)]
	if config then
		task.defer(function()
			setupSectorModel(child, config)
		end)
	end
end)
]]></string>
        </Properties>
      </Item>
      <Item class="Script" referent="99">
        <Properties>
          <string name="Name">SectorInteriorHandler</string>
          <token name="RunContext">0</token>
          <string name="Source"><![CDATA[-- Hooks baked sector pipe/interior parts. This script does not build map geometry.
local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Workspace = game:GetService("Workspace")

local ColorData = require(ReplicatedStorage:WaitForChild("ColorData"))
local Events = ReplicatedStorage:WaitForChild("Events")
local transitionEvent = Events:FindFirstChild("ShopTransition")
local travelResultEvent = Events:FindFirstChild("TravelToLocationResult")
local dataDirtyEvent = Events:FindFirstChild("PlayerDataDirty")

local COOLDOWN = 1.2
local FADE_IN_TIME = 0.18
local SAFE_LANDING_HEIGHT = 6
local locks = {}
local teleportTokens = {}
local hooked = {}
local AUTO_PIPE_NAMES = {
	pipe = true,
	orangesectorpipe = true,
	orangeinteriorexitpipe = true,
}

local function getCharacterRoot(player)
	local character = player.Character
	return character and character:FindFirstChild("HumanoidRootPart")
end

local function beginTeleportGrace(player)
	local token = (teleportTokens[player] or 0) + 1
	teleportTokens[player] = token
	player:SetAttribute("IsTeleporting", true)

	task.delay(1, function()
		if player.Parent and teleportTokens[player] == token then
			player:SetAttribute("IsTeleporting", false)
		end
	end)
end

local function setRootCFrame(player, cframe)
	local character = player.Character
	local root = getCharacterRoot(player)
	if not character or not root then
		return false
	end
	local humanoid = character:FindFirstChildOfClass("Humanoid")
	if humanoid then
		humanoid.Sit = false
		humanoid.PlatformStand = false
	end
	root.AssemblyLinearVelocity = Vector3.zero
	root.AssemblyAngularVelocity = Vector3.zero
	character:PivotTo(cframe)
	root.CFrame = cframe
	root.AssemblyLinearVelocity = Vector3.zero
	root.AssemblyAngularVelocity = Vector3.zero
	task.defer(function()
		if root and root.Parent then
			root.AssemblyLinearVelocity = Vector3.zero
			root.AssemblyAngularVelocity = Vector3.zero
		end
	end)
	return true
end

local function getSafeLandingCFrame(player, desiredCFrame)
	local character = player.Character
	local rayParams = RaycastParams.new()
	rayParams.FilterType = Enum.RaycastFilterType.Exclude
	rayParams.FilterDescendantsInstances = character and { character } or {}

	local origin = desiredCFrame.Position + Vector3.new(0, 90, 0)
	local result = Workspace:Raycast(origin, Vector3.new(0, -260, 0), rayParams)
	if not result then
		return desiredCFrame
	end

	local normal = result.Normal
	if normal.Y < 0.65 then
		return desiredCFrame
	end

	local _, yaw, _ = desiredCFrame:ToOrientation()
	local pos = result.Position + Vector3.new(0, SAFE_LANDING_HEIGHT, 0)
	return CFrame.new(pos) * CFrame.Angles(0, yaw, 0)
end

local function getPlayerFromTouchedPart(part)
	local character = part and part.Parent
	local humanoid = character and character:FindFirstChildOfClass("Humanoid")
	if not humanoid then
		return nil
	end
	return Players:GetPlayerFromCharacter(character)
end

local function unlockTeleport(player, locationId, displayName)
	local storage = player and player:FindFirstChild("ColorStorage")
	local teleports = storage and storage:FindFirstChild("UnlockedTeleports")
	if not teleports or not teleports:IsA("StringValue") then
		return
	end

	local set = {}
	for _, existing in ipairs(string.split(teleports.Value or "", ",")) do
		if existing ~= "" then
			set[existing] = true
		end
	end
	set.OriginSector = true
	if set[locationId] then
		return
	end
	set[locationId] = true

	local ordered = {}
	for _, id in ipairs({ "OriginSector", "RedWastelands", "ZorkShop", "OrangeSector", "InsidePipes" }) do
		if set[id] then
			table.insert(ordered, id)
		end
	end
	teleports.Value = table.concat(ordered, ",")
	if dataDirtyEvent and dataDirtyEvent:IsA("BindableEvent") then
		dataDirtyEvent:Fire(player, "unlocked-teleport")
	end
	if travelResultEvent and travelResultEvent:IsA("RemoteEvent") then
		travelResultEvent:FireClient(player, {
			Success = true,
			LocationId = locationId,
			DisplayName = displayName or locationId,
			UnlockedTeleport = true,
			Message = (displayName or locationId) .. " teleport unlocked.",
			UnlockedTeleports = teleports.Value,
		})
	end
end

local function findPartByAttribute(attributeName, colorType, destinationName)
	for _, obj in ipairs(Workspace:GetDescendants()) do
		if obj:IsA("BasePart") and obj:GetAttribute(attributeName) == true then
			local objColor = obj:GetAttribute("SectorColor") or obj:GetAttribute("ColorType") or obj:GetAttribute("AreaColor")
			local nameMatches = not destinationName or obj:FindFirstAncestor(destinationName) ~= nil
			if objColor == colorType and nameMatches then
				return obj
			end
		end
	end
	return nil
end

local function getModelBounds(container)
	if not container then
		return nil, nil
	end
	if container:IsA("Model") then
		return container:GetBoundingBox()
	end
	if container:IsA("Folder") or container:IsA("BasePart") then
		local minPoint = Vector3.new(math.huge, math.huge, math.huge)
		local maxPoint = Vector3.new(-math.huge, -math.huge, -math.huge)
		local found = false
		for _, obj in ipairs(container:GetDescendants()) do
			if obj:IsA("BasePart") then
				local half = obj.Size * 0.5
				local low = obj.Position - half
				local high = obj.Position + half
				minPoint = Vector3.new(math.min(minPoint.X, low.X), math.min(minPoint.Y, low.Y), math.min(minPoint.Z, low.Z))
				maxPoint = Vector3.new(math.max(maxPoint.X, high.X), math.max(maxPoint.Y, high.Y), math.max(maxPoint.Z, high.Z))
				found = true
			end
		end
		if container:IsA("BasePart") then
			local half = container.Size * 0.5
			local low = container.Position - half
			local high = container.Position + half
			minPoint = Vector3.new(math.min(minPoint.X, low.X), math.min(minPoint.Y, low.Y), math.min(minPoint.Z, low.Z))
			maxPoint = Vector3.new(math.max(maxPoint.X, high.X), math.max(maxPoint.Y, high.Y), math.max(maxPoint.Z, high.Z))
			found = true
		end
		if not found then
			return nil, nil
		end
		local center = (minPoint + maxPoint) * 0.5
		return CFrame.new(center), maxPoint - minPoint
	end
	return nil, nil
end

local function getObjectPosition(object)
	if object:IsA("BasePart") then
		return object.Position
	end
	if object:IsA("Model") then
		return object:GetPivot().Position
	end
	local part = object:FindFirstChildWhichIsA("BasePart", true)
	return part and part.Position or Vector3.zero
end

local function isInsideBounds(position, boundsCFrame, boundsSize, margin)
	if not boundsCFrame or not boundsSize then
		return false
	end
	local localPoint = boundsCFrame:PointToObjectSpace(position)
	local half = boundsSize * 0.5 + Vector3.new(margin, margin, margin)
	return math.abs(localPoint.X) <= half.X
		and math.abs(localPoint.Y) <= half.Y
		and math.abs(localPoint.Z) <= half.Z
end

local function getInteriorContainer(destinationName)
	destinationName = destinationName or "OrangeSectorInterior"
	local direct = Workspace:FindFirstChild(destinationName, true)
	if direct then
		return direct
	end
	for _, obj in ipairs(Workspace:GetDescendants()) do
		if obj:GetAttribute("SectorInterior") == true
			and (obj:GetAttribute("SectorColor") == "Orange" or obj:GetAttribute("ColorType") == "Orange")
		then
			return obj
		end
	end
	return nil
end

local function getLargestHorizontalPart(container)
	local best = nil
	local bestArea = -math.huge
	if not container then
		return nil
	end
	for _, obj in ipairs(container:GetDescendants()) do
		if obj:IsA("BasePart") then
			local size = obj.Size
			local flat = size.Y <= math.max(1, math.min(size.X, size.Z) * 0.25)
			local area = size.X * size.Z
			if flat and area > bestArea then
				best = obj
				bestArea = area
			end
		end
	end
	return best
end

local function getPipeParts(pipeObject)
	local parts = {}
	if pipeObject:IsA("BasePart") then
		table.insert(parts, pipeObject)
	else
		for _, descendant in ipairs(pipeObject:GetDescendants()) do
			if descendant:IsA("BasePart") then
				table.insert(parts, descendant)
			end
		end
	end
	return parts
end

local function configurePipeObject(pipeObject)
	local lowered = string.lower(pipeObject.Name or "")
	if not AUTO_PIPE_NAMES[lowered] and not string.match(lowered, "pipe") then
		return
	end
	if pipeObject:FindFirstAncestor("PetAppearanceStudio") then
		return
	end

	local colorType = pipeObject:GetAttribute("SectorColor") or pipeObject:GetAttribute("ColorType") or "Orange"
	if colorType ~= "Orange" then
		return
	end

	local destinationName = pipeObject:GetAttribute("SectorInteriorDestination") or "OrangeSectorInterior"
	local interior = getInteriorContainer(destinationName)
	local boundsCFrame, boundsSize = getModelBounds(interior)
	local insideInterior = pipeObject:FindFirstAncestor(destinationName) ~= nil
		or isInsideBounds(getObjectPosition(pipeObject), boundsCFrame, boundsSize, 20)

	for _, part in ipairs(getPipeParts(pipeObject)) do
		if not part:GetAttribute("SectorInteriorEntrance") and not part:GetAttribute("SectorInteriorExit") then
			if insideInterior then
				part:SetAttribute("SectorInteriorExit", true)
			else
				part:SetAttribute("SectorInteriorEntrance", true)
				part:SetAttribute("SectorInteriorDestination", destinationName)
			end
		end
		part:SetAttribute("SectorColor", colorType)
		part:SetAttribute("ColorType", colorType)
		part.CanTouch = true
		part.CanQuery = true
	end
end

local function findInteriorSpawn(trigger)
	local colorType = trigger:GetAttribute("SectorColor") or trigger:GetAttribute("ColorType") or "Orange"
	local destinationName = trigger:GetAttribute("SectorInteriorDestination")
	local spawn = findPartByAttribute("SectorInteriorSpawn", colorType, destinationName)
	if spawn then
		return spawn
	end
	local interior = getInteriorContainer(destinationName)
	for _, name in ipairs({ "OrangeInteriorSpawn", "InteriorSpawn", "Spawn", "StartPad" }) do
		local named = interior and interior:FindFirstChild(name, true)
		if named and named:IsA("BasePart") then
			return named
		end
	end
	return getLargestHorizontalPart(interior)
end

local function findExteriorReturn(trigger)
	local colorType = trigger:GetAttribute("SectorColor") or trigger:GetAttribute("ColorType") or "Orange"
	local destination = findPartByAttribute("SectorInteriorExteriorReturn", colorType)
	if destination then
		return destination
	end
	for _, obj in ipairs(Workspace:GetDescendants()) do
		if obj:IsA("BasePart")
			and obj:GetAttribute("SectorInteriorEntrance") == true
			and (obj:GetAttribute("SectorColor") or obj:GetAttribute("ColorType") or "Orange") == colorType
		then
			return obj
		end
	end
	return nil
end

local function destinationCFrame(part, lookTarget)
	local pos = part.Position + Vector3.new(0, math.max(4, part.Size.Y * 0.5 + 3), 0)
	if lookTarget then
		return CFrame.lookAt(pos, Vector3.new(lookTarget.Position.X, pos.Y, lookTarget.Position.Z))
	end
	return CFrame.new(pos)
end

local function exteriorReturnCFrame(part, lookTarget)
	if part:GetAttribute("SectorInteriorEntrance") ~= true then
		return destinationCFrame(part, lookTarget)
	end
	local distance = math.max(part.Size.Z * 1.35 + 20, 34)
	local pos = part.CFrame:PointToWorldSpace(Vector3.new(0, math.max(8, part.Size.Y * 0.5 + 8), -distance))
	if lookTarget then
		return CFrame.lookAt(pos, Vector3.new(part.Position.X, pos.Y, part.Position.Z))
	end
	return CFrame.new(pos)
end

local function normalizePipeExitSpawn(part)
	part.Name = "PipeExitSpawn"
	part.Anchored = true
	part.CanCollide = false
	part.CanTouch = false
	part.CanQuery = true
	part.Transparency = 1
	part:SetAttribute("PipeExitSpawn", true)
	return part
end

local function ensurePipeExitSpawn(trigger)
	local existing = Workspace:FindFirstChild("PipeExitSpawn")
	if existing and existing:IsA("BasePart") then
		return normalizePipeExitSpawn(existing)
	end

	local exteriorReturn = findExteriorReturn(trigger)
	local exitCFrame
	if exteriorReturn then
		exitCFrame = exteriorReturnCFrame(exteriorReturn, trigger)
	else
		exitCFrame = trigger.CFrame + Vector3.new(0, math.max(8, trigger.Size.Y * 0.5 + 8), -34)
		warn("SectorInteriorHandler: missing SectorInteriorExteriorReturn for " .. trigger:GetFullName() .. "; creating fallback PipeExitSpawn.")
	end

	local marker = Instance.new("Part")
	marker.Size = Vector3.new(8, 1, 8)
	marker.CFrame = exitCFrame
	marker.Parent = Workspace
	return normalizePipeExitSpawn(marker)
end

local function playTransition(player, callback)
	local now = os.clock()
	if locks[player] and now - locks[player] < COOLDOWN then
		return
	end
	locks[player] = now
	beginTeleportGrace(player)

	if transitionEvent and transitionEvent:IsA("RemoteEvent") then
		transitionEvent:FireClient(player, "FadeIn")
	end
	task.delay(FADE_IN_TIME, function()
		if not player.Parent then
			return
		end
		callback()
		task.delay(0.08, function()
			if player.Parent and transitionEvent and transitionEvent:IsA("RemoteEvent") then
				transitionEvent:FireClient(player, "FadeOut")
			end
		end)
	end)
end

local function enterInterior(player, trigger)
	local colorType = trigger:GetAttribute("SectorColor") or trigger:GetAttribute("ColorType") or "Orange"
	local storage = player:FindFirstChild("ColorStorage")
	local unlocked = storage and storage:FindFirstChild("UnlockedColors")
	if unlocked and not ColorData.isColorUnlocked(unlocked.Value, colorType) then
		return
	end

	local spawn = findInteriorSpawn(trigger)
	if not spawn then
		warn("SectorInteriorHandler: missing SectorInteriorSpawn for " .. trigger:GetFullName())
		return
	end
	playTransition(player, function()
		local ok = setRootCFrame(player, getSafeLandingCFrame(player, destinationCFrame(spawn, trigger)))
		if ok then
			if colorType then
				player:SetAttribute("ActiveWorldColor", colorType)
			end
			player:SetAttribute("InsideSectorInterior", true)
			player:SetAttribute("VisitedMutationSectorInterior", true)
			unlockTeleport(player, "InsidePipes", "Inside the Pipes")
		end
	end)
end

local function exitInterior(player, trigger)
	local destination = ensurePipeExitSpawn(trigger)
	playTransition(player, function()
		local ok = setRootCFrame(player, destination.CFrame + Vector3.new(0, 4, 0))
		if ok then
			player:SetAttribute("InsideSectorInterior", false)
		end
	end)
end

local function hookTrigger(part)
	if hooked[part] then
		return
	end
	local isEntrance = part:GetAttribute("SectorInteriorEntrance") == true
	local isExit = part:GetAttribute("SectorInteriorExit") == true
	if not isEntrance and not isExit then
		return
	end

	hooked[part] = true
	local function use(player)
		if isEntrance then
			enterInterior(player, part)
		else
			exitInterior(player, part)
		end
	end

	for _, child in ipairs(part:GetChildren()) do
		if child:IsA("ProximityPrompt") then
			child.Triggered:Connect(use)
		end
	end
	part.ChildAdded:Connect(function(child)
		if child:IsA("ProximityPrompt") then
			child.Triggered:Connect(use)
		end
	end)

	part.Touched:Connect(function(hit)
		local player = getPlayerFromTouchedPart(hit)
		if player then
			use(player)
		end
	end)
end

local function hookExisting()
	for _, obj in ipairs(Workspace:GetDescendants()) do
		configurePipeObject(obj)
		if obj:IsA("BasePart") then
			hookTrigger(obj)
		end
	end
end

hookExisting()
Workspace.DescendantAdded:Connect(function(obj)
	configurePipeObject(obj)
	if obj:IsA("BasePart") then
		hookTrigger(obj)
	end
end)

Players.PlayerRemoving:Connect(function(player)
	locks[player] = nil
	teleportTokens[player] = nil
end)
]]></string>
        </Properties>
      </Item>
      <Item class="Script" referent="100">
        <Properties>
          <string name="Name">SellHandler</string>
          <token name="RunContext">0</token>
          <string name="Source"><![CDATA[-- SellHandler.server.luau
local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local RunService = game:GetService("RunService")
local DEBUG_LOGS = RunService:IsStudio()

local ColorData = require(ReplicatedStorage:WaitForChild("ColorData"))
local PetData = require(ReplicatedStorage:WaitForChild("PetData"))
local GameBalance = require(ReplicatedStorage:WaitForChild("GameBalance"))
local GamepassBenefits = require(script.Parent:WaitForChild("GamepassBenefits"))
local ColorEffectHandler = require(script.Parent:WaitForChild("ColorEffectHandler"))

local Events = ReplicatedStorage:WaitForChild("Events")
local teleportToSellEvent = Events:WaitForChild("TeleportToSell")
local sellColorEvent = Events:FindFirstChild("SellColor")
local dataDirtyEvent = Events:FindFirstChild("PlayerDataDirty")
local serverSellPaint = ReplicatedStorage:FindFirstChild("ServerSellPaint")
if not serverSellPaint then
	serverSellPaint = Instance.new("BindableFunction")
	serverSellPaint.Name = "ServerSellPaint"
	serverSellPaint.Parent = ReplicatedStorage
end
local sellDebounce = {}
local unexpectedSellWarnings = {}
local SELLING_ENABLED = false

local function warnUnexpectedSellValuesOnce(player, action)
	local key = tostring(player and player.UserId or "server") .. ":" .. tostring(action)
	if unexpectedSellWarnings[key] then
		return
	end
	unexpectedSellWarnings[key] = true
	warn("Sell request ignored unexpected client value fields for " .. tostring(action) .. ". Server calculates Coins.")
end
local SELL_DEBOUNCE = 1.25

local SELL_DARK = Color3.fromRGB(28, 35, 42)
local SELL_GREEN = Color3.fromRGB(98, 255, 190)
local SELL_CYAN = Color3.fromRGB(118, 238, 244)
local SELL_YELLOW = Color3.fromRGB(255, 226, 92)

local function disableSellPart(sellPart)
	if not sellPart or not sellPart:IsA("BasePart") then
		return
	end

	sellPart:SetAttribute("SellZoneDisabled", true)
	sellPart.CanTouch = false
	sellPart.CanCollide = false
	sellPart.Transparency = math.max(sellPart.Transparency, 0.9)

	local prompt = sellPart:FindFirstChild("SellPrompt")
	if prompt then
		prompt.Enabled = false
	end

	for _, child in ipairs(sellPart:GetDescendants()) do
		if child:IsA("ProximityPrompt") then
			child.Enabled = false
		elseif child:IsA("BillboardGui") or child:IsA("SurfaceGui") then
			child.Enabled = false
		elseif child:IsA("BasePart") and child:GetAttribute("SellZoneDecor") then
			child.Transparency = 1
			child.CanCollide = false
			child.CanTouch = false
			child.CanQuery = false
		elseif child:IsA("ParticleEmitter") or child:IsA("PointLight") then
			child.Enabled = false
		end
	end
end

local function sellPartMatchesColor(part, colorType)
	if not part or not colorType then
		return false
	end

	local sellColor = part:GetAttribute("ColorType")
		or part:GetAttribute("AreaColor")
		or part:GetAttribute("SellColor")
	if not sellColor then
		local worldIndex = ColorData.getWorldIndex(colorType)
		if part.Name == tostring(colorType) .. "SellPad"
			or part.Name == tostring(colorType) .. "SellStation"
			or (worldIndex and (part.Name == "World" .. tostring(worldIndex) .. "Sell" or part.Name == "World" .. tostring(worldIndex) .. "_Sell"))
		then
			sellColor = colorType
			part:SetAttribute("ColorType", colorType)
			part:SetAttribute("AreaColor", colorType)
			part:SetAttribute("SellColor", colorType)
		end
	end
	return sellColor == colorType
end

local function isSellPart(obj)
	return obj:IsA("BasePart")
		and (obj:GetAttribute("SellZone")
			or obj:GetAttribute("SellLocation")
			or obj.Name == "SellZone"
			or obj.Name == "Sell"
			or obj.Name == "SellPart"
			or obj.Name == "SellArea"
			or obj.Name == "SellPad"
			or obj.Name == "OrangeSellPad"
			or obj.Name == "OrangeSellStation"
			or obj.Name == "World2Sell"
			or string.match(obj.Name, "^World%d+_Sell$")
			or string.match(obj.Name, "^World%d+Sell$")
			or string.match(obj.Name, "SellStation$"))
end

local function findSellPart(colorType)
	local fallback = nil
	for _, obj in ipairs(workspace:GetDescendants()) do
		if isSellPart(obj) then
			fallback = fallback or obj
			if sellPartMatchesColor(obj, colorType) then
				return obj
			end
		end
	end

	return colorType == "Red" and fallback or nil
end

local function ensureSellBillboard(sellPart)
	for _, child in ipairs(sellPart:GetChildren()) do
		if child:IsA("BillboardGui") and child.Name ~= "SellZoneLabel" then
			child:Destroy()
		end
	end

	local billboard = sellPart:FindFirstChild("SellZoneLabel")
	if not billboard then
		billboard = Instance.new("BillboardGui")
		billboard.Name = "SellZoneLabel"
		billboard.AlwaysOnTop = true
		billboard.LightInfluence = 0
		billboard.MaxDistance = 190
		billboard.Size = UDim2.new(0, 310, 0, 96)
		billboard.StudsOffset = Vector3.new(0, 10.5, 0)
		billboard.Parent = sellPart
	end

	local title = billboard:FindFirstChild("Title")
	if not title then
		title = Instance.new("TextLabel")
		title.Name = "Title"
		title.BackgroundTransparency = 1
		title.Size = UDim2.new(1, 0, 0, 48)
		title.Font = Enum.Font.LuckiestGuy
		title.TextSize = 34
		title.TextColor3 = Color3.fromRGB(255, 255, 255)
		title.TextStrokeTransparency = 0
		title.TextStrokeColor3 = SELL_DARK
		title.Parent = billboard
	end
	title.Text = "SELL COLOR"

	local sub = billboard:FindFirstChild("Subtitle")
	if not sub then
		sub = Instance.new("TextLabel")
		sub.Name = "Subtitle"
		sub.BackgroundTransparency = 1
		sub.Size = UDim2.new(1, 0, 0, 28)
		sub.Position = UDim2.new(0, 0, 0, 50)
		sub.Font = Enum.Font.GothamBold
		sub.TextSize = 16
		sub.TextColor3 = Color3.fromRGB(205, 255, 236)
		sub.TextStrokeTransparency = 0.15
		sub.TextStrokeColor3 = SELL_DARK
		sub.Parent = billboard
	end
	sub.Text = "Turn Color into Coins"
end

local function makeVisualPart(root, name, size, offset, color, material, transparency)
	local part = root:FindFirstChild(name)
	if not part then
		part = Instance.new("Part")
		part.Name = name
		part.Anchored = true
		part.CanCollide = false
		part.CanTouch = false
		part.CanQuery = false
		part.CastShadow = false
		part.Parent = root
	end

	part.Size = size
	part.CFrame = root.CFrame * CFrame.new(offset)
	part.Color = color
	part.Material = material or Enum.Material.SmoothPlastic
	part.Transparency = transparency or 0
	part:SetAttribute("SellZoneDecor", true)
	return part
end

local function ensureSellVisuals(sellPart)
	for _, child in ipairs(sellPart:GetChildren()) do
		if (child:IsA("BasePart") and child:GetAttribute("SellZoneDecor"))
			or child:IsA("ParticleEmitter")
			or child:IsA("PointLight")
			or child.Name == "SellSparkles"
			or child.Name == "SellZoneLabel"
		then
			child:Destroy()
		elseif child:IsA("BillboardGui") and (child.Name == "SellZoneLabel" or child.Name == "ProximityStationLabel") then
			child:Destroy()
		end
	end

	sellPart:SetAttribute("SellZone", true)
	sellPart.Anchored = true
	sellPart.CanCollide = false
	sellPart.CanTouch = true

	local prompt = sellPart:FindFirstChild("SellPrompt")
	if not prompt then
		prompt = Instance.new("ProximityPrompt")
		prompt.Name = "SellPrompt"
		prompt.Parent = sellPart
	end
	prompt.ActionText = "Sell Color"
	prompt.ObjectText = "Sell Station"
	prompt.HoldDuration = 0
	prompt.MaxActivationDistance = 20
	prompt.RequiresLineOfSight = false

	return prompt
end

local function parseInventory(str)
	local inventory = {}
	if not str or str == "" then
		return inventory
	end

	for _, part in ipairs(string.split(str, ",")) do
		local segments = string.split(part, ":")
		local variantKey
		local petId
		local stackIndex
		if tonumber(segments[2]) then
			petId = segments[1]
			stackIndex = 2
		else
			variantKey = segments[1]
			petId = segments[2]
			stackIndex = 3
		end
		local stackAmount = tonumber(segments[stackIndex]) or 1
		local traitId = PetData.normalizeTraitId(segments[stackIndex + 1])
		local shinyStr = segments[stackIndex + 2] or "normal"
		local personalityId = PetData.normalizePersonalityId(segments[stackIndex + 3] or "Neutral")
		local mutationId = PetData.normalizeMutationId(segments[stackIndex + 4] or "None")
		variantKey = variantKey or PetData.makeVariantKey(petId, personalityId, mutationId, traitId)
		if petId and petId ~= "" then
			inventory[variantKey] = {
				petId = petId,
				stackAmount = stackAmount,
				traitId = traitId,
				isShiny = shinyStr == "shiny" or shinyStr == "true",
				personalityId = personalityId,
				mutationId = mutationId,
			}
		end
	end

	return inventory
end

local function getPetCoinMultiplier(player)
	return ColorEffectHandler.GetSellCoinsMultiplier(player)
end

local function getSellMultiplier(player)
	local multiplier = getPetCoinMultiplier(player)
	local boostFolder = player:FindFirstChild("Boosts")
	local coinBoost = boostFolder and boostFolder:FindFirstChild("coins")
	if coinBoost and os.time() < coinBoost.Value then
		multiplier *= 2
	end
	multiplier *= GamepassBenefits.getCoinMultiplier(player)

	return multiplier
end

local function isPointInside(part, worldPosition, margin)
	local localPoint = part.CFrame:PointToObjectSpace(worldPosition)
	local half = part.Size * 0.5 + Vector3.new(margin, margin, margin)
	return math.abs(localPoint.X) <= half.X
		and math.abs(localPoint.Y) <= half.Y
		and math.abs(localPoint.Z) <= half.Z
end

local function getHighestUnlockedColor(player)
	local storage = player:FindFirstChild("ColorStorage")
	local unlockedValue = storage and storage:FindFirstChild("UnlockedColors")
	local unlocked = ColorData.getUnlockedColorSet(unlockedValue and unlockedValue.Value or "Red")
	local highest = "Red"
	for _, world in ipairs(ColorData.Worlds or {}) do
		if unlocked[world.primaryColor] then
			highest = world.primaryColor
		end
	end
	return highest
end

local function getStoredCurrentWorldColor(player)
	local storage = player:FindFirstChild("ColorStorage")
	local unlockedValue = storage and storage:FindFirstChild("UnlockedColors")
	local unlockedCsv = unlockedValue and unlockedValue.Value or "Red"
	local currentWorld = storage and storage:FindFirstChild("CurrentWorld")
	local colorType = currentWorld and currentWorld.Value or player:GetAttribute("ActiveWorldColor")
	local world = ColorData.getWorldByColor(colorType)
	if world and ColorData.isColorUnlocked(unlockedCsv, world.primaryColor) then
		return world.primaryColor
	end
	return nil
end

local function setCurrentWorld(player, colorType)
	local storage = player:FindFirstChild("ColorStorage")
	local unlockedValue = storage and storage:FindFirstChild("UnlockedColors")
	if not ColorData.isColorUnlocked(unlockedValue and unlockedValue.Value or "Red", colorType) then
		return
	end

	player:SetAttribute("ActiveWorldColor", colorType)
	local currentWorld = storage and storage:FindFirstChild("CurrentWorld")
	if currentWorld and currentWorld:IsA("StringValue") and currentWorld.Value ~= colorType then
		currentWorld.Value = colorType
		if dataDirtyEvent and dataDirtyEvent:IsA("BindableEvent") then
			dataDirtyEvent:Fire(player, "current-world")
		end
	end
end

local function getCurrentSellColor(player)
	local root = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
	local storedColor = getStoredCurrentWorldColor(player)
	if root then
		local nearestColor = nil
		local nearestDistance = math.huge
		local storage = player:FindFirstChild("ColorStorage")
		local unlockedValue = storage and storage:FindFirstChild("UnlockedColors")
		local unlockedCsv = unlockedValue and unlockedValue.Value or "Red"
		for _, obj in ipairs(workspace:GetDescendants()) do
			if obj:IsA("BasePart") and obj:GetAttribute("ColorZone") and obj:GetAttribute("ColorType") then
				local colorType = obj:GetAttribute("ColorType")
				if isPointInside(obj, root.Position, 8) then
					setCurrentWorld(player, colorType)
					return colorType
				end
				if ColorData.isColorUnlocked(unlockedCsv, colorType) then
					local distance = (root.Position - obj.Position).Magnitude
					if distance < nearestDistance then
						nearestDistance = distance
						nearestColor = colorType
					end
				end
			end
		end
		if storedColor then
			return storedColor
		end
		if nearestColor then
			return nearestColor
		end
	end
	if storedColor then
		return storedColor
	end
	return getHighestUnlockedColor(player)
end

local function getZoneColorValueMultiplier(player)
	local colorType = getCurrentSellColor(player)
	local configured = GameBalance.Sell
		and GameBalance.Sell.ColorValueMultipliers
		and GameBalance.Sell.ColorValueMultipliers[colorType]
	local world = ColorData.getWorldByColor(colorType)
	return tonumber(configured or (world and world.colorValueMultiplier)) or 1, colorType or "Red"
end

local function sellPaint(player)
	return false, "Selling is disabled. Break Color to earn Coins instantly."
end

serverSellPaint.OnInvoke = function(player)
	return sellPaint(player)
end

local function teleportToSell(player)
	if not SELLING_ENABLED then
		return
	end

	local sellPart = findSellPart(getCurrentSellColor(player))
	local character = player.Character
	local root = character and character:FindFirstChild("HumanoidRootPart")

	if sellPart and root then
		root.CFrame = sellPart.CFrame + Vector3.new(0, 4, 0)
	end
end

local function handleSell(player, shouldTeleport, responseEvent)
	if not SELLING_ENABLED then
		responseEvent = responseEvent or teleportToSellEvent
		if responseEvent then
			responseEvent:FireClient(player, false, "Selling is disabled. Break Color to earn Coins instantly.")
		end
		return
	end

	if shouldTeleport then
		teleportToSell(player)
	end

	local ok, result = sellPaint(player)
	responseEvent = responseEvent or teleportToSellEvent
	if ok then
		if DEBUG_LOGS then
			print("Sell zone sold " .. tostring(result.colorSold) .. " Color for " .. tostring(result.coinsEarned) .. " Coins")
		end
		responseEvent:FireClient(player, true, result)
	else
		responseEvent:FireClient(player, false, result)
	end
end

local function useSellZone(player, responseEvent)
	local now = os.clock()
	if sellDebounce[player] and now - sellDebounce[player] < SELL_DEBOUNCE then
		return
	end
	sellDebounce[player] = now

	if DEBUG_LOGS then
		print("Sell zone used")
	end
	handleSell(player, false, responseEvent or sellColorEvent or teleportToSellEvent)
end

teleportToSellEvent.OnServerEvent:Connect(function(player, action, ...)
	if select("#", ...) > 0 then
		warnUnexpectedSellValuesOnce(player, "TeleportToSell")
	end
	handleSell(player, action ~= "sell", teleportToSellEvent)
end)

if sellColorEvent then
	sellColorEvent.OnServerEvent:Connect(function(player, ...)
		if select("#", ...) > 0 then
			warnUnexpectedSellValuesOnce(player, "SellColor")
		end
		handleSell(player, false, sellColorEvent)
	end)
end

local function hookSellPart(sellPart)
	if not sellPart or not sellPart:IsA("BasePart") or sellPart:GetAttribute("SellZoneHooked") then
		return
	end
	sellPart:SetAttribute("SellZoneHooked", true)

	if not SELLING_ENABLED then
		disableSellPart(sellPart)
		return
	end

	local prompt = ensureSellVisuals(sellPart)
	prompt.Triggered:Connect(function(player)
		useSellZone(player, sellColorEvent or teleportToSellEvent)
	end)

	sellPart.Touched:Connect(function(hit)
		local character = hit and hit.Parent
		local player = character and Players:GetPlayerFromCharacter(character)
		if player then
			useSellZone(player, sellColorEvent or teleportToSellEvent)
		end
	end)
end

task.defer(function()
	for _, obj in ipairs(workspace:GetDescendants()) do
		if isSellPart(obj) then
			hookSellPart(obj)
		end
	end
end)

workspace.DescendantAdded:Connect(function(obj)
	if not SELLING_ENABLED and obj:IsA("ProximityPrompt") and obj.Name == "SellPrompt" then
		obj.Enabled = false
		return
	end
	if obj:IsA("BasePart") and isSellPart(obj) then
		task.defer(function()
			hookSellPart(obj)
		end)
	end
end)

Players.PlayerRemoving:Connect(function(player)
	sellDebounce[player] = nil
end)
]]></string>
        </Properties>
      </Item>
      <Item class="Script" referent="101">
        <Properties>
          <string name="Name">ShopInteriorNpcHandler</string>
          <token name="RunContext">0</token>
          <string name="Source"><![CDATA[-- Hooks the baked shop interior to the existing brush shop UI.
-- The NPC is intentionally small and system-owned: the actual buying still uses ShopUI/PurchasePaintTool.
local Workspace = game:GetService("Workspace")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Players = game:GetService("Players")

local Events = ReplicatedStorage:WaitForChild("Events")
local shopTransitionEvent = Events:FindFirstChild("ShopTransition")
if not shopTransitionEvent then
	shopTransitionEvent = Instance.new("RemoteEvent")
	shopTransitionEvent.Name = "ShopTransition"
	shopTransitionEvent.Parent = Events
end

local tutorialShopEnteredEvent = Events:FindFirstChild("TutorialShopEntered")
if not tutorialShopEnteredEvent then
	tutorialShopEnteredEvent = Instance.new("BindableEvent")
	tutorialShopEnteredEvent.Name = "TutorialShopEntered"
	tutorialShopEnteredEvent.Parent = Events
end

local MAP_NAME = "ColorSimulatorMap"
local SHOP_FOLDER_NAME = "Shop"
local SHOP_INSIDE_NAME = "shopinside"
local NPC_NAME = "Zork"
local NPC_DISPLAY_NAME = "Zork"
local NPC_ROLE = "Brush Merchant"
local SHOP_COLOR = "Red"
local FADE_IN_TIME = 0.18
local SHOP_TELEPORT_COOLDOWN = 1.2

local teleportLocks = {}

local function getMap()
	return Workspace:FindFirstChild(MAP_NAME)
end

local function findCaseInsensitiveChild(parent, childName)
	if not parent then
		return nil
	end
	local wanted = string.lower(childName)
	for _, child in ipairs(parent:GetChildren()) do
		if string.lower(child.Name) == wanted then
			return child
		end
	end
	return nil
end

local function getShopInside()
	local map = getMap()
	local shop = map and findCaseInsensitiveChild(map, SHOP_FOLDER_NAME)
	if not shop then
		shop = Workspace:FindFirstChild(SHOP_FOLDER_NAME)
	end
	return findCaseInsensitiveChild(shop, SHOP_INSIDE_NAME)
end

local function getShopFolder()
	local map = getMap()
	return map and findCaseInsensitiveChild(map, SHOP_FOLDER_NAME) or Workspace:FindFirstChild(SHOP_FOLDER_NAME)
end

local function isNpcPart(part)
	return part and part:IsDescendantOf(Workspace) and part:FindFirstAncestor(NPC_NAME) ~= nil
end

local function findInteriorFloor(shopInside)
	local best
	local bestScore = -math.huge
	for _, obj in ipairs(shopInside:GetDescendants()) do
		if obj:IsA("BasePart") and not isNpcPart(obj) then
			local size = obj.Size
			local flatEnough = size.Y <= math.max(0.5, math.min(size.X, size.Z) * 0.25)
			local area = size.X * size.Z
			local score = area - obj.Position.Y * 20
			if flatEnough and score > bestScore then
				best = obj
				bestScore = score
			end
		end
	end

	if best then
		return best
	end

	for _, obj in ipairs(shopInside:GetDescendants()) do
		if obj:IsA("BasePart") and not isNpcPart(obj) then
			local area = obj.Size.X * obj.Size.Z
			if area > bestScore then
				best = obj
				bestScore = area
			end
		end
	end
	return best
end

local function findExteriorEntrance(shop)
	if not shop then
		return nil
	end
	for _, obj in ipairs(shop:GetDescendants()) do
		if obj:IsA("BasePart") and (obj.Name == "ShopEntrance" or obj.Name == "Door" or obj.Name == "Entrance") then
			return obj
		end
	end

	local best
	local bestScore = -math.huge
	for _, obj in ipairs(shop:GetChildren()) do
		if obj:IsA("BasePart") then
			local color = obj.Color
			local blueScore = color.B - math.max(color.R, color.G) * 0.35
			local verticalScore = obj.Size.Y - math.min(obj.Size.X, obj.Size.Z)
			local score = blueScore * 10 + verticalScore
			if score > bestScore then
				best = obj
				bestScore = score
			end
		end
	end
	return best
end

local function makePart(parent, name, size, cframe, color, material, shape)
	local part = parent:FindFirstChild(name)
	if not part then
		part = Instance.new("Part")
		part.Name = name
		part.Parent = parent
	end
	part.Size = size
	part.CFrame = cframe
	part.Color = color
	part.Material = material or Enum.Material.SmoothPlastic
	part.Shape = shape or Enum.PartType.Block
	part.Anchored = true
	part.CanCollide = false
	part.CanTouch = false
	part.CanQuery = true
	part.CastShadow = false
	return part
end

local function applyShopAttributes(instance)
	instance:SetAttribute("BrushShop", true)
	instance:SetAttribute("CombinedShop", true)
	instance:SetAttribute("ShopStation", true)
	instance:SetAttribute("ColorType", SHOP_COLOR)
	instance:SetAttribute("AreaColor", SHOP_COLOR)
	instance:SetAttribute("ShopColor", SHOP_COLOR)
	instance:SetAttribute("BrushNpc", true)
end

local function ensurePrompt(core)
	local prompt = core:FindFirstChild("BrushShopPrompt")
	if not prompt then
		prompt = Instance.new("ProximityPrompt")
		prompt.Name = "BrushShopPrompt"
		prompt.Parent = core
	end
	prompt.ActionText = "Talk"
	prompt.ObjectText = NPC_DISPLAY_NAME
	prompt.KeyboardKeyCode = Enum.KeyCode.E
	prompt.GamepadKeyCode = Enum.KeyCode.ButtonX
	prompt.HoldDuration = 0
	prompt.MaxActivationDistance = 14
	prompt.RequiresLineOfSight = false
	prompt:SetAttribute("BrushShopPrompt", true)
	prompt:SetAttribute("CombinedShopPrompt", true)
	prompt:SetAttribute("BrushNpcDialogue", true)
	prompt:SetAttribute("NpcName", NPC_DISPLAY_NAME)
	prompt:SetAttribute("ColorType", SHOP_COLOR)
	prompt:SetAttribute("ShopColor", SHOP_COLOR)
	return prompt
end

local function ensureNpcLabel(core)
	local label = core:FindFirstChild("BrushNpcLabel")
	if not label then
		label = Instance.new("BillboardGui")
		label.Name = "BrushNpcLabel"
		label.Parent = core
	end
	label.AlwaysOnTop = true
	label.LightInfluence = 0
	label.MaxDistance = 70
	label.Size = UDim2.fromOffset(190, 58)
	label.StudsOffset = Vector3.new(0, 4.7, 0)

	local background = label:FindFirstChild("Background")
	if not background then
		background = Instance.new("Frame")
		background.Name = "Background"
		background.Parent = label
	end
	background.AnchorPoint = Vector2.new(0.5, 0.5)
	background.Position = UDim2.fromScale(0.5, 0.5)
	background.Size = UDim2.new(1, -14, 1, -8)
	background.BackgroundColor3 = Color3.fromRGB(24, 28, 38)
	background.BackgroundTransparency = 0.18
	background.BorderSizePixel = 0
	local bgCorner = background:FindFirstChildOfClass("UICorner") or Instance.new("UICorner")
	bgCorner.CornerRadius = UDim.new(0, 12)
	bgCorner.Parent = background
	local bgStroke = background:FindFirstChildOfClass("UIStroke") or Instance.new("UIStroke")
	bgStroke.Color = Color3.fromRGB(118, 238, 244)
	bgStroke.Thickness = 2
	bgStroke.Transparency = 0.18
	bgStroke.Parent = background

	local text = label:FindFirstChild("Text")
	if not text then
		text = Instance.new("TextLabel")
		text.Name = "Text"
		text.Parent = label
	end
	text.Size = UDim2.new(1, -20, 0, 28)
	text.Position = UDim2.new(0, 10, 0, 6)
	text.BackgroundTransparency = 1
	text.Font = Enum.Font.GothamBlack
	text.TextSize = 20
	text.TextColor3 = Color3.fromRGB(255, 255, 255)
	text.TextStrokeTransparency = 0.35
	text.TextStrokeColor3 = Color3.fromRGB(30, 33, 42)
	text.Text = NPC_DISPLAY_NAME

	local role = label:FindFirstChild("Role")
	if not role then
		role = Instance.new("TextLabel")
		role.Name = "Role"
		role.Parent = label
	end
	role.Size = UDim2.new(1, -20, 0, 20)
	role.Position = UDim2.new(0, 10, 0, 32)
	role.BackgroundTransparency = 1
	role.Font = Enum.Font.GothamBold
	role.TextSize = 12
	role.TextColor3 = Color3.fromRGB(170, 244, 248)
	role.TextStrokeTransparency = 0.65
	role.TextStrokeColor3 = Color3.fromRGB(30, 33, 42)
	role.Text = NPC_ROLE
	return label
end

local function getCharacterRoot(player)
	local character = player.Character
	return character and character:FindFirstChild("HumanoidRootPart")
end

local function setRootCFrame(player, cframe)
	local root = getCharacterRoot(player)
	if not root then
		return false
	end
	root.CFrame = cframe
	root.AssemblyLinearVelocity = Vector3.zero
	root.AssemblyAngularVelocity = Vector3.zero
	return true
end

local function teleportToInterior(player, floor, npcCore)
	if not floor then
		return false
	end
	local floorTopY = floor.Position.Y + floor.Size.Y * 0.5 + 3.2
	local targetPosition = npcCore and npcCore.Position or floor.Position
	local distance = math.clamp(math.min(floor.Size.X, floor.Size.Z) * 0.26, 7, 14)
	local destination = floor.Position + floor.CFrame.LookVector * distance
	destination = Vector3.new(destination.X, floorTopY, destination.Z)
	local lookAt = Vector3.new(targetPosition.X, floorTopY, targetPosition.Z)
	return setRootCFrame(player, CFrame.lookAt(destination, lookAt))
end

local function getExteriorShopCenter(entrance)
	local shop = getShopFolder()
	if not shop then
		return nil
	end

	local shopInside = getShopInside()
	local total = Vector3.zero
	local count = 0
	for _, obj in ipairs(shop:GetDescendants()) do
		if obj:IsA("BasePart")
			and obj ~= entrance
			and (not shopInside or not obj:IsDescendantOf(shopInside))
			and obj.Name ~= "ShopDoorTeleportTrigger"
			and not isNpcPart(obj)
		then
			total += obj.Position
			count += 1
		end
	end

	if count <= 0 then
		return nil
	end
	return total / count
end

local function findExteriorExitAnchor(entrance)
	local shop = getShopFolder()
	if not shop then
		return nil
	end

	for _, obj in ipairs(shop:GetDescendants()) do
		if obj:IsA("BasePart")
			and (
				obj:GetAttribute("ShopExitSpawn") == true
				or obj.Name == "ShopExitSpawn"
				or obj.Name == "ShopExteriorSpawn"
				or obj.Name == "ShopExteriorExit"
			)
		then
			return obj
		end
	end
	return nil
end

local function teleportToExterior(player, entrance)
	if not entrance then
		return false
	end

	local exitAnchor = findExteriorExitAnchor(entrance)
	if exitAnchor then
		local destination = exitAnchor.Position + Vector3.new(0, exitAnchor.Size.Y * 0.5 + 3.2, 0)
		local lookAt = Vector3.new(entrance.Position.X, destination.Y, entrance.Position.Z)
		return setRootCFrame(player, CFrame.lookAt(destination, lookAt))
	end

	local shopCenter = getExteriorShopCenter(entrance)
	local outward = shopCenter and (entrance.Position - shopCenter) or Vector3.zero
	if outward.Magnitude < 0.01 then
		outward = -entrance.CFrame.LookVector
	else
		outward = outward.Unit
	end

	local offset = math.max(math.max(entrance.Size.X, entrance.Size.Z) * 0.5 + 14, 16)
	local destination = entrance.Position + outward * offset
	destination = Vector3.new(destination.X, entrance.Position.Y + entrance.Size.Y * 0.5 + 3.2, destination.Z)
	local lookAt = Vector3.new(entrance.Position.X, destination.Y, entrance.Position.Z)
	return setRootCFrame(player, CFrame.lookAt(destination, lookAt))
end

local function playShopTransition(player, teleportCallback, afterTeleport)
	local now = os.clock()
	if teleportLocks[player] and now - teleportLocks[player] < SHOP_TELEPORT_COOLDOWN then
		return
	end
	teleportLocks[player] = now

	if shopTransitionEvent and shopTransitionEvent:IsA("RemoteEvent") then
		shopTransitionEvent:FireClient(player, "FadeIn")
	end
	task.delay(FADE_IN_TIME, function()
		if not player.Parent then
			return
		end
		local ok = teleportCallback()
		if ok and afterTeleport then
			afterTeleport()
		end
		task.delay(0.08, function()
			if player.Parent and shopTransitionEvent and shopTransitionEvent:IsA("RemoteEvent") then
				shopTransitionEvent:FireClient(player, "FadeOut")
			end
		end)
	end)
end

local function getPlayerFromTouchedPart(part)
	local character = part and part.Parent
	if not character then
		return nil
	end
	local humanoid = character:FindFirstChildOfClass("Humanoid")
	if not humanoid then
		return nil
	end
	return Players:GetPlayerFromCharacter(character)
end

local function ensureShopTeleportPrompts(shopInside, floor, npcCore)
	local shop = getShopFolder()
	local entrance = findExteriorEntrance(shop)
	if not entrance or not floor then
		return
	end

	entrance:SetAttribute("ShopEntrance", true)
	entrance:SetAttribute("ColorType", SHOP_COLOR)
	local enterPrompt = entrance:FindFirstChild("EnterShopPrompt")
	if not enterPrompt then
		enterPrompt = Instance.new("ProximityPrompt")
		enterPrompt.Name = "EnterShopPrompt"
		enterPrompt.Parent = entrance
	end
	enterPrompt.ActionText = "Enter"
	enterPrompt.ObjectText = "Brush Shop"
	enterPrompt.KeyboardKeyCode = Enum.KeyCode.E
	enterPrompt.GamepadKeyCode = Enum.KeyCode.ButtonX
	enterPrompt.HoldDuration = 0
	enterPrompt.MaxActivationDistance = 14
	enterPrompt.RequiresLineOfSight = false
	enterPrompt:SetAttribute("ShopEnterPrompt", true)

	local function enterShop(player)
		playShopTransition(player, function()
			return teleportToInterior(player, floor, npcCore or floor)
		end, function()
			if tutorialShopEnteredEvent and tutorialShopEnteredEvent:IsA("BindableEvent") then
				tutorialShopEnteredEvent:Fire(player)
			end
		end)
	end

	if enterPrompt:GetAttribute("ShopTeleportHooked") ~= true then
		enterPrompt:SetAttribute("ShopTeleportHooked", true)
		enterPrompt.Triggered:Connect(enterShop)
	end

	local trigger = entrance:FindFirstChild("ShopDoorTeleportTrigger")
	if not trigger then
		trigger = Instance.new("Part")
		trigger.Name = "ShopDoorTeleportTrigger"
		trigger.Parent = entrance
	end
	trigger.Size = Vector3.new(
		math.max(entrance.Size.X + 2, 6),
		math.max(entrance.Size.Y + 2, 7),
		math.max(entrance.Size.Z + 3, 5)
	)
	trigger.CFrame = entrance.CFrame
	trigger.Anchored = true
	trigger.CanCollide = false
	trigger.CanTouch = true
	trigger.CanQuery = false
	trigger.Transparency = 1
	trigger:SetAttribute("ShopDoorTeleport", true)

	if trigger:GetAttribute("ShopTeleportHooked") ~= true then
		trigger:SetAttribute("ShopTeleportHooked", true)
		trigger.Touched:Connect(function(hit)
			local player = getPlayerFromTouchedPart(hit)
			if player then
				enterShop(player)
			end
		end)
	end

	local exitAnchor = shopInside:FindFirstChild("ShopExitPromptAnchor")
	if not exitAnchor then
		exitAnchor = Instance.new("Part")
		exitAnchor.Name = "ShopExitPromptAnchor"
		exitAnchor.Parent = shopInside
	end
	exitAnchor.Size = Vector3.new(4, 4, 4)
	exitAnchor.CFrame = floor.CFrame * CFrame.new(0, floor.Size.Y * 0.5 + 3, math.max(floor.Size.Z * 0.35, 7))
	exitAnchor.Anchored = true
	exitAnchor.CanCollide = false
	exitAnchor.CanTouch = false
	exitAnchor.CanQuery = false
	exitAnchor.Transparency = 1

	local exitPrompt = exitAnchor:FindFirstChild("ExitShopPrompt")
	if not exitPrompt then
		exitPrompt = Instance.new("ProximityPrompt")
		exitPrompt.Name = "ExitShopPrompt"
		exitPrompt.Parent = exitAnchor
	end
	exitPrompt.ActionText = "Exit"
	exitPrompt.ObjectText = "Shop Exit"
	exitPrompt.KeyboardKeyCode = Enum.KeyCode.E
	exitPrompt.GamepadKeyCode = Enum.KeyCode.ButtonX
	exitPrompt.HoldDuration = 0
	exitPrompt.MaxActivationDistance = 12
	exitPrompt.RequiresLineOfSight = false
	exitPrompt:SetAttribute("ShopExitPrompt", true)
	if exitPrompt:GetAttribute("ShopTeleportHooked") ~= true then
		exitPrompt:SetAttribute("ShopTeleportHooked", true)
		exitPrompt.Triggered:Connect(function(player)
			playShopTransition(player, function()
				return teleportToExterior(player, entrance)
			end)
		end)
	end
end

local function ensureColorBrushNpc()
	local shopInside = getShopInside()
	if not shopInside then
		return false
	end

	local floor = findInteriorFloor(shopInside)
	if not floor then
		return false
	end

	local npc = shopInside:FindFirstChild(NPC_NAME) or shopInside:FindFirstChild("ColorBrushNpc")
	if not npc then
		npc = Instance.new("Model")
		npc.Parent = shopInside
	end
	npc.Name = NPC_NAME
	applyShopAttributes(npc)

	local basePosition = floor.Position + Vector3.new(0, floor.Size.Y * 0.5 + 3.2, 0)
	local baseCFrame = CFrame.new(basePosition)

	local root = makePart(npc, "HumanoidRootPart", Vector3.new(2, 5, 2), baseCFrame, Color3.fromRGB(80, 210, 255), Enum.Material.SmoothPlastic)
	root.Transparency = 1
	root.CanQuery = false
	npc.PrimaryPart = root

	local body = makePart(npc, "ColorBody", Vector3.new(3.2, 3.2, 3.2), baseCFrame, Color3.fromRGB(55, 198, 255), Enum.Material.Neon, Enum.PartType.Ball)
	local core = makePart(npc, "ShopPromptCore", Vector3.new(3.8, 4.6, 3.8), baseCFrame, Color3.fromRGB(55, 198, 255), Enum.Material.SmoothPlastic)
	core.Transparency = 1
	local head = makePart(npc, "ColorHead", Vector3.new(1.7, 1.7, 1.7), baseCFrame * CFrame.new(0, 2.35, 0), Color3.fromRGB(148, 255, 119), Enum.Material.Neon, Enum.PartType.Ball)
	local glow = makePart(npc, "ColorGlow", Vector3.new(4.3, 0.25, 4.3), baseCFrame * CFrame.new(0, -1.75, 0), Color3.fromRGB(92, 235, 255), Enum.Material.Neon, Enum.PartType.Cylinder)
	glow.Transparency = 0.22

	local handle = makePart(npc, "BrushHandle", Vector3.new(0.28, 3.1, 0.28), baseCFrame * CFrame.new(1.75, 0.2, 0) * CFrame.Angles(0, 0, math.rad(24)), Color3.fromRGB(255, 218, 112), Enum.Material.SmoothPlastic, Enum.PartType.Cylinder)
	local bristles = makePart(npc, "BrushBristles", Vector3.new(0.8, 0.65, 0.8), baseCFrame * CFrame.new(2.35, 1.55, 0) * CFrame.Angles(0, 0, math.rad(24)), Color3.fromRGB(255, 85, 130), Enum.Material.Neon, Enum.PartType.Ball)

	for _, part in ipairs({ root, body, core, head, glow, handle, bristles }) do
		applyShopAttributes(part)
	end
	ensurePrompt(core)
	ensureNpcLabel(core)
	ensureShopTeleportPrompts(shopInside, floor, core)

	return true
end

task.defer(ensureColorBrushNpc)
task.delay(2, ensureColorBrushNpc)
task.delay(6, ensureColorBrushNpc)

Players.PlayerRemoving:Connect(function(player)
	teleportLocks[player] = nil
end)

Workspace.DescendantAdded:Connect(function(obj)
	if obj.Name == SHOP_FOLDER_NAME or string.lower(obj.Name) == SHOP_INSIDE_NAME then
		task.defer(ensureColorBrushNpc)
	end
end)
]]></string>
