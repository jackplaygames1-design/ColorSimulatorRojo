    <Item class="ModuleScript" referent="53">
      <Properties>
        <string name="Name">RobuxShopConfig</string>
        <string name="Source"><![CDATA[-- ModuleScript in ReplicatedStorage named "RobuxShopConfig"
local RobuxShopConfig = {}

-- Replace any 0 gamepassId/productId values with the real IDs from creator.roblox.com.
-- The in-game UI is safe: passes without a real ID show as "Set ID" instead of prompting.
RobuxShopConfig.Gamepasses = {
	{
		id = "AutoSell",
		displayName = "AUTO SELL",
		description = "Legacy pass hidden while Color breaks award Coins instantly.",
		icon = "AUTO",
		iconImage = "rbxthumb://type=GamePass&id=1825700534&w=150&h=150",
		price = 149,
		color = Color3.fromRGB(255, 199, 87),
		gamepassId = 1825700534,
		sortOrder = 50,
		badge = "AUTOMATION",
		autoSell = true,
		showInShop = false,
	},
	{
		id = "Plus3Colors",
		displayName = "+3 COLORS",
		description = "Equip 3 extra Colors for more power and better bonuses.",
		icon = "+3",
		iconImage = "rbxthumb://type=GamePass&id=1825682519&w=150&h=150",
		price = 199,
		color = Color3.fromRGB(114, 203, 255),
		gamepassId = 1825682519,
		sortOrder = 40,
		badge = "MORE POWER",
		extraEquippedColors = 3,
	},
	{
		id = "DoubleCoins",
		displayName = "2x COINS",
		description = "Earn 2x more Coins from Color breaks and progression.",
		icon = "2x",
		iconImage = "rbxthumb://type=GamePass&id=1823157511&w=150&h=150",
		price = 249,
		color = Color3.fromRGB(255, 221, 84),
		gamepassId = 1823157511,
		sortOrder = 30,
		badge = "BEST FOR GRINDING",
		coinMultiplier = 2,
	},
	{
		id = "VIP",
		displayName = "VIP",
		description = "VIP tag, bonus rewards, and future VIP perks.",
		icon = "VIP",
		iconImage = "rbxthumb://type=GamePass&id=1825282612&w=150&h=150",
		price = 299,
		color = Color3.fromRGB(177, 141, 255),
		gamepassId = 1825282612,
		sortOrder = 10,
		badge = "PREMIUM",
		isVIP = true,
		extraEquippedColors = 1,
		luckMultiplier = 1.1,
	},
	{
		id = "LuckyHatch",
		displayName = "LUCKY HATCH",
		description = "Better chance for rare Colors and mutations.",
		icon = "LUCK",
		iconImage = "rbxthumb://type=GamePass&id=1823292559&w=150&h=150",
		price = 199,
		color = Color3.fromRGB(128, 239, 150),
		gamepassId = 1823292559,
		sortOrder = 20,
		badge = "POPULAR",
		luckMultiplier = 1.35,
	},
	{
		id = "SupportDev",
		displayName = "SUPPORT DEV",
		description = "Support Color Simulator and receive a special heart chat tag.",
		icon = "<3",
		iconImage = "rbxthumb://type=GamePass&id=1823390286&w=150&h=150",
		price = 99,
		color = Color3.fromRGB(255, 162, 196),
		gamepassId = 1823390286,
		sortOrder = 60,
		badge = "THANK YOU",
		earlySupporterTag = true,
	},
}

RobuxShopConfig.DevProducts = {
	{
		id = "Coins1k",
		displayName = "1,000 Coins",
		description = "Instantly receive 1,000 Coins.",
		icon = "1K",
		price = 49,
		color = Color3.fromRGB(255, 230, 100),
		productId = 0,
		showInShop = false,
		coinReward = 1000,
	},
	{
		id = "Coins10k",
		displayName = "10,000 Coins",
		description = "Instantly receive 10,000 Coins.",
		icon = "10K",
		price = 399,
		color = Color3.fromRGB(255, 200, 50),
		productId = 0,
		showInShop = false,
		coinReward = 10000,
		badge = "BEST VALUE",
	},
	{
		id = "Coins100k",
		displayName = "100,000 Coins",
		description = "Instantly receive 100,000 Coins.",
		icon = "100K",
		price = 999,
		color = Color3.fromRGB(220, 160, 0),
		productId = 0,
		showInShop = false,
		coinReward = 100000,
		badge = "MEGA PACK",
	},
}

function RobuxShopConfig.getGamepass(passId)
	for _, pass in ipairs(RobuxShopConfig.Gamepasses) do
		if pass.id == passId then
			return pass
		end
	end
	return nil
end

function RobuxShopConfig.getGamepassByRobloxId(gamepassId)
	gamepassId = tonumber(gamepassId)
	for _, pass in ipairs(RobuxShopConfig.Gamepasses) do
		if tonumber(pass.gamepassId) == gamepassId then
			return pass
		end
	end
	return nil
end

function RobuxShopConfig.getSortedGamepasses()
	local passes = {}
	for _, pass in ipairs(RobuxShopConfig.Gamepasses) do
		if pass.showInShop ~= false then
			table.insert(passes, pass)
		end
	end
	table.sort(passes, function(a, b)
		return (a.sortOrder or 999) < (b.sortOrder or 999)
	end)
	return passes
end

function RobuxShopConfig.getSortedDevProducts()
	local products = {}
	for _, product in ipairs(RobuxShopConfig.DevProducts or {}) do
		if product.showInShop ~= false and tonumber(product.productId) and tonumber(product.productId) > 0 then
			table.insert(products, product)
		end
	end
	table.sort(products, function(a, b)
		return (a.sortOrder or 999) < (b.sortOrder or 999)
	end)
	return products
end

return RobuxShopConfig
]]></string>
      </Properties>
    </Item>
    <Item class="ModuleScript" referent="54">
      <Properties>
        <string name="Name">SettingsData</string>
        <string name="Source"><![CDATA[local SettingsData = {}

SettingsData.Defaults = {
	Music = true,
	SFX = true,
	Popups = true,
	LowFX = false,
}

SettingsData.AllowedKeys = {
	Music = true,
	SFX = true,
	Popups = true,
	LowFX = true,
}

function SettingsData.IsAllowedKey(key)
	return SettingsData.AllowedKeys[tostring(key or "")] == true
end

function SettingsData.Normalize(settings)
	local normalized = {}
	for key, defaultValue in pairs(SettingsData.Defaults) do
		local value = type(settings) == "table" and settings[key]
		normalized[key] = type(value) == "boolean" and value or defaultValue
	end
	return normalized
end

return SettingsData
]]></string>
      </Properties>
    </Item>
    <Item class="ModuleScript" referent="55">
      <Properties>
        <string name="Name">StudioMapCleaner</string>
        <string name="Source"><![CDATA[-- ModuleScript in ReplicatedStorage named "StudioMapCleaner".
-- Run in Studio edit mode from the command bar:
-- require(game.ReplicatedStorage.StudioMapCleaner).toneDownExisting()
local StudioMapCleaner = {}

local MAP_NAME = "ColorSimulatorMap"

local THEME = {
	Red = { color = Color3.fromRGB(210, 82, 82), accent = Color3.fromRGB(150, 70, 70), material = Enum.Material.SmoothPlastic },
	Blue = { color = Color3.fromRGB(72, 132, 210), accent = Color3.fromRGB(80, 125, 170), material = Enum.Material.Sand },
	Yellow = { color = Color3.fromRGB(215, 190, 76), accent = Color3.fromRGB(155, 135, 70), material = Enum.Material.Sand },
	Green = { color = Color3.fromRGB(82, 175, 95), accent = Color3.fromRGB(70, 125, 78), material = Enum.Material.Grass },
	Purple = { color = Color3.fromRGB(132, 82, 185), accent = Color3.fromRGB(105, 70, 145), material = Enum.Material.Slate },
	Neon = { color = Color3.fromRGB(46, 170, 150), accent = Color3.fromRGB(30, 115, 108), material = Enum.Material.SmoothPlastic },
	Rainbow = { color = Color3.fromRGB(178, 190, 215), accent = Color3.fromRGB(135, 110, 165), material = Enum.Material.SmoothPlastic },
}

local function toneBreakable(part)
	if part:GetAttribute("BreakableType") then
		local colorType = part:GetAttribute("ColorType")
		local theme = THEME[colorType]
		part.Material = Enum.Material.SmoothPlastic
		if theme then
			part.Color = colorType == "Rainbow" and Color3.fromRGB(215, 180, 255) or theme.color
		end

		local light = part:FindFirstChildOfClass("PointLight")
		if light then
			light.Brightness = 0.08
			light.Range = math.max(2, part.Size.X * 0.9)
		end

		local fx = part:FindFirstChild("IdleColorFx")
		local motes = fx and fx:FindFirstChild("GlowMotes")
		if motes and motes:IsA("ParticleEmitter") then
			motes.Rate = 0.75
			motes.LightEmission = 0.2
		end
	end
end

function StudioMapCleaner.toneDownExisting()
	local map = workspace:FindFirstChild(MAP_NAME)
	if not map then
		warn("StudioMapCleaner: no " .. MAP_NAME .. " found.")
		return nil
	end

	for _, obj in ipairs(map:GetDescendants()) do
		if obj:IsA("BillboardGui") or obj:IsA("SurfaceGui") then
			obj:Destroy()
		elseif obj:IsA("BasePart") then
			local colorType = obj:GetAttribute("ColorType")
			local theme = colorType and THEME[colorType]

			if obj:GetAttribute("ColorZone") and theme then
				obj.Color = theme.color
				obj.Material = theme.material
				obj.Transparency = 0
			elseif obj:GetAttribute("AreaGate") then
				obj.Color = Color3.fromRGB(75, 82, 105)
				obj.Material = Enum.Material.Glass
				obj.Transparency = 0.25
			elseif obj:GetAttribute("AreaSpawn") and theme then
				obj.Color = theme.accent
				obj.Material = Enum.Material.SmoothPlastic
				obj.Transparency = 0
			elseif obj:GetAttribute("EggId") then
				obj.Material = Enum.Material.SmoothPlastic
				obj.Transparency = 0
			elseif obj.Name == "SellZone" then
				obj.Color = Color3.fromRGB(88, 190, 72)
				obj.Material = Enum.Material.SmoothPlastic
				obj.Transparency = 0
			elseif string.find(obj.Name, "Border") or string.find(obj.Name, "BuildMarker") then
				if theme then
					obj.Color = theme.accent
				end
				obj.Material = Enum.Material.SmoothPlastic
				obj.Transparency = 0.25
			end

			toneBreakable(obj)
		end
	end

	print("StudioMapCleaner: toned down " .. MAP_NAME .. " and removed floating labels.")
	return map
end

return StudioMapCleaner
]]></string>
      </Properties>
    </Item>
    <Item class="ModuleScript" referent="56">
      <Properties>
        <string name="Name">StudioMenuWindowsBuilder</string>
        <string name="Source"><![CDATA[-- Studio-only helper for creating editable menu window shells in StarterGui.
-- Run from the Studio command bar in edit mode:
-- require(game.ReplicatedStorage.StudioMenuWindowsBuilder).Build()
local RunService = game:GetService("RunService")
local StarterGui = game:GetService("StarterGui")

local Builder = {}

local function findOrCreate(parent, className, name)
	local existing = parent:FindFirstChild(name)
	if existing then
		return existing, false
	end
	local instance = Instance.new(className)
	instance.Name = name
	instance.Parent = parent
	return instance, true
end

local function applyCorner(instance, radius)
	local corner = instance:FindFirstChildOfClass("UICorner") or Instance.new("UICorner")
	corner.CornerRadius = UDim.new(0, radius or 18)
	corner.Parent = instance
	return corner
end

local function applyStroke(instance, color, thickness)
	local stroke = instance:FindFirstChildOfClass("UIStroke") or Instance.new("UIStroke")
	stroke.Color = color or Color3.fromRGB(35, 38, 45)
	stroke.Thickness = thickness or 3
	stroke.Parent = instance
	return stroke
end

local function text(parent, name, value, position, size, textSize)
	local label, created = findOrCreate(parent, "TextLabel", name)
	if created then
		label.BackgroundTransparency = 1
		label.Font = Enum.Font.GothamBlack
		label.TextColor3 = Color3.fromRGB(38, 36, 52)
		label.TextStrokeColor3 = Color3.fromRGB(255, 255, 255)
		label.TextStrokeTransparency = 0.35
		label.TextXAlignment = Enum.TextXAlignment.Left
		label.TextYAlignment = Enum.TextYAlignment.Center
	end
	label.Text = value
	label.Position = position
	label.Size = size
	label.TextSize = textSize or 22
	return label
end

local function button(parent, name, value, position, size, color)
	local btn, created = findOrCreate(parent, "TextButton", name)
	if created then
		btn.AutoButtonColor = true
		btn.Font = Enum.Font.GothamBlack
		btn.TextColor3 = Color3.fromRGB(255, 255, 255)
		btn.TextStrokeColor3 = Color3.fromRGB(35, 38, 45)
		btn.TextStrokeTransparency = 0
	end
	btn.Text = value
	btn.Position = position
	btn.Size = size
	btn.BackgroundColor3 = color or Color3.fromRGB(84, 225, 112)
	btn.BorderSizePixel = 0
	applyCorner(btn, 12)
	applyStroke(btn, Color3.fromRGB(35, 38, 45), 2)
	return btn
end

local function frame(parent, name, position, size, color)
	local f, created = findOrCreate(parent, "Frame", name)
	if created then
		f.BorderSizePixel = 0
	end
	f.Position = position
	f.Size = size
	f.BackgroundColor3 = color or Color3.fromRGB(255, 255, 255)
	applyCorner(f, 18)
	applyStroke(f, Color3.fromRGB(35, 38, 45), 2)
	return f
end

local function makeTabs(window, names)
	local tabs = frame(window, "Tabs", UDim2.fromOffset(22, 68), UDim2.new(1, -44, 0, 40), Color3.fromRGB(255, 255, 255))
	tabs.BackgroundTransparency = 1
	local layout = tabs:FindFirstChildOfClass("UIListLayout") or Instance.new("UIListLayout")
	layout.FillDirection = Enum.FillDirection.Horizontal
	layout.HorizontalAlignment = Enum.HorizontalAlignment.Left
	layout.VerticalAlignment = Enum.VerticalAlignment.Center
	layout.Padding = UDim.new(0, 10)
	layout.SortOrder = Enum.SortOrder.LayoutOrder
	layout.Parent = tabs

	for index, tabName in ipairs(names) do
		local tab = button(tabs, tabName .. "Tab", tabName, UDim2.fromOffset(0, 0), UDim2.fromOffset(118, 34), index == 1 and Color3.fromRGB(82, 219, 225) or Color3.fromRGB(232, 238, 248))
		tab.LayoutOrder = index
		tab.TextColor3 = index == 1 and Color3.fromRGB(255, 255, 255) or Color3.fromRGB(38, 36, 52)
	end
	return tabs
end

local function makeWindow(windowsFolder, name, title, tabs)
	local window = frame(windowsFolder, name, UDim2.fromScale(0.5, 0.43), UDim2.fromOffset(780, 470), Color3.fromRGB(255, 255, 255))
	window.AnchorPoint = Vector2.new(0.5, 0.5)
	window.Visible = false
	window.ClipsDescendants = false
	applyCorner(window, 24)
	applyStroke(window, Color3.fromRGB(35, 38, 45), 4)

	text(window, "Title", title, UDim2.fromOffset(24, 14), UDim2.new(1, -112, 0, 42), 30)
	button(window, "CloseButton", "X", UDim2.new(1, -70, 0, 14), UDim2.fromOffset(52, 48), Color3.fromRGB(188, 21, 28))
	if tabs and #tabs > 0 then
		makeTabs(window, tabs)
	end

	local content = frame(window, "Content", UDim2.fromOffset(22, tabs and 122 or 82), UDim2.new(1, -44, 1, tabs and -148 or -108), Color3.fromRGB(244, 248, 252))
	content.ClipsDescendants = false
	return window, content
end

local function makeInventory(windowsFolder)
	local window, content = makeWindow(windowsFolder, "InventoryWindow", "INVENTORY", { "Colors", "Brushes", "Potions", "Items" })
	local grid = frame(content, "ItemGrid", UDim2.fromOffset(12, 12), UDim2.new(0.62, -20, 1, -24), Color3.fromRGB(246, 249, 255))
	local details = frame(content, "DetailsPanel", UDim2.new(0.64, 0, 0, 12), UDim2.new(0.36, -12, 1, -24), Color3.fromRGB(239, 246, 255))
	text(details, "SelectLabel", "Select an Item", UDim2.fromOffset(14, 12), UDim2.new(1, -28, 0, 36), 22).TextXAlignment = Enum.TextXAlignment.Center
	for i = 1, 8 do
		local x = ((i - 1) % 4) * 104 + 14
		local y = math.floor((i - 1) / 4) * 104 + 14
		local slot = frame(grid, "Slot" .. i, UDim2.fromOffset(x, y), UDim2.fromOffset(92, 92), Color3.fromRGB(235, 239, 246))
		text(slot, "Icon", "IMG", UDim2.fromScale(0, 0), UDim2.fromScale(1, 1), 18).TextXAlignment = Enum.TextXAlignment.Center
	end
	button(details, "EquipButton", "EQUIP", UDim2.new(0, 14, 1, -132), UDim2.new(1, -28, 0, 34), Color3.fromRGB(84, 225, 112))
	button(details, "LockButton", "LOCK", UDim2.new(0, 14, 1, -90), UDim2.new(1, -28, 0, 34), Color3.fromRGB(88, 174, 255))
	button(details, "DeleteButton", "DELETE", UDim2.new(0, 14, 1, -48), UDim2.new(1, -28, 0, 34), Color3.fromRGB(220, 46, 58))
	return window
end

local function makeCardGrid(content, names)
	for index, item in ipairs(names) do
		local x = ((index - 1) % 3) * 238 + 14
		local y = math.floor((index - 1) / 3) * 132 + 14
		local card = frame(content, item:gsub("%s+", "") .. "Card", UDim2.fromOffset(x, y), UDim2.fromOffset(222, 118), Color3.fromRGB(255, 255, 255))
		local icon = frame(card, "Icon", UDim2.fromOffset(10, 10), UDim2.fromOffset(58, 58), Color3.fromRGB(225, 244, 255))
		text(icon, "IconText", item:sub(1, 2):upper(), UDim2.fromScale(0, 0), UDim2.fromScale(1, 1), 18).TextXAlignment = Enum.TextXAlignment.Center
		text(card, "Name", item, UDim2.fromOffset(78, 8), UDim2.new(1, -88, 0, 28), 17)
		text(card, "Description", "Editable item card.", UDim2.fromOffset(78, 38), UDim2.new(1, -88, 0, 34), 12)
		text(card, "Price", "Price", UDim2.fromOffset(10, 76), UDim2.fromOffset(90, 28), 13)
		button(card, "BuyButton", "BUY", UDim2.new(1, -110, 1, -42), UDim2.fromOffset(96, 32), Color3.fromRGB(84, 225, 112))
	end
end

local function makeShopTemplates(shopWindow)
	local templates = findOrCreate(shopWindow, "Folder", "Templates")
	local card, created = findOrCreate(templates, "Frame", "ShopCardTemplate")
	card.Visible = false
	card.Size = UDim2.new(1, -6, 0, 116)
	card.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
	card.BorderSizePixel = 0
	applyCorner(card, 12)
	applyStroke(card, Color3.fromRGB(35, 38, 45), 2)

	local icon = frame(card, "Icon", UDim2.fromOffset(12, 14), UDim2.fromOffset(72, 72), Color3.fromRGB(244, 248, 252))
	text(icon, "IconText", "VIP", UDim2.fromScale(0, 0), UDim2.fromScale(1, 1), 20).TextXAlignment = Enum.TextXAlignment.Center

	local image = icon:FindFirstChild("IconImage")
	if not image then
		image = Instance.new("ImageLabel")
		image.Name = "IconImage"
		image.Parent = icon
	end
	image.BackgroundTransparency = 1
	image.Size = UDim2.fromScale(1, 1)
	image.Visible = false

	text(card, "Name", "Product", UDim2.fromOffset(96, 10), UDim2.new(1, -238, 0, 26), 18)
	text(card, "Description", "Description", UDim2.fromOffset(96, 38), UDim2.new(1, -238, 0, 40), 13)
	text(card, "Badge", "BADGE", UDim2.fromOffset(96, 80), UDim2.new(1, -238, 0, 22), 12)
	text(card, "Price", "R$ 0", UDim2.new(1, -130, 0, 14), UDim2.fromOffset(112, 24), 14).TextXAlignment = Enum.TextXAlignment.Center
	button(card, "BuyButton", "BUY", UDim2.new(1, -130, 1, -48), UDim2.fromOffset(112, 34), Color3.fromRGB(84, 225, 112))

	if created then
		print("StudioMenuWindowsBuilder: created ShopWindow.Templates.ShopCardTemplate")
	end
end

function Builder.Build()
	if not RunService:IsStudio() then
		warn("StudioMenuWindowsBuilder.Build can only run in Roblox Studio.")
		return
	end
	if RunService:IsRunning() then
		warn("StudioMenuWindowsBuilder.Build should be run in edit mode, not during Play.")
		return
	end

	local root = findOrCreate(StarterGui, "ScreenGui", "ClientUIRoot")
	root.ResetOnSpawn = false
	root.IgnoreGuiInset = false
	root.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
	root.DisplayOrder = math.max(root.DisplayOrder, 100)

	local mainHud = frame(root, "MainHUD", UDim2.fromScale(0, 0), UDim2.fromScale(1, 1), Color3.fromRGB(255, 255, 255))
	mainHud.BackgroundTransparency = 1
	mainHud.Visible = true
	mainHud.ClipsDescendants = false

	findOrCreate(mainHud, "Frame", "CurrencyBar").BackgroundTransparency = 1
	findOrCreate(mainHud, "Frame", "BottomRow").BackgroundTransparency = 1
	local dim = findOrCreate(mainHud, "TextButton", "DimBackground")
	dim.Size = UDim2.fromScale(1, 1)
	dim.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
	dim.BackgroundTransparency = 0.45
	dim.AutoButtonColor = false
	dim.ZIndex = 10
	dim.Text = ""
	dim.Visible = false

	local modalWindows = findOrCreate(mainHud, "Folder", "ModalWindows")
	local windowsFolder = findOrCreate(modalWindows, "Folder", "Windows")
	makeInventory(windowsFolder)
	local shopWindow = makeWindow(windowsFolder, "ShopWindow", "ROBUX SHOP", { "Bundles", "Gamepasses", "Potions", "Currency" })
	makeShopTemplates(shopWindow)
	local _, upgradesContent = makeWindow(windowsFolder, "UpgradesWindow", "UPGRADES", { "Player", "Colors", "Rank" })
	makeCardGrid(upgradesContent, { "Walk Speed", "Brush Power", "Coin Boost", "Gem Luck" })
	local _, settingsContent = makeWindow(windowsFolder, "SettingsWindow", "SETTINGS", {})
	makeCardGrid(settingsContent, { "Music", "SFX", "Hide Pets", "Low Detail", "Auto Delete" })
	local _, codesContent = makeWindow(windowsFolder, "CodesWindow", "CODES", {})
	makeCardGrid(codesContent, { "CodeBox", "RedeemButton", "InfoText", "RecentRewards" })
	local _, tradeContent = makeWindow(windowsFolder, "TradeWindow", "TRADE", {})
	text(tradeContent, "ComingSoon", "Trading is coming soon!", UDim2.fromScale(0, 0.35), UDim2.fromScale(1, 0.18), 28).TextXAlignment = Enum.TextXAlignment.Center
	local _, worldsContent = makeWindow(windowsFolder, "WorldsWindow", "WORLDS", {})
	makeCardGrid(worldsContent, { "Origin Sector", "Red Wastelands", "Orange Sector", "Inside Pipes" })
	local _, questsContent = makeWindow(windowsFolder, "DailyQuestsWindow", "DAILY QUESTS", {})
	makeCardGrid(questsContent, { "Clean Color Spills", "Earn Coins", "Hatch Colors" })

	print("StudioMenuWindowsBuilder: editable UI created at StarterGui.ClientUIRoot.MainHUD.ModalWindows.Windows")
end

return Builder
]]></string>
      </Properties>
    </Item>
    <Item class="ModuleScript" referent="57">
      <Properties>
        <string name="Name">StudioPetAppearanceBuilder</string>
        <string name="Source"><![CDATA[local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Workspace = game:GetService("Workspace")

local PetData = require(ReplicatedStorage:WaitForChild("PetData"))
local ColorData = require(ReplicatedStorage:WaitForChild("ColorData"))
local PetModelUtil = require(ReplicatedStorage:WaitForChild("Modules"):WaitForChild("PetModelUtil"))

local StudioPetAppearanceBuilder = {}

local SOURCE_NAME = "PetAppearanceStudio"
local ORIGIN = Vector3.new(50000, 5000, 50000)
local ROW_SPACING = 35
local PET_SPACING = 14

local function isVisualObject(object)
	return object and (object:IsA("Model") or object:IsA("BasePart"))
end

local function getOrCreateSource()
	local source = Workspace:FindFirstChild(SOURCE_NAME)
	if not source then
		source = Instance.new("Folder")
		source.Name = SOURCE_NAME
		source:SetAttribute("EditablePetAppearanceSource", true)
		source.Parent = Workspace
	end
	return source
end

local function getSortedChildren(parent)
	local children = parent:GetChildren()
	table.sort(children, function(a, b)
		return a.Name < b.Name
	end)
	return children
end

local function getOrCreateFolder(parent, name)
	local folder = parent:FindFirstChild(name)
	if not folder then
		folder = Instance.new("Folder")
		folder.Name = name
		folder.Parent = parent
	end
	return folder
end

local function makePreviewPart(model, name, shape, size, cframe, color, material, transparency)
	local part = Instance.new("Part")
	part.Name = name
	part.Shape = shape or Enum.PartType.Ball
	part.Size = size
	part.CFrame = cframe or CFrame.new()
	part.Color = color
	part.Material = material or Enum.Material.SmoothPlastic
	part.Transparency = transparency or 0
	part.Anchored = true
	part.CanCollide = false
	part.CanTouch = false
	part.CanQuery = false
	part.CastShadow = false
	part.Parent = model
	return part
end

local function createEggModel(eggId, egg)
	local model = Instance.new("Model")
	model.Name = "EggModel"
	model:SetAttribute("EggId", eggId)
	model:SetAttribute("DisplayName", egg.displayName or eggId)

	local color = egg.color or Color3.fromRGB(255, 255, 255)
	local dark = color:Lerp(Color3.fromRGB(30, 32, 42), 0.32)
	local light = color:Lerp(Color3.fromRGB(255, 255, 255), 0.5)

	local core = makePreviewPart(model, "Core", Enum.PartType.Ball, Vector3.new(4.4, 5.4, 4.4), CFrame.new(0, 2.7, 0), color, Enum.Material.SmoothPlastic)
	model.PrimaryPart = core
	makePreviewPart(model, "LowerBand", Enum.PartType.Cylinder, Vector3.new(0.26, 4.7, 4.7), CFrame.new(0, 1.55, 0) * CFrame.Angles(0, 0, math.rad(90)), dark, Enum.Material.SmoothPlastic, 0.05)
	makePreviewPart(model, "UpperBand", Enum.PartType.Cylinder, Vector3.new(0.22, 3.9, 3.9), CFrame.new(0, 3.72, 0) * CFrame.Angles(0, 0, math.rad(90)), light, Enum.Material.SmoothPlastic, 0.12)
	makePreviewPart(model, "Highlight", Enum.PartType.Ball, Vector3.new(0.8, 1.15, 0.24), CFrame.new(-1.2, 4, -1.6) * CFrame.Angles(0, math.rad(-25), math.rad(-15)), Color3.fromRGB(255, 255, 255), Enum.Material.SmoothPlastic, 0.1)

	local lightObject = Instance.new("PointLight")
	lightObject.Name = "EggGlow"
	lightObject.Color = color
	lightObject.Brightness = 1.1
	lightObject.Range = 12
	lightObject.Parent = core

	return model
end

local function applyPetAttributes(petObject, eggId, entry)
	local pet = PetData.Pets[entry.petId]
	petObject:SetAttribute("EggId", eggId)
	petObject:SetAttribute("PetId", entry.petId)
	petObject:SetAttribute("Weight", tonumber(entry.chance) or tonumber(entry.weight) or 1)
	petObject:SetAttribute("Rarity", pet and pet.rarity or "Common")
	petObject:SetAttribute("DisplayName", pet and pet.displayName or entry.petId)
end

local function createPetTemplate(entry)
	local petId = entry.petId
	local clone = PetModelUtil.ClonePetModel(petId, { anchored = true, removeBillboards = true })
	if clone and clone:IsA("Model") then
		clone.Name = petId
		return clone
	end

	local pet = PetData.Pets[petId]
	if not pet then
		return nil
	end

	local model = Instance.new("Model")
	model.Name = petId
	local core = makePreviewPart(model, "Core", Enum.PartType.Ball, Vector3.new(2.2, 2.2, 2.2), CFrame.new(0, 1.1, 0), pet.color or Color3.fromRGB(255, 255, 255), Enum.Material.SmoothPlastic)
	model.PrimaryPart = core
	return model
end

local function preparePreviewObject(object)
	for _, part in ipairs(object:GetDescendants()) do
		if part:IsA("BasePart") then
			part.Anchored = true
			part.CanCollide = false
		end
	end

	if object:IsA("BasePart") then
		object.Anchored = true
		object.CanCollide = false
	end
end

local function findPrimary(model)
	if model.PrimaryPart then
		return model.PrimaryPart
	end
	local core = model:FindFirstChild("Core", true)
	if core and core:IsA("BasePart") then
		model.PrimaryPart = core
		return core
	end
	local first = model:FindFirstChildWhichIsA("BasePart", true)
	if first then
		model.PrimaryPart = first
		return first
	end
	return nil
end

local function pivotObject(object, cframe)
	if object:IsA("Model") then
		findPrimary(object)
		object:PivotTo(cframe)
	elseif object:IsA("BasePart") then
		object.CFrame = cframe
	end
end

local function getBounds(object)
	if object:IsA("Model") then
		return object:GetBoundingBox()
	elseif object:IsA("BasePart") then
		return object.CFrame, object.Size
	end
	return CFrame.new(), Vector3.new(4, 4, 4)
end

local function placeOnGround(object, position, yawDegrees)
	preparePreviewObject(object)
	local yaw = math.rad(yawDegrees or 0)
	pivotObject(object, CFrame.new(position) * CFrame.Angles(0, yaw, 0))

	local boundsCFrame, boundsSize = getBounds(object)
	local bottomY = boundsCFrame.Position.Y - boundsSize.Y / 2
	local yOffset = ORIGIN.Y - bottomY
	local currentCFrame = object:IsA("Model") and object:GetPivot() or object.CFrame
	pivotObject(object, currentCFrame + Vector3.new(0, yOffset, 0))
end

local function addPreviewLabel(object, text)
	local oldLabel = object:FindFirstChild("PreviewLabel", true)
	if oldLabel and oldLabel:GetAttribute("PreviewOnly") == true then
		oldLabel:Destroy()
	end

	local holder
	if object:IsA("Model") then
		holder = findPrimary(object)
	elseif object:IsA("BasePart") then
		holder = object
	end
	if not holder then
		return
	end

	local billboard = Instance.new("BillboardGui")
	billboard.Name = "PreviewLabel"
	billboard:SetAttribute("PreviewOnly", true)
	billboard.Size = UDim2.fromOffset(190, 64)
	billboard.StudsOffset = Vector3.new(0, 5, 0)
	billboard.AlwaysOnTop = true
	billboard.Parent = holder

	local label = Instance.new("TextLabel")
	label.Name = "Text"
	label:SetAttribute("PreviewOnly", true)
	label.BackgroundTransparency = 1
	label.Size = UDim2.fromScale(1, 1)
	label.Font = Enum.Font.GothamBold
	label.TextSize = 14
	label.TextColor3 = Color3.fromRGB(255, 255, 255)
	label.TextStrokeTransparency = 0
	label.Text = text
	label.Parent = billboard
end

function StudioPetAppearanceBuilder.Build()
	local source = getOrCreateSource()
	local createdPets = 0
	local createdEggs = 0

	for _, eggId in ipairs(PetData.EggOrder or {}) do
		local egg = PetData.Eggs[eggId]
		if not egg then
			continue
		end

		local eggFolder = getOrCreateFolder(source, eggId)
		eggFolder:SetAttribute("EggId", eggId)
		eggFolder:SetAttribute("DisplayName", egg.displayName or eggId)

		if not isVisualObject(eggFolder:FindFirstChild("EggModel")) then
			local eggModel = createEggModel(eggId, egg)
			eggModel.Parent = eggFolder
			createdEggs += 1
		end

		local petsFolder = getOrCreateFolder(eggFolder, "Pets")
		for _, entry in ipairs(egg.pets or {}) do
			if not entry.petId then
				continue
			end
			local petObject = petsFolder:FindFirstChild(entry.petId)
			if not isVisualObject(petObject) then
				petObject = createPetTemplate(entry)
				if petObject then
					petObject.Parent = petsFolder
					createdPets += 1
				end
			end
			if petObject then
				applyPetAttributes(petObject, eggId, entry)
			end
		end
	end

	StudioPetAppearanceBuilder.Arrange()
	print("StudioPetAppearanceBuilder: ready at Workspace." .. SOURCE_NAME .. " with " .. tostring(createdEggs) .. " new egg models and " .. tostring(createdPets) .. " new Color models.")
	return source
end

function StudioPetAppearanceBuilder.Arrange()
	local source = getOrCreateSource()
	local row = 0

	for _, eggFolder in ipairs(getSortedChildren(source)) do
		if not (eggFolder:IsA("Folder") or eggFolder:IsA("Model")) then
			continue
		end

		local rowOrigin = ORIGIN + Vector3.new(0, 0, row * ROW_SPACING)
		local eggModel = eggFolder:FindFirstChild("EggModel")
		if isVisualObject(eggModel) then
			placeOnGround(eggModel, rowOrigin, 0)
			addPreviewLabel(eggModel, eggFolder.Name .. "\nEGG")
		end

		local petsFolder = eggFolder:FindFirstChild("Pets")
		if petsFolder then
			local column = 1
			for _, pet in ipairs(getSortedChildren(petsFolder)) do
				if isVisualObject(pet) then
					local petPosition = rowOrigin + Vector3.new(column * PET_SPACING, 0, 0)
					placeOnGround(pet, petPosition, 0)

					local rarity = pet:GetAttribute("Rarity")
					local weight = pet:GetAttribute("Weight")
					local labelText = pet.Name
					if rarity then
						labelText ..= "\n" .. tostring(rarity)
					end
					if weight ~= nil then
						labelText ..= "\nWeight: " .. tostring(weight)
					end
					addPreviewLabel(pet, labelText)
					column += 1
				end
			end
		end

		row += 1
	end

	print("StudioPetAppearanceBuilder: arranged PetAppearanceStudio at " .. tostring(ORIGIN) .. ". Select it in Explorer and press F to jump there.")
	return source
end

StudioPetAppearanceBuilder.BuildAndArrange = StudioPetAppearanceBuilder.Build

return StudioPetAppearanceBuilder
]]></string>
      </Properties>
    </Item>
    <Item class="ModuleScript" referent="58">
      <Properties>
        <string name="Name">StudioSectorInteriorBuilder</string>
        <string name="Source"><![CDATA[-- Studio-only builder for editable sector interiors.
-- Command bar:
-- require(game.ReplicatedStorage.StudioSectorInteriorBuilder).BuildOrangeMutationInterior({ overwrite = true })
-- require(game.ReplicatedStorage.StudioSectorInteriorBuilder).BuildZorkOnPads()

local RunService = game:GetService("RunService")
local Workspace = game:GetService("Workspace")

local Builder = {}

local MAP_NAME = "ColorSimulatorMap"
local INTERIORS_FOLDER_NAME = "SectorInteriors"
local PIPES_FOLDER_NAME = "SectorPipes"
local ZORK_NAME = "Zork"

local COLORS = {
	Dark = Color3.fromRGB(17, 17, 20),
	Cyan = Color3.fromRGB(68, 218, 240),
	Orange = Color3.fromRGB(255, 132, 32),
	OrangeDark = Color3.fromRGB(172, 64, 16),
	OrangeDeep = Color3.fromRGB(98, 34, 14),
	Yellow = Color3.fromRGB(255, 216, 82),
	Green = Color3.fromRGB(125, 255, 112),
	Purple = Color3.fromRGB(145, 84, 255),
	White = Color3.fromRGB(255, 248, 232),
}

local function assertStudio()
	if not RunService:IsStudio() or RunService:IsRunning() then
		warn("StudioSectorInteriorBuilder: run this from the Studio command bar in edit mode.")
		return false
	end
	return true
end

local function getOrCreateFolder(parent, name)
	local folder = parent:FindFirstChild(name)
	if not folder then
		folder = Instance.new("Folder")
		folder.Name = name
		folder.Parent = parent
	end
	return folder
end

local function getMap()
	local map = Workspace:FindFirstChild(MAP_NAME)
	if not map then
		map = Instance.new("Folder")
		map.Name = MAP_NAME
		map.Parent = Workspace
	end
	return map
end

local function destroyIfOverwrite(parent, name, overwrite)
	local existing = parent:FindFirstChild(name)
	if existing and overwrite then
		existing:Destroy()
		return nil
	end
	return existing
end

local function makePart(parent, name, size, cframe, color, material, transparency)
	local part = parent:FindFirstChild(name)
	if not part then
		part = Instance.new("Part")
		part.Name = name
		part.Parent = parent
	end
	part.Size = size
	part.CFrame = cframe
	part.Color = color
	part.Material = material or Enum.Material.SmoothPlastic
	part.Transparency = transparency or 0
	part.Anchored = true
	part.CanCollide = true
	part.CanTouch = false
	part.CanQuery = true
	part.CastShadow = false
	part.TopSurface = Enum.SurfaceType.Smooth
	part.BottomSurface = Enum.SurfaceType.Smooth
	return part
end

local function makeCylinder(parent, name, size, cframe, color, material, transparency)
	local part = makePart(parent, name, size, cframe, color, material, transparency)
	part.Shape = Enum.PartType.Cylinder
	return part
end

local function makePrompt(parent, name, objectText, actionText, distance)
	local prompt = parent:FindFirstChild(name)
	if not prompt then
		prompt = Instance.new("ProximityPrompt")
		prompt.Name = name
		prompt.Parent = parent
	end
	prompt.ObjectText = objectText
	prompt.ActionText = actionText
	prompt.KeyboardKeyCode = Enum.KeyCode.E
	prompt.GamepadKeyCode = Enum.KeyCode.ButtonX
	prompt.HoldDuration = 0
	prompt.MaxActivationDistance = distance or 14
	prompt.RequiresLineOfSight = false
	return prompt
end

local function setShopAttrs(instance, colorType)
	instance:SetAttribute("BrushShop", true)
	instance:SetAttribute("CombinedShop", true)
	instance:SetAttribute("ShopStation", true)
	instance:SetAttribute("BrushNpc", true)
	instance:SetAttribute("ColorType", colorType)
	instance:SetAttribute("AreaColor", colorType)
	instance:SetAttribute("ShopColor", colorType)
end

local function setInteriorAttrs(instance, colorType)
	instance:SetAttribute("SectorInterior", true)
	instance:SetAttribute("SectorColor", colorType)
	instance:SetAttribute("ColorType", colorType)
	instance:SetAttribute("AreaColor", colorType)
	instance:SetAttribute("ColorZone", false)
	instance:SetAttribute("ColorBlobSpawn", false)
	instance:SetAttribute("DecorativeOnly", true)
end

local function addNameTag(core)
	local label = core:FindFirstChild("BrushNpcLabel")
	if not label then
		label = Instance.new("BillboardGui")
		label.Name = "BrushNpcLabel"
		label.Parent = core
	end
	label.AlwaysOnTop = true
	label.LightInfluence = 0
	label.MaxDistance = 70
	label.Size = UDim2.fromOffset(190, 58)
	label.StudsOffset = Vector3.new(0, 4.7, 0)

	local background = label:FindFirstChild("Background")
	if not background then
		background = Instance.new("Frame")
		background.Name = "Background"
		background.Parent = label
	end
	background.AnchorPoint = Vector2.new(0.5, 0.5)
	background.Position = UDim2.fromScale(0.5, 0.5)
	background.Size = UDim2.new(1, -14, 1, -8)
	background.BackgroundColor3 = Color3.fromRGB(24, 28, 38)
	background.BackgroundTransparency = 0.18
	background.BorderSizePixel = 0
	local corner = background:FindFirstChildOfClass("UICorner") or Instance.new("UICorner")
	corner.CornerRadius = UDim.new(0, 12)
	corner.Parent = background
	local stroke = background:FindFirstChildOfClass("UIStroke") or Instance.new("UIStroke")
	stroke.Color = COLORS.Cyan
	stroke.Thickness = 2
	stroke.Transparency = 0.18
	stroke.Parent = background

	local name = label:FindFirstChild("Text")
	if not name then
		name = Instance.new("TextLabel")
		name.Name = "Text"
		name.Parent = label
	end
	name.Size = UDim2.new(1, -20, 0, 28)
	name.Position = UDim2.new(0, 10, 0, 6)
	name.BackgroundTransparency = 1
	name.Font = Enum.Font.GothamBlack
	name.TextSize = 20
	name.TextColor3 = COLORS.White
	name.TextStrokeTransparency = 0.35
	name.TextStrokeColor3 = COLORS.Dark
	name.Text = "Zork"

	local role = label:FindFirstChild("Role")
	if not role then
		role = Instance.new("TextLabel")
		role.Name = "Role"
		role.Parent = label
	end
	role.Size = UDim2.new(1, -20, 0, 20)
	role.Position = UDim2.new(0, 10, 0, 32)
	role.BackgroundTransparency = 1
	role.Font = Enum.Font.GothamBold
	role.TextSize = 12
	role.TextColor3 = Color3.fromRGB(170, 244, 248)
	role.TextStrokeTransparency = 0.65
	role.TextStrokeColor3 = COLORS.Dark
	role.Text = "Brush Merchant"
end

local function buildZorkAtPad(pad, colorType)
	colorType = colorType or pad:GetAttribute("ColorType") or pad:GetAttribute("SectorColor") or "Red"
	pad:SetAttribute("ZorkPad", true)
	pad:SetAttribute("ColorType", colorType)
	pad:SetAttribute("AreaColor", colorType)
	pad:SetAttribute("BrushShop", true)
	pad:SetAttribute("DecorativeOnly", true)

	local old = pad.Parent and pad.Parent:FindFirstChild(ZORK_NAME)
	if old and old:GetAttribute("BuiltFromZorkPad") == pad.Name then
		old:Destroy()
	end

	local npc = Instance.new("Model")
	npc.Name = ZORK_NAME
	npc:SetAttribute("BuiltFromZorkPad", pad.Name)
	npc.Parent = pad.Parent
	setShopAttrs(npc, colorType)

	local baseCFrame = pad.CFrame * CFrame.new(0, pad.Size.Y * 0.5 + 3.15, 0)
	local root = makePart(npc, "HumanoidRootPart", Vector3.new(2, 5, 2), baseCFrame, COLORS.Cyan, Enum.Material.SmoothPlastic, 1)
	root.CanCollide = false
	root.CanQuery = false
	npc.PrimaryPart = root

	local body = makePart(npc, "ColorBody", Vector3.new(3.2, 3.2, 3.2), baseCFrame, COLORS.Cyan, Enum.Material.Neon)
	body.Shape = Enum.PartType.Ball
	local core = makePart(npc, "ShopPromptCore", Vector3.new(3.8, 4.6, 3.8), baseCFrame, COLORS.Cyan, Enum.Material.SmoothPlastic, 1)
	core.CanCollide = false
	local head = makePart(npc, "ColorHead", Vector3.new(1.7, 1.7, 1.7), baseCFrame * CFrame.new(0, 2.35, 0), COLORS.Green, Enum.Material.Neon)
	head.Shape = Enum.PartType.Ball
	local glow = makeCylinder(npc, "ColorGlow", Vector3.new(4.3, 0.25, 4.3), baseCFrame * CFrame.new(0, -1.75, 0) * CFrame.Angles(0, 0, math.rad(90)), COLORS.Cyan, Enum.Material.Neon, 0.22)
	glow.CanCollide = false
	local handle = makeCylinder(npc, "BrushHandle", Vector3.new(0.28, 3.1, 0.28), baseCFrame * CFrame.new(1.75, 0.2, 0) * CFrame.Angles(0, 0, math.rad(24)), COLORS.Yellow, Enum.Material.SmoothPlastic)
	local bristles = makePart(npc, "BrushBristles", Vector3.new(0.8, 0.65, 0.8), baseCFrame * CFrame.new(2.35, 1.55, 0) * CFrame.Angles(0, 0, math.rad(24)), Color3.fromRGB(255, 85, 130), Enum.Material.Neon)
	bristles.Shape = Enum.PartType.Ball

	for _, part in ipairs({ root, body, core, head, glow, handle, bristles }) do
		part.CanCollide = false
		part.CanTouch = false
		setShopAttrs(part, colorType)
	end

	local prompt = makePrompt(core, "BrushShopPrompt", "Zork", "Talk", 14)
	prompt:SetAttribute("BrushShopPrompt", true)
	prompt:SetAttribute("CombinedShopPrompt", true)
	prompt:SetAttribute("BrushNpcDialogue", true)
	prompt:SetAttribute("NpcName", "Zork")
	prompt:SetAttribute("ColorType", colorType)
	prompt:SetAttribute("ShopColor", colorType)
	addNameTag(core)
	return npc
end

function Builder.BuildZorkOnPads()
	if not assertStudio() then
		return 0
	end

	local built = 0
	for _, obj in ipairs(Workspace:GetDescendants()) do
		if obj:IsA("BasePart") and (obj:GetAttribute("ZorkPad") == true or string.lower(obj.Name) == "zorkpad" or string.match(string.lower(obj.Name), "zorkpad$")) then
			buildZorkAtPad(obj)
			built += 1
		end
	end
	print("StudioSectorInteriorBuilder: baked Zork on " .. tostring(built) .. " Zork pad(s).")
	return built
end

local function findOrangeAnchor()
	local map = Workspace:FindFirstChild(MAP_NAME)
	local distant = map and map:FindFirstChild("DistantSectors")
	if distant then
		for _, obj in ipairs(distant:GetDescendants()) do
			if obj:IsA("BasePart") and (obj:GetAttribute("SectorColor") == "Orange" or obj:GetAttribute("ColorType") == "Orange") then
				return obj
			end
		end
	end
	local redFloor = map and map:FindFirstChild("RedFloor1", true)
	return redFloor
end

function Builder.BuildOrangeMutationInterior(options)
	if not assertStudio() then
		return nil
	end
	options = options or {}
	local overwrite = options.overwrite == true
	local map = getMap()
	local interiors = getOrCreateFolder(map, INTERIORS_FOLDER_NAME)
	local pipes = getOrCreateFolder(map, PIPES_FOLDER_NAME)
	local colorType = "Orange"

	local existingInterior = destroyIfOverwrite(interiors, "OrangeSectorInterior", overwrite)
	if existingInterior then
		warn("StudioSectorInteriorBuilder: OrangeSectorInterior already exists. Pass { overwrite = true } to rebuild it.")
		return existingInterior
	end
	local existingPipe = pipes:FindFirstChild("OrangeSectorPipe")
	if existingPipe and overwrite then
		existingPipe:Destroy()
	elseif existingPipe then
		warn("StudioSectorInteriorBuilder: OrangeSectorPipe already exists. Pass { overwrite = true } to rebuild it.")
		return existingPipe
	end

	local anchor = findOrangeAnchor()
	local anchorPos = anchor and anchor.Position or Vector3.new(0, 0, 0)
	local pipeOrigin = anchorPos + Vector3.new(48, 8, -42)
	local interiorOrigin = options.interiorOrigin or Vector3.new(1800, -420, 1800)

	local interior = Instance.new("Folder")
	interior.Name = "OrangeSectorInterior"
	interior.Parent = interiors

	local floor = makePart(interior, "OrangeInteriorFloor", Vector3.new(430, 3, 430), CFrame.new(interiorOrigin), COLORS.OrangeDeep, Enum.Material.SmoothPlastic)
	floor:SetAttribute("MutationUnlockArea", true)
	setInteriorAttrs(floor, colorType)

	local wallHeight = 180
	local wallY = interiorOrigin.Y + wallHeight * 0.5
	local walls = {
		makePart(interior, "OrangeWallNorth", Vector3.new(450, wallHeight, 14), CFrame.new(interiorOrigin.X, wallY, interiorOrigin.Z - 222), COLORS.Orange, Enum.Material.SmoothPlastic),
		makePart(interior, "OrangeWallSouth", Vector3.new(450, wallHeight, 14), CFrame.new(interiorOrigin.X, wallY, interiorOrigin.Z + 222), COLORS.OrangeDark, Enum.Material.SmoothPlastic),
		makePart(interior, "OrangeWallEast", Vector3.new(14, wallHeight, 450), CFrame.new(interiorOrigin.X + 222, wallY, interiorOrigin.Z), COLORS.Orange, Enum.Material.SmoothPlastic),
		makePart(interior, "OrangeWallWest", Vector3.new(14, wallHeight, 450), CFrame.new(interiorOrigin.X - 222, wallY, interiorOrigin.Z), COLORS.OrangeDark, Enum.Material.SmoothPlastic),
	}
	for _, wall in ipairs(walls) do
		setInteriorAttrs(wall, colorType)
	end

	for index = 1, 12 do
		local side = index % 4
		local x = interiorOrigin.X + ((index % 3) - 1) * 118
		local z = interiorOrigin.Z + (math.floor(index / 3) % 2 == 0 and -196 or 196)
		if side == 1 then
			x = interiorOrigin.X - 196
			z = interiorOrigin.Z + ((index % 4) - 1.5) * 86
		elseif side == 3 then
			x = interiorOrigin.X + 196
			z = interiorOrigin.Z + ((index % 4) - 1.5) * 86
		end
		local columnHeight = 80 + (index % 5) * 36
		local column = makePart(
			interior,
			"OrangeInteriorColumn_" .. string.format("%02d", index),
			Vector3.new(18, columnHeight, 18),
			CFrame.new(x, interiorOrigin.Y + columnHeight * 0.5, z),
			index % 2 == 0 and COLORS.Orange or COLORS.OrangeDark,
			Enum.Material.SmoothPlastic
		)
		setInteriorAttrs(column, colorType)
	end

	local spawn = makePart(interior, "OrangeInteriorSpawn", Vector3.new(28, 1, 28), CFrame.new(interiorOrigin + Vector3.new(0, 3, 172)), COLORS.Cyan, Enum.Material.Neon, 0.12)
	spawn.CanCollide = false
	spawn:SetAttribute("SectorInteriorSpawn", true)
	spawn:SetAttribute("MutationUnlockArea", true)
	setInteriorAttrs(spawn, colorType)

	local zorkPad = makePart(interior, "OrangeZorkPad", Vector3.new(24, 1, 24), CFrame.new(interiorOrigin + Vector3.new(-74, 3, 80)), COLORS.Cyan, Enum.Material.Neon, 0.08)
	zorkPad.CanCollide = false
	zorkPad:SetAttribute("ZorkPad", true)
	zorkPad:SetAttribute("MutationUnlockArea", true)
	setInteriorAttrs(zorkPad, colorType)
	buildZorkAtPad(zorkPad, colorType)

	local mutationStation = makePart(interior, "MutationUnlockStation", Vector3.new(42, 1.2, 32), CFrame.new(interiorOrigin + Vector3.new(78, 3, 78)), COLORS.Purple, Enum.Material.Neon, 0.08)
	mutationStation.CanCollide = false
	mutationStation:SetAttribute("MutationUnlockStation", true)
	mutationStation:SetAttribute("MutationUnlockArea", true)
	mutationStation:SetAttribute("FeatureUnlock", "Mutations")
	setInteriorAttrs(mutationStation, colorType)

	local exitPipe = Instance.new("Model")
	exitPipe.Name = "OrangeInteriorExitPipe"
	exitPipe.Parent = interior
	local exitBase = interiorOrigin + Vector3.new(0, 12, 202)
	makeCylinder(exitPipe, "PipeRing", Vector3.new(24, 5, 24), CFrame.new(exitBase) * CFrame.Angles(0, 0, math.rad(90)), COLORS.Orange, Enum.Material.Neon)
	local exitTrigger = makePart(exitPipe, "OrangeInteriorExitTrigger", Vector3.new(22, 20, 10), CFrame.new(exitBase), COLORS.Cyan, Enum.Material.ForceField, 0.86)
	exitTrigger.CanCollide = false
	exitTrigger.CanTouch = true
	exitTrigger:SetAttribute("SectorInteriorExit", true)
	exitTrigger:SetAttribute("SectorColor", colorType)
	exitTrigger:SetAttribute("ColorType", colorType)
	makePrompt(exitTrigger, "ExitSectorPrompt", "Orange Sector Pipe", "Exit", 14)

	local pipe = Instance.new("Model")
	pipe.Name = "OrangeSectorPipe"
	pipe.Parent = pipes
	local pipeCFrame = CFrame.new(pipeOrigin) * CFrame.Angles(0, math.rad(35), 0)
	makeCylinder(pipe, "PipeOuterRing", Vector3.new(34, 7, 34), pipeCFrame * CFrame.Angles(0, 0, math.rad(90)), COLORS.Orange, Enum.Material.Neon)
	makeCylinder(pipe, "PipeInnerDark", Vector3.new(25, 7.4, 25), pipeCFrame * CFrame.Angles(0, 0, math.rad(90)), COLORS.Dark, Enum.Material.SmoothPlastic)
	local trigger = makePart(pipe, "OrangeSectorPipeTrigger", Vector3.new(26, 24, 12), pipeCFrame, COLORS.Cyan, Enum.Material.ForceField, 0.86)
	trigger.CanCollide = false
	trigger.CanTouch = true
	trigger:SetAttribute("SectorInteriorEntrance", true)
	trigger:SetAttribute("SectorInteriorDestination", "OrangeSectorInterior")
	trigger:SetAttribute("SectorColor", colorType)
	trigger:SetAttribute("ColorType", colorType)
	makePrompt(trigger, "EnterSectorPrompt", "Orange Sector Pipe", "Enter", 16)

	local pipeExitSpawn = makePart(Workspace, "PipeExitSpawn", Vector3.new(8, 1, 8), pipeCFrame * CFrame.new(0, 12, -56), COLORS.Cyan, Enum.Material.Neon, 1)
	pipeExitSpawn.Anchored = true
	pipeExitSpawn.CanCollide = false
	pipeExitSpawn.CanTouch = false
	pipeExitSpawn.CanQuery = true
	pipeExitSpawn:SetAttribute("PipeExitSpawn", true)

	local returnAnchor = makePart(pipe, "OrangeSectorExteriorReturn", Vector3.new(14, 1, 14), pipeCFrame * CFrame.new(0, -10, -22), COLORS.Cyan, Enum.Material.Neon, 0.35)
	returnAnchor.CanCollide = false
	returnAnchor:SetAttribute("SectorInteriorExteriorReturn", true)
	returnAnchor:SetAttribute("SectorColor", colorType)
	returnAnchor:SetAttribute("ColorType", colorType)

	print("StudioSectorInteriorBuilder: built editable Orange Sector interior, pipe, MutationUnlockStation, ZorkPad, and baked Zork.")
	return interior
end

Builder.BuildSectorInteriors = Builder.BuildOrangeMutationInterior
Builder.BuildOrangeSectorInterior = Builder.BuildOrangeMutationInterior

return Builder
]]></string>
      </Properties>
    </Item>
    <Item class="ModuleScript" referent="59">
      <Properties>
        <string name="Name">StudioZoneBuilder</string>
        <string name="Source"><![CDATA[-- ModuleScript in ReplicatedStorage named "StudioZoneBuilder".
-- Run in Studio edit mode from the command bar:
-- require(game.ReplicatedStorage.StudioZoneBuilder).BuildEditableStarterMap()
--
-- Legacy full-world builder:
-- require(game.ReplicatedStorage.StudioZoneBuilder).build()
--
-- This creates editable Workspace parts for each world. It does not run by itself.
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local RunService = game:GetService("RunService")
local Lighting = game:GetService("Lighting")

local ColorData = require(ReplicatedStorage:WaitForChild("ColorData"))
local PetData = require(ReplicatedStorage:WaitForChild("PetData"))
local UpdateLogData = require(ReplicatedStorage:WaitForChild("UpdateLogData"))
local GroupRewardsConfig = require(ReplicatedStorage:WaitForChild("GroupRewardsConfig"))

local StudioZoneBuilder = {}

local MAP_NAME = "ColorSimulatorMap"
local ZONE_SIZE = Vector3.new(300, 1, 300)
local ZONE_SPACING = 430
local WALL_HEIGHT = 170
local WALL_THICKNESS = 28
local GATE_WIDTH = 48
local GATE_HEIGHT = 44
local GATE_DEPTH = 8
local GATE_SURFACE_OFFSET = 0.25
local GATE_INTERACTION_DISTANCE = 30
local GATE_INTERACTION_ZONE_NAME = "GateInteractionZone"
local COMPACT_ZONE_SPACING = 365
local BIG_WORLD_SIZE = 420
local BIG_WORLD_GAP = 10
local currentOptions = {}

local THEME = {
	Red = {
		color = Color3.fromRGB(210, 82, 82),
		material = Enum.Material.SmoothPlastic,
		accent = Color3.fromRGB(150, 70, 70),
	},
	Blue = {
		color = Color3.fromRGB(72, 132, 210),
		material = Enum.Material.Sand,
		accent = Color3.fromRGB(80, 125, 170),
	},
	Yellow = {
		color = Color3.fromRGB(215, 190, 76),
		material = Enum.Material.Sand,
		accent = Color3.fromRGB(155, 135, 70),
	},
	Green = {
		color = Color3.fromRGB(82, 175, 95),
		material = Enum.Material.Grass,
		accent = Color3.fromRGB(70, 125, 78),
	},
	Purple = {
		color = Color3.fromRGB(132, 82, 185),
		material = Enum.Material.Slate,
		accent = Color3.fromRGB(105, 70, 145),
	},
	Neon = {
		color = Color3.fromRGB(46, 170, 150),
		material = Enum.Material.SmoothPlastic,
		accent = Color3.fromRGB(30, 115, 108),
	},
	Rainbow = {
		color = Color3.fromRGB(178, 190, 215),
		material = Enum.Material.SmoothPlastic,
		accent = Color3.fromRGB(135, 110, 165),
	},
}

local EGG_BY_WORLD = {
	Red = "ColorEgg",
	Blue = "BlueEgg",
	Yellow = "YellowEgg",
	Green = "GreenEgg",
	Purple = "PurpleEgg",
	Neon = "NeonEgg",
	Rainbow = "RainbowEgg",
}

local WALL_PANEL_COLORS = {
	Color3.fromRGB(255, 75, 95),
	Color3.fromRGB(255, 210, 75),
	Color3.fromRGB(85, 230, 125),
	Color3.fromRGB(85, 190, 255),
	Color3.fromRGB(180, 95, 255),
	Color3.fromRGB(255, 110, 220),
	Color3.fromRGB(95, 245, 235),
}

local TEST_PLAZA_COLORS = {
	grass = Color3.fromRGB(92, 184, 88),
	grassDark = Color3.fromRGB(45, 130, 70),
	path = Color3.fromRGB(218, 176, 122),
	pathEdge = Color3.fromRGB(190, 148, 105),
	stone = Color3.fromRGB(196, 210, 224),
	dark = Color3.fromRGB(35, 42, 58),
	blue = Color3.fromRGB(70, 135, 215),
	cyan = Color3.fromRGB(115, 214, 220),
	purple = Color3.fromRGB(148, 100, 214),
	yellow = Color3.fromRGB(236, 196, 82),
	orange = Color3.fromRGB(218, 142, 58),
	green = Color3.fromRGB(98, 196, 120),
	pink = Color3.fromRGB(232, 120, 184),
	red = Color3.fromRGB(232, 76, 78),
	white = Color3.fromRGB(218, 230, 242),
}

local SOFT_NEON_WHITE = Color3.fromRGB(175, 245, 238)

local function clearExistingMap()
	local existing = workspace:FindFirstChild(MAP_NAME)
	if existing then
		existing:Destroy()
	end
end

local function makeFolder(parent, name)
	local folder = Instance.new("Folder")
	folder.Name = name
	folder.Parent = parent
	return folder
end

local function makePart(parent, name, size, position, color, material)
	local part = Instance.new("Part")
	part.Name = name
	part.Size = size
	part.Position = position
	part.Anchored = true
	part.TopSurface = Enum.SurfaceType.Smooth
	part.BottomSurface = Enum.SurfaceType.Smooth
	part.Color = color
	part.Material = material or Enum.Material.SmoothPlastic
	part.Parent = parent
	return part
end

local function makeBillboard(parent, text, offset, size)
	if not currentOptions.showLabels then
		return nil
	end

	local billboard = Instance.new("BillboardGui")
	billboard.Name = "Label"
	billboard.Size = size or UDim2.new(0, 260, 0, 70)
	billboard.StudsOffset = offset or Vector3.new(0, 8, 0)
	billboard.AlwaysOnTop = true
	billboard.Parent = parent

	local label = Instance.new("TextLabel")
	label.Size = UDim2.fromScale(1, 1)
	label.BackgroundTransparency = 1
	label.Font = Enum.Font.LuckiestGuy
	label.TextScaled = true
	label.TextColor3 = Color3.new(1, 1, 1)
	label.TextStrokeTransparency = 0
	label.TextStrokeColor3 = Color3.fromRGB(35, 38, 45)
	label.Text = text
	label.Parent = billboard
end

local function makeWallPanel(parent, name, size, position, color)
	local panel = makePart(parent, name, size, position, color, Enum.Material.Neon)
	panel.CanCollide = false
	panel.CastShadow = false
	panel:SetAttribute("WallColorBlock", true)
	return panel
end

local function makeWallPanels(parent, colorType, center, theme)
	local halfX = ZONE_SIZE.X / 2
	local halfZ = ZONE_SIZE.Z / 2
	local wallSpecs = {
		{ name = "North", axis = "X", z = -halfZ + 0.65 },
		{ name = "South", axis = "X", z = halfZ - 0.65 },
		{ name = "West", axis = "Z", x = -halfX + 0.65 },
		{ name = "East", axis = "Z", x = halfX - 0.65 },
	}

	for wallIndex, spec in ipairs(wallSpecs) do
		for i = 1, 12 do
			local lane = (i - 6.5) * 22
			local height = 16 + ((i + wallIndex) % 4) * 8
			local width = 14 + ((i * 3 + wallIndex) % 5) * 7
			local y = 20 + ((i * 17 + wallIndex * 11) % 115)
			local paletteColor = WALL_PANEL_COLORS[((i + wallIndex + (ColorData.getWorldIndex(colorType) or 1)) - 1) % #WALL_PANEL_COLORS + 1]
			local color = paletteColor:Lerp(theme.color, 0.25)
			local size
			local position

			if spec.axis == "X" then
				size = Vector3.new(width, height, 1.2)
				position = center + Vector3.new(lane, y, spec.z)
			else
				size = Vector3.new(1.2, height, width)
				position = center + Vector3.new(spec.x, y, lane)
			end

			makeWallPanel(parent, colorType .. spec.name .. "ColorBlock" .. i, size, position, color)
		end
	end
end

local function makeZoneDecor(parent, colorType, center, theme)
	local ringColor = theme.accent
	local halfX = ZONE_SIZE.X / 2
	local halfZ = ZONE_SIZE.Z / 2

	local wallColor = ringColor:Lerp(Color3.fromRGB(245, 248, 255), 0.28)
	local north = makePart(parent, colorType .. "NorthWall", Vector3.new(ZONE_SIZE.X + WALL_THICKNESS * 2, WALL_HEIGHT, WALL_THICKNESS), center + Vector3.new(0, WALL_HEIGHT / 2, -halfZ - WALL_THICKNESS / 2), wallColor, Enum.Material.SmoothPlastic)
	local south = makePart(parent, colorType .. "SouthWall", Vector3.new(ZONE_SIZE.X + WALL_THICKNESS * 2, WALL_HEIGHT, WALL_THICKNESS), center + Vector3.new(0, WALL_HEIGHT / 2, halfZ + WALL_THICKNESS / 2), wallColor, Enum.Material.SmoothPlastic)
	local west = makePart(parent, colorType .. "WestWall", Vector3.new(WALL_THICKNESS, WALL_HEIGHT, ZONE_SIZE.Z + WALL_THICKNESS * 2), center + Vector3.new(-halfX - WALL_THICKNESS / 2, WALL_HEIGHT / 2, 0), wallColor, Enum.Material.SmoothPlastic)
	local east = makePart(parent, colorType .. "EastWall", Vector3.new(WALL_THICKNESS, WALL_HEIGHT, ZONE_SIZE.Z + WALL_THICKNESS * 2), center + Vector3.new(halfX + WALL_THICKNESS / 2, WALL_HEIGHT / 2, 0), wallColor, Enum.Material.SmoothPlastic)
	for _, wall in ipairs({ north, south, west, east }) do
		wall.Transparency = 0
		wall.CastShadow = false
		wall:SetAttribute("WorldBarrier", true)
		wall:SetAttribute("ColorType", colorType)
	end

	makePart(parent, colorType .. "NorthTrim", Vector3.new(ZONE_SIZE.X, 3, 4), center + Vector3.new(0, 2.5, -halfZ), ringColor, Enum.Material.SmoothPlastic).Transparency = 0.08
	makePart(parent, colorType .. "SouthTrim", Vector3.new(ZONE_SIZE.X, 3, 4), center + Vector3.new(0, 2.5, halfZ), ringColor, Enum.Material.SmoothPlastic).Transparency = 0.08
	makePart(parent, colorType .. "WestTrim", Vector3.new(4, 3, ZONE_SIZE.Z), center + Vector3.new(-halfX, 2.5, 0), ringColor, Enum.Material.SmoothPlastic).Transparency = 0.08
	makePart(parent, colorType .. "EastTrim", Vector3.new(4, 3, ZONE_SIZE.Z), center + Vector3.new(halfX, 2.5, 0), ringColor, Enum.Material.SmoothPlastic).Transparency = 0.08

	makeWallPanels(parent, colorType, center, theme)
end

local function makeEgg(parent, world, center, theme)
	local eggId = EGG_BY_WORLD[world.primaryColor]
	local eggData = eggId and PetData.Eggs[eggId]
	if not eggData then
		return
	end

	local eggOffset = world.primaryColor == "Red" and Vector3.new(62, 8.5, 82) or Vector3.new(88, 7.5, -96)
	local egg = makePart(parent, eggId, Vector3.new(12, 15, 12), center + eggOffset, eggData.color or theme.accent, Enum.Material.SmoothPlastic)
	egg.Shape = Enum.PartType.Ball
	egg:SetAttribute("EggId", eggId)
	egg:SetAttribute("ColorType", world.primaryColor)
	egg:SetAttribute("AreaColor", world.primaryColor)

	local prompt = Instance.new("ProximityPrompt")
	prompt.Name = "EggShopPrompt"
	prompt.ActionText = "Hatch"
	prompt.ObjectText = "Egg"
	prompt.KeyboardKeyCode = Enum.KeyCode.E
	prompt.GamepadKeyCode = Enum.KeyCode.ButtonX
	prompt.HoldDuration = 0
	prompt.MaxActivationDistance = 14
	prompt.RequiresLineOfSight = false
	prompt.Style = Enum.ProximityPromptStyle.Custom
	prompt:SetAttribute("EggShopPrompt", true)
	prompt.Parent = egg

	makeBillboard(egg, eggData.displayName or eggId, Vector3.new(0, 8, 0), UDim2.new(0, 220, 0, 52))
end

local function getFlatDirection(fromCenter, toCenter)
	local delta = Vector3.new(toCenter.X - fromCenter.X, 0, toCenter.Z - fromCenter.Z)
	if delta.Magnitude < 0.001 then
		return Vector3.new(1, 0, 0)
	end
	return delta.Unit
end

local function getZoneHalfExtentAlong(zone, direction)
	if not zone then
		return ZONE_SIZE.X / 2
	end

	return math.abs(direction.X) * zone.Size.X / 2 + math.abs(direction.Z) * zone.Size.Z / 2
end

local function getWallGateCFrame(previousZone, currentZone, height, depth)
	height = height or GATE_HEIGHT
	depth = depth or GATE_DEPTH

	local previousCenter = previousZone and previousZone.Position or Vector3.zero
	local currentCenter = currentZone and currentZone.Position or previousCenter + Vector3.new(ZONE_SPACING, 0, 0)
	local direction = getFlatDirection(previousCenter, currentCenter)
	local halfExtent = getZoneHalfExtentAlong(previousZone, direction)
	local groundY = previousCenter.Y + ((previousZone and previousZone.Size.Y or ZONE_SIZE.Y) / 2)
	local position = Vector3.new(previousCenter.X, groundY + height / 2, previousCenter.Z)
		+ direction * (halfExtent + depth / 2 + GATE_SURFACE_OFFSET)

	return CFrame.lookAt(position, position - direction), direction
end

local function setPartLocal(part, rootCFrame, size, localOffset, color, material)
	if not part then
		return
	end

	part.Anchored = true
	part.CanCollide = false
	part.CastShadow = false
	part.Size = size
	part.CFrame = rootCFrame * CFrame.new(localOffset)
	if color then
		part.Color = color
	end
	if material then
		part.Material = material
	end
end

local function ensureGateInteractionZone(gate, world, gateWidth, gateHeight, gateDepth)
	local zone = gate:FindFirstChild(GATE_INTERACTION_ZONE_NAME)
	if not zone then
		zone = Instance.new("Part")
		zone.Name = GATE_INTERACTION_ZONE_NAME
		zone.Parent = gate
	end

	local width = math.max(24, gateWidth + 24)
	local height = 14
	local depth = 26
	zone.Anchored = true
	zone.CanCollide = false
	zone.CanTouch = false
	zone.CanQuery = false
	zone.CastShadow = false
	zone.Transparency = 1
	zone.Size = Vector3.new(width, height, depth)
	zone.CFrame = gate.CFrame * CFrame.new(0, -gateHeight / 2 + height / 2 + 2, -(gateDepth / 2 + depth / 2 + 4))
	zone:SetAttribute("GateInteraction", true)
	zone:SetAttribute("GateColor", world.primaryColor)
	zone:SetAttribute("UnlockColor", world.primaryColor)
	zone:SetAttribute("ColorType", world.primaryColor)
	return zone
end

local function ensureGatePrompt(gate, world, gateWidth, gateHeight, gateDepth)
	local zone = ensureGateInteractionZone(gate, world, gateWidth, gateHeight, gateDepth)
	local existingPrompt = gate:FindFirstChild("GatePrompt")
	if existingPrompt and existingPrompt.Parent ~= zone then
		existingPrompt.Parent = zone
	end

	local prompt = zone:FindFirstChild("GatePrompt")
	if not prompt then
		prompt = Instance.new("ProximityPrompt")
		prompt.Name = "GatePrompt"
		prompt.Parent = zone
	end

	prompt.ActionText = "Unlock"
	prompt.ObjectText = world.name .. " - " .. tostring(world.unlockCost) .. " Coins"
	prompt.HoldDuration = 0.1
	prompt.MaxActivationDistance = GATE_INTERACTION_DISTANCE
	prompt.RequiresLineOfSight = false
	prompt.KeyboardKeyCode = Enum.KeyCode.E
	prompt.GamepadKeyCode = Enum.KeyCode.ButtonX
	prompt:SetAttribute("AreaGatePrompt", true)
	return prompt
end

local function makeSpawn(parent, world, center, theme)
	local spawn = makePart(parent, world.primaryColor .. "Spawn", Vector3.new(18, 1, 18), center + Vector3.new(-105, 1, -105), theme.accent, Enum.Material.SmoothPlastic)
	spawn:SetAttribute("AreaSpawn", true)
	spawn:SetAttribute("AreaSpawnColor", world.primaryColor)
	spawn:SetAttribute("SpawnColor", world.primaryColor)
	spawn:SetAttribute("TeleportColor", world.primaryColor)
	spawn:SetAttribute("ColorType", world.primaryColor)
	makeBillboard(spawn, "SPAWN", Vector3.new(0, 5, 0), UDim2.new(0, 120, 0, 42))
	return spawn
end

local function makeGate(parent, world, previousCenter, currentCenter, previousZone, currentZone)
	local worldColor = ColorData.Colors[world.primaryColor] and ColorData.Colors[world.primaryColor].color or Color3.fromRGB(120, 220, 255)
	local fallbackPreviousZone = previousZone or { Position = previousCenter, Size = ZONE_SIZE }
	local fallbackCurrentZone = currentZone or { Position = currentCenter, Size = ZONE_SIZE }
	local gateCFrame = getWallGateCFrame(fallbackPreviousZone, fallbackCurrentZone, GATE_HEIGHT, GATE_DEPTH)
	local gate = makePart(parent, world.primaryColor .. "Gate", Vector3.new(GATE_WIDTH, GATE_HEIGHT, GATE_DEPTH), gateCFrame.Position, worldColor:Lerp(Color3.fromRGB(35, 38, 45), 0.45), Enum.Material.SmoothPlastic)
	gate.CFrame = gateCFrame
	gate.Transparency = 0.18
	gate:SetAttribute("AreaGate", true)
	gate:SetAttribute("GateColor", world.primaryColor)
	gate:SetAttribute("UnlockColor", world.primaryColor)
	gate:SetAttribute("ColorType", world.primaryColor)

	ensureGatePrompt(gate, world, GATE_WIDTH, GATE_HEIGHT, GATE_DEPTH)

	local frameColor = Color3.fromRGB(35, 38, 65)
	local leftPost = makePart(parent, world.primaryColor .. "GateLeftPost", Vector3.new(7, GATE_HEIGHT + 8, GATE_DEPTH + 2), gateCFrame.Position, frameColor, Enum.Material.SmoothPlastic)
	local rightPost = makePart(parent, world.primaryColor .. "GateRightPost", Vector3.new(7, GATE_HEIGHT + 8, GATE_DEPTH + 2), gateCFrame.Position, frameColor, Enum.Material.SmoothPlastic)
	local topBeam = makePart(parent, world.primaryColor .. "GateTopBeam", Vector3.new(GATE_WIDTH + 10, 7, GATE_DEPTH + 2), gateCFrame.Position, frameColor, Enum.Material.SmoothPlastic)
	setPartLocal(leftPost, gateCFrame, leftPost.Size, Vector3.new(-GATE_WIDTH / 2 - 3.5, 0, 0), frameColor, Enum.Material.SmoothPlastic)
	setPartLocal(rightPost, gateCFrame, rightPost.Size, Vector3.new(GATE_WIDTH / 2 + 3.5, 0, 0), frameColor, Enum.Material.SmoothPlastic)
	setPartLocal(topBeam, gateCFrame, topBeam.Size, Vector3.new(0, GATE_HEIGHT / 2 + 3.5, 0), frameColor, Enum.Material.SmoothPlastic)
	for _, part in ipairs({ leftPost, rightPost, topBeam }) do
		part:SetAttribute("GateDecor", true)
		part:SetAttribute("ColorType", world.primaryColor)
	end

	for i = 1, 3 do
		local stripeSize = Vector3.new(2, 30 - i * 4, GATE_DEPTH + 1)
		local stripeOffset = Vector3.new((i - 2) * 11, 0, -GATE_DEPTH / 2 - 0.45)
		local stripe = makePart(parent, world.primaryColor .. "GateGlow" .. i, stripeSize, gateCFrame.Position, worldColor:Lerp(Color3.fromRGB(255, 255, 255), i * 0.18), Enum.Material.Neon)
		setPartLocal(stripe, gateCFrame, stripeSize, stripeOffset, worldColor:Lerp(Color3.fromRGB(255, 255, 255), i * 0.18), Enum.Material.Neon)
		stripe.Transparency = 0.35 + i * 0.12
		stripe.CanCollide = false
		stripe:SetAttribute("GateDecor", true)
		stripe:SetAttribute("ColorType", world.primaryColor)
	end

	return gate
end

local function makeSellZone(parent, world, center, index)
	local colorType = world.primaryColor
	local sell = makePart(parent, "World" .. tostring(index) .. "_Sell", Vector3.new(24, 1, 24), center + Vector3.new(-34, 1, 74), Color3.fromRGB(88, 190, 72), Enum.Material.SmoothPlastic)
	sell:SetAttribute("SellZone", true)
	sell:SetAttribute("SellLocation", true)
	sell:SetAttribute("ColorType", colorType)
	sell:SetAttribute("AreaColor", colorType)
	sell:SetAttribute("SellColor", colorType)
	makeBillboard(sell, "SELL", Vector3.new(0, 5, 0), UDim2.new(0, 130, 0, 46))
	return sell
end

local function clearLightingEffects()
	for _, child in ipairs(Lighting:GetChildren()) do
		if child:GetAttribute("ColorSimulatorSky") then
			child:Destroy()
		end
	end
end

function StudioZoneBuilder.applySky()
	clearLightingEffects()

	Lighting.Brightness = 3
	Lighting.ClockTime = 14
	Lighting.ExposureCompensation = 0.1
	Lighting.EnvironmentDiffuseScale = 0.45
	Lighting.EnvironmentSpecularScale = 0.65
	Lighting.Ambient = Color3.fromRGB(150, 165, 210)
	Lighting.OutdoorAmbient = Color3.fromRGB(190, 205, 235)
	Lighting.FogColor = Color3.fromRGB(190, 210, 245)
	Lighting.FogStart = 650
	Lighting.FogEnd = 1800

	local sky = Instance.new("Sky")
	sky.Name = "ColorSimulatorPastelSky"
	sky.SkyboxBk = "rbxassetid://6444884337"
	sky.SkyboxDn = "rbxassetid://6444884785"
	sky.SkyboxFt = "rbxassetid://6444884337"
	sky.SkyboxLf = "rbxassetid://6444884337"
	sky.SkyboxRt = "rbxassetid://6444884337"
	sky.SkyboxUp = "rbxassetid://6412503613"
	sky.SunAngularSize = 8
	sky.MoonAngularSize = 0
	sky.StarCount = 0
	sky:SetAttribute("ColorSimulatorSky", true)
	sky.Parent = Lighting

	local atmosphere = Instance.new("Atmosphere")
	atmosphere.Name = "ColorSimulatorAtmosphere"
	atmosphere.Color = Color3.fromRGB(185, 210, 255)
	atmosphere.Decay = Color3.fromRGB(255, 180, 225)
	atmosphere.Density = 0.22
	atmosphere.Offset = 0.15
	atmosphere.Glare = 0.1
	atmosphere.Haze = 1.2
	atmosphere:SetAttribute("ColorSimulatorSky", true)
	atmosphere.Parent = Lighting

	local bloom = Instance.new("BloomEffect")
	bloom.Name = "ColorSimulatorBloom"
	bloom.Intensity = 0.35
	bloom.Size = 24
	bloom.Threshold = 1.2
	bloom:SetAttribute("ColorSimulatorSky", true)
	bloom.Parent = Lighting

	local colorCorrection = Instance.new("ColorCorrectionEffect")
	colorCorrection.Name = "ColorSimulatorColor"
	colorCorrection.Brightness = 0.02
	colorCorrection.Contrast = 0.08
	colorCorrection.Saturation = 0.18
	colorCorrection.TintColor = Color3.fromRGB(255, 245, 255)
	colorCorrection:SetAttribute("ColorSimulatorSky", true)
	colorCorrection.Parent = Lighting

	print("StudioZoneBuilder: applied colorful sky and lighting.")
end

function StudioZoneBuilder.build(options)
	options = options or {}
	currentOptions = options

	if RunService:IsRunning() and not options.allowDuringPlay then
		warn("StudioZoneBuilder: run this in Studio edit mode, not while the game is playing.")
		return nil
	end

	local existing = workspace:FindFirstChild(MAP_NAME)
	if existing and not options.overwrite then
		warn("StudioZoneBuilder: " .. MAP_NAME .. " already exists. Use .build({ overwrite = true }) to rebuild it.")
		return existing
	end

	if options.overwrite then
		clearExistingMap()
	end

	local map = Instance.new("Folder")
	map.Name = MAP_NAME
	map.Parent = workspace

	local zones = makeFolder(map, "Zones")
	local spawns = makeFolder(map, "Spawns")
	local eggs = makeFolder(map, "Eggs")
	local gates = makeFolder(map, "Gates")
	local decor = makeFolder(map, "BuildDecor")

	if options.applySky ~= false then
		StudioZoneBuilder.applySky()
	end

	local previousCenter = nil
	local previousZone = nil
	for index, world in ipairs(ColorData.Worlds) do
		local colorType = world.primaryColor
		local theme = THEME[colorType] or {
			color = ColorData.Colors[colorType] and ColorData.Colors[colorType].color or Color3.new(1, 1, 1),
			material = Enum.Material.SmoothPlastic,
			accent = Color3.new(1, 1, 1),
		}

		local buildSpacing = tonumber(options.spacing) or ZONE_SPACING
		local center = Vector3.new((index - 1) * buildSpacing, 0, 0)
		local zone = makePart(zones, colorType .. "Zone", ZONE_SIZE, center, theme.color, theme.material)
		zone.Transparency = 0
		zone:SetAttribute("ColorZone", true)
		zone:SetAttribute("ColorType", colorType)
		zone:SetAttribute("WorldId", world.id)
		zone:SetAttribute("WorldName", world.name)
		zone:SetAttribute("RewardMultiplier", world.rewardMultiplier or math.max(1, world.breakableHealth / 10))
		zone:SetAttribute("BlobCount", world.blobCount or 32)

		makeBillboard(zone, string.upper(world.name), Vector3.new(0, 10, 0))
		makeZoneDecor(decor, colorType, center, theme)
		makeSpawn(spawns, world, center, theme)
		makeEgg(eggs, world, center, theme)

		makeSellZone(zones, world, center, index)
		if index > 1 and previousCenter then
			makeGate(gates, world, previousCenter, center, previousZone, zone)
		end

		previousCenter = center
		previousZone = zone
	end

	print("StudioZoneBuilder: created " .. MAP_NAME .. " with editable zones, gates, spawns, eggs, and sell zone.")
	return map
end

function StudioZoneBuilder.toneDownExisting()
	local map = workspace:FindFirstChild(MAP_NAME)
	if not map then
		warn("StudioZoneBuilder: no " .. MAP_NAME .. " found to tone down.")
		return nil
	end

	for _, obj in ipairs(map:GetDescendants()) do
		if obj:IsA("BillboardGui") or obj:IsA("SurfaceGui") then
			obj:Destroy()
		elseif obj:IsA("BasePart") then
			local colorType = obj:GetAttribute("ColorType")
			local theme = colorType and THEME[colorType]

			if obj:GetAttribute("ColorZone") and theme then
				obj.Color = theme.color
				obj.Material = theme.material
				obj.Transparency = 0
			elseif obj:GetAttribute("AreaGate") then
				obj.Color = Color3.fromRGB(75, 82, 105)
				obj.Material = Enum.Material.Glass
				obj.Transparency = 0.25
			elseif obj:GetAttribute("AreaSpawn") and theme then
				obj.Color = theme.accent
				obj.Material = Enum.Material.SmoothPlastic
				obj.Transparency = 0
			elseif obj:GetAttribute("EggId") then
				obj.Material = Enum.Material.SmoothPlastic
				obj.Transparency = 0
			elseif obj.Name == "SellZone" then
				obj.Color = Color3.fromRGB(88, 190, 72)
				obj.Material = Enum.Material.SmoothPlastic
				obj.Transparency = 0
			elseif obj:GetAttribute("WorldBarrier") and theme then
				obj.Color = theme.accent:Lerp(Color3.fromRGB(245, 248, 255), 0.28)
				obj.Material = Enum.Material.SmoothPlastic
				obj.Transparency = 0
			elseif string.find(obj.Name, "Border") or string.find(obj.Name, "Trim") or string.find(obj.Name, "BuildMarker") then
				if theme then
					obj.Color = theme.accent
				end
				obj.Material = Enum.Material.SmoothPlastic
				obj.Transparency = string.find(obj.Name, "Trim") and 0.08 or 0.25
			end
		end
	end

	print("StudioZoneBuilder: toned down " .. MAP_NAME .. " and removed builder labels.")
	return map
end

function StudioZoneBuilder.coolifyExisting()
	local map = workspace:FindFirstChild(MAP_NAME)
	if not map then
		warn("StudioZoneBuilder: no " .. MAP_NAME .. " found. Run .build({ overwrite = true }) first.")
		return nil
	end

	local decor = map:FindFirstChild("BuildDecor")
	if not decor then
		decor = Instance.new("Folder")
		decor.Name = "BuildDecor"
		decor.Parent = map
	end

	for _, obj in ipairs(map:GetDescendants()) do
		if obj:IsA("BasePart") and (string.find(obj.Name, "BuildMarker") or obj:GetAttribute("WallColorBlock")) then
			obj:Destroy()
		end
	end

	for _, zone in ipairs(map:GetDescendants()) do
		if zone:IsA("BasePart") and zone:GetAttribute("ColorZone") then
			local colorType = zone:GetAttribute("ColorType") or "Red"
			local theme = THEME[colorType] or {
				color = ColorData.Colors[colorType] and ColorData.Colors[colorType].color or Color3.new(1, 1, 1),
				material = Enum.Material.SmoothPlastic,
				accent = Color3.new(1, 1, 1),
			}
			makeWallPanels(decor, colorType, zone.Position, theme)
		end
	end

	print("StudioZoneBuilder: removed floor markers and added wall color blocks.")
	return map
end

local function makeBlock(parent, name, size, cframe, color, material)
	local part = Instance.new("Part")
	part.Name = name
	part.Size = size
	part.CFrame = cframe
	part.Anchored = true
	part.TopSurface = Enum.SurfaceType.Smooth
	part.BottomSurface = Enum.SurfaceType.Smooth
	part.Color = color
	part.Material = material or Enum.Material.SmoothPlastic
	part.Parent = parent
	return part
end

local function makeTestLabel(parent, text, subtitle, offset, size)
	local billboard = Instance.new("BillboardGui")
	billboard.Name = "BlockoutLabel"
	billboard.Size = size or UDim2.new(0, 280, 0, subtitle and 80 or 54)
	billboard.StudsOffset = offset or Vector3.new(0, 6, 0)
	billboard.AlwaysOnTop = true
	billboard.MaxDistance = 220
	billboard.Parent = parent

	local title = Instance.new("TextLabel")
	title.Size = UDim2.new(1, 0, 0, subtitle and 42 or 54)
	title.BackgroundTransparency = 1
	title.Font = Enum.Font.LuckiestGuy
	title.TextScaled = true
	title.TextColor3 = TEST_PLAZA_COLORS.white
	title.TextStrokeTransparency = 0
	title.TextStrokeColor3 = TEST_PLAZA_COLORS.dark
	title.Text = text
	title.Parent = billboard

	if subtitle then
		local sub = Instance.new("TextLabel")
		sub.Size = UDim2.new(1, 0, 0, 24)
		sub.Position = UDim2.new(0, 0, 0, 44)
		sub.BackgroundTransparency = 1
		sub.Font = Enum.Font.GothamBold
		sub.TextSize = 15
		sub.TextColor3 = Color3.fromRGB(230, 245, 255)
		sub.TextStrokeTransparency = 0.12
		sub.TextStrokeColor3 = TEST_PLAZA_COLORS.dark
		sub.Text = subtitle
		sub.Parent = billboard
	end

	return billboard
end

local function makeCylinder(parent, name, radius, height, cframe, color, material)
	local part = makeBlock(parent, name, Vector3.new(radius * 2, height, radius * 2), cframe, color, material)
	part.Shape = Enum.PartType.Cylinder
	part.CFrame = cframe * CFrame.Angles(0, 0, math.rad(90))
	return part
end

local function makeTree(parent, name, position, scale)
	scale = scale or 1
	local trunk = makeBlock(parent, name .. "Trunk", Vector3.new(4 * scale, 18 * scale, 4 * scale), CFrame.new(position + Vector3.new(0, 9 * scale, 0)), Color3.fromRGB(132, 86, 45), Enum.Material.Wood)
	trunk:SetAttribute("TestPlazaDecor", true)
	local leaves = makeBlock(parent, name .. "Leaves", Vector3.new(18 * scale, 14 * scale, 18 * scale), CFrame.new(position + Vector3.new(0, 24 * scale, 0)), TEST_PLAZA_COLORS.grassDark, Enum.Material.SmoothPlastic)
	leaves:SetAttribute("TestPlazaDecor", true)
	local top = makeBlock(parent, name .. "TopLeaves", Vector3.new(14 * scale, 10 * scale, 14 * scale), CFrame.new(position + Vector3.new(0, 34 * scale, 0)), TEST_PLAZA_COLORS.green, Enum.Material.SmoothPlastic)
	top:SetAttribute("TestPlazaDecor", true)
	return leaves
end

local function plazaOffset(origin, spread, x, y, z)
	spread = spread or 1
	return origin + Vector3.new(x * spread, y, z * spread)
end

