      <Item class="Script" referent="72">
        <Properties>
          <string name="Name">CodeHandler</string>
          <token name="RunContext">0</token>
          <string name="Source"><![CDATA[-- Server-authoritative redeem code handling.
local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")

local codeDataModule = ReplicatedStorage:FindFirstChild("CodeData")
local CodeData = codeDataModule and require(codeDataModule) or {
	Codes = {
		RELEASE = {
			Code = "RELEASE",
			Active = true,
			MaxUsesPerPlayer = 1,
			Message = "Release reward claimed!",
			Rewards = {
				{ Type = "Coins", Amount = 1000 },
			},
		},
		COLOR = {
			Code = "COLOR",
			Active = true,
			MaxUsesPerPlayer = 1,
			Message = "Color boost claimed!",
			Rewards = {
				{ Type = "Coins", Amount = 250 },
			},
		},
		PET = {
			Code = "PET",
			Active = true,
			MaxUsesPerPlayer = 1,
			Message = "Starter Color claimed!",
			Rewards = {
				{ Type = "Pet", PetId = "RedBlob", Amount = 5 },
			},
		},
	},
}

CodeData.normalize = CodeData.normalize or function(code)
	return string.upper((tostring(code or ""):gsub("%s+", "")))
end

CodeData.getCode = CodeData.getCode or function(code)
	return CodeData.Codes[CodeData.normalize(code)]
end

local Events = ReplicatedStorage:WaitForChild("Events")
local redeemEvent = Events:FindFirstChild("RedeemCode")
if not redeemEvent then
	redeemEvent = Instance.new("RemoteEvent")
	redeemEvent.Name = "RedeemCode"
	redeemEvent.Parent = Events
end
local grantPetFunction = ReplicatedStorage:FindFirstChild("ServerGrantPet")
if not grantPetFunction then
	grantPetFunction = Instance.new("BindableFunction")
	grantPetFunction.Name = "ServerGrantPet"
	grantPetFunction.Parent = ReplicatedStorage
end

local cooldowns = {}
local COOLDOWN = 0.8

local function getRedeemedFolder(player)
	local folder = player:FindFirstChild("RedeemedCodes")
	if not folder then
		folder = Instance.new("Folder")
		folder.Name = "RedeemedCodes"
		folder.Parent = player
	end
	return folder
end

local function getUses(player, normalizedCode)
	local existing = getRedeemedFolder(player):FindFirstChild(normalizedCode)
	return existing and existing.Value or 0
end

local function setUses(player, normalizedCode, uses)
	local folder = getRedeemedFolder(player)
	local existing = folder:FindFirstChild(normalizedCode)
	if not existing then
		existing = Instance.new("IntValue")
		existing.Name = normalizedCode
		existing.Parent = folder
	end
	existing.Value = uses
end

local function awardReward(player, reward)
	local rewardType = tostring(reward.Type or reward.type or "")
	local amount = math.max(1, math.floor(tonumber(reward.Amount or reward.amount) or 1))

	if rewardType == "Coins" then
		local stats = player:FindFirstChild("leaderstats")
		local coins = stats and stats:FindFirstChild("Coins")
		if not coins then
			return false, "Coins are not ready."
		end
		coins.Value += amount
		return true
	elseif rewardType == "Color" or rewardType == "Storage" then
		local stats = player:FindFirstChild("leaderstats")
		local coins = stats and stats:FindFirstChild("Coins")
		if not coins then
			return false, "Coins are not ready."
		end
		coins.Value += amount
		return true
	elseif rewardType == "Pet" then
		if not grantPetFunction then
			return false, "Color rewards are not ready."
		end
		local ok, granted = pcall(function()
			return grantPetFunction:Invoke(player, reward.PetId or reward.petId, amount)
		end)
		if not ok or not granted then
			return false, "Color reward failed."
		end
		return true
	end

	return false, "Unsupported reward type."
end

redeemEvent.OnServerEvent:Connect(function(player, rawCode)
	local now = os.clock()
	if cooldowns[player] and now - cooldowns[player] < COOLDOWN then
		return
	end
	cooldowns[player] = now

	local normalized = CodeData.normalize(rawCode)
	if normalized == "" then
		redeemEvent:FireClient(player, false, "Enter a code first.")
		return
	end

	local code = CodeData.getCode(normalized)
	if not code or code.Active == false then
		redeemEvent:FireClient(player, false, "Invalid or expired code.")
		return
	end

	if code.ExpiresAt and os.time() > code.ExpiresAt then
		redeemEvent:FireClient(player, false, "That code has expired.")
		return
	end

	local maxUses = tonumber(code.MaxUsesPerPlayer) or 1
	local uses = getUses(player, normalized)
	if uses >= maxUses then
		redeemEvent:FireClient(player, false, "You already redeemed that code.")
		return
	end

	for _, reward in ipairs(code.Rewards or {}) do
		local ok, message = awardReward(player, reward)
		if not ok then
			redeemEvent:FireClient(player, false, message or "Could not redeem code.")
			return
		end
	end

	setUses(player, normalized, uses + 1)
	redeemEvent:FireClient(player, true, code.Message or "Code redeemed!")
end)

Players.PlayerRemoving:Connect(function(player)
	cooldowns[player] = nil
end)
]]></string>
        </Properties>
      </Item>
      <Item class="Script" referent="73">
        <Properties>
          <string name="Name">ColorCollectHandler</string>
          <token name="RunContext">0</token>
          <string name="Source"><![CDATA[-- Server-authoritative click collection for color breakables.
local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local RunService = game:GetService("RunService")
local ServerStorage = game:GetService("ServerStorage")
local DEBUG_LOGS = RunService:IsStudio()

local ColorData = require(ReplicatedStorage:WaitForChild("ColorData"))
local GameBalance = require(ReplicatedStorage:WaitForChild("GameBalance"))
local PetData = require(ReplicatedStorage:WaitForChild("PetData"))
local GamepassBenefits = require(script.Parent:WaitForChild("GamepassBenefits"))
local GroupRewardsService = require(script.Parent:WaitForChild("GroupRewardsService"))
local ColorEffectHandler = require(script.Parent:WaitForChild("ColorEffectHandler"))

local function loadToolData()
	local module = ReplicatedStorage:WaitForChild("ToolData", 3)
	if module then
		return require(module)
	end

	warn("ColorCollectHandler: ToolData missing; using Starter Brush fallback config.")
	local fallback = {}
	fallback.Tools = {
		StarterBrush = {
			Id = "StarterBrush",
			DisplayName = "Starter Brush",
			Range = 9,
			Width = 7,
			Cooldown = 0.45,
			PowerMultiplier = 1,
			CollectPowerMultiplier = 1,
			SweepWidthMultiplier = 1,
			UseSpeedMultiplier = 1,
			PickupRadiusMultiplier = 1,
			VisualType = "Brush",
			MaxTargets = 8,
			MaxServerRange = 24,
		},
	}
	function fallback.get(toolId)
		return fallback.Tools[toolId or ""] or fallback.Tools.StarterBrush
	end
	function fallback.GetEffectiveStats(toolId)
		local tool = fallback.get(toolId)
		return {
			Id = tool.Id,
			CollectPowerMultiplier = tool.CollectPowerMultiplier or tool.PowerMultiplier or 1,
			SweepWidthMultiplier = tool.SweepWidthMultiplier or 1,
			UseSpeedMultiplier = tool.UseSpeedMultiplier or 1,
			PickupRadiusMultiplier = tool.PickupRadiusMultiplier or 1,
			PassiveId = tool.PassiveId or "None",
			PassiveDescription = tool.PassiveDescription or "",
			PassiveEnabled = tool.PassiveEnabled == true,
		}
	end
	return fallback
end

local ToolData = loadToolData()

local Events = ReplicatedStorage:WaitForChild("Events")
local collectEvent = Events:WaitForChild("CollectColor")
local paintSweepEvent = Events:FindFirstChild("PaintToolSweep")
if not paintSweepEvent then
	paintSweepEvent = Instance.new("RemoteEvent")
	paintSweepEvent.Name = "PaintToolSweep"
	paintSweepEvent.Parent = Events
end
local colorEffectVfxEvent = Events:FindFirstChild("ColorEffectVFX")
if not colorEffectVfxEvent then
	colorEffectVfxEvent = Instance.new("RemoteEvent")
	colorEffectVfxEvent.Name = "ColorEffectVFX"
	colorEffectVfxEvent.Parent = Events
end
local tutorialPatchClearedEvent = Events:FindFirstChild("TutorialPatchCleared")
if not tutorialPatchClearedEvent then
	tutorialPatchClearedEvent = Instance.new("BindableEvent")
	tutorialPatchClearedEvent.Name = "TutorialPatchCleared"
	tutorialPatchClearedEvent.Parent = Events
end

local COLLECT_RANGE = 22
local COLLECT_COOLDOWN = 0.18
local WALK_SWEEP_COOLDOWN = 0.16
local WALK_PICKUP_RANGE = 8
local WALK_MAX_TARGETS = 5
local RESPAWN_DELAY = 4
local PET_PRIORITY_SECONDS = 6

local lastCollectAt = {}
local lastSweepAt = {}
local lastWalkSweepAt = {}
local lastLightningAt = {}
local lastMagnetAt = {}
local collectionWarnings = {}
local touchConnections = {}
local unexpectedClientWarnings = {}

local function reportDailyQuestProgress(player, questId, amount)
	local event = ServerStorage:FindFirstChild("DailyQuestProgress")
	if event and event:IsA("BindableEvent") then
		event:Fire(player, questId, amount)
	end
end

local function warnCollectionOnce(player, reason, detail)
	local playerKey = player and player.UserId or "server"
	local key = tostring(playerKey) .. ":" .. tostring(reason)
	if collectionWarnings[key] then
		return
	end
	collectionWarnings[key] = true
	warn("Collection ignored: " .. tostring(reason) .. (detail and (" - " .. tostring(detail)) or ""))
end

local function markPetPriorityTarget(player, part)
	if not player or typeof(part) ~= "Instance" or not part:IsA("BasePart") then
		return
	end
	part:SetAttribute("PetPriorityOwnerUserId", player.UserId)
	part:SetAttribute("PetPriorityUntil", os.clock() + PET_PRIORITY_SECONDS)
	part:SetAttribute("PetPrioritySetAt", os.clock())
end

local function warnUnexpectedClientValuesOnce(player, action)
	local key = tostring(player and player.UserId or "server") .. ":" .. tostring(action)
	if unexpectedClientWarnings[key] then
		return
	end
	unexpectedClientWarnings[key] = true
	warn("Collection request ignored unexpected client value fields for " .. tostring(action) .. ". Server calculates rewards.")
end

local function isTouchFallbackEnabled()
	return GameBalance.Collection and GameBalance.Collection.AllowTouchCollectionFallback == true
end

local function getVisualColor(colorType)
	if colorType == "Rainbow" then
		return Color3.fromRGB(215, 180, 255)
	end

	local colorInfo = ColorData.Colors[colorType]
	return colorInfo and colorInfo.color or Color3.new(1, 1, 1)
end

local function getStoredColor(part, colorType)
	local stored = part and part:GetAttribute("SpawnColor")
	if typeof(stored) == "Color3" then
		return stored
	end
	return getVisualColor(colorType)
end

local function parseInventory(str)
	local inventory = {}
	if not str or str == "" then
		return inventory
	end

	for _, part in ipairs(string.split(str, ",")) do
		local segments = string.split(part, ":")
		local variantKey
		local petId
		local stackIndex
		if tonumber(segments[2]) then
			petId = segments[1]
			stackIndex = 2
		else
			variantKey = segments[1]
			petId = segments[2]
			stackIndex = 3
		end
		local stackAmount = tonumber(segments[stackIndex]) or 1
		local traitId = PetData.normalizeTraitId(segments[stackIndex + 1])
		local shinyStr = segments[stackIndex + 2] or "normal"
		local personalityId = PetData.normalizePersonalityId(segments[stackIndex + 3] or "Neutral")
		local mutationId = PetData.normalizeMutationId(segments[stackIndex + 4] or "None")
		variantKey = variantKey or PetData.makeVariantKey(petId, personalityId, mutationId, traitId)
		if petId and petId ~= "" then
			inventory[variantKey] = {
				petId = petId,
				stackAmount = stackAmount,
				traitId = traitId,
				isShiny = shinyStr == "shiny" or shinyStr == "true",
				personalityId = personalityId,
				mutationId = mutationId,
			}
		end
	end

	return inventory
end

local function getPetColorMultiplier(player)
	return ColorEffectHandler.GetColorGainMultiplier(player)
end

local function getPickupRange(player)
	local range = COLLECT_RANGE
	local upgrades = player:FindFirstChild("Upgrades")
	local pickupRange = upgrades and upgrades:FindFirstChild("PickupRange")
	if pickupRange then
		range = pickupRange.Value
	end

	local boostFolder = player:FindFirstChild("Boosts")
	local rangeBoost = boostFolder and boostFolder:FindFirstChild("range")
	if rangeBoost and os.time() < rangeBoost.Value then
		range *= 1.5
	end

	range *= ColorEffectHandler.CalculateEquippedColorEffects(player).BrushRangeMultiplier

	return range
end

local function getCollectMultiplier(player)
	local multiplier = getPetColorMultiplier(player)
	local upgrades = player:FindFirstChild("Upgrades")
	local colorMultiplier = upgrades and upgrades:FindFirstChild("ColorMultiplier")
	if colorMultiplier then
		multiplier *= colorMultiplier.Value
	end

	return multiplier
end

local function getZoneCoinMultiplier(colorType)
	local configured = GameBalance.Sell
		and GameBalance.Sell.ColorValueMultipliers
		and GameBalance.Sell.ColorValueMultipliers[colorType]
	local world = ColorData.getWorldByColor(colorType)
	return tonumber(configured or (world and world.colorValueMultiplier)) or 1
end

local function getInstantCoinMultiplier(player, colorType)
	local multiplier = getZoneCoinMultiplier(colorType)
	multiplier *= ColorEffectHandler.GetSellCoinsMultiplier(player)

	local boostFolder = player:FindFirstChild("Boosts")
	local coinBoost = boostFolder and boostFolder:FindFirstChild("coins")
	if coinBoost and os.time() < coinBoost.Value then
		multiplier *= 2
	end

	multiplier *= GamepassBenefits.getCoinMultiplier(player)
	multiplier *= GroupRewardsService.GetCoinMultiplier(player)
	return multiplier
end

local function awardCoins(player, amount)
	amount = math.max(0, math.floor(tonumber(amount) or 0))
	if amount <= 0 then
		return false
	end

	local stats = player:FindFirstChild("leaderstats")
	local coins = stats and stats:FindFirstChild("Coins")
	if not coins then
		warnCollectionOnce(player, "missing player data", "leaderstats/Coins not ready")
		return false
	end

	coins.Value += amount
	reportDailyQuestProgress(player, "CoinsEarned", amount)
	return true
end

local function getPickupUpgradeValue(player)
	local upgrades = player:FindFirstChild("Upgrades")
	local pickupRange = upgrades and upgrades:FindFirstChild("PickupRange")
	return pickupRange and pickupRange.Value or 8
end

local function getToolEffectiveStats(toolConfig)
	if ToolData.GetEffectiveStats then
		return ToolData.GetEffectiveStats(toolConfig and toolConfig.Id or "StarterBrush")
	end

	return {
		CollectPowerMultiplier = toolConfig and (toolConfig.CollectPowerMultiplier or toolConfig.PowerMultiplier) or 1,
		SweepWidthMultiplier = toolConfig and toolConfig.SweepWidthMultiplier or 1,
		UseSpeedMultiplier = toolConfig and toolConfig.UseSpeedMultiplier or 1,
		PickupRadiusMultiplier = toolConfig and toolConfig.PickupRadiusMultiplier or 1,
	}
end

local function getPaintToolRange(player, toolConfig)
	local upgradeRange = getPickupUpgradeValue(player)
	local upgradedBonus = math.max(0, upgradeRange - 8) * 0.35
	local effects = ColorEffectHandler.CalculateEquippedColorEffects(player)
	local baseRange = (toolConfig.Range or 9) + upgradedBonus
	local toolStats = getToolEffectiveStats(toolConfig)
	return math.min(baseRange * effects.BrushRangeMultiplier * (toolStats.PickupRadiusMultiplier or 1), toolConfig.MaxServerRange or 24)
end

local function getBaseBreakableReward(part, data)
	local reward = tonumber(part:GetAttribute("BaseColorReward"))
		or tonumber(data.baseReward)
		or tonumber(data.rewardMin)
		or 1
	return math.max(1, math.floor(reward))
end

local function ownsPaintTool(player, toolId)
	if toolId == "StarterBrush" then
		return true
	end

	local toolsFolder = player:FindFirstChild("PaintTools")
	local ownedValue = toolsFolder and toolsFolder:FindFirstChild("Owned")
	for _, ownedId in ipairs(string.split(ownedValue and ownedValue.Value or "", ",")) do
		if ownedId == toolId then
			return true
		end
	end
	return false
end

local function canUsePaintTool(player, toolConfig)
	if not toolConfig then
		return false
	end
	if not ownsPaintTool(player, toolConfig.Id) then
		return false
	end

	local requiredColor = toolConfig.RequiredColor or "Red"
	if requiredColor == "Red" then
		return true
	end

	local storage = player:FindFirstChild("ColorStorage")
	local unlocked = storage and storage:FindFirstChild("UnlockedColors")
	return unlocked and ColorData.isColorUnlocked(unlocked.Value, requiredColor)
end

local function getEquippedPaintTool(player)
	local character = player.Character
	if not character then
		return nil, nil
	end

	local toolsFolder = player:FindFirstChild("PaintTools")
	local equippedValue = toolsFolder and toolsFolder:FindFirstChild("Equipped")
	local equippedToolId = equippedValue and equippedValue.Value or "StarterBrush"
	local equippedConfig = ToolData.get(equippedToolId)
	if not canUsePaintTool(player, equippedConfig) then
		equippedConfig = ToolData.get("StarterBrush")
	end

	for _, child in ipairs(character:GetChildren()) do
		if child:IsA("Tool") and child:GetAttribute("PaintToolId") then
			return child, equippedConfig
		end
	end

	return nil, equippedConfig
end

local function isInsideToolSweep(player, part, range, width)
	local character = player.Character
	local root = character and character:FindFirstChild("HumanoidRootPart")
	if not root or not part then
		return false
	end

	local offset = part.Position - root.Position
	local distance = offset.Magnitude
	if distance > range then
		return false
	end

	local look = root.CFrame.LookVector
	local forward = distance > 0 and offset.Unit:Dot(look) or 1
	local side = math.abs(offset:Cross(look).Magnitude)
	return forward > -0.2 and side <= width
end

local function isInsideWalkPickup(player, part, range)
	local character = player.Character
	local root = character and character:FindFirstChild("HumanoidRootPart")
	if not root or not part then
		return false
	end

	return (part.Position - root.Position).Magnitude <= range
end

local function isPointInsideZone(part, worldPosition, margin)
	local localPoint = part.CFrame:PointToObjectSpace(worldPosition)
	local half = part.Size * 0.5 + Vector3.new(margin or 0, margin or 0, margin or 0)
	return math.abs(localPoint.X) <= half.X
		and math.abs(localPoint.Y) <= half.Y
		and math.abs(localPoint.Z) <= half.Z
end

local function isPlayerInsideColorZone(root, colorType)
	if not root or not colorType then
		return false
	end

	for _, obj in ipairs(workspace:GetDescendants()) do
		if obj:IsA("BasePart")
			and obj:GetAttribute("ColorZone") == true
			and obj:GetAttribute("ColorType") == colorType
			and isPointInsideZone(obj, root.Position, 12)
		then
			return true
		end
	end
	return false
end

local function canAccessBreakableColor(player, colorType, root)
	if not colorType then
		return true
	end

	local storage = player:FindFirstChild("ColorStorage")
	local unlocked = storage and storage:FindFirstChild("UnlockedColors")
	if unlocked and ColorData.isColorUnlocked(unlocked.Value, colorType) then
		return true
	end
	if isPlayerInsideColorZone(root, colorType) then
		return true
	end
	return unlocked == nil
end

local function resetBreakable(part)
	if not part or not part.Parent then
		return
	end

	local breakableType = part:GetAttribute("BreakableType")
	local colorType = part:GetAttribute("ColorType")
	local data = breakableType and ColorData.Breakables[breakableType]
	if not data then
		part:SetAttribute("Respawning", false)
		part:SetAttribute("IsCollected", false)
		return
	end

	local colorInfo = colorType and ColorData.Colors[colorType]
	if colorInfo then
		local visualColor = getStoredColor(part, colorType)
		part.Color = visualColor
		local light = part:FindFirstChildOfClass("PointLight")
		if light then
			light.Color = visualColor
		end
	end

	part.Size = part:GetAttribute("OriginalSize") or data.size
	part.Transparency = part:GetAttribute("CollectorBaseTransparency") or 0
	part.CanCollide = false
	part.CanQuery = true
	part:SetAttribute("IsCollected", false)
	part:SetAttribute("Respawning", false)
	part:SetAttribute("PetPriorityOwnerUserId", nil)
	part:SetAttribute("PetPriorityUntil", nil)
	part:SetAttribute("PetPrioritySetAt", nil)
end

local function hideAndRespawn(part)
	part:SetAttribute("IsCollected", true)
	part:SetAttribute("PetPriorityOwnerUserId", nil)
	part:SetAttribute("PetPriorityUntil", nil)
	part:SetAttribute("PetPrioritySetAt", nil)
	part.Transparency = 1
	part.CanCollide = false
	part.CanTouch = false

	for _, child in ipairs(part:GetDescendants()) do
		if child:IsA("BasePart") then
			child.Transparency = 1
			child.CanCollide = false
			child.CanTouch = false
			child.CanQuery = false
		end
	end

	if part:GetAttribute("TutorialColorPatch") or part:GetAttribute("NoRespawn") then
		part:SetAttribute("Respawning", false)
		part.CanQuery = false
		return
	end

	part:SetAttribute("Respawning", true)

	task.delay(RESPAWN_DELAY, function()
		resetBreakable(part)
	end)
end

local function canCollect(player, part, options)
	options = options or {}
	if typeof(part) ~= "Instance" or not part:IsA("BasePart") or not part:IsDescendantOf(workspace) then
		return false, "Invalid target."
	end

	local breakableType = part:GetAttribute("BreakableType")
	if not breakableType or not ColorData.Breakables[breakableType] then
		return false, "That is not color."
	end

	local character = player.Character
	local root = character and character:FindFirstChild("HumanoidRootPart")
	local humanoid = character and character:FindFirstChildOfClass("Humanoid")
	if not root or not humanoid or humanoid.Health <= 0 then
		return false, "You cannot collect right now."
	end

	local colorType = part:GetAttribute("ColorType")
	if not canAccessBreakableColor(player, colorType, root) then
		return false, "Area locked."
	end

	if part:GetAttribute("IsCollected") or part.Transparency >= 1 then
		return false, "Already collected."
	end

	local maxRange = options.maxRange or getPickupRange(player)
	if (root.Position - part.Position).Magnitude > maxRange then
		return false, "Too far away."
	end

	local now = os.clock()
	if not options.skipCooldown and lastCollectAt[player] and now - lastCollectAt[player] < COLLECT_COOLDOWN then
		return false, "Slow down."
	end

	if not options.skipCooldown then
		lastCollectAt[player] = now
	end
	return true
end

local function collectBreakable(player, part, options)
	options = options or {}
	local ok, message = canCollect(player, part, options)
	if not ok then
		return false, 0, message
	end

	local data = ColorData.Breakables[part:GetAttribute("BreakableType")]
	local colorType = part:GetAttribute("ColorType")
	local areaMult = tonumber(part:GetAttribute("RewardMultiplier")) or 1
	local toolMult = options.powerMultiplier or 1
	local reward = math.floor(
		getBaseBreakableReward(part, data)
		* areaMult
		* getCollectMultiplier(player)
		* toolMult
		* getInstantCoinMultiplier(player, colorType)
	)
	reward = math.max(reward, 1)

	if not awardCoins(player, reward) then
		return false, 0, "Coins are not ready."
	end

	if options.source == "brush" and tutorialPatchClearedEvent then
		tutorialPatchClearedEvent:Fire(player, colorType, reward, part, options.mode or "sweep")
	end

	hideAndRespawn(part)
	reportDailyQuestProgress(player, "ColorSpillsCleaned", 1)
	if colorType == "Red" then
		reportDailyQuestProgress(player, "RedWastelandsSpillsCleaned", 1)
	end
	if options.source == "brush" then
		reportDailyQuestProgress(player, "BrushUses", 1)
	end
	return true, reward, "Coins"
end

local function getPlayerFromHit(hit)
	local character = hit and hit.Parent
	if not character then
		return nil
	end

	local humanoid = character:FindFirstChildOfClass("Humanoid")
	if not humanoid and character.Parent then
		character = character.Parent
		humanoid = character:FindFirstChildOfClass("Humanoid")
	end
	if not humanoid then
		return nil
	end

	return Players:GetPlayerFromCharacter(character)
end

local function hookTouchCollection(part)
	if not isTouchFallbackEnabled() then
		return
	end
	if typeof(part) ~= "Instance" or not part:IsA("BasePart") then
		return
	end
	if not part:GetAttribute("BreakableType") then
		return
	end
	if touchConnections[part] then
		part.CanTouch = true
		return
	end

	part.CanTouch = true
	touchConnections[part] = part.Touched:Connect(function(hit)
		local player = getPlayerFromHit(hit)
		if not player then
			return
		end

		local ok, awarded, message = collectBreakable(player, part, {
			source = "touch",
		})
		if ok then
			collectEvent:FireClient(player, true, awarded, "Coins")
		elseif message == "Coins are not ready." then
			warnCollectionOnce(player, "missing player data", message)
		elseif message == "Invalid target." or message == "That is not color." then
			warnCollectionOnce(player, "blob invalid", message)
		end
	end)

	part.Destroying:Connect(function()
		local connection = touchConnections[part]
		if connection then
			connection:Disconnect()
		end
		touchConnections[part] = nil
	end)
end

local function getPlayerRoot(player)
	local character = player.Character
	return character and character:FindFirstChild("HumanoidRootPart")
end

local function hasCompletedTutorial(player)
	local folder = player and player:FindFirstChild("TutorialObjectives")
	local completed = folder and folder:FindFirstChild("TutorialCompleted")
	return completed and completed.Value == true
end

local function canWalkCollectDuringTutorial(player, candidates)
	local folder = player and player:FindFirstChild("TutorialObjectives")
	local completed = folder and folder:FindFirstChild("TutorialCompleted")
	if completed and completed.Value == true then
		return true
	end

	local stage = folder and folder:FindFirstChild("Stage")
	if stage and stage.Value ~= "CleanSpills" and stage.Value ~= "GoToRed" then
		return false
	end

	if type(candidates) ~= "table" then
		return false
	end

	local root = getPlayerRoot(player)
	for _, part in ipairs(candidates) do
		if typeof(part) == "Instance"
			and part:IsA("BasePart")
			and part:GetAttribute("BreakableType")
			and not part:GetAttribute("IsCollected")
			and part.Transparency < 1
		then
			local colorType = part:GetAttribute("ColorType")
			if colorType == "Red" or canAccessBreakableColor(player, colorType, root) then
				return true
			end
		end
	end

	return false
end

local function findNearbyBreakables(player, origin, range, maxTargets)
	local candidates = {}
	for _, obj in ipairs(workspace:GetDescendants()) do
		if obj:IsA("BasePart")
			and obj:GetAttribute("BreakableType")
			and not obj:GetAttribute("IsCollected")
			and obj.Transparency < 1
		then
			local distance = (obj.Position - origin).Magnitude
			if distance <= range then
				table.insert(candidates, { part = obj, distance = distance })
			end
		end
	end

	table.sort(candidates, function(a, b)
		return a.distance < b.distance
	end)

	local result = {}
	for _, candidate in ipairs(candidates) do
		table.insert(result, candidate.part)
		if #result >= maxTargets then
			break
		end
	end
	return result
end

local function fireEffectVfx(player, effectName, fromPosition, targetPositions, mutationId)
	if #targetPositions == 0 then
		return
	end

	colorEffectVfxEvent:FireClient(player, {
		Effect = effectName,
		From = fromPosition,
		Targets = targetPositions,
		MutationId = mutationId or "None",
	})
end

local function collectProcTargets(player, targets, range)
	local total = 0
	local collected = 0
	local positions = {}

	for _, part in ipairs(targets) do
		local position = part.Position
		local ok, awarded = collectBreakable(player, part, {
			maxRange = range,
			skipCooldown = true,
			powerMultiplier = 1,
		})
		if ok and awarded > 0 then
			table.insert(positions, position)
			collected += 1
			total += awarded
		end
	end

	return collected, total, positions
end

local function tryBrushEffectProcs(player)
	local root = getPlayerRoot(player)
	if not root then
		return 0
	end

	local effects = ColorEffectHandler.CalculateEquippedColorEffects(player)
	local now = os.clock()
	local totalAwarded = 0
	local caps = GameBalance.ColorEffects or {}

	if effects.LightningProcChance > 0 then
		local cooldown = math.max(
			effects.LightningCooldown or 0,
			caps.LightningGlobalCooldown or 1
		)
		if (not lastLightningAt[player] or now - lastLightningAt[player] >= cooldown)
			and math.random() < effects.LightningProcChance
		then
			lastLightningAt[player] = now
			local range = math.min(effects.LightningRange, caps.LightningMaxRange or 55)
			local maxTargets = math.clamp(
				effects.LightningTargets,
				1,
				caps.LightningMaxTargetsPerProc or 4
			)
			local targets = findNearbyBreakables(player, root.Position, range, maxTargets)
			local _, awarded, positions = collectProcTargets(player, targets, range)
			totalAwarded += awarded
			fireEffectVfx(player, "Lightning", root.Position, positions, effects.SourceMutationId)
		end
	end

	if effects.MagnetProcChance > 0 then
		local cooldown = caps.MagnetGlobalCooldown or 1
		if (not lastMagnetAt[player] or now - lastMagnetAt[player] >= cooldown)
			and math.random() < effects.MagnetProcChance
		then
			lastMagnetAt[player] = now
			local range = math.min(effects.MagnetRange, caps.MagnetMaxRange or 55)
			local maxTargets = math.clamp(
				effects.MagnetTargets,
				1,
				caps.MagnetMaxTargetsPerProc or 5
			)
			local targets = findNearbyBreakables(player, root.Position, range, maxTargets)
			local _, awarded, positions = collectProcTargets(player, targets, range)
			totalAwarded += awarded
			fireEffectVfx(player, "Magnet", root.Position, positions, effects.SourceMutationId)
		end
	end

	return totalAwarded
end

collectEvent.OnServerEvent:Connect(function(player, part, ...)
	if select("#", ...) > 0 then
		warnUnexpectedClientValuesOnce(player, "CollectColor")
	end

	if GameBalance.Collection and GameBalance.Collection.RequireBrushToCollect then
		collectEvent:FireClient(player, false, 0, "Use your Brush to collect Color.")
		return
	end

	local ok, awarded, message = collectBreakable(player, part)
	if not ok then
		if message == "Coins are not ready." then
			warnCollectionOnce(player, "missing player data", message)
		elseif message == "Invalid target." or message == "That is not color." then
			warnCollectionOnce(player, "blob invalid", message)
		elseif message ~= "Slow down." and message ~= "Already collected." then
			warnCollectionOnce(player, "server rejected request", message)
		end
	end
	collectEvent:FireClient(player, ok, awarded, message)
end)

paintSweepEvent.OnServerEvent:Connect(function(player, toolId, candidates, mode, ...)
	if select("#", ...) > 0 then
		warnUnexpectedClientValuesOnce(player, "PaintToolSweep")
	end

	local tool, toolConfig = getEquippedPaintTool(player)
	if not toolConfig then
		paintSweepEvent:FireClient(player, {
			success = false,
			total = 0,
			collected = 0,
			message = "Equip your Brush first.",
		})
		return
	end

	if tool and toolId and toolConfig.Id ~= toolId then
		paintSweepEvent:FireClient(player, {
			success = false,
			total = 0,
			collected = 0,
			message = "Wrong Brush.",
		})
		return
	end

	mode = mode == "walk" and "walk" or "sweep"

	local effects = ColorEffectHandler.CalculateEquippedColorEffects(player)
	local toolStats = getToolEffectiveStats(toolConfig)
	local useSpeedMultiplier = math.max(tonumber(toolStats.UseSpeedMultiplier) or 1, 0.01)
	local cooldown = ((mode == "walk" and WALK_SWEEP_COOLDOWN or (toolConfig.Cooldown or 0.45)) * effects.BrushCooldownMultiplier) / useSpeedMultiplier
	local minimumCooldown = mode == "walk" and 0.1 or ((GameBalance.ColorEffects and GameBalance.ColorEffects.MinimumBrushCooldown) or 0.2)
	cooldown = math.max(cooldown, minimumCooldown)

	local now = os.clock()
	local cooldowns = mode == "walk" and lastWalkSweepAt or lastSweepAt
	if cooldowns[player] and now - cooldowns[player] < cooldown then
		return
	end
	cooldowns[player] = now

	if type(candidates) ~= "table" then
		paintSweepEvent:FireClient(player, {
			success = false,
			total = 0,
			collected = 0,
			message = "No Color in range.",
		})
		return
	end

	if mode == "walk" and not canWalkCollectDuringTutorial(player, candidates) then
		return
	end

	local range = getPaintToolRange(player, toolConfig)
	local width = (tonumber(toolConfig.Width) or 7) * (tonumber(toolStats.SweepWidthMultiplier) or 1)
	if mode == "walk" then
		range = math.min(WALK_PICKUP_RANGE * (tonumber(toolStats.PickupRadiusMultiplier) or 1), range)
	end
	local maxTargets = mode == "walk" and WALK_MAX_TARGETS or math.clamp(tonumber(toolConfig.MaxTargets) or 8, 1, 18)
	local collected = 0
	local total = 0
	local lastMessage = "No Color in range."
	local seen = {}

	for _, part in ipairs(candidates) do
		if collected >= maxTargets then
			break
		end
		if typeof(part) == "Instance" and not seen[part] then
			seen[part] = true
			if part:GetAttribute("GemDeposit") then
				continue
			end
			local inRange = mode == "walk"
				and isInsideWalkPickup(player, part, range)
				or isInsideToolSweep(player, part, range, width)
			if inRange then
				markPetPriorityTarget(player, part)
				local ok, awarded, message = collectBreakable(player, part, {
					maxRange = range,
					skipCooldown = true,
					powerMultiplier = toolStats.CollectPowerMultiplier or toolConfig.PowerMultiplier or 1,
					source = "brush",
					mode = mode,
				})
				lastMessage = message or lastMessage
				if ok and awarded > 0 then
					collected += 1
					total += awarded
				end
			end
		end
	end

	local procAwarded = mode == "sweep" and tryBrushEffectProcs(player) or 0
	total += procAwarded

	local success = total > 0
	if DEBUG_LOGS and success then
		print("PaintToolSweep: " .. player.Name .. " broke " .. tostring(collected) .. " Color blobs for " .. tostring(total) .. " Coins via " .. mode)
	end
	paintSweepEvent:FireClient(player, {
		success = success,
		total = total,
		collected = collected,
		message = success and ("+" .. tostring(total) .. " Coins") or lastMessage,
	})
	if success then
		collectEvent:FireClient(player, true, total, "Coins")
	end
end)

Players.PlayerRemoving:Connect(function(player)
	lastCollectAt[player] = nil
	lastSweepAt[player] = nil
	lastWalkSweepAt[player] = nil
	lastLightningAt[player] = nil
	lastMagnetAt[player] = nil
end)

if isTouchFallbackEnabled() then
	for _, obj in ipairs(workspace:GetDescendants()) do
		if obj:IsA("BasePart") and obj:GetAttribute("BreakableType") then
			hookTouchCollection(obj)
		end
	end

	workspace.DescendantAdded:Connect(function(obj)
		if obj:IsA("BasePart") and obj:GetAttribute("BreakableType") then
			hookTouchCollection(obj)
		end
	end)
end
]]></string>
        </Properties>
      </Item>
      <Item class="ModuleScript" referent="74">
        <Properties>
          <string name="Name">ColorEffectHandler</string>
          <string name="Source"><![CDATA[local ReplicatedStorage = game:GetService("ReplicatedStorage")

local PetData = require(ReplicatedStorage:WaitForChild("PetData"))
local ColorTraitData = require(ReplicatedStorage:WaitForChild("ColorTraitData"))
local ColorMutationData = require(ReplicatedStorage:WaitForChild("ColorMutationData"))
local GameBalance = require(ReplicatedStorage:WaitForChild("GameBalance"))
local BuffService = require(script.Parent:WaitForChild("BuffService"))

local ColorEffectHandler = {}

local CAPS = GameBalance.ColorEffects or {}

local DEFAULT_EFFECTS = {
	WalkSpeedBonus = 0,
	WalkSpeedMultiplier = 1,
	JumpPowerBonus = 0,
	BrushCooldownMultiplier = 1,
	BrushRangeMultiplier = 1,
	ColorGainMultiplier = 1,
	SellCoinsMultiplier = 1,
	HatchLuckBonus = 0,
	HatchLuckMultiplier = 1,
	LightningProcChance = 0,
	LightningTargets = 0,
	LightningRange = 0,
	LightningCooldown = 0,
	MagnetProcChance = 0,
	MagnetRange = 0,
	MagnetTargets = 0,
	GemRewardMultiplier = 1,
	GemDamageMultiplier = 1,
	GemSpawnChanceMultiplier = 1,
	ItemDropMultiplier = 1,
	CritChanceBonus = 0,
	InstantWeakSpillChance = 0,
	CoinBurstChance = 0,
	DoubleGemChance = 0,
	MutationLuckMultiplier = 1,
	RandomMultiplierCeiling = 1,
	ComboCoinMultiplier = 1,
	SourceMutationId = "None",
	BaseColorGainMultiplier = 1,
	BaseSellCoinsMultiplier = 1,
}

local function cloneDefaults()
	local result = {}
	for key, value in pairs(DEFAULT_EFFECTS) do
		result[key] = value
	end
	return result
end

local function parseInventory(str)
	local inventory = {}
	if not str or str == "" then
		return inventory
	end

	for _, part in ipairs(string.split(str, ",")) do
		local segments = string.split(part, ":")
		local variantKey
		local petId
		local stackIndex
		if tonumber(segments[2]) then
			petId = segments[1]
			stackIndex = 2
		else
			variantKey = segments[1]
			petId = segments[2]
			stackIndex = 3
		end

		if not petId or petId == "" or not PetData.Pets[petId] then
			continue
		end

		local stackAmount = math.max(1, tonumber(segments[stackIndex]) or 1)
		local traitId = PetData.normalizeTraitId(segments[stackIndex + 1])
		local shinyStr = segments[stackIndex + 2] or "normal"
		local personalityId = PetData.normalizePersonalityId(segments[stackIndex + 3] or "Neutral")
		local mutationId = PetData.normalizeMutationId(segments[stackIndex + 4] or "None")
		variantKey = PetData.makeVariantKey(petId, personalityId, mutationId, traitId)

		inventory[variantKey] = {
			petId = petId,
			stackAmount = stackAmount,
			traitId = traitId,
			isShiny = shinyStr == "shiny" or shinyStr == "true",
			personalityId = personalityId,
			mutationId = mutationId,
		}
	end

	return inventory
end

local function getPlayerInventoryData(player)
	local petFolder = player:FindFirstChild("PetData")
	local invVal = petFolder and petFolder:FindFirstChild("Inventory")
	local equippedVal = petFolder and petFolder:FindFirstChild("Equipped")
	if not invVal or not equippedVal then
		return {}, {}
	end

	local inventory = parseInventory(invVal.Value)
	local equipped = {}
	for _, rawKey in ipairs(string.split(equippedVal.Value or "", ",")) do
		local key = rawKey
		if inventory[key] then
			table.insert(equipped, key)
		else
			local legacyParts = string.split(rawKey, "|")
			for variantKey, data in pairs(inventory) do
				if rawKey == data.petId
					or rawKey == variantKey
					or (#legacyParts >= 3 and legacyParts[1] == data.petId and PetData.normalizeMutationId(legacyParts[3]) == data.mutationId)
				then
					table.insert(equipped, variantKey)
					break
				end
			end
		end
	end

	return inventory, equipped
end

local function multiplyEffect(result, key, value)
	value = tonumber(value)
	if value and value > 0 then
		result[key] *= value
	end
end

local function addEffect(result, key, value)
	value = tonumber(value)
	if value then
		result[key] += value
	end
end

local function mergeEffects(result, effects)
	if type(effects) ~= "table" then
		return
	end

	addEffect(result, "WalkSpeedBonus", effects.WalkSpeedBonus)
	multiplyEffect(result, "WalkSpeedMultiplier", effects.WalkSpeedMultiplier)
	addEffect(result, "JumpPowerBonus", effects.JumpPowerBonus)
	multiplyEffect(result, "BrushCooldownMultiplier", effects.BrushCooldownMultiplier)
	multiplyEffect(result, "BrushRangeMultiplier", effects.BrushRangeMultiplier)
	multiplyEffect(result, "ColorGainMultiplier", effects.ColorGainMultiplier)
	multiplyEffect(result, "SellCoinsMultiplier", effects.SellCoinsMultiplier)
	addEffect(result, "HatchLuckBonus", effects.HatchLuckBonus)
	multiplyEffect(result, "HatchLuckMultiplier", effects.HatchLuckMultiplier)
	addEffect(result, "LightningProcChance", effects.LightningProcChance)
	result.LightningTargets += math.floor(tonumber(effects.LightningTargets) or 0)
	result.LightningRange = math.max(result.LightningRange, tonumber(effects.LightningRange) or 0)
	result.LightningCooldown = result.LightningCooldown == 0
		and (tonumber(effects.LightningCooldown) or 0)
		or math.min(result.LightningCooldown, tonumber(effects.LightningCooldown) or result.LightningCooldown)
	addEffect(result, "MagnetProcChance", effects.MagnetProcChance)
	result.MagnetRange = math.max(result.MagnetRange, tonumber(effects.MagnetRange) or 0)
	result.MagnetTargets += math.floor(tonumber(effects.MagnetTargets) or 0)
	multiplyEffect(result, "GemRewardMultiplier", effects.GemRewardMultiplier)
	multiplyEffect(result, "GemDamageMultiplier", effects.GemDamageMultiplier)
	multiplyEffect(result, "GemSpawnChanceMultiplier", effects.GemSpawnChanceMultiplier)
	multiplyEffect(result, "ItemDropMultiplier", effects.ItemDropMultiplier)
	addEffect(result, "CritChanceBonus", effects.CritChanceBonus)
	addEffect(result, "InstantWeakSpillChance", effects.InstantWeakSpillChance)
	addEffect(result, "CoinBurstChance", effects.CoinBurstChance)
	addEffect(result, "DoubleGemChance", effects.DoubleGemChance)
	multiplyEffect(result, "MutationLuckMultiplier", effects.MutationLuckMultiplier)
	multiplyEffect(result, "RandomMultiplierCeiling", effects.RandomMultiplierCeiling)
	multiplyEffect(result, "ComboCoinMultiplier", effects.ComboCoinMultiplier)
end

local function clampEffects(result)
	result.WalkSpeedBonus = math.clamp(
		result.WalkSpeedBonus,
		0,
		CAPS.MaxWalkSpeedFromColors or 8
	)
	result.WalkSpeedMultiplier = math.clamp(result.WalkSpeedMultiplier, 1, CAPS.MaxWalkSpeedMultiplierFromBuffs or 1.6)
	result.JumpPowerBonus = math.clamp(
		result.JumpPowerBonus,
		0,
		CAPS.MaxJumpPowerFromColors or 30
	)
	result.BrushRangeMultiplier = math.clamp(
		result.BrushRangeMultiplier,
		1,
		CAPS.MaxBrushRangeMultiplier or 1.75
	)
	result.ColorGainMultiplier = math.clamp(
		result.ColorGainMultiplier,
		1,
		CAPS.MaxColorGainMultiplierFromColors or 3
	)
	result.SellCoinsMultiplier = math.clamp(
		result.SellCoinsMultiplier,
		1,
		CAPS.MaxSellMultiplierFromColors or 3
	)
	result.HatchLuckBonus = math.clamp(
		result.HatchLuckBonus,
		0,
		CAPS.MaxHatchLuckBonusFromColors or 0.5
	)
	result.HatchLuckMultiplier = math.clamp(result.HatchLuckMultiplier, 1, CAPS.MaxHatchLuckMultiplierFromBuffs or 2)
	result.LightningProcChance = math.clamp(result.LightningProcChance, 0, 0.75)
	result.LightningTargets = math.clamp(
		result.LightningTargets,
		0,
		CAPS.LightningMaxTargetsPerProc or 4
	)
	result.LightningRange = math.clamp(result.LightningRange, 0, CAPS.LightningMaxRange or 55)
	result.MagnetProcChance = math.clamp(result.MagnetProcChance, 0, 0.75)
	result.MagnetTargets = math.clamp(
		result.MagnetTargets > 0 and result.MagnetTargets or 2,
		0,
		CAPS.MagnetMaxTargetsPerProc or 5
	)
	result.MagnetRange = math.clamp(result.MagnetRange, 0, CAPS.MagnetMaxRange or 55)
	result.GemRewardMultiplier = math.clamp(result.GemRewardMultiplier, 1, 5)
	result.GemDamageMultiplier = math.clamp(result.GemDamageMultiplier, 1, 6)
	result.GemSpawnChanceMultiplier = math.clamp(result.GemSpawnChanceMultiplier, 1, 4)
	result.ItemDropMultiplier = math.clamp(result.ItemDropMultiplier, 1, 5)
	result.CritChanceBonus = math.clamp(result.CritChanceBonus, 0, 0.75)
	result.InstantWeakSpillChance = math.clamp(result.InstantWeakSpillChance, 0, 0.5)
	result.CoinBurstChance = math.clamp(result.CoinBurstChance, 0, 0.75)
	result.DoubleGemChance = math.clamp(result.DoubleGemChance, 0, 0.75)
	result.MutationLuckMultiplier = math.clamp(result.MutationLuckMultiplier, 1, 4)
	result.RandomMultiplierCeiling = math.clamp(result.RandomMultiplierCeiling, 1, 6)
	result.ComboCoinMultiplier = math.clamp(result.ComboCoinMultiplier, 1, 4)
	if result.LightningCooldown <= 0 then
		result.LightningCooldown = 4
	end
end

function ColorEffectHandler.CalculateEquippedColorEffects(player)
	local result = cloneDefaults()
	local inventory, equipped = getPlayerInventoryData(player)

	for _, variantKey in ipairs(equipped) do
		local data = inventory[variantKey]
		if data then
			local entry = PetData.buildPetEntry(
				data.petId,
				data.stackAmount,
				data.isShiny,
				data.personalityId,
				data.mutationId,
				data.traitId
			)
			if entry then
				multiplyEffect(result, "BaseColorGainMultiplier", entry.colorMult or 1)
				multiplyEffect(result, "BaseSellCoinsMultiplier", entry.coinMult or 1)
			end

			local trait = ColorTraitData.get(data.traitId)
			local mutation = ColorMutationData.get(data.mutationId)
			mergeEffects(result, trait and trait.Effects)
			mergeEffects(result, mutation and mutation.Effects)
			if mutation and ColorMutationData.isMutated(mutation.Id) then
				result.SourceMutationId = mutation.Id
			end
		end
	end

	mergeEffects(result, BuffService.GetEffects(player))

	clampEffects(result)
	result.ColorGainMultiplier *= result.BaseColorGainMultiplier
	result.SellCoinsMultiplier *= result.BaseSellCoinsMultiplier
	return result
end

function ColorEffectHandler.GetColorGainMultiplier(player)
	return ColorEffectHandler.CalculateEquippedColorEffects(player).ColorGainMultiplier
end

function ColorEffectHandler.GetSellCoinsMultiplier(player)
	return ColorEffectHandler.CalculateEquippedColorEffects(player).SellCoinsMultiplier
end

function ColorEffectHandler.GetHatchLuckBonus(player)
	return ColorEffectHandler.CalculateEquippedColorEffects(player).HatchLuckBonus
end

function ColorEffectHandler.GetHatchLuckMultiplier(player)
	return ColorEffectHandler.CalculateEquippedColorEffects(player).HatchLuckMultiplier
end

function ColorEffectHandler.ApplyCharacterEffects(player)
	local character = player.Character
	local humanoid = character and character:FindFirstChildOfClass("Humanoid")
	if not humanoid then
		return
	end

	local effects = ColorEffectHandler.CalculateEquippedColorEffects(player)
	local upgrades = player:FindFirstChild("Upgrades")
	local walkSpeedValue = upgrades and upgrades:FindFirstChild("WalkSpeed")
	local baseWalkSpeed = walkSpeedValue and walkSpeedValue.Value or (CAPS.BaseWalkSpeed or 16)
	local walkSpeed = math.min(
		(baseWalkSpeed + effects.WalkSpeedBonus) * effects.WalkSpeedMultiplier,
		CAPS.AbsoluteMaxWalkSpeed or 28
	)
	humanoid.WalkSpeed = walkSpeed

	humanoid.UseJumpPower = true
	local baseJumpPower = CAPS.BaseJumpPower or 50
	local jumpPower = math.min(
		baseJumpPower + effects.JumpPowerBonus,
		CAPS.AbsoluteMaxJumpPower or 85
	)
	humanoid.JumpPower = jumpPower
end

return ColorEffectHandler
]]></string>
        </Properties>
      </Item>
      <Item class="Script" referent="75">
        <Properties>
          <string name="Name">DailyQuestService</string>
          <token name="RunContext">0</token>
          <string name="Source"><![CDATA[-- ServerScriptService/Server/DailyQuestService
-- Server-owned daily quests. Other server systems report progress through ServerStorage.DailyQuestProgress.
local Players = game:GetService("Players")
local DataStoreService = game:GetService("DataStoreService")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local ServerStorage = game:GetService("ServerStorage")

local NPC_NAME = "Zork"
local QUESTS_PER_DAY = 3
local ZORK_INTRO_VERSION = 3

local Events = ReplicatedStorage:FindFirstChild("Events")
if not Events then
	Events = Instance.new("Folder")
	Events.Name = "Events"
	Events.Parent = ReplicatedStorage
end

local tutorialDailyQuestsIntroducedEvent = Events:FindFirstChild("TutorialDailyQuestsIntroduced")
if not tutorialDailyQuestsIntroducedEvent then
	tutorialDailyQuestsIntroducedEvent = Instance.new("BindableEvent")
	tutorialDailyQuestsIntroducedEvent.Name = "TutorialDailyQuestsIntroduced"
	tutorialDailyQuestsIntroducedEvent.Parent = Events
end

local DailyQuestStore = DataStoreService:GetDataStore("DailyQuestData_v1")

local DailyQuestRemote = ReplicatedStorage:FindFirstChild("DailyQuestRemote")
if not DailyQuestRemote then
	DailyQuestRemote = Instance.new("RemoteEvent")
	DailyQuestRemote.Name = "DailyQuestRemote"
	DailyQuestRemote.Parent = ReplicatedStorage
end

local DailyQuestProgress = ServerStorage:FindFirstChild("DailyQuestProgress")
if not DailyQuestProgress then
	DailyQuestProgress = Instance.new("BindableEvent")
	DailyQuestProgress.Name = "DailyQuestProgress"
	DailyQuestProgress.Parent = ServerStorage
end

local DAILY_QUEST_POOL = {
	{
		Id = "CleanColorSpills",
		Title = "CLEAN COLOR SPILLS",
		Description = "Clean 40 color spills.",
		IconText = "BRUSH",
		ProgressType = "ColorSpillsCleaned",
		Target = 40,
		RewardCurrency = "Gems",
		RewardAmount = 20,
	},
	{
		Id = "EarnCoins",
		Title = "EARN COINS",
		Description = "Earn 1,000 coins.",
		IconText = "COINS",
		ProgressType = "CoinsEarned",
		Target = 1000,
		RewardCurrency = "Gems",
		RewardAmount = 25,
	},
	{
		Id = "HatchColors",
		Title = "HATCH COLORS",
		Description = "Hatch 3 colors from eggs.",
		IconText = "EGG",
		ProgressType = "ColorsHatched",
		Target = 3,
		RewardCurrency = "Gems",
		RewardAmount = 30,
	},
	{
		Id = "BreakGemDeposits",
		Title = "BREAK GEM DEPOSITS",
		Description = "Break 3 gem deposits.",
		IconText = "GEM",
		ProgressType = "GemDepositsBroken",
		Target = 3,
		RewardCurrency = "Gems",
		RewardAmount = 25,
	},
	{
		Id = "CleanRedWastelands",
		Title = "CLEAN RED WASTELANDS",
		Description = "Clean 25 spills in the Red Wastelands.",
		IconText = "RED",
		ProgressType = "RedWastelandsSpillsCleaned",
		Target = 25,
		RewardCurrency = "Gems",
		RewardAmount = 20,
	},
	{
		Id = "UseBrush",
		Title = "USE YOUR BRUSH",
		Description = "Clean with your brush 75 times.",
		IconText = "BRUSH",
		ProgressType = "BrushUses",
		Target = 75,
		RewardCurrency = "Gems",
		RewardAmount = 15,
	},
}

local profiles = {}

local QUEST_BY_ID = {}
local DEFAULT_QUEST_IDS = {
	"CleanColorSpills",
	"EarnCoins",
	"HatchColors",
}
local LEGACY_QUEST_ID_MAP = {
	CleanSpills = "CleanColorSpills",
	BreakGems = "BreakGemDeposits",
}

for _, quest in ipairs(DAILY_QUEST_POOL) do
	QUEST_BY_ID[quest.Id] = quest
end

local function getCurrentDayId()
	return math.floor(os.time() / 86400)
end

local function getSecondsUntilReset()
	return 86400 - (os.time() % 86400)
end

local function getKey(player)
	return "Player_" .. player.UserId
end

local function copyQuest(template, existing)
	local target = math.max(1, tonumber(template.Target) or 1)
	local progress = existing and math.clamp(tonumber(existing.progress or existing.Progress) or 0, 0, target) or 0
	return {
		id = template.Id,
		title = template.Title,
		description = template.Description,
		iconText = template.IconText,
		progressType = template.ProgressType,
		target = target,
		rewardCurrency = template.RewardCurrency,
		rewardAmount = math.max(0, tonumber(template.RewardAmount) or 0),
		reward = math.max(0, tonumber(template.RewardAmount) or 0),
		progress = progress,
		claimed = existing and existing.claimed == true or false,
	}
end

local function buildNewProfile(player, zorkIntroduced)
	local dayId = getCurrentDayId()
	local seed = (math.abs(player.UserId) * 97 + dayId * 1009) % 2147483647
	local rng = Random.new(seed)

	local pool = table.clone(DAILY_QUEST_POOL)
	local quests = {}
	local questIds = {}
	for _ = 1, math.min(QUESTS_PER_DAY, #pool) do
		local index = rng:NextInteger(1, #pool)
		table.insert(quests, copyQuest(pool[index]))
		table.insert(questIds, pool[index].Id)
		table.remove(pool, index)
	end
	for index = #quests + 1, QUESTS_PER_DAY do
		local template = QUEST_BY_ID[DEFAULT_QUEST_IDS[index]] or DAILY_QUEST_POOL[index]
		table.insert(quests, copyQuest(template))
		table.insert(questIds, template.Id)
	end

	return {
		dayId = dayId,
		questIds = questIds,
		quests = quests,
		zorkIntroduced = zorkIntroduced == true,
		zorkIntroVersion = zorkIntroduced == true and ZORK_INTRO_VERSION or 0,
		dirty = true,
	}
end

local function buildFallbackQuest(index)
	local template = QUEST_BY_ID[DEFAULT_QUEST_IDS[index]] or DAILY_QUEST_POOL[index] or DAILY_QUEST_POOL[1]
	return copyQuest(template)
end

local function getExactlyThreeQuests(profile)
	local quests = {}
	for index = 1, QUESTS_PER_DAY do
		local quest = profile and type(profile.quests) == "table" and profile.quests[index] or nil
		if type(quest) == "table" then
			local questId = tostring(quest.id or quest.Id or "")
			questId = LEGACY_QUEST_ID_MAP[questId] or questId
			local template = QUEST_BY_ID[questId]
			if template then
				quests[index] = copyQuest(template, quest)
			else
				quests[index] = buildFallbackQuest(index)
			end
		else
			quests[index] = buildFallbackQuest(index)
		end
	end
	return quests
end

local function hasCurrentZorkIntro(data)
	return data
		and data.zorkIntroduced == true
		and tonumber(data.zorkIntroVersion) == ZORK_INTRO_VERSION
end

local function normalizeProfile(player, data)
	if type(data) ~= "table" then
		return buildNewProfile(player)
	end
	if tonumber(data.dayId) ~= getCurrentDayId() then
		return buildNewProfile(player, hasCurrentZorkIntro(data))
	end
	if type(data.quests) ~= "table" or #data.quests ~= QUESTS_PER_DAY then
		return buildNewProfile(player, hasCurrentZorkIntro(data))
	end

	local questIds = {}
	for index, quest in ipairs(data.quests) do
		local questId = tostring(quest.id or quest.Id or "")
		questId = LEGACY_QUEST_ID_MAP[questId] or questId
		local template = QUEST_BY_ID[questId]
		if not template then
			return buildNewProfile(player, hasCurrentZorkIntro(data))
		end
		data.quests[index] = copyQuest(template, quest)
		table.insert(questIds, template.Id)
	end

	data.questIds = questIds
	data.zorkIntroduced = hasCurrentZorkIntro(data)
	data.zorkIntroVersion = data.zorkIntroduced and ZORK_INTRO_VERSION or 0
	data.dirty = false
	return data
end

local function serializeProfile(profile)
	local quests = {}
	for index, quest in ipairs(getExactlyThreeQuests(profile)) do
		quests[index] = {
			id = quest.id,
			iconText = quest.iconText,
			progressType = quest.progressType,
			title = quest.title,
			description = quest.description,
			target = quest.target,
			rewardCurrency = quest.rewardCurrency,
			rewardAmount = quest.rewardAmount,
			reward = quest.reward,
			progress = quest.progress,
			claimed = quest.claimed == true,
		}
	end
	return {
		dayId = profile.dayId,
		questIds = profile.questIds,
		quests = quests,
		zorkIntroduced = profile.zorkIntroduced == true,
		zorkIntroVersion = profile.zorkIntroduced == true and ZORK_INTRO_VERSION or 0,
	}
end

local function makeClientData(profile)
	local quests = {}
	for index, quest in ipairs(getExactlyThreeQuests(profile)) do
		quests[index] = {
			id = quest.id,
			iconText = quest.iconText,
			progressType = quest.progressType,
			title = quest.title,
			description = quest.description,
			target = quest.target,
			rewardCurrency = quest.rewardCurrency,
			rewardAmount = quest.rewardAmount,
			reward = quest.reward,
			progress = quest.progress,
			claimed = quest.claimed == true,
		}
	end
	return {
		resetIn = getSecondsUntilReset(),
		quests = quests,
		Quests = quests,
		zorkIntroduced = profile.zorkIntroduced == true,
	}
end

local function setZorkIntroduced(player, profile)
	if not profile then
		return
	end

	if profile.zorkIntroduced ~= true then
		profile.zorkIntroduced = true
		profile.zorkIntroVersion = ZORK_INTRO_VERSION
		profile.dirty = true
	end
	player:SetAttribute("DailyQuestsHudUnlocked", true)
	if tutorialDailyQuestsIntroducedEvent and tutorialDailyQuestsIntroducedEvent:IsA("BindableEvent") then
		tutorialDailyQuestsIntroducedEvent:Fire(player)
	end
end

local function saveProfile(player, force)
	local profile = profiles[player]
	if not profile then
		return false
	end
	if not force and not profile.dirty then
		return true
	end

	local dataToSave = serializeProfile(profile)
	local success, err = pcall(function()
		DailyQuestStore:UpdateAsync(getKey(player), function()
			return dataToSave
		end)
	end)

	if success then
		profile.dirty = false
		return true
	end

	warn("Daily quest save failed for " .. player.Name .. ": " .. tostring(err))
	return false
end

local function findGemValue(player)
	local foldersToCheck = {
		"leaderstats",
		"Stats",
		"Data",
		"PlayerData",
		"Currencies",
	}

	for _, folderName in ipairs(foldersToCheck) do
		local folder = player:FindFirstChild(folderName)
		if folder then
			local gems = folder:FindFirstChild("Gems")
			if gems and (gems:IsA("IntValue") or gems:IsA("NumberValue")) then
				return gems
			end
		end
	end

	local directGems = player:FindFirstChild("Gems")
	if directGems and (directGems:IsA("IntValue") or directGems:IsA("NumberValue")) then
		return directGems
	end
	return nil
end

local function addGems(player, amount)
	local gems = findGemValue(player)
	if not gems then
		local leaderstats = player:FindFirstChild("leaderstats")
		if not leaderstats then
			leaderstats = Instance.new("Folder")
			leaderstats.Name = "leaderstats"
			leaderstats.Parent = player
		end

		local existing = leaderstats:FindFirstChild("Gems")
		if existing then
			warn("Gems exists but is not an IntValue or NumberValue.")
			return false
		end

		gems = Instance.new("IntValue")
		gems.Name = "Gems"
		gems.Value = 0
		gems.Parent = leaderstats
	end

	gems.Value += math.max(0, math.floor(tonumber(amount) or 0))

	local events = ReplicatedStorage:FindFirstChild("Events")
	local dirtyEvent = events and events:FindFirstChild("PlayerDataDirty")
	if dirtyEvent and dirtyEvent:IsA("BindableEvent") then
		dirtyEvent:Fire(player, "gems")
	end
	return true
end

local function refreshDailyQuests(player)
	local profile = profiles[player]
	if not profile then
		return nil
	end

	if tonumber(profile.dayId) ~= getCurrentDayId() then
		profiles[player] = buildNewProfile(player, profile.zorkIntroduced == true)
		profile = profiles[player]
		saveProfile(player, true)
	end
	if type(profile.quests) ~= "table" or #profile.quests ~= QUESTS_PER_DAY then
		warn("DailyQuestService: repaired invalid quest list for " .. player.Name)
		profile.quests = getExactlyThreeQuests(profile)
		profile.questIds = {}
		for index, quest in ipairs(profile.quests) do
			profile.questIds[index] = quest.id
		end
		profile.dirty = true
	end
	player:SetAttribute("DailyQuestsHudUnlocked", profile.zorkIntroduced == true)

	return profile
end

local function loadProfile(player)
	local data
	local success, result = pcall(function()
		return DailyQuestStore:GetAsync(getKey(player))
	end)

	if success then
		data = result
	else
		warn("Daily quest load failed for " .. player.Name .. ": " .. tostring(result))
	end

	local profile = normalizeProfile(player, data)
	profiles[player] = profile
	player:SetAttribute("DailyQuestsHudUnlocked", profile.zorkIntroduced == true)
	DailyQuestRemote:FireClient(player, "Update", makeClientData(profile))
end

local function addQuestProgress(player, progressType, amount)
	if typeof(player) ~= "Instance" or not player:IsA("Player") then
		return
	end

	local profile = profiles[player]
	if not profile then
		return
	end

	profile = refreshDailyQuests(player)
	if not profile then
		return
	end

	progressType = tostring(progressType)
	amount = math.max(1, math.floor(tonumber(amount) or 1))

	local changed = false
	for _, quest in ipairs(profile.quests) do
		if (quest.progressType == progressType or quest.id == progressType) and not quest.claimed then
			local oldProgress = quest.progress
			quest.progress = math.min(quest.target, quest.progress + amount)
			if quest.progress ~= oldProgress then
				changed = true
			end
		end
	end

	if changed then
		profile.dirty = true
		DailyQuestRemote:FireClient(player, "Update", makeClientData(profile))
	end
end

local function claimQuest(player, slot)
	local profile = profiles[player]
	if not profile then
		return
	end

	profile = refreshDailyQuests(player)
	if not profile then
		return
	end

	local quest = profile.quests[tonumber(slot)]
	if not quest or quest.claimed or quest.progress < quest.target then
		return
	end

	quest.claimed = true
	profile.dirty = true

	if not addGems(player, quest.reward) then
		quest.claimed = false
		return
	end

	saveProfile(player, true)
	DailyQuestRemote:FireClient(player, "Update", makeClientData(profile))
end

DailyQuestProgress.Event:Connect(addQuestProgress)

DailyQuestRemote.OnServerEvent:Connect(function(player, action, value)
	if action == "Get" then
		if not profiles[player] then
			loadProfile(player)
		end
		local profile = refreshDailyQuests(player)
		if profile then
			if profile.zorkIntroduced ~= true then
				player:SetAttribute("DailyQuestsHudUnlocked", false)
				DailyQuestRemote:FireClient(player, "Locked", makeClientData(profile))
				return
			end
			DailyQuestRemote:FireClient(player, "Open", makeClientData(profile))
		end
	elseif action == "UnlockFromZork" then
		if not profiles[player] then
			loadProfile(player)
		end
		local profile = refreshDailyQuests(player)
		if profile then
			setZorkIntroduced(player, profile)
			saveProfile(player, true)
			DailyQuestRemote:FireClient(player, "Open", makeClientData(profile))
		end
	elseif action == "Claim" then
		local profile = profiles[player]
		if profile and profile.zorkIntroduced == true then
			claimQuest(player, value)
		end
	end
end)

local function findZork()
	for _ = 1, 60 do
		local npc = workspace:FindFirstChild(NPC_NAME, true)
		if npc then
			return npc
		end
		task.wait(0.5)
	end
	return nil
end

local function findPromptPart(zork)
	if zork:IsA("Model") then
		return zork.PrimaryPart
			or zork:FindFirstChild("ShopPromptCore", true)
			or zork:FindFirstChild("HumanoidRootPart", true)
			or zork:FindFirstChild("Head", true)
			or zork:FindFirstChildWhichIsA("BasePart", true)
	end
	return zork:IsA("BasePart") and zork or zork:FindFirstChildWhichIsA("BasePart", true)
end

local function removeLegacyZorkQuestPrompt()
	local zork = findZork()
	if not zork then
		return
	end

	for _, descendant in ipairs(zork:GetDescendants()) do
		if descendant:IsA("ProximityPrompt") and descendant.Name == "DailyQuestPrompt" then
			descendant:Destroy()
		end
	end
end

Players.PlayerAdded:Connect(loadProfile)

Players.PlayerRemoving:Connect(function(player)
	saveProfile(player, true)
	profiles[player] = nil
end)

for _, player in ipairs(Players:GetPlayers()) do
	task.spawn(loadProfile, player)
end

task.spawn(removeLegacyZorkQuestPrompt)

task.spawn(function()
	while true do
		task.wait(60)
		for player in pairs(profiles) do
			saveProfile(player, false)
		end
	end
end)

game:BindToClose(function()
	for player in pairs(profiles) do
		saveProfile(player, true)
	end
end)
]]></string>
        </Properties>
      </Item>
      <Item class="Script" referent="76">
        <Properties>
          <string name="Name">DataManager</string>
          <token name="RunContext">0</token>
          <string name="Source"><![CDATA[-- Script in ServerScriptService named "DataManager"
local Players = game:GetService("Players")
local DataStoreService = game:GetService("DataStoreService")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local RunService = game:GetService("RunService")

local ColorData = require(ReplicatedStorage:WaitForChild("ColorData"))
local PetData = require(ReplicatedStorage:WaitForChild("PetData"))
local SettingsData = require(ReplicatedStorage:WaitForChild("SettingsData"))
local ToolData = require(ReplicatedStorage:WaitForChild("ToolData"))

local GameStore = DataStoreService:GetDataStore("ColorSimulator_v1")
local Events = ReplicatedStorage:WaitForChild("Events")
local playerDataDirtyEvent = Events:FindFirstChild("PlayerDataDirty")
if not playerDataDirtyEvent then
	playerDataDirtyEvent = Instance.new("BindableEvent")
	playerDataDirtyEvent.Name = "PlayerDataDirty"
	playerDataDirtyEvent.Parent = Events
end
local requestSetSettingEvent = Events:FindFirstChild("RequestSetSetting")
if not requestSetSettingEvent then
	requestSetSettingEvent = Instance.new("RemoteEvent")
	requestSetSettingEvent.Name = "RequestSetSetting"
	requestSetSettingEvent.Parent = Events
end
local settingsUpdatedEvent = Events:FindFirstChild("SettingsUpdated")
if not settingsUpdatedEvent then
	settingsUpdatedEvent = Instance.new("RemoteEvent")
	settingsUpdatedEvent.Name = "SettingsUpdated"
	settingsUpdatedEvent.Parent = Events
end
local markTutorialProgressEvent = Events:FindFirstChild("MarkTutorialProgress")
if not markTutorialProgressEvent then
	markTutorialProgressEvent = Instance.new("RemoteEvent")
	markTutorialProgressEvent.Name = "MarkTutorialProgress"
	markTutorialProgressEvent.Parent = Events
end

local ENABLE_STUDIO_DATASTORE = false
local AUTO_SAVE_INTERVAL = RunService:IsStudio() and 0 or 180
local MIN_SAVE_INTERVAL = 90
local CRITICAL_SAVE_DELAY = 8
local CRITICAL_SAVE_COOLDOWN = 45
local CURRENT_DATA_VERSION = 5
local sessionData

local warnedMigrationKeys = {}
local function warnOnce(key, message)
	if warnedMigrationKeys[key] then
		return
	end
	warnedMigrationKeys[key] = true
	warn(message)
end

-- Default data for a brand new player.
-- Player-facing companions are called Colors, but saved data keeps Pet fields for backward compatibility.
local DEFAULT_DATA = {
	Version      = CURRENT_DATA_VERSION,
	DataVersion  = CURRENT_DATA_VERSION,
	Coins        = 0,
	Gems         = 0,
	Diamonds     = 0,
	Rebirths     = 0,
	UnlockedColors = {"Red"},
	CurrentWorld = "Red",
	UnlockedTeleports = { "OriginSector" },
	PetInventory = {},   -- canonical saved Color inventory; list of { petId = "RedBlob", stackAmount = 1, traitId = "Neutral", mutationId = "None" }
	EquippedPets = {},   -- list of Color variant keys
	LockedPets = {},     -- variant keys protected from deletion
	OwnedPaintTools = {"StarterBrush"},
	EquippedPaintTool = "StarterBrush",
	Settings = {
		Music = true,
		SFX = true,
		Popups = true,
		LowFX = false,
	},
	Upgrades = {},
	RedeemedCodes = {},   -- [normalizedCode] = uses
	TutorialCompleted = false,
	TutorialProgress = {
		SeenTraitsTutorial = false,
		MutationsUnlocked = false,
		HasSeenMutationTutorial = false,
	},
	GroupRewards = {
		LastDailyGemClaim = "",
	},
	GamepassGrants = {},
}

local OWNER_RAINBOW_PET_ID = "DevRainbowPet"
local OWNER_RAINBOW_PET_TRAIT = "SuperLucky"
local OWNER_RAINBOW_PET_NAMES = {
	jackdoesrb = true,
}

local function shouldOwnRainbowPet(player)
	if not player then
		return false
	end
	if OWNER_RAINBOW_PET_NAMES[string.lower(player.Name)] then
		return true
	end
	return game.CreatorType == Enum.CreatorType.User and player.UserId == game.CreatorId
end

local function makeOwnerRainbowRecord()
	return {
		petId = OWNER_RAINBOW_PET_ID,
		stackAmount = 1,
		traitId = PetData.normalizeTraitId(OWNER_RAINBOW_PET_TRAIT),
		traitName = PetData.normalizeTraitId(OWNER_RAINBOW_PET_TRAIT),
		isShiny = false,
		personalityId = "Neutral",
		mutationId = PetData.normalizeMutationId("None"),
		mergeTier = "Normal",
	}
end

local function ensureOwnerRainbowPetList(player, list)
	if not shouldOwnRainbowPet(player) then
		return list
	end

	list = type(list) == "table" and list or {}
	local wanted = makeOwnerRainbowRecord()
	local wantedKey = PetData.makeVariantKey(wanted.petId, wanted.personalityId, wanted.mutationId, wanted.traitId)
	for _, record in ipairs(list) do
		if type(record) == "table" then
			local traitId = PetData.normalizeTraitId(record.traitId or record.TraitId or record.traitName or "Neutral")
			local mutationId = PetData.normalizeMutationId(record.mutationId or record.MutationId or "None")
			local personalityId = PetData.normalizePersonalityId(record.personalityId or record.PersonalityId or "Neutral")
			local recordKey = PetData.makeVariantKey(record.petId or record.PetId, personalityId, mutationId, traitId)
			if recordKey == wantedKey then
				record.petId = OWNER_RAINBOW_PET_ID
				record.stackAmount = math.max(1, tonumber(record.stackAmount or record.StackAmount) or 1)
				record.traitId = wanted.traitId
				record.traitName = wanted.traitName
				record.isShiny = false
				record.personalityId = "Neutral"
				record.mutationId = wanted.mutationId
				record.mergeTier = "Normal"
				return list
			end
		end
	end

	table.insert(list, wanted)
	return list
end

-- Deep copy a table so defaults are never mutated
local function deepCopy(tbl)
	if type(tbl) ~= "table" then
		return tbl
	end
	local copy = {}
	for k, v in pairs(tbl) do
		copy[k] = type(v) == "table" and deepCopy(v) or v
	end
	return copy
end

-- Fill defaults only where fields are missing. Existing saved tables are preserved.
local function DeepFillMissing(target, defaults)
	if type(target) ~= "table" then
		target = {}
	end
	for key, defaultValue in pairs(defaults or {}) do
		local currentValue = target[key]
		if currentValue == nil then
			target[key] = deepCopy(defaultValue)
		elseif type(currentValue) == "table" and type(defaultValue) == "table" then
			DeepFillMissing(currentValue, defaultValue)
		end
	end
	return target
end

local function normalizeUnlockedColorList(value)
	local set = {}
	if type(value) == "table" then
		for key, colorType in pairs(value) do
			if colorType == true then
				colorType = key
			end
			local world = ColorData.getWorldByColor(colorType)
			if world then
				set[world.primaryColor] = true
			end
		end
	elseif type(value) == "string" then
		for _, colorType in ipairs(string.split(value, ",")) do
			local world = ColorData.getWorldByColor(colorType)
			if world then
				set[world.primaryColor] = true
			end
		end
	end

	set.Red = true
	local highestUnlockedIndex = 1
	for index, world in ipairs(ColorData.Worlds or {}) do
		if set[world.primaryColor] then
			highestUnlockedIndex = math.max(highestUnlockedIndex, index)
		end
	end
	for index = 1, highestUnlockedIndex do
		local world = ColorData.Worlds[index]
		if world then
			set[world.primaryColor] = true
		end
	end

	local ordered = {}
	for _, world in ipairs(ColorData.Worlds or {}) do
		if set[world.primaryColor] then
			table.insert(ordered, world.primaryColor)
		end
	end
	return ordered
end

local function getHighestUnlockedColor(unlockedColors)
	local set = {}
	for _, colorType in ipairs(unlockedColors or {}) do
		set[colorType] = true
	end

	local highest = "Red"
	for _, world in ipairs(ColorData.Worlds or {}) do
		if set[world.primaryColor] then
			highest = world.primaryColor
		end
	end
	return highest
end

local function normalizeCurrentWorld(colorType, unlockedColors)
	local world = ColorData.getWorldByColor(colorType)
	local normalized = world and world.primaryColor or nil
	if normalized then
		for _, unlockedColor in ipairs(unlockedColors or {}) do
			if unlockedColor == normalized then
				return normalized
			end
		end
	end
	return getHighestUnlockedColor(unlockedColors)
end

local function normalizeTeleportList(value)
	local seen = {}
	local ordered = {}

	local function add(locationId)
		locationId = tostring(locationId or "")
		if locationId == "" or seen[locationId] then
			return
		end
		seen[locationId] = true
		table.insert(ordered, locationId)
	end

	add("OriginSector")
	if type(value) == "table" then
		for key, locationId in pairs(value) do
			if locationId == true then
				locationId = key
			end
			add(locationId)
		end
	elseif type(value) == "string" then
		for _, locationId in ipairs(string.split(value, ",")) do
			add(locationId)
		end
	end

	return ordered
end

local function normalizePaintToolList(value)
	local seen = {}
	local ordered = {}

	local function add(toolId)
		toolId = tostring(toolId or "")
		if toolId == "" or seen[toolId] then
			return
		end
		if ToolData.isValid and not ToolData.isValid(toolId) then
			warnOnce("invalid-brush-" .. toolId, "DataManager: invalid saved brush id repaired: " .. toolId)
			return
		end
		seen[toolId] = true
		table.insert(ordered, toolId)
	end

	if type(value) == "string" then
		for _, toolId in ipairs(string.split(value, ",")) do
			add(toolId)
		end
	elseif type(value) == "table" then
		for key, toolId in pairs(value) do
			if toolId == true then
				add(key)
			else
				add(toolId)
			end
		end
	end

	if not seen.StarterBrush then
		table.insert(ordered, 1, "StarterBrush")
	end
	return ordered
end

local function normalizeEquippedPaintTool(toolId, ownedTools)
	toolId = tostring(toolId or "")
	local owned = {}
	for _, ownedToolId in ipairs(ownedTools or {}) do
		owned[ownedToolId] = true
	end

	if toolId ~= "" and owned[toolId] then
		return toolId
	end
	return "StarterBrush"
end

local function normalizeSettings(settings)
	return SettingsData.Normalize(settings)
end

local function applySettingAttributes(player, settings)
	local normalized = normalizeSettings(settings)
	for key, value in pairs(normalized) do
		player:SetAttribute("Setting" .. key, value)
	end
end

local function sendSettings(player, success, settingKey, message)
	local settingsFolder = player:FindFirstChild("Settings")
	local settings = {}
	if settingsFolder then
		for key, defaultValue in pairs(SettingsData.Defaults) do
			local value = settingsFolder:FindFirstChild(key)
			settings[key] = value and value:IsA("BoolValue") and value.Value or defaultValue
		end
	else
		local cached = sessionData and sessionData[player]
		settings = normalizeSettings(cached and cached.Settings)
	end

	settingsUpdatedEvent:FireClient(player, normalizeSettings(settings), success ~= false, settingKey, message)
end

local function encodePetRecord(record)
	if type(record) == "string" then
		return record
	end

	local petId = record.petId or record.PetId
	if not petId or petId == "" then
		return nil
	end

	local stackAmount = tonumber(record.stackAmount or record.StackAmount or record.amount or record.Amount) or 1
	local traitId = record.traitId or record.TraitId or record.traitName or record.TraitName or record.trait or "Neutral"
	if type(traitId) == "table" then
		traitId = traitId.Id or traitId.id or traitId.name or "Neutral"
	end
	traitId = PetData.normalizeTraitId(traitId)

	local shiny = record.isShiny or record.IsShiny
	local shinyText = shiny and "shiny" or "normal"
	local personalityId = record.personalityId or record.PersonalityId or "Neutral"
	local mutationId = PetData.normalizeMutationId(record.mutationId or record.MutationId or "None")
	local variantKey = PetData.makeVariantKey(petId, personalityId, mutationId, traitId)

	return tostring(variantKey) .. ":" .. tostring(petId) .. ":" .. tostring(math.max(1, stackAmount)) .. ":" .. tostring(traitId) .. ":" .. shinyText .. ":" .. tostring(personalityId) .. ":" .. tostring(mutationId)
end

local function decodePetRecord(encoded)
	local segments = string.split(encoded, ":")
	local variantKey
	local petId
	local stackIndex
	if tonumber(segments[2]) then
		petId = segments[1]
		variantKey = petId
		stackIndex = 2
	else
		variantKey = segments[1]
		petId = segments[2]
		stackIndex = 3
	end
	if not petId or petId == "" then
		return nil
	end

	return {
		variantKey = variantKey,
		petId = petId,
		stackAmount = tonumber(segments[stackIndex]) or 1,
		traitId = PetData.normalizeTraitId(segments[stackIndex + 1]),
		traitName = PetData.normalizeTraitId(segments[stackIndex + 1]),
		isShiny = segments[stackIndex + 2] == "shiny" or segments[stackIndex + 2] == "true",
		personalityId = segments[stackIndex + 3] or "Neutral",
		mutationId = PetData.normalizeMutationId(segments[stackIndex + 4] or "None"),
	}
end

local function countPetStacks(records)
	if type(records) ~= "table" then
		return 0
	end

	local count = 0
	for _, record in pairs(records) do
		if type(record) == "table" or type(record) == "string" then
			count += 1
		end
	end
	return count
end

local function countPetAmount(records)
	if type(records) ~= "table" then
		return 0
	end

	local total = 0
	for _, record in pairs(records) do
		if type(record) == "table" then
			total += math.max(1, tonumber(record.stackAmount or record.StackAmount or record.amount or record.Amount or record.count or record.Count) or 1)
		elseif type(record) == "string" and record ~= "" then
			local decoded = decodePetRecord(record)
			total += decoded and math.max(1, tonumber(decoded.stackAmount) or 1) or 1
		end
	end
	return total
end

local function countList(value)
	return type(value) == "table" and #value or 0
end

local function countMap(value)
	if type(value) ~= "table" then
		return 0
	end

	local total = 0
	for _ in pairs(value) do
		total += 1
	end
	return total
end

local function countUnlockedSectors(data)
	return countList(data and data.UnlockedColors)
end

local function ownsUnlockedColor(data, colorType)
	for _, unlockedColor in ipairs((data and data.UnlockedColors) or {}) do
		if unlockedColor == colorType then
			return true
		end
	end
	return false
end

local function ownsPaintTool(data, toolId)
	for _, ownedToolId in ipairs((data and data.OwnedPaintTools) or {}) do
		if ownedToolId == toolId then
			return true
		end
	end
	return false
end

local function finiteNumber(value, fallback, fieldName, player)
	local numberValue = tonumber(value)
	if not numberValue or numberValue ~= numberValue or numberValue == math.huge or numberValue == -math.huge then
		if player then
			warn("DataManager: repaired invalid numeric field " .. tostring(fieldName) .. " for " .. player.Name)
		end
		return fallback
	end
	return numberValue
end

local function getRecordVariantKey(record)
	if type(record) ~= "table" then
		return nil
	end
	return PetData.makeVariantKey(record.petId, record.personalityId, record.mutationId, record.traitId)
end

local function resolveEquippedPetKey(records, key)
	if not key or key == "" then
		return nil
	end

	key = tostring(key)
	for _, record in ipairs(records or {}) do
		local variantKey = getRecordVariantKey(record)
		if variantKey == key or record.petId == key then
			return variantKey
		end

		local legacyParts = string.split(key, "|")
		if #legacyParts >= 3 and legacyParts[1] == record.petId then
			local traitMatches = PetData.normalizeTraitId(legacyParts[2]) == PetData.normalizeTraitId(record.traitId)
			local mutationMatches = PetData.normalizeMutationId(legacyParts[3]) == PetData.normalizeMutationId(record.mutationId)
			if traitMatches and mutationMatches then
				return variantKey
			end
		end
	end
	return nil
end

local function sanitizeEquippedPetList(equippedList, petRecords, player)
	local sanitized = {}
	local seen = {}
	if type(equippedList) ~= "table" then
		return sanitized
	end

	for _, key in ipairs(equippedList) do
		local resolvedKey = resolveEquippedPetKey(petRecords, key)
		if resolvedKey and not seen[resolvedKey] then
			seen[resolvedKey] = true
			table.insert(sanitized, resolvedKey)
		elseif key and key ~= "" and player then
			warn("DataManager: removed invalid equipped Color for " .. player.Name .. ": " .. tostring(key))
		end
	end
	return sanitized
end

local function formatProfileSummary(data)
	return "v=" .. tostring(data and (data.DataVersion or data.Version))
		.. " coins=" .. tostring(data and data.Coins or 0)
		.. " gems=" .. tostring(data and data.Gems or 0)
		.. " colorStacks=" .. tostring(countPetStacks(data and data.PetInventory))
		.. " colorAmount=" .. tostring(countPetAmount(data and data.PetInventory))
		.. " equippedColors=" .. tostring(countList(data and data.EquippedPets))
		.. " brushes=" .. tostring(countList(data and data.OwnedPaintTools))
		.. " equippedBrush=" .. tostring(data and data.EquippedPaintTool or "")
		.. " sectors=" .. tostring(countUnlockedSectors(data))
		.. " currentWorld=" .. tostring(data and data.CurrentWorld or "")
		.. " codes=" .. tostring(countMap(data and data.RedeemedCodes))
		.. " grants=" .. tostring(countMap(data and data.GamepassGrants))
end

local function logProfileSummary(player, phase, data, reason)
	print("DataManager [" .. tostring(phase) .. "] "
		.. tostring(player and (player.Name .. "/" .. player.UserId) or "unknown")
		.. " reason=" .. tostring(reason or "load")
		.. " " .. formatProfileSummary(data))
end

local function normalizePetIdFromKey(key)
	if type(key) ~= "string" or key == "" then
		return nil
	end

	local colonParts = string.split(key, ":")
	if #colonParts >= 2 then
		return colonParts[2] ~= "" and colonParts[2] or colonParts[1]
	end

	local variantParts = string.split(key, "|")
	return variantParts[1] ~= "" and variantParts[1] or key
end

local function normalizePetRecord(record, sourceKey, backupList)
	local normalized

	if type(record) == "string" then
		if string.find(record, ":", 1, true) then
			normalized = decodePetRecord(record)
		elseif record ~= "" then
			normalized = {
				petId = record,
				stackAmount = 1,
			}
		end
	elseif type(record) == "number" and sourceKey ~= nil then
		normalized = {
			petId = normalizePetIdFromKey(tostring(sourceKey)),
			stackAmount = record,
		}
	elseif type(record) == "table" then
		local petId = record.petId or record.PetId
			or record.colorId or record.ColorId
			or record.id or record.Id
			or normalizePetIdFromKey(type(sourceKey) == "string" and sourceKey or nil)

		if petId and petId ~= "" then
			normalized = {
				variantKey = record.variantKey or record.VariantKey or record.key or record.Key,
				petId = tostring(petId),
				stackAmount = tonumber(record.stackAmount or record.StackAmount or record.amount or record.Amount or record.count or record.Count or record.qty or record.Quantity) or 1,
				traitId = record.traitId or record.TraitId or record.traitName or record.TraitName or record.trait or record.Trait,
				mutationId = record.mutationId or record.MutationId or record.mutation or record.Mutation,
				mergeTier = record.mergeTier or record.MergeTier or record.currentStackTier or record.CurrentStackTier,
				isShiny = record.isShiny or record.IsShiny or record.shiny or record.Shiny,
				personalityId = record.personalityId or record.PersonalityId or "Neutral",
			}
		end
	end

	if not normalized or not normalized.petId or normalized.petId == "" then
		table.insert(backupList, deepCopy(record))
		warnOnce("unreadable-color-entry", "DataManager: unreadable saved Color entry preserved in LegacyPetsBackup.")
		return nil
	end

	normalized.petId = tostring(normalized.petId)
	normalized.stackAmount = math.max(1, math.floor(tonumber(normalized.stackAmount) or 1))
	normalized.traitId = PetData.normalizeTraitId(normalized.traitId or "Neutral")
	normalized.traitName = normalized.traitId
	normalized.mutationId = PetData.normalizeMutationId(normalized.mutationId or "None")
	normalized.personalityId = PetData.normalizePersonalityId(normalized.personalityId or "Neutral")
	normalized.mergeTier = normalized.mergeTier or "Normal"
	normalized.isShiny = normalized.isShiny == true or normalized.isShiny == "true" or normalized.isShiny == "shiny"

	if not PetData.Pets[normalized.petId] then
		warnOnce("unknown-color-" .. normalized.petId, "Unknown saved ColorId preserved: " .. tostring(normalized.petId))
	end

	return normalized
end

local function addNormalizedInventoryRecord(recordsByKey, record)
	if not record then
		return
	end

	local variantKey = PetData.makeVariantKey(record.petId, record.personalityId, record.mutationId, record.traitId)
	local existing = recordsByKey[variantKey]
	if existing then
		existing.stackAmount += math.max(1, tonumber(record.stackAmount) or 1)
		existing.isShiny = existing.isShiny or record.isShiny == true
	else
		record.variantKey = variantKey
		recordsByKey[variantKey] = record
	end
end

local function normalizeInventorySource(source, recordsByKey, backupList)
	if type(source) == "string" then
		for _, encoded in ipairs(string.split(source, ",")) do
			if encoded ~= "" then
				addNormalizedInventoryRecord(recordsByKey, normalizePetRecord(encoded, nil, backupList))
			end
		end
	elseif type(source) == "table" then
		for key, value in pairs(source) do
			addNormalizedInventoryRecord(recordsByKey, normalizePetRecord(value, key, backupList))
		end
	end
end

local function mergeInventorySource(source, recordsByKey, backupList)
	local sourceRecordsByKey = {}
	normalizeInventorySource(source, sourceRecordsByKey, backupList)
	for variantKey, record in pairs(sourceRecordsByKey) do
		local existing = recordsByKey[variantKey]
		if existing then
			-- Same variant found in legacy aliases. Keep the highest stack to avoid duplicating
			-- mirrored Pets/Colors aliases on future loads.
			existing.stackAmount = math.max(tonumber(existing.stackAmount) or 1, tonumber(record.stackAmount) or 1)
			existing.isShiny = existing.isShiny or record.isShiny == true
		else
			recordsByKey[variantKey] = record
		end
	end
end

local function inventoryMapToList(recordsByKey)
	local list = {}
	for _, record in pairs(recordsByKey) do
		table.insert(list, {
			petId = record.petId,
			stackAmount = math.max(1, tonumber(record.stackAmount) or 1),
			traitId = PetData.normalizeTraitId(record.traitId),
			traitName = PetData.normalizeTraitId(record.traitId),
			isShiny = record.isShiny == true,
			personalityId = PetData.normalizePersonalityId(record.personalityId),
			mutationId = PetData.normalizeMutationId(record.mutationId),
			mergeTier = record.mergeTier or "Normal",
		})
	end
	table.sort(list, function(a, b)
		return tostring(a.petId) < tostring(b.petId)
	end)
	return list
end

local function normalizeEquippedSource(source, equippedList, seen)
	if type(source) == "string" then
		for _, key in ipairs(string.split(source, ",")) do
			if key ~= "" and not seen[key] then
				seen[key] = true
				table.insert(equippedList, key)
			end
		end
	elseif type(source) == "table" then
		for key, value in pairs(source) do
			local equippedKey
			if type(value) == "string" then
				equippedKey = value
			elseif type(value) == "table" then
				equippedKey = value.variantKey or value.VariantKey or value.petId or value.PetId or value.colorId or value.ColorId
			else
				equippedKey = tostring(key)
			end
			if equippedKey and equippedKey ~= "" and value ~= false and not seen[equippedKey] then
				seen[equippedKey] = true
				table.insert(equippedList, equippedKey)
			end
		end
	end
end

local function sourceHasEntries(source)
	if type(source) == "string" then
		return source ~= ""
	elseif type(source) == "table" then
		return next(source) ~= nil
	end
	return false
end

local function backupLegacyCompanionData(data, oldVersion)
	local hasLegacyInventory = sourceHasEntries(data.Pets)
		or sourceHasEntries(data.Colors)
		or sourceHasEntries(data.PetStacks)
		or sourceHasEntries(data.ColorStacks)
		or sourceHasEntries(data.ColorInventory)
		or sourceHasEntries(data.Inventory)
	local hasOlderCanonicalInventory = (tonumber(oldVersion) or 0) < CURRENT_DATA_VERSION
		and (sourceHasEntries(data.PetInventory) or sourceHasEntries(data.EquippedPets) or sourceHasEntries(data.EquippedColors))
	if not hasLegacyInventory and not hasOlderCanonicalInventory then
		return
	end

	data.MigrationBackups = type(data.MigrationBackups) == "table" and data.MigrationBackups or {}
	local backupKey = "Pets_v" .. tostring(oldVersion or "unknown")
	if not data.MigrationBackups[backupKey] then
		data.MigrationBackups[backupKey] = {
			PetInventory = deepCopy(data.PetInventory),
			Pets = deepCopy(data.Pets),
			Colors = deepCopy(data.Colors),
			PetStacks = deepCopy(data.PetStacks),
			ColorStacks = deepCopy(data.ColorStacks),
			ColorInventory = deepCopy(data.ColorInventory),
			Inventory = deepCopy(data.Inventory),
			EquippedPets = deepCopy(data.EquippedPets),
			EquippedColors = deepCopy(data.EquippedColors),
		}
	end

	if data.LegacyPetsBackup == nil then
		data.LegacyPetsBackup = deepCopy(data.MigrationBackups[backupKey])
	end
end

local function migrateData(saved)
	local raw = type(saved) == "table" and saved or {}
	local data = deepCopy(raw)
	local oldVersion = tonumber(data.DataVersion or data.Version) or 0
	local hadTutorialCompletionFlag = raw.TutorialCompleted ~= nil
	local savedCurrentWorld = raw.CurrentWorld or raw.ActiveWorldColor or raw.HighestUnlockedWorld

	backupLegacyCompanionData(data, oldVersion)
	DeepFillMissing(data, DEFAULT_DATA)
	if not sourceHasEntries(raw.UnlockedColors) then
		local inferredUnlocked = {}
		for _, colorType in pairs({ raw.HighestUnlockedWorld, raw.ActiveWorldColor, raw.CurrentWorld }) do
			if ColorData.getWorldByColor(colorType) then
				table.insert(inferredUnlocked, colorType)
			end
		end
		if #inferredUnlocked > 0 then
			data.UnlockedColors = inferredUnlocked
		end
	end
	data.UnlockedColors = normalizeUnlockedColorList(data.UnlockedColors)
	data.CurrentWorld = normalizeCurrentWorld(savedCurrentWorld or data.CurrentWorld or data.ActiveWorldColor or data.HighestUnlockedWorld, data.UnlockedColors)
	data.ActiveWorldColor = data.CurrentWorld
	data.UnlockedTeleports = normalizeTeleportList(data.UnlockedTeleports or data.UnlockedLocations or data.UnlockedZones)
	data.HighestUnlockedWorld = getHighestUnlockedColor(data.UnlockedColors)
	data.OwnedPaintTools = normalizePaintToolList(data.OwnedPaintTools)
	data.EquippedPaintTool = normalizeEquippedPaintTool(data.EquippedPaintTool, data.OwnedPaintTools)
	if not hadTutorialCompletionFlag then
		local hasOldProgress = (#data.UnlockedColors > 1)
			or (#(data.OwnedPaintTools or {}) > 1)
			or (#(data.PetInventory or {}) > 0)
			or sourceHasEntries(data.Pets)
			or sourceHasEntries(data.Colors)
			or sourceHasEntries(data.Inventory)
			or sourceHasEntries(data.ColorInventory)
			or ((tonumber(data.Coins) or 0) > 0)
		if hasOldProgress then
			data.TutorialCompleted = true
		end
	end

	local backupList = {}
	local recordsByKey = {}
	mergeInventorySource(data.PetInventory, recordsByKey, backupList)
	mergeInventorySource(data.Pets, recordsByKey, backupList)
	mergeInventorySource(data.Colors, recordsByKey, backupList)
	mergeInventorySource(data.PetStacks, recordsByKey, backupList)
	mergeInventorySource(data.ColorStacks, recordsByKey, backupList)
	mergeInventorySource(data.ColorInventory, recordsByKey, backupList)
	mergeInventorySource(data.Inventory, recordsByKey, backupList)

	data.PetInventory = inventoryMapToList(recordsByKey)
	data.Pets = deepCopy(data.PetInventory)
	data.Colors = deepCopy(data.PetInventory)
	data.LockedPets = type(data.LockedPets) == "table" and data.LockedPets or {}

	data.EquippedPets = {}
	local seenEquipped = {}
	normalizeEquippedSource(raw.EquippedPets, data.EquippedPets, seenEquipped)
	normalizeEquippedSource(raw.EquippedColors, data.EquippedPets, seenEquipped)

	if #backupList > 0 then
		data.LegacyPetsBackup = data.LegacyPetsBackup or {}
		data.LegacyPetsBackup.UnreadableEntries = data.LegacyPetsBackup.UnreadableEntries or {}
		for _, entry in ipairs(backupList) do
			table.insert(data.LegacyPetsBackup.UnreadableEntries, entry)
		end
	end

	data.RedeemedCodes = type(data.RedeemedCodes) == "table" and data.RedeemedCodes or {}
	data.Settings = normalizeSettings(data.Settings)
	data.TutorialProgress = type(data.TutorialProgress) == "table" and data.TutorialProgress or {}
	data.TutorialProgress.SeenTraitsTutorial = data.TutorialProgress.SeenTraitsTutorial == true
	data.TutorialProgress.MutationsUnlocked = data.TutorialProgress.MutationsUnlocked == true
	data.TutorialProgress.HasSeenMutationTutorial = data.TutorialProgress.HasSeenMutationTutorial == true
	data.GroupRewards = type(data.GroupRewards) == "table" and data.GroupRewards or {}
	data.GamepassGrants = type(data.GamepassGrants) == "table" and data.GamepassGrants or {}
	data.DataVersion = CURRENT_DATA_VERSION
	data.Version = CURRENT_DATA_VERSION
	return data
end

local function validateProfileData(player, data, context)
	data = type(data) == "table" and data or deepCopy(DEFAULT_DATA)

	data.Coins = math.max(0, math.floor(finiteNumber(data.Coins, 0, "Coins", player)))
	data.Gems = math.max(0, math.floor(finiteNumber(data.Gems, 0, "Gems", player)))
	data.Diamonds = math.max(0, math.floor(finiteNumber(data.Diamonds, 0, "Diamonds", player)))
	data.Rebirths = math.max(0, math.floor(finiteNumber(data.Rebirths, 0, "Rebirths", player)))

	data.UnlockedColors = normalizeUnlockedColorList(data.UnlockedColors)
	data.CurrentWorld = normalizeCurrentWorld(data.CurrentWorld or data.ActiveWorldColor or data.HighestUnlockedWorld, data.UnlockedColors)
	data.ActiveWorldColor = data.CurrentWorld
	data.UnlockedTeleports = normalizeTeleportList(data.UnlockedTeleports or data.UnlockedLocations or data.UnlockedZones)
	data.HighestUnlockedWorld = getHighestUnlockedColor(data.UnlockedColors)

	local recordsByKey = {}
	local backupList = {}
	mergeInventorySource(data.PetInventory, recordsByKey, backupList)
	data.PetInventory = inventoryMapToList(recordsByKey)
	data.EquippedPets = sanitizeEquippedPetList(data.EquippedPets, data.PetInventory, player)
	data.LockedPets = type(data.LockedPets) == "table" and data.LockedPets or {}

	data.OwnedPaintTools = normalizePaintToolList(data.OwnedPaintTools)
	data.EquippedPaintTool = normalizeEquippedPaintTool(data.EquippedPaintTool, data.OwnedPaintTools)
	data.Settings = normalizeSettings(data.Settings)
	data.Upgrades = type(data.Upgrades) == "table" and data.Upgrades or {}
	for key, value in pairs(data.Upgrades) do
		data.Upgrades[key] = math.max(0, math.floor(finiteNumber(value, 0, "Upgrades." .. tostring(key), player)))
	end
	data.RedeemedCodes = type(data.RedeemedCodes) == "table" and data.RedeemedCodes or {}
	data.TutorialCompleted = data.TutorialCompleted == true
	data.TutorialProgress = type(data.TutorialProgress) == "table" and data.TutorialProgress or {}
	data.TutorialProgress.SeenTraitsTutorial = data.TutorialProgress.SeenTraitsTutorial == true
	data.TutorialProgress.MutationsUnlocked = data.TutorialProgress.MutationsUnlocked == true
	data.TutorialProgress.HasSeenMutationTutorial = data.TutorialProgress.HasSeenMutationTutorial == true
	data.GroupRewards = type(data.GroupRewards) == "table" and data.GroupRewards or {}
	data.GroupRewards.LastDailyGemClaim = tostring(data.GroupRewards.LastDailyGemClaim or "")
	data.GamepassGrants = type(data.GamepassGrants) == "table" and data.GamepassGrants or {}
	data.DataVersion = CURRENT_DATA_VERSION
	data.Version = CURRENT_DATA_VERSION
	data.Pets = deepCopy(data.PetInventory)
	data.Colors = deepCopy(data.PetInventory)

	if #backupList > 0 then
		data.LegacyPetsBackup = data.LegacyPetsBackup or {}
		data.LegacyPetsBackup.UnreadableEntries = data.LegacyPetsBackup.UnreadableEntries or {}
		for _, entry in ipairs(backupList) do
			table.insert(data.LegacyPetsBackup.UnreadableEntries, entry)
		end
		if player then
			warn("DataManager: preserved unreadable Color entries during " .. tostring(context or "validation") .. " for " .. player.Name)
		end
	end

	return data
end

local function markPlayerDirty(player, reason)
	if player then
		playerDataDirtyEvent:Fire(player, reason)
	end
end

local function watchValueForDirty(player, valueObject, reason)
	if valueObject and valueObject:IsA("ValueBase") then
		valueObject:GetPropertyChangedSignal("Value"):Connect(function()
			markPlayerDirty(player, reason)
		end)
	end
end

local DATA_FOLDERS = {
	leaderstats = true,
	ColorStorage = true,
	Upgrades = true,
	PetData = true,
	RedeemedCodes = true,
	Settings = true,
	GroupRewards = true,
	GamepassGrants = true,
}

local function clearGeneratedDataFolders(player)
	for _, child in ipairs(player:GetChildren()) do
		if DATA_FOLDERS[child.Name] then
			child:Destroy()
		end
	end
end

-- ========================
--   LOAD DATA
-- ========================
local function loadData(player)
	if RunService:IsStudio() and not ENABLE_STUDIO_DATASTORE then
		print("DataManager: using unsaved Studio test data for " .. player.Name)
		return validateProfileData(player, migrateData(deepCopy(DEFAULT_DATA)), "studio-default")
	end

	local key = "Player_" .. player.UserId
	local data
	local lastError

	-- Retry up to 3 times in case of DataStore hiccups
	for attempt = 1, 3 do
		local success, result = pcall(function()
			return GameStore:GetAsync(key)
		end)
		if success then
			data = validateProfileData(player, migrateData(result or deepCopy(DEFAULT_DATA)), result and "cloud-load" or "new-profile")
			break
		else
			lastError = result
			warn("DataStore load failed (attempt " .. attempt .. "): " .. tostring(result))
			task.wait(2)
		end
	end

	-- Never fall back to blank/default cloud data after a load failure.
	-- Saving a default profile in this state can permanently wipe real player progress.
	if not data then
		warn("DataManager: profile load failed for " .. player.Name .. "/" .. player.UserId .. "; save disabled for this session. " .. tostring(lastError))
		return nil
	end

	return data
end

-- ========================
--   SAVE DATA
-- ========================
local function saveData(player, data)
	if not data then return end
	if RunService:IsStudio() and not ENABLE_STUDIO_DATASTORE then
		return true
	end

	local key = "Player_" .. player.UserId

	for attempt = 1, 3 do
		local success, err = pcall(function()
			GameStore:UpdateAsync(key, function(oldData)
				local merged = type(oldData) == "table" and deepCopy(oldData) or {}
				for field, value in pairs(data) do
					merged[field] = deepCopy(value)
				end
				return merged
			end)
		end)
		if success then
			return true
		else
			warn("DataStore save failed (attempt " .. attempt .. "): " .. tostring(err))
			task.wait(2)
		end
	end
	warn("All save attempts failed for " .. player.Name)
	return false
end

-- ========================
--   BUILD PLAYER INSTANCES
--   from their loaded data
-- ========================
local function applyData(player, data)
	clearGeneratedDataFolders(player)
	data.PetInventory = ensureOwnerRainbowPetList(player, data.PetInventory)
	data.Pets = deepCopy(data.PetInventory)
	data.Colors = deepCopy(data.PetInventory)

	-- Leaderstats (shows on leaderboard)
	local leaderstats = Instance.new("Folder")
	leaderstats.Name = "leaderstats"
	leaderstats.Parent = player

	player.ChildAdded:Connect(function(child)
		if child.Name == "leaderstats" and child ~= leaderstats then
			task.defer(function()
				if child.Parent == player then
					child:Destroy()
					warn("DataManager: removed duplicate leaderstats folder for " .. player.Name)
				end
			end)
		end
	end)

	local coins = Instance.new("IntValue")
	coins.Name = "Coins"
	coins.Value = data.Coins
	coins.Parent = leaderstats

	local gems = Instance.new("IntValue")
	gems.Name = "Gems"
	gems.Value = data.Gems
	gems.Parent = leaderstats

	local diamonds = Instance.new("IntValue")
	diamonds.Name = "Diamonds"
	diamonds.Value = data.Diamonds
	diamonds.Parent = leaderstats

	local rebirths = Instance.new("IntValue")
	rebirths.Name = "Rebirths"
	rebirths.Value = data.Rebirths
	rebirths.Parent = leaderstats

	-- ColorStorage keeps world/unlock state for backward compatibility with existing scripts and saves.
	local storage = Instance.new("Folder")
	storage.Name = "ColorStorage"
	storage.Parent = player

	local unlockedColors = Instance.new("StringValue")
	unlockedColors.Name = "UnlockedColors"
	unlockedColors.Value = table.concat(data.UnlockedColors, ",")
	unlockedColors.Parent = storage

	-- Legacy client compatibility only. The current loop awards Coins instantly
	-- and does not use storage/selling, but older in-place HUD scripts may still
	-- wait for these values before wiring menu buttons.
	local colorHeld = Instance.new("IntValue")
	colorHeld.Name = "ColorHeld"
	colorHeld.Value = 0
	colorHeld.Parent = storage

	local maxCapacity = Instance.new("IntValue")
	maxCapacity.Name = "MaxCapacity"
	maxCapacity.Value = 1000000
	maxCapacity.Parent = storage

	local storageCapacity = Instance.new("IntValue")
	storageCapacity.Name = "StorageCapacity"
	storageCapacity.Value = maxCapacity.Value
	storageCapacity.Parent = storage

	local currentWorld = Instance.new("StringValue")
	currentWorld.Name = "CurrentWorld"
	currentWorld.Value = normalizeCurrentWorld(data.CurrentWorld, data.UnlockedColors)
	currentWorld.Parent = storage
	player:SetAttribute("ActiveWorldColor", currentWorld.Value)
	currentWorld:GetPropertyChangedSignal("Value"):Connect(function()
		currentWorld.Value = normalizeCurrentWorld(currentWorld.Value, string.split(unlockedColors.Value, ","))
		player:SetAttribute("ActiveWorldColor", currentWorld.Value)
	end)

	local unlockedTeleports = Instance.new("StringValue")
	unlockedTeleports.Name = "UnlockedTeleports"
	unlockedTeleports.Value = table.concat(normalizeTeleportList(data.UnlockedTeleports), ",")
	unlockedTeleports.Parent = storage

	watchValueForDirty(player, coins, "coins")
	watchValueForDirty(player, gems, "gems")
	watchValueForDirty(player, diamonds, "diamonds")
	watchValueForDirty(player, rebirths, "rebirths")
	watchValueForDirty(player, unlockedColors, "unlocked-colors")
	watchValueForDirty(player, currentWorld, "current-world")
	watchValueForDirty(player, unlockedTeleports, "unlocked-teleports")

	local groupRewardsFolder = Instance.new("Folder")
	groupRewardsFolder.Name = "GroupRewards"
	groupRewardsFolder.Parent = player

	local lastGroupDailyClaim = Instance.new("StringValue")
	lastGroupDailyClaim.Name = "LastDailyGemClaim"
	lastGroupDailyClaim.Value = data.GroupRewards and tostring(data.GroupRewards.LastDailyGemClaim or "") or ""
	lastGroupDailyClaim.Parent = groupRewardsFolder
	watchValueForDirty(player, lastGroupDailyClaim, "group-rewards")

	local gamepassGrantsFolder = Instance.new("Folder")
	gamepassGrantsFolder.Name = "GamepassGrants"
	gamepassGrantsFolder.Parent = player

	for passId, owns in pairs(data.GamepassGrants or {}) do
		if owns == true then
			local value = Instance.new("BoolValue")
			value.Name = tostring(passId)
			value.Value = true
			value.Parent = gamepassGrantsFolder
			watchValueForDirty(player, value, "gamepass-grants")
			player:SetAttribute("Pass_" .. tostring(passId), true)
		end
	end

	gamepassGrantsFolder.ChildAdded:Connect(function(child)
		watchValueForDirty(player, child, "gamepass-grants")
		markPlayerDirty(player, "gamepass-grants")
	end)

	-- Upgrade level storage (read by UpgradeHandler)
	local upgradeFolder = Instance.new("Folder")
	upgradeFolder.Name   = "Upgrades"
	upgradeFolder.Parent = player

	for levelKey, levelVal in pairs(data.Upgrades or {}) do
		if levelKey == "ColorStorage_Level" then
			continue
		end
		local v = Instance.new("IntValue")
		v.Name   = levelKey
		v.Value  = levelVal
		v.Parent = upgradeFolder
		watchValueForDirty(player, v, "upgrade")
	end
	upgradeFolder.ChildAdded:Connect(function(child)
		watchValueForDirty(player, child, "upgrade")
		markPlayerDirty(player, "upgrade-added")
	end)

	-- Pet data (stored as folder with values)
	local petFolder = Instance.new("Folder")
	petFolder.Name = "PetData"
	petFolder.Parent = player

	local invValue = Instance.new("StringValue")
	invValue.Name = "Inventory"
	-- Encoded as: variantKey:petId:stackAmount:traitId:shiny:personalityId:mutationId
	local invList = {}
	for _, p in ipairs(data.PetInventory or {}) do
		local encoded = encodePetRecord(p)
		if encoded then
			table.insert(invList, encoded)
		end
	end
	invValue.Value = table.concat(invList, ",")
	invValue.Parent = petFolder
	watchValueForDirty(player, invValue, "color-inventory")

	local equippedValue = Instance.new("StringValue")
	equippedValue.Name = "Equipped"
	equippedValue.Value = table.concat(data.EquippedPets, ",")
	equippedValue.Parent = petFolder
	watchValueForDirty(player, equippedValue, "equipped-colors")

	local lockedValue = Instance.new("StringValue")
	lockedValue.Name = "Locked"
	lockedValue.Value = table.concat(type(data.LockedPets) == "table" and data.LockedPets or {}, ",")
	lockedValue.Parent = petFolder
	watchValueForDirty(player, lockedValue, "locked-colors")

	local toolsFolder = player:FindFirstChild("PaintTools")
	if not toolsFolder then
		toolsFolder = Instance.new("Folder")
		toolsFolder.Name = "PaintTools"
		toolsFolder.Parent = player
	end

	local ownedPaintTools = normalizePaintToolList(data.OwnedPaintTools)
	local equippedPaintTool = normalizeEquippedPaintTool(data.EquippedPaintTool, ownedPaintTools)

	local ownedTools = toolsFolder:FindFirstChild("Owned")
	if not ownedTools then
		ownedTools = Instance.new("StringValue")
		ownedTools.Name = "Owned"
		ownedTools.Parent = toolsFolder
	end
	ownedTools.Value = table.concat(ownedPaintTools or {"StarterBrush"}, ",")
	if ownedTools.Value == "" then
		ownedTools.Value = "StarterBrush"
	end
	watchValueForDirty(player, ownedTools, "paint-tools-owned")

	local equippedTool = toolsFolder:FindFirstChild("Equipped")
	if not equippedTool then
		equippedTool = Instance.new("StringValue")
		equippedTool.Name = "Equipped"
		equippedTool.Parent = toolsFolder
	end
	equippedTool.Value = equippedPaintTool or "StarterBrush"
	if equippedTool.Value == "" then
		equippedTool.Value = "StarterBrush"
	end
	watchValueForDirty(player, equippedTool, "paint-tool-equipped")

	local settingsFolder = Instance.new("Folder")
	settingsFolder.Name = "Settings"
	settingsFolder.Parent = player
	local normalizedSettings = normalizeSettings(data.Settings)
	for key, value in pairs(normalizedSettings) do
		local setting = Instance.new("BoolValue")
		setting.Name = key
		setting.Value = value == true
		setting.Parent = settingsFolder
		watchValueForDirty(player, setting, "settings")
	end
	applySettingAttributes(player, normalizedSettings)

	local redeemedFolder = Instance.new("Folder")
	redeemedFolder.Name = "RedeemedCodes"
	redeemedFolder.Parent = player
	for code, uses in pairs(data.RedeemedCodes or {}) do
		local v = Instance.new("IntValue")
		v.Name = tostring(code)
		v.Value = tonumber(uses) or 1
		v.Parent = redeemedFolder
		watchValueForDirty(player, v, "redeemed-code")
	end
	redeemedFolder.ChildAdded:Connect(function(child)
		watchValueForDirty(player, child, "redeemed-code")
		markPlayerDirty(player, "redeemed-code-added")
	end)

	local tutorialFolder = player:FindFirstChild("TutorialObjectives")
	if not tutorialFolder then
		tutorialFolder = Instance.new("Folder")
		tutorialFolder.Name = "TutorialObjectives"
		tutorialFolder.Parent = player
	end

	local tutorialCompleted = tutorialFolder:FindFirstChild("TutorialCompleted")
	if not tutorialCompleted then
		tutorialCompleted = Instance.new("BoolValue")
		tutorialCompleted.Name = "TutorialCompleted"
		tutorialCompleted.Parent = tutorialFolder
	end
	tutorialCompleted.Value = data.TutorialCompleted == true
	watchValueForDirty(player, tutorialCompleted, "tutorial-completed")

	local tutorialProgress = player:FindFirstChild("TutorialProgress")
	if not tutorialProgress then
		tutorialProgress = Instance.new("Folder")
		tutorialProgress.Name = "TutorialProgress"
		tutorialProgress.Parent = player
	end
	local seenTraits = tutorialProgress:FindFirstChild("SeenTraitsTutorial")
	if not seenTraits then
		seenTraits = Instance.new("BoolValue")
		seenTraits.Name = "SeenTraitsTutorial"
		seenTraits.Parent = tutorialProgress
	end
	seenTraits.Value = data.TutorialProgress and data.TutorialProgress.SeenTraitsTutorial == true
	watchValueForDirty(player, seenTraits, "tutorial-progress")

	local mutationsUnlocked = tutorialProgress:FindFirstChild("MutationsUnlocked")
	if not mutationsUnlocked then
		mutationsUnlocked = Instance.new("BoolValue")
		mutationsUnlocked.Name = "MutationsUnlocked"
		mutationsUnlocked.Parent = tutorialProgress
	end
	mutationsUnlocked.Value = data.TutorialProgress and data.TutorialProgress.MutationsUnlocked == true
	watchValueForDirty(player, mutationsUnlocked, "tutorial-progress")

	local hasSeenMutationTutorial = tutorialProgress:FindFirstChild("HasSeenMutationTutorial")
	if not hasSeenMutationTutorial then
		hasSeenMutationTutorial = Instance.new("BoolValue")
		hasSeenMutationTutorial.Name = "HasSeenMutationTutorial"
		hasSeenMutationTutorial.Parent = tutorialProgress
	end
	hasSeenMutationTutorial.Value = data.TutorialProgress and data.TutorialProgress.HasSeenMutationTutorial == true
	watchValueForDirty(player, hasSeenMutationTutorial, "tutorial-progress")
	sendSettings(player, true, nil, "Settings loaded.")
end

-- ========================
--   COLLECT CURRENT DATA
--   from player instances (to save)
-- ========================
local function collectData(player)
	local data = deepCopy(DEFAULT_DATA)

	local stats = player:FindFirstChild("leaderstats")
	if stats then
		data.Coins    = stats:FindFirstChild("Coins")    and stats.Coins.Value    or 0
		data.Gems     = stats:FindFirstChild("Gems")     and stats.Gems.Value     or 0
		data.Diamonds = stats:FindFirstChild("Diamonds") and stats.Diamonds.Value or 0
		data.Rebirths = stats:FindFirstChild("Rebirths") and stats.Rebirths.Value or 0
	end

	local storage = player:FindFirstChild("ColorStorage")
	if storage then
		local upgradeFolder = player:FindFirstChild("Upgrades")
		if upgradeFolder then
			data.Upgrades = {}
			for _, child in ipairs(upgradeFolder:GetChildren()) do
				if child:IsA("IntValue") and child.Name:find("_Level") and child.Name ~= "ColorStorage_Level" then
					data.Upgrades[child.Name] = child.Value
				end
			end
		end

		local colorsVal = storage:FindFirstChild("UnlockedColors")
		if colorsVal and colorsVal.Value ~= "" then
			data.UnlockedColors = normalizeUnlockedColorList(colorsVal.Value)
		end

		local currentWorld = storage:FindFirstChild("CurrentWorld")
		data.CurrentWorld = normalizeCurrentWorld(
			currentWorld and currentWorld.Value or player:GetAttribute("ActiveWorldColor"),
			data.UnlockedColors
		)

		local teleportsVal = storage:FindFirstChild("UnlockedTeleports")
		data.UnlockedTeleports = normalizeTeleportList(teleportsVal and teleportsVal.Value or data.UnlockedTeleports)
	end

	local petFolder = player:FindFirstChild("PetData")
	if petFolder then
		local invVal = petFolder:FindFirstChild("Inventory")
		if invVal and invVal.Value ~= "" then
			for _, encoded in ipairs(string.split(invVal.Value, ",")) do
				local record = decodePetRecord(encoded)
				if record then
					table.insert(data.PetInventory, record)
				end
			end
		end
		data.PetInventory = ensureOwnerRainbowPetList(player, data.PetInventory)

		local equippedVal = petFolder:FindFirstChild("Equipped")
		if equippedVal and equippedVal.Value ~= "" then
			data.EquippedPets = string.split(equippedVal.Value, ",")
		end

		local lockedVal = petFolder:FindFirstChild("Locked")
		if lockedVal and lockedVal.Value ~= "" then
			data.LockedPets = string.split(lockedVal.Value, ",")
		else
			data.LockedPets = {}
		end
	end

	local toolsFolder = player:FindFirstChild("PaintTools")
	if toolsFolder then
		local ownedTools = toolsFolder:FindFirstChild("Owned")
		if ownedTools and ownedTools.Value ~= "" then
			data.OwnedPaintTools = string.split(ownedTools.Value, ",")
		end

		local equippedTool = toolsFolder:FindFirstChild("Equipped")
		if equippedTool and equippedTool.Value ~= "" then
			data.EquippedPaintTool = equippedTool.Value
		end
	end
	data.OwnedPaintTools = normalizePaintToolList(data.OwnedPaintTools)
	data.EquippedPaintTool = normalizeEquippedPaintTool(data.EquippedPaintTool, data.OwnedPaintTools)

	local settingsFolder = player:FindFirstChild("Settings")
	if settingsFolder then
		data.Settings = {}
		for key, defaultValue in pairs(SettingsData.Defaults) do
			local setting = settingsFolder:FindFirstChild(key)
			data.Settings[key] = setting and setting:IsA("BoolValue") and setting.Value or defaultValue
		end
	else
		local previousData = sessionData and sessionData[player]
		data.Settings = normalizeSettings(previousData and previousData.Settings)
	end

	local redeemedFolder = player:FindFirstChild("RedeemedCodes")
	if redeemedFolder then
		data.RedeemedCodes = {}
		for _, child in ipairs(redeemedFolder:GetChildren()) do
			if child:IsA("IntValue") then
				data.RedeemedCodes[child.Name] = child.Value
			end
		end
	end

	local tutorialFolder = player:FindFirstChild("TutorialObjectives")
	local tutorialCompleted = tutorialFolder and tutorialFolder:FindFirstChild("TutorialCompleted")
	data.TutorialCompleted = tutorialCompleted and tutorialCompleted.Value == true or false
	local tutorialProgress = player:FindFirstChild("TutorialProgress")
	local seenTraits = tutorialProgress and tutorialProgress:FindFirstChild("SeenTraitsTutorial")
	local mutationsUnlocked = tutorialProgress and tutorialProgress:FindFirstChild("MutationsUnlocked")
	local hasSeenMutationTutorial = tutorialProgress and tutorialProgress:FindFirstChild("HasSeenMutationTutorial")
	data.TutorialProgress = {
		SeenTraitsTutorial = seenTraits and seenTraits.Value == true or false,
		MutationsUnlocked = mutationsUnlocked and mutationsUnlocked.Value == true or false,
		HasSeenMutationTutorial = hasSeenMutationTutorial and hasSeenMutationTutorial.Value == true or false,
	}
	local groupRewardsFolder = player:FindFirstChild("GroupRewards")
	local lastGroupDailyClaim = groupRewardsFolder and groupRewardsFolder:FindFirstChild("LastDailyGemClaim")
	data.GroupRewards = {
		LastDailyGemClaim = lastGroupDailyClaim and tostring(lastGroupDailyClaim.Value or "") or "",
	}
	local gamepassGrantsFolder = player:FindFirstChild("GamepassGrants")
	data.GamepassGrants = {}
	if gamepassGrantsFolder then
		for _, child in ipairs(gamepassGrantsFolder:GetChildren()) do
			if child:IsA("BoolValue") and child.Value == true then
				data.GamepassGrants[child.Name] = true
			end
		end
	end
	data.PetInventory = ensureOwnerRainbowPetList(player, data.PetInventory)
	data.DataVersion = CURRENT_DATA_VERSION
	data.Version = CURRENT_DATA_VERSION
	data.Pets = deepCopy(data.PetInventory)
	data.Colors = deepCopy(data.PetInventory)

	return data
end

-- ========================
--   PLAYER ADDED / REMOVING
-- ========================
sessionData = {}  -- cache data per player during session
local sessionStartPetAmounts = {}
local profileLoaded = {}
local profileLoadFailed = {}
local lastSaveAt = {}
local lastCriticalSaveAt = {}
local saveInFlight = {}
local dirtyPlayers = {}
local lastDirtyReasons = {}
local criticalSaveQueued = {}

local CRITICAL_REASONS = {
	["hatch-color"] = true,
	["grant-color"] = true,
	["merge-color"] = true,
	["color-inventory"] = true,
	["paint-tool-purchased"] = true,
	["paint-tools-owned"] = true,
	["paint-tool-equipped"] = true,
	["unlocked-colors"] = true,
	["current-world"] = true,
	["tutorial-completed"] = true,
	["tutorial-progress"] = true,
	["settings"] = true,
	["group-rewards"] = true,
	["gamepass-grants"] = true,
}

local function addDestructiveIssue(issues, label, oldValue, newValue)
	table.insert(issues, label .. " " .. tostring(oldValue) .. " -> " .. tostring(newValue))
end

local function getEffectiveSaveReason(player, reason)
	if (reason == "leaving" or reason == "shutdown" or reason == "autosave") and lastDirtyReasons[player] then
		return tostring(lastDirtyReasons[player])
	end
	return tostring(reason or lastDirtyReasons[player] or "save")
end

local function checkDestructiveSave(player, previousData, newData, reason)
	if not previousData or player:GetAttribute("IntentionalProfileReset") == true then
		return true
	end

	local issues = {}
	local effectiveReason = getEffectiveSaveReason(player, reason)
	local previousPetAmount = countPetAmount(previousData.PetInventory)
	local newPetAmount = countPetAmount(newData.PetInventory)
	if previousPetAmount > 0 and newPetAmount == 0 then
		addDestructiveIssue(issues, "Color amount", previousPetAmount, newPetAmount)
	end

	local previousToolCount = countList(previousData.OwnedPaintTools)
	local newToolCount = countList(newData.OwnedPaintTools)
	if previousToolCount > 1 and newToolCount <= 1 then
		addDestructiveIssue(issues, "owned brushes", previousToolCount, newToolCount)
	end

	local previousSectorCount = countUnlockedSectors(previousData)
	local newSectorCount = countUnlockedSectors(newData)
	if previousSectorCount > 1 and newSectorCount <= 1 then
		addDestructiveIssue(issues, "unlocked sectors", previousSectorCount, newSectorCount)
	end
	if ownsUnlockedColor(previousData, "Orange") and not ownsUnlockedColor(newData, "Orange") then
		table.insert(issues, "Orange unlock would be removed")
	end

	local previousEquippedTool = tostring(previousData.EquippedPaintTool or "")
	local newEquippedTool = tostring(newData.EquippedPaintTool or "")
	if previousEquippedTool ~= "" and previousEquippedTool ~= "StarterBrush"
		and newEquippedTool == "StarterBrush"
		and ownsPaintTool(newData, previousEquippedTool)
		and effectiveReason ~= "paint-tool-equipped"
	then
		addDestructiveIssue(issues, "equipped brush", previousEquippedTool, newEquippedTool)
	end

	if #issues == 0 then
		return true
	end

	warn("DATA LOSS PROTECTION: blocked save for "
		.. player.Name .. "/" .. player.UserId
		.. " reason=" .. effectiveReason
		.. " issues=[" .. table.concat(issues, "; ") .. "]"
		.. " old={" .. formatProfileSummary(previousData) .. "}"
		.. " new={" .. formatProfileSummary(newData) .. "}")
	return false
end

local function savePlayerNow(player, reason, force)
	if not player then
		return false
	end

	if profileLoadFailed[player] then
		warn("DataManager: blocked save for " .. player.Name .. " because profile load failed.")
		return false
	end

	if not profileLoaded[player] then
		warn("DataManager: blocked save before profile load completed for " .. player.Name .. " (" .. tostring(reason or "save") .. ")")
		return false
	end

	if saveInFlight[player] then
		if not force then
			return false
		end

		local waitStartedAt = os.clock()
		while saveInFlight[player] and os.clock() - waitStartedAt < 10 do
			task.wait(0.1)
		end

		if saveInFlight[player] then
			warn("DataManager: save still in flight for " .. player.Name .. "; skipped forced " .. tostring(reason or "save"))
			return false
		end
	end

	local now = os.clock()
	if not force and lastSaveAt[player] and now - lastSaveAt[player] < MIN_SAVE_INTERVAL then
		return false
	end

	saveInFlight[player] = true
	local data = validateProfileData(player, collectData(player), "pre-save")
	local previousData = sessionData[player]

	if previousData then
		data.MigrationBackups = deepCopy(previousData.MigrationBackups)
		data.LegacyPetsBackup = deepCopy(previousData.LegacyPetsBackup)
	end

	local intentionalReset = player:GetAttribute("IntentionalProfileReset") == true
	local loadedPetAmount = sessionStartPetAmounts[player] or countPetAmount(previousData and previousData.PetInventory)
	local currentPetAmount = countPetAmount(data.PetInventory)
	if loadedPetAmount > 0 and currentPetAmount == 0 and not intentionalReset then
		warn("DataManager: Refusing to save suspicious empty pet inventory for player because session loaded with pets.")
		saveInFlight[player] = nil
		return false
	end
	if not checkDestructiveSave(player, previousData, data, reason) then
		saveInFlight[player] = nil
		return false
	end

	logProfileSummary(player, "save", data, getEffectiveSaveReason(player, reason))
	local ok = saveData(player, data)
	saveInFlight[player] = nil

	if ok then
		lastSaveAt[player] = now
		dirtyPlayers[player] = nil
		lastDirtyReasons[player] = nil
		sessionData[player] = deepCopy(data)
		sessionStartPetAmounts[player] = currentPetAmount
		if intentionalReset then
			player:SetAttribute("IntentionalProfileReset", nil)
		end
	end

	return ok
end

local function queueCriticalSave(player, reason, delaySeconds)
	if RunService:IsStudio() and not ENABLE_STUDIO_DATASTORE then
		return
	end
	if not player or criticalSaveQueued[player] then
		return
	end

	criticalSaveQueued[player] = true
	task.delay(delaySeconds or CRITICAL_SAVE_DELAY, function()
		criticalSaveQueued[player] = nil
		if not player or not player.Parent or not dirtyPlayers[player] then
			return
		end

		local now = os.clock()
		local last = lastCriticalSaveAt[player] or 0
		local remaining = CRITICAL_SAVE_COOLDOWN - (now - last)
		if remaining > 0 then
			queueCriticalSave(player, reason, remaining)
			return
		end

		if savePlayerNow(player, "critical-" .. tostring(reason or "data"), true) then
			lastCriticalSaveAt[player] = os.clock()
			print("DataManager: critical save completed for " .. player.Name .. " (" .. tostring(reason or "data") .. ")")
		end
	end)
end

playerDataDirtyEvent.Event:Connect(function(player, reason)
	if not player or not player:IsA("Player") then
		return
	end
	if profileLoadFailed[player] then
		warn("DataManager: ignored dirty flag after load failure for " .. player.Name .. " (" .. tostring(reason) .. ")")
		return
	end
	if not profileLoaded[player] then
		warn("DataManager: ignored dirty flag before profile load for " .. player.Name .. " (" .. tostring(reason) .. ")")
		return
	end

	dirtyPlayers[player] = reason or true
	lastDirtyReasons[player] = tostring(reason or true)
	if CRITICAL_REASONS[tostring(reason)] then
		queueCriticalSave(player, reason, CRITICAL_SAVE_DELAY)
	end
end)

local ALLOWED_TUTORIAL_PROGRESS_KEYS = {
	SeenTraitsTutorial = true,
	MutationsUnlocked = true,
	HasSeenMutationTutorial = true,
}

markTutorialProgressEvent.OnServerEvent:Connect(function(player, key)
	if not profileLoaded[player] then
		warn("DataManager: rejected tutorial progress before profile load for " .. player.Name)
		return
	end
	key = tostring(key or "")
	if not ALLOWED_TUTORIAL_PROGRESS_KEYS[key] then
		return
	end
	local folder = player:FindFirstChild("TutorialProgress")
	if not folder then
		folder = Instance.new("Folder")
		folder.Name = "TutorialProgress"
		folder.Parent = player
	end
	local value = folder:FindFirstChild(key)
	if not value then
		value = Instance.new("BoolValue")
		value.Name = key
		value.Parent = folder
	end
	if value.Value ~= true then
		value.Value = true
		markPlayerDirty(player, "tutorial-progress")
	end
end)

requestSetSettingEvent.OnServerEvent:Connect(function(player, settingKey, value)
	if not profileLoaded[player] then
		sendSettings(player, false, settingKey, "Data is still loading.")
		return
	end
	settingKey = tostring(settingKey or "")
	if not SettingsData.IsAllowedKey(settingKey) then
		warn("Settings: rejected invalid key from " .. player.Name .. ": " .. settingKey)
		sendSettings(player, false, settingKey, "Invalid setting.")
		return
	end

	if type(value) ~= "boolean" then
		warn("Settings: rejected non-boolean value from " .. player.Name .. " for " .. settingKey)
		sendSettings(player, false, settingKey, "Invalid setting value.")
		return
	end

	local settingsFolder = player:FindFirstChild("Settings")
	if not settingsFolder then
		player:WaitForChild("Settings", 5)
		settingsFolder = player:FindFirstChild("Settings")
	end
	if not settingsFolder then
		sendSettings(player, false, settingKey, "Settings are still loading.")
		return
	end

	local settingValue = settingsFolder:FindFirstChild(settingKey)
	if not settingValue then
		settingValue = Instance.new("BoolValue")
		settingValue.Name = settingKey
		settingValue.Value = SettingsData.Defaults[settingKey] == true
		settingValue.Parent = settingsFolder
		watchValueForDirty(player, settingValue, "settings")
	end

	settingValue.Value = value
	player:SetAttribute("Setting" .. settingKey, value)
	local cached = sessionData[player]
	if cached then
		cached.Settings = normalizeSettings(cached.Settings)
		cached.Settings[settingKey] = value
	end
	markPlayerDirty(player, "settings")
	sendSettings(player, true, settingKey, "Saved.")
end)

local function printPetData(player)
	if not RunService:IsStudio() or not player then
		return false
	end

	local data = player.Parent and collectData(player) or sessionData[player]
	if not data then
		warn("PrintPetData: no data found for player")
		return false
	end

	print("PrintPetData for " .. player.Name)
	print("  Summary = " .. formatProfileSummary(data))
	print("  DataVersion = " .. tostring(data.DataVersion or data.Version))
	print("  Color stacks = " .. tostring(countPetStacks(data.PetInventory)))
	print("  Color amount = " .. tostring(countPetAmount(data.PetInventory)))
	print("  Equipped count = " .. tostring(type(data.EquippedPets) == "table" and #data.EquippedPets or 0))
	print("  Legacy Pets alias present = " .. tostring(type(data.Pets) == "table"))
	print("  Legacy Colors alias present = " .. tostring(type(data.Colors) == "table"))
	print("  Legacy backup present = " .. tostring(data.LegacyPetsBackup ~= nil or data.MigrationBackups ~= nil))

	for index, entry in ipairs(data.PetInventory or {}) do
		if index > 5 then
			break
		end
		print("  Sample " .. index
			.. ": " .. tostring(entry.petId)
			.. " x" .. tostring(entry.stackAmount or entry.Amount or 1)
			.. " trait=" .. tostring(entry.traitId or entry.TraitId or "Neutral")
			.. " mutation=" .. tostring(entry.mutationId or entry.MutationId or "None"))
	end

	return true
end

if RunService:IsStudio() then
	local printPetDataFunction = ReplicatedStorage:FindFirstChild("PrintPetData")
	if not printPetDataFunction then
		printPetDataFunction = Instance.new("BindableFunction")
		printPetDataFunction.Name = "PrintPetData"
		printPetDataFunction.Parent = ReplicatedStorage
	end
	printPetDataFunction.OnInvoke = function(playerName)
		local player = playerName and Players:FindFirstChild(tostring(playerName)) or Players:GetPlayers()[1]
		return printPetData(player)
	end

	local printProfileDataFunction = ReplicatedStorage:FindFirstChild("PrintProfileData")
	if not printProfileDataFunction then
		printProfileDataFunction = Instance.new("BindableFunction")
		printProfileDataFunction.Name = "PrintProfileData"
		printProfileDataFunction.Parent = ReplicatedStorage
	end
	printProfileDataFunction.OnInvoke = function(playerName)
		local player = playerName and Players:FindFirstChild(tostring(playerName)) or Players:GetPlayers()[1]
		return printPetData(player)
	end

	local testPetMigrationFunction = ReplicatedStorage:FindFirstChild("TestPetMigration")
	if not testPetMigrationFunction then
		testPetMigrationFunction = Instance.new("BindableFunction")
		testPetMigrationFunction.Name = "TestPetMigration"
		testPetMigrationFunction.Parent = ReplicatedStorage
	end
	testPetMigrationFunction.OnInvoke = function(fakeOldData)
		local migrated = validateProfileData(nil, migrateData(type(fakeOldData) == "table" and fakeOldData or {}), "studio-migration-test")
		print("TestPetMigration: DataVersion=" .. tostring(migrated.DataVersion)
			.. " stacks=" .. tostring(countPetStacks(migrated.PetInventory))
			.. " amount=" .. tostring(countPetAmount(migrated.PetInventory)))
		return migrated
	end
end

Players.PlayerAdded:Connect(function(player)
	profileLoaded[player] = false
	profileLoadFailed[player] = false
	player:SetAttribute("DataManagerReady", false)
	player:SetAttribute("DataManagerLoadFailed", false)
	local data = loadData(player)
	if not data then
		profileLoadFailed[player] = true
		player:SetAttribute("DataManagerLoadFailed", true)
		player:Kick("Your data did not load safely. Please rejoin.")
		return
	end
	sessionData[player] = data
	sessionStartPetAmounts[player] = countPetAmount(data.PetInventory)
	applyData(player, data)
	profileLoaded[player] = true
	player:SetAttribute("DataManagerReady", true)
	logProfileSummary(player, "load", data, "PlayerAdded")
	print("Loaded data for " .. player.Name)
end)

Players.PlayerRemoving:Connect(function(player)
	savePlayerNow(player, "leaving", true)
	sessionData[player] = nil
	lastSaveAt[player] = nil
	lastCriticalSaveAt[player] = nil
	saveInFlight[player] = nil
	dirtyPlayers[player] = nil
	lastDirtyReasons[player] = nil
	criticalSaveQueued[player] = nil
	sessionStartPetAmounts[player] = nil
	profileLoaded[player] = nil
	profileLoadFailed[player] = nil
end)

-- ========================
--   AUTO SAVE
-- ========================
task.spawn(function()
	if AUTO_SAVE_INTERVAL <= 0 then
		return
	end

	while true do
		task.wait(AUTO_SAVE_INTERVAL)
		for _, player in ipairs(Players:GetPlayers()) do
			if dirtyPlayers[player] then
				savePlayerNow(player, "autosave", false)
			end
		end
	end
end)

-- ========================
--   SAVE ON SERVER CLOSE
--   (handles crashes / shutdowns)
-- ========================
game:BindToClose(function()
	if RunService:IsStudio() and not ENABLE_STUDIO_DATASTORE then
		print("DataManager: Studio server closing; DataStore save skipped.")
		return
	end

	for _, player in ipairs(Players:GetPlayers()) do
		savePlayerNow(player, "shutdown", true)
	end
	print("Server closing — all data saved.")
end)
