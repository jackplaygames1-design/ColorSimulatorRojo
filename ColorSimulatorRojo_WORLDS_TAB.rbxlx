		rarity      = "Legendary",
		category    = "Exclusives",
		description = "A rare collectible slot for exclusive rewards.",
		usable      = false,
	},
}

function ItemsData.formatNum(n)
	n = tonumber(n) or 0
	if n >= 1000000 then
		return string.format("%.1fM", n / 1000000)
	elseif n >= 1000 then
		return string.format("%.1fK", n / 1000)
	end
	return tostring(n)
end

return ItemsData
]]></string>
